<script src="https://cdn.jsdelivr.net/npm/livekit-client/dist/livekit-client.umd.min.js"></script>
<script>
(function(window, document) {
  if (window.WoLiveKitLive && window.WoLiveKitLive.__ready) {
    return;
  }

  var players = {};
  var fullscreenState = {
    shell: null,
    stageHost: null,
    commentsHost: null,
    inputHost: null,
    metaName: null,
    metaAvatar: null,
    metaCount: null,
    metaLink: null,
    hearts: null,
    activePostId: null,
    reactionCloseTimer: null,
    escBound: false
  };
  function ensureEntry(postId) {
    var safePostId = String(postId);
    if (!players[safePostId]) {
      players[safePostId] = {
        postId: safePostId,
        placeholders: {},
        streamState: 'live',
        stopped: false,
        connecting: false
      };
    }
    var entry = players[safePostId];
    entry.wrap = document.getElementById('wo-livekit-wrap-' + safePostId);
    entry.stage = document.getElementById('wo-livekit-stage-' + safePostId);
    entry.audioSink = document.getElementById('wo-livekit-audio-' + safePostId);
    entry.button = document.getElementById('wo-livekit-open-fullscreen-' + safePostId);
    entry.commentFeed = document.getElementById('live_post_comments_' + safePostId);
    entry.postComments = document.getElementById('post-comments-' + safePostId);
    entry.countNode = document.getElementById('live_count_' + safePostId);
    entry.publisherId = (entry.wrap && entry.wrap.getAttribute('data-publisher-id')) || entry.publisherId || '0';
    entry.pageId = (entry.wrap && entry.wrap.getAttribute('data-page-id')) || entry.pageId || '0';
    entry.hostName = (entry.wrap && entry.wrap.getAttribute('data-host-name')) || entry.hostName || '';
    entry.hostAvatar = (entry.wrap && entry.wrap.getAttribute('data-host-avatar')) || entry.hostAvatar || '';
    entry.hostUrl = (entry.wrap && entry.wrap.getAttribute('data-host-url')) || entry.hostUrl || '#';

    if (!entry.openBound) {
      bindOpenTrigger(entry);
      entry.openBound = true;
    }
    if (!entry.countObserved && entry.countNode && window.MutationObserver) {
      entry.countObserved = true;
      entry.countObserver = new MutationObserver(function() {
        updateFullscreenMeta(entry.postId);
      });
      entry.countObserver.observe(entry.countNode, {childList: true, characterData: true, subtree: true});
    }
    if (!entry.commentsObserved && entry.commentFeed && window.MutationObserver) {
      entry.commentsObserved = true;
      entry.commentsObserver = new MutationObserver(function() {
        syncFullscreenComments(entry.postId);
      });
      entry.commentsObserver.observe(entry.commentFeed, {childList: true, characterData: true, subtree: true});
    }
    return entry;
  }

  function bindOpenTrigger(entry) {
    if (!entry.button) {
      return;
    }
    entry.button.addEventListener('click', function(event) {
      event.preventDefault();
      event.stopPropagation();
      event.stopImmediatePropagation();
      openFullscreen(entry.postId);
    }, true);
  }

  function createPlaceholder(node) {
    var placeholder = document.createElement('div');
    placeholder.className = 'wo-livekit-fs-placeholder';
    placeholder.style.display = 'block';
    placeholder.style.width = '100%';
    placeholder.style.minHeight = Math.max(node ? node.offsetHeight : 0, 1) + 'px';
    return placeholder;
  }

  function restoreNode(node, placeholder) {
    if (!placeholder || !placeholder.parentNode) {
      return;
    }
    if (node && node.isConnected) {
      placeholder.parentNode.insertBefore(node, placeholder);
    }
    placeholder.parentNode.removeChild(placeholder);
  }

  function hasRenderedVideo(entry) {
    return !!(entry && entry.stage && entry.stage.querySelector('video'));
  }

  function renderStageMessage(entry, message, ended) {
    if (!entry || !entry.stage) {
      return;
    }
    if (!ended && hasRenderedVideo(entry)) {
      return;
    }
    entry.stage.innerHTML = '';
    var state = document.createElement('div');
    state.className = 'wo-livekit-live-state' + (ended ? ' is-ended' : '');
    state.textContent = message;
    entry.stage.appendChild(state);
  }

  function refreshStageState(entry) {
    if (!entry) {
      return;
    }
    if (entry.stopped) {
      renderStageMessage(entry, entry.endedText || 'Livestream đã kết thúc.', true);
      return;
    }
    if (hasRenderedVideo(entry)) {
      return;
    }
    if (entry.streamState === 'stale') {
      renderStageMessage(entry, 'Đang giữ kết nối livestream...', false);
      return;
    }
    renderStageMessage(entry, 'Đang chờ host bắt đầu livestream...', false);
  }

  function clearRetry(entry) {
    if (entry && entry.retryTimer) {
      clearTimeout(entry.retryTimer);
      entry.retryTimer = null;
    }
  }

  function scheduleReconnect(entry) {
    if (!entry || entry.stopped || entry.retryTimer) {
      return;
    }
    entry.retryTimer = window.setTimeout(function() {
      entry.retryTimer = null;
      startPlayer(entry.postId);
    }, 2500);
  }

  function clearAttachedTrack(track) {
    if (!track || typeof track.detach !== 'function') {
      return;
    }
    track.detach().forEach(function(element) {
      element.remove();
    });
  }

  function attachTrack(postId, track) {
    var entry = ensureEntry(postId);
    if (!entry.stage || !entry.audioSink) {
      return;
    }
    var element = track.attach();
    element.autoplay = true;
    element.playsInline = true;
    element.setAttribute('playsinline', 'playsinline');
    if (track.kind === 'video') {
      entry.stage.innerHTML = '';
      entry.stage.appendChild(element);
      clearRetry(entry);
      entry.streamState = 'live';
      enableCommentComposer(postId);
      updateFullscreenShellState(entry);
      return;
    }
    element.classList.add('wo-livekit-live-hidden');
    entry.audioSink.appendChild(element);
  }

  async function fetchJoinPayload(joinUrl, postId) {
    var response = await fetch(joinUrl, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: 'post_id=' + encodeURIComponent(postId)
    });
    var raw = await response.text();
    return raw ? JSON.parse(raw) : {};
  }

  async function startPlayer(postId) {
    var entry = ensureEntry(postId);
    if (!entry || entry.stopped || entry.connecting || !entry.joinUrl) {
      return;
    }
    if (entry.room) {
      return;
    }
    entry.connecting = true;
    refreshStageState(entry);
    try {
      var payload = await fetchJoinPayload(entry.joinUrl, postId);
      if (!payload || payload.status !== 200 || !payload.token || !payload.ws_url) {
        entry.connecting = false;
        if (payload && payload.removed === 'yes') {
          markEnded(postId, entry.endedText);
        } else {
          entry.streamState = 'stale';
          refreshStageState(entry);
          scheduleReconnect(entry);
        }
        return;
      }
      entry.streamState = payload.stream_state || 'live';
      entry.room = new window.LivekitClient.Room({adaptiveStream: true, dynacast: true});
      entry.room.on(window.LivekitClient.RoomEvent.TrackSubscribed, function(track) {
        attachTrack(postId, track);
      });
      entry.room.on(window.LivekitClient.RoomEvent.TrackUnsubscribed, function(track) {
        clearAttachedTrack(track);
        refreshStageState(entry);
      });
      entry.room.on(window.LivekitClient.RoomEvent.ParticipantConnected, function() {
        entry.streamState = 'live';
        enableCommentComposer(postId);
        updateFullscreenShellState(entry);
      });
      entry.room.on(window.LivekitClient.RoomEvent.Disconnected, function() {
        entry.room = null;
        entry.connecting = false;
        if (entry.stopped) {
          return;
        }
        entry.streamState = 'stale';
        refreshStageState(entry);
        updateFullscreenShellState(entry);
        scheduleReconnect(entry);
      });
      await entry.room.connect(payload.ws_url, payload.token);
      entry.connecting = false;
      entry.started = true;
      enableCommentComposer(postId);
      updateFullscreenShellState(entry);
      if (!entry.room.remoteParticipants.size) {
        refreshStageState(entry);
      }
      entry.room.remoteParticipants.forEach(function(participant) {
        participant.trackPublications.forEach(function(publication) {
          if (publication && publication.track) {
            attachTrack(postId, publication.track);
          }
        });
      });
    } catch (error) {
      entry.connecting = false;
      entry.room = null;
      if (entry.stopped) {
        return;
      }
      entry.streamState = 'stale';
      refreshStageState(entry);
      updateFullscreenShellState(entry);
      scheduleReconnect(entry);
    }
  }

  function disableCommentComposer(postId, placeholder) {
    var entry = ensureEntry(postId);
    var sourceTextarea = entry.postComments ? entry.postComments.querySelector('.comment-textarea') : null;
    var sendButton = entry.postComments ? entry.postComments.querySelector('.sendbtn') : null;
    if (sourceTextarea) {
      sourceTextarea.disabled = true;
      sourceTextarea.placeholder = placeholder || 'Livestream đã kết thúc';
    }
    if (sendButton) {
      sendButton.disabled = true;
    }
    if (fullscreenState.shell) {
      fullscreenState.shell.querySelectorAll('.wo-livekit-fs-composer-textarea').forEach(function(node) {
        node.disabled = true;
        node.placeholder = placeholder || 'Livestream đã kết thúc';
      });
      fullscreenState.shell.querySelectorAll('.wo-livekit-fs-composer-send').forEach(function(node) {
        node.disabled = true;
      });
    }
  }

  function enableCommentComposer(postId) {
    var entry = ensureEntry(postId);
    if (entry.stopped) {
      return;
    }
    var sourceTextarea = entry.postComments ? entry.postComments.querySelector('.comment-textarea') : null;
    var sendButton = entry.postComments ? entry.postComments.querySelector('.sendbtn') : null;
    if (sourceTextarea) {
      if (!sourceTextarea.getAttribute('data-livekit-placeholder')) {
        sourceTextarea.setAttribute('data-livekit-placeholder', sourceTextarea.placeholder || 'Viết bình luận...');
      }
      sourceTextarea.disabled = false;
      sourceTextarea.placeholder = sourceTextarea.getAttribute('data-livekit-placeholder') || 'Viết bình luận...';
    }
    if (sendButton) {
      sendButton.disabled = false;
    }
    if (fullscreenState.shell) {
      fullscreenState.shell.querySelectorAll('.wo-livekit-fs-composer-textarea').forEach(function(node) {
        node.disabled = false;
        node.placeholder = 'Viết bình luận...';
      });
      fullscreenState.shell.querySelectorAll('.wo-livekit-fs-composer-send').forEach(function(node) {
        node.disabled = false;
      });
    }
  }

  function markEnded(postId, endedText) {
    var entry = ensureEntry(postId);
    entry.stopped = true;
    entry.streamState = 'offline';
    clearRetry(entry);
    if (entry.room) {
      try {
        entry.room.disconnect();
      } catch (err) {}
      entry.room = null;
    }
    if (entry.audioSink) {
      entry.audioSink.innerHTML = '';
    }
    disableCommentComposer(postId, 'Livestream đã kết thúc');
    renderStageMessage(entry, endedText || entry.endedText || 'Livestream đã kết thúc.', true);
    updateFullscreenShellState(entry);
  }

  function buildComposerMarkup() {
    return '' +
      '<div class="wo-livekit-fs-composer">' +
        '<textarea class="wo-livekit-fs-composer-textarea" rows="1" placeholder="Viết bình luận..."></textarea>' +
        '<button type="button" class="wo-livekit-fs-composer-send" aria-label="Gửi bình luận">' +
          '<svg viewBox="0 0 24 24"><path d="M2.01 21 23 12 2.01 3 2 10l15 2-15 2Z"/></svg>' +
        '</button>' +
      '</div>';
  }

  function ensureFullscreenShell() {
    if (fullscreenState.shell) {
      return fullscreenState.shell;
    }
    var shell = document.createElement('div');
    shell.className = 'wo-livekit-fs-shell';
    shell.innerHTML =
      '<div class="wo-livekit-fs-backdrop"></div>' +
      '<div class="wo-livekit-fs-stage-panel">' +
        '<div class="wo-livekit-fs-stage-host"></div>' +
        '<div class="wo-livekit-fs-topbar">' +
          '<div class="wo-livekit-fs-meta">' +
            '<a class="wo-livekit-fs-user-link" href="#" data-role="meta-link">' +
              '<img class="wo-livekit-fs-avatar" data-role="meta-avatar" src="" alt="avatar">' +
              '<span class="wo-livekit-fs-user-copy">' +
                '<span class="wo-livekit-fs-name" data-role="meta-name"></span>' +
                '<span class="wo-livekit-fs-badge">LIVE</span>' +
                '<span class="wo-livekit-fs-count"><svg viewBox="0 0 24 24"><path d="M12 5C6.5 5 2 12 2 12S6.5 19 12 19 22 12 22 12 17.5 5 12 5Zm0 11a4 4 0 1 1 0-8 4 4 0 0 1 0 8Z"/></svg><span data-role="meta-count">0</span></span>' +
              '</span>' +
            '</a>' +
          '</div>' +
          '<button type="button" class="wo-livekit-fs-close" data-role="close-fullscreen" aria-label="Đóng fullscreen">' +
            '<svg viewBox="0 0 24 24"><path d="M18.3 5.71 12 12l6.3 6.29-1.41 1.42L10.59 13.4 4.29 19.71 2.88 18.3 9.17 12 2.88 5.71 4.29 4.29l6.3 6.3 6.3-6.3Z"/></svg>' +
          '</button>' +
        '</div>' +
        '<div class="wo-livekit-fs-comments"></div>' +
        '<div class="wo-livekit-fs-input"></div>' +
        '<div class="wo-livekit-fs-action-stack">' +
          '<button type="button" class="wo-livekit-fs-share" data-role="share-live" aria-label="Chia sẻ livestream">' +
            '<svg viewBox="0 0 24 24"><path d="M18,16.08C17.24,16.08 16.56,16.38 16.04,16.85L8.91,12.7C8.96,12.47 9,12.24 9,12C9,11.76 8.96,11.53 8.91,11.3L15.96,7.19C16.5,7.69 17.21,8 18,8A3,3 0 0,0 21,5A3,3 0 0,0 18,2A3,3 0 0,0 15,5C15,5.24 15.04,5.47 15.09,5.7L8.04,9.81C7.5,9.31 6.79,9 6,9A3,3 0 0,0 3,12A3,3 0 0,0 6,15C6.79,15 7.5,14.69 8.04,14.19L15.16,18.34C15.11,18.55 15.08,18.77 15.08,19C15.08,20.61 16.39,21.91 18,21.91C19.61,21.91 20.92,20.61 20.92,19A2.92,2.92 0 0,0 18,16.08Z"/></svg>' +
          '</button>' +
          '<div class="wo-livekit-fs-react-wrap">' +
            '<div class="wo-livekit-fs-reactions-popup" data-role="reactions-popup"></div>' +
            '<button type="button" class="wo-livekit-fs-react" data-role="react-live" aria-label="Reaction">' +
              '<span class="wo-livekit-fs-react-emoji" data-role="react-emoji"></span>' +
              '<svg viewBox="0 0 24 24"><path d="M12.1 21.35 10.55 19.93C5.4 15.24 2 12.16 2 8.38A5.38 5.38 0 0 1 7.5 3c1.74 0 3.41.81 4.5 2.09A5.93 5.93 0 0 1 16.5 3 5.38 5.38 0 0 1 22 8.38c0 3.78-3.4 6.86-8.55 11.57L12.1 21.35Z"/></svg>' +
            '</button>' +
          '</div>' +
        '</div>' +
        '<div class="wo-livekit-fs-hearts"></div>' +
      '</div>';
    document.body.appendChild(shell);
    fullscreenState.shell = shell;
    fullscreenState.stageHost = shell.querySelector('.wo-livekit-fs-stage-host');
    fullscreenState.commentsHost = shell.querySelector('.wo-livekit-fs-comments');
    fullscreenState.inputHost = shell.querySelector('.wo-livekit-fs-input');
    fullscreenState.metaName = shell.querySelector('[data-role="meta-name"]');
    fullscreenState.metaAvatar = shell.querySelector('[data-role="meta-avatar"]');
    fullscreenState.metaCount = shell.querySelector('[data-role="meta-count"]');
    fullscreenState.metaLink = shell.querySelector('[data-role="meta-link"]');
    fullscreenState.hearts = shell.querySelector('.wo-livekit-fs-hearts');
    fullscreenState.inputHost.innerHTML = buildComposerMarkup();
    buildReactionPopup(shell.querySelector('[data-role="reactions-popup"]'));
    shell.querySelector('.wo-livekit-fs-backdrop').addEventListener('click', closeFullscreen);
    shell.querySelector('[data-role="close-fullscreen"]').addEventListener('click', closeFullscreen);
    shell.querySelector('[data-role="share-live"]').addEventListener('click', function(event) {
      event.preventDefault();
      event.stopPropagation();
      openShareModal();
    });
    bindReactionControls(shell);
    bindComposer(fullscreenState.inputHost);
    if (!fullscreenState.escBound) {
      fullscreenState.escBound = true;
      document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape' && fullscreenState.activePostId) {
          event.preventDefault();
          closeFullscreen();
        }
      });
      window.addEventListener('resize', function() {
        if (fullscreenState.activePostId) {
          syncFullscreenComments(fullscreenState.activePostId);
        }
      });
    }
    return shell;
  }

  function syncComposerText(value) {
    if (!fullscreenState.shell) {
      return;
    }
    fullscreenState.shell.querySelectorAll('.wo-livekit-fs-composer-textarea').forEach(function(node) {
      if (node.value !== value) {
        node.value = value;
      }
    });
  }

  function bindComposer(scope) {
    if (!scope) {
      return;
    }
    var textarea = scope.querySelector('.wo-livekit-fs-composer-textarea');
    var sendButton = scope.querySelector('.wo-livekit-fs-composer-send');
    if (!textarea || !sendButton) {
      return;
    }
    textarea.addEventListener('input', function() {
      syncComposerText(textarea.value);
    });
    textarea.addEventListener('keydown', function(event) {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        submitFullscreenComment();
      }
    });
    sendButton.addEventListener('click', function(event) {
      event.preventDefault();
      submitFullscreenComment();
    });
  }

  function getActiveComposerValue() {
    if (!fullscreenState.shell) {
      return '';
    }
    var active = fullscreenState.shell.querySelector('.wo-livekit-fs-composer-textarea:not([disabled])');
    return active ? String(active.value || '').trim() : '';
  }

  function submitFullscreenComment() {
    if (!fullscreenState.activePostId) {
      return;
    }
    var entry = ensureEntry(fullscreenState.activePostId);
    var text = getActiveComposerValue();
    var sourceTextarea = entry.postComments ? entry.postComments.querySelector('.comment-textarea') : null;
    if (!text || !sourceTextarea || sourceTextarea.disabled) {
      return;
    }
    sourceTextarea.value = text;
    syncComposerText(text);
    if (typeof window.Wo_LiveComment === 'function') {
      window.Wo_LiveComment(text, {keyCode: 13}, entry.postId, 1);
    }
    if (typeof window.Wo_RegisterComment2 === 'function') {
      window.Wo_RegisterComment2(entry.postId, entry.publisherId || '0', entry.pageId || '0');
    }
    sourceTextarea.value = '';
    syncComposerText('');
  }

  function cloneCommentFeed(entry, limit) {
    var cloneHost = document.createElement('div');
    cloneHost.className = 'wow_liv_comments_feed';
    if (!entry.commentFeed) {
      return cloneHost;
    }
    var comments = Array.prototype.slice.call(entry.commentFeed.querySelectorAll('.live_comments'));
    if (limit && comments.length > limit) {
      comments = comments.slice(comments.length - limit);
    }
    comments.forEach(function(node) {
      cloneHost.appendChild(node.cloneNode(true));
    });
    return cloneHost;
  }

  function renderEmptyComments() {
    var empty = document.createElement('div');
    empty.className = 'wo-livekit-fs-empty';
    empty.textContent = 'Chưa có bình luận';
    return empty;
  }

  function buildReactionPopup(popup) {
    if (!popup) {
      return;
    }
    popup.innerHTML = '';
    if (!fullscreenState.activePostId) {
      return;
    }
    var postId = String(fullscreenState.activePostId);
    var source = document.querySelector('#post-' + postId + ' .reactions-box-container-' + postId);
    if (!source) {
      return;
    }
    var clone = source.cloneNode(true);
    clone.classList.add('wo-livekit-fs-reactions-box');
    clone.style.display = '';
    clone.style.right = 'auto';
    clone.style.left = 'auto';
    clone.querySelectorAll('.reaction').forEach(function(item) {
      item.removeAttribute('onclick');
      item.addEventListener('click', function(event) {
        event.preventDefault();
        event.stopPropagation();
        registerOverlayReaction(item);
      });
    });
    popup.appendChild(clone);
  }

  function clearReactionCloseTimer() {
    if (fullscreenState.reactionCloseTimer) {
      clearTimeout(fullscreenState.reactionCloseTimer);
      fullscreenState.reactionCloseTimer = null;
    }
  }

  function scheduleReactionClose() {
    clearReactionCloseTimer();
    fullscreenState.reactionCloseTimer = window.setTimeout(function() {
      fullscreenState.reactionCloseTimer = null;
      setReactionPopupOpen(false);
    }, 180);
  }

  function setReactionPopupOpen(isOpen) {
    if (!fullscreenState.shell) {
      return;
    }
    var popup = fullscreenState.shell.querySelector('[data-role="reactions-popup"]');
    if (popup) {
      popup.classList.toggle('is-open', !!isOpen);
    }
  }

  function syncReactionButton() {
    if (!fullscreenState.shell) {
      return;
    }
    var button = fullscreenState.shell.querySelector('[data-role="react-live"]');
    var emojiNode = fullscreenState.shell.querySelector('[data-role="react-emoji"]');
    var postId = fullscreenState.activePostId ? String(fullscreenState.activePostId) : '';
    var sourceButton = postId ? document.getElementById('react_' + postId) : null;
    var activeIcon = postId ? document.querySelector('#react_' + postId + ' .inline_post_count_emoji') : null;
    if (!button || !emojiNode) {
      return;
    }
    if (!sourceButton || sourceButton.getAttribute('data_react') !== '1' || !activeIcon) {
      button.classList.remove('active-reaction');
      button.removeAttribute('data-current-reaction');
      emojiNode.textContent = '';
      emojiNode.innerHTML = '';
      return;
    }
    button.classList.add('active-reaction');
    button.setAttribute('data-current-reaction', sourceButton.getAttribute('data-reaction-id') || '');
    button.setAttribute('aria-label', sourceButton.getAttribute('data-reaction-lang') || 'Reaction');
    emojiNode.innerHTML = activeIcon.innerHTML;
  }

  function registerOverlayReaction(clonedItem) {
    if (!fullscreenState.activePostId) {
      return;
    }
    var postId = String(fullscreenState.activePostId);
    var reactionId = clonedItem ? clonedItem.getAttribute('data-reaction-id') : '';
    var sourceItem = reactionId ? document.querySelector('#post-' + postId + ' .reactions-box-container-' + postId + ' .reaction[data-reaction-id="' + reactionId + '"]') : null;
    if (!sourceItem) {
      return;
    }
    sourceItem.click();
    setReactionPopupOpen(false);
    window.setTimeout(function() {
      syncReactionButton();
      triggerReaction(clonedItem ? clonedItem.innerHTML : '');
      buildReactionPopup(fullscreenState.shell ? fullscreenState.shell.querySelector('[data-role="reactions-popup"]') : null);
    }, 150);
  }

  function bindReactionControls(shell) {
    var wrap = shell.querySelector('.wo-livekit-fs-react-wrap');
    var popup = shell.querySelector('[data-role="reactions-popup"]');
    var button = shell.querySelector('[data-role="react-live"]');
    if (!wrap || !popup || !button) {
      return;
    }

    function openPopup() {
      clearReactionCloseTimer();
      buildReactionPopup(popup);
      setReactionPopupOpen(true);
    }

    wrap.addEventListener('mouseenter', openPopup);
    wrap.addEventListener('mouseleave', scheduleReactionClose);
    popup.addEventListener('mouseenter', clearReactionCloseTimer);
    popup.addEventListener('mouseleave', scheduleReactionClose);

    button.addEventListener('click', function(event) {
      event.preventDefault();
      event.stopPropagation();
      clearReactionCloseTimer();
      var postId = fullscreenState.activePostId ? String(fullscreenState.activePostId) : '';
      var sourceButton = postId ? document.getElementById('react_' + postId) : null;
      if (sourceButton && sourceButton.getAttribute('data_react') === '1') {
        sourceButton.click();
        window.setTimeout(function() {
          syncReactionButton();
          buildReactionPopup(popup);
        }, 120);
        return;
      }
      if (popup.classList.contains('is-open')) {
        setReactionPopupOpen(false);
        return;
      }
      openPopup();
    });
    shell.addEventListener('click', function(event) {
      if (!wrap.contains(event.target)) {
        clearReactionCloseTimer();
        setReactionPopupOpen(false);
      }
    });
  }

  function openShareModal() {
    if (!fullscreenState.activePostId) {
      return;
    }
    var entry = ensureEntry(fullscreenState.activePostId);
    var shareTrigger = document.querySelector('#post-' + entry.postId + ' [onclick*="Wo_SharePostOn("]');
    if (shareTrigger && typeof shareTrigger.click === 'function') {
      closeFullscreen();
      window.setTimeout(function() {
        shareTrigger.click();
      }, 120);
      return;
    }
    if (typeof window.Wo_SharePostOn === 'function') {
      closeFullscreen();
      window.setTimeout(function() {
        window.Wo_SharePostOn(parseInt(entry.postId, 10), parseInt(entry.publisherId || '0', 10), 'timeline');
      }, 120);
    }
  }

  function syncFullscreenComments(postId) {
    if (!fullscreenState.activePostId || String(fullscreenState.activePostId) !== String(postId) || !fullscreenState.commentsHost) {
      return;
    }
    var entry = ensureEntry(postId);
    var clone = cloneCommentFeed(entry, 3);
    fullscreenState.commentsHost.innerHTML = '';
    if (clone.children.length) {
      fullscreenState.commentsHost.appendChild(clone);
    } else {
      fullscreenState.commentsHost.appendChild(renderEmptyComments());
    }
  }

  function updateFullscreenShellState(entry) {
    if (!fullscreenState.shell) {
      return;
    }
    fullscreenState.shell.classList.toggle('is-ended', !!entry.stopped);
    fullscreenState.shell.classList.toggle('is-stale', entry.streamState === 'stale' && !entry.stopped);
  }

  function updateFullscreenMeta(postId) {
    if (!fullscreenState.shell || fullscreenState.activePostId !== String(postId)) {
      return;
    }
    var entry = ensureEntry(postId);
    fullscreenState.metaName.textContent = entry.hostName || 'Livestream';
    fullscreenState.metaAvatar.src = entry.hostAvatar || '';
    fullscreenState.metaAvatar.alt = entry.hostName || 'avatar';
    fullscreenState.metaLink.href = entry.hostUrl || '#';
    fullscreenState.metaCount.textContent = entry.countNode ? String(entry.countNode.textContent || '0').trim() : '0';
    updateFullscreenShellState(entry);
  }

  function openFullscreen(postId) {
    var entry = ensureEntry(postId);
    if (!entry || !entry.wrap) {
      return;
    }
    if (fullscreenState.activePostId && fullscreenState.activePostId !== String(postId)) {
      closeFullscreen();
    }
    ensureFullscreenShell();
    if (!entry.placeholders.wrap && entry.wrap.parentNode) {
      entry.placeholders.wrap = createPlaceholder(entry.wrap);
      entry.wrap.parentNode.insertBefore(entry.placeholders.wrap, entry.wrap);
    }
    fullscreenState.stageHost.appendChild(entry.wrap);
    fullscreenState.activePostId = String(postId);
    window.wo_active_fullscreen_post_id = String(postId);
    document.documentElement.classList.add('wo-livekit-fs-lock');
    document.body.classList.add('wo-livekit-fs-lock');
    fullscreenState.shell.classList.add('is-active');
    updateFullscreenMeta(postId);
    syncFullscreenComments(postId);
    buildReactionPopup(fullscreenState.shell.querySelector('[data-role="reactions-popup"]'));
    syncReactionButton();
    var sourceTextarea = entry.postComments ? entry.postComments.querySelector('.comment-textarea') : null;
    syncComposerText(sourceTextarea ? String(sourceTextarea.value || '') : '');
    updateFullscreenShellState(entry);
  }

  function closeFullscreen() {
    if (!fullscreenState.activePostId) {
      return;
    }
    var entry = ensureEntry(fullscreenState.activePostId);
    restoreNode(entry.wrap, entry.placeholders.wrap);
    entry.placeholders = {};
    fullscreenState.activePostId = null;
    window.wo_active_fullscreen_post_id = null;
    if (fullscreenState.stageHost) {
      fullscreenState.stageHost.innerHTML = '';
    }
    if (fullscreenState.commentsHost) {
      fullscreenState.commentsHost.innerHTML = '';
    }
    if (fullscreenState.hearts) {
      fullscreenState.hearts.innerHTML = '';
    }
    if (fullscreenState.shell) {
      fullscreenState.shell.classList.remove('is-active', 'is-ended', 'is-stale');
      setReactionPopupOpen(false);
      var emojiNode = fullscreenState.shell.querySelector('[data-role="react-emoji"]');
      var button = fullscreenState.shell.querySelector('[data-role="react-live"]');
      if (emojiNode) {
        emojiNode.innerHTML = '';
      }
      if (button) {
        button.classList.remove('active-reaction');
      }
    }
    document.documentElement.classList.remove('wo-livekit-fs-lock');
    document.body.classList.remove('wo-livekit-fs-lock');
  }

  function triggerReaction(emoji) {
    if (!fullscreenState.activePostId) {
      return;
    }
    if (!fullscreenState.hearts) {
      return;
    }
    var reactionGlyph = emoji || '❤';
    for (var i = 0; i < 5; i += 1) {
      var heart = document.createElement('span');
      heart.className = 'wo-livekit-fs-heart';
      if (String(reactionGlyph).indexOf('<') !== -1) {
        heart.innerHTML = reactionGlyph;
      } else {
        heart.textContent = reactionGlyph;
      }
      heart.style.setProperty('--drift', ((Math.random() * 44) - 22) + 'px');
      heart.style.setProperty('--rise', '-' + (120 + Math.round(Math.random() * 90)) + 'px');
      fullscreenState.hearts.appendChild(heart);
      (function(target) {
        setTimeout(function() {
          target.remove();
        }, 1300);
      })(heart);
    }
  }

  window.WoLiveKitLive = {
    __ready: true,
    register: function(options) {
      if (!options || !options.postId) {
        return;
      }
      var entry = ensureEntry(options.postId);
      entry.joinUrl = options.joinUrl || '';
      entry.endedText = options.endedText || 'Livestream đã kết thúc.';
      entry.hostName = options.hostName || entry.hostName || '';
      entry.hostAvatar = options.hostAvatar || entry.hostAvatar || '';
      entry.hostUrl = options.hostUrl || entry.hostUrl || '#';
      entry.stopped = options.isStillLive === false;
      entry.streamState = entry.stopped ? 'offline' : 'live';
      if (entry.stopped) {
        markEnded(entry.postId, entry.endedText);
        return;
      }
      enableCommentComposer(entry.postId);
      startPlayer(entry.postId);
    },
    stopPlayer: function(postId, endedText) {
      markEnded(String(postId), endedText);
    },
    markEnded: function(postId, endedText) {
      markEnded(String(postId), endedText);
    },
    setStreamState: function(postId, state) {
      var entry = ensureEntry(String(postId));
      if (!entry || entry.stopped) {
        return;
      }
      entry.streamState = state === 'offline' ? 'stale' : (state || 'live');
      if (entry.streamState === 'live') {
        clearRetry(entry);
        enableCommentComposer(entry.postId);
        if (!entry.room) {
          startPlayer(entry.postId);
        }
      } else if (entry.streamState === 'stale') {
        refreshStageState(entry);
      }
      updateFullscreenShellState(entry);
      updateFullscreenMeta(entry.postId);
    },
    openFullscreen: function(postId) {
      openFullscreen(String(postId));
    },
    closeFullscreen: function() {
      closeFullscreen();
    }
  };
})(window, document);
</script>
<?php } ?>
