	var usesNativePinnedMarker = Wo_ExploreNearbyShouldUseGoogleNativePinnedMarker(point);
	var legacyPinnedLabel = Wo_ExploreNearbyGetGoogleNativePinnedMarkerLabelOptions(point);
	var collisionBehavior = Wo_ExploreNearbyGetGoogleMarkerCollisionBehavior(point);

