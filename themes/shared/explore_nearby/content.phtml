	googleRouteGlow: null,
	leafletRouteLine: null,
	renderedPoints: []
};
window.WoExploreNearbyMapState = WoExploreNearbyMapState;
var defaultUserTypeLabel = <?php echo json_encode($user_type_label, $json_flags); ?>;
var defaultShopTypeLabel = <?php echo json_encode($shop_type_label, $json_flags); ?>;
var focusMapTitle = <?php echo json_encode($wo['lang']['show_location'], $json_flags); ?>;
var defaultDistanceValue = <?php echo (int) $default_distance; ?>;
var emptyUsersText = <?php echo json_encode($wo['lang']['no_users_found'], $json_flags); ?>;
var emptyShopsText = <?php echo json_encode($wo['lang']['no_shops_found'], $json_flags); ?>;
var currentUserMapPoint = {
	item_key: <?php echo json_encode($build_item_key('user', (!empty($wo['user']['url']) ? $wo['user']['url'] : ''), $current_user_id), $json_flags); ?>,
	name: <?php echo json_encode($wo['user']['name'], $json_flags); ?>,
	title: <?php echo json_encode($wo['user']['name'], $json_flags); ?>,
	lat: <?php echo !empty($wo['user']['lat']) ? (float) $wo['user']['lat'] : 0; ?>,
