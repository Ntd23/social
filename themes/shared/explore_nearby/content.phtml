function Wo_ExploreNearbyEnsureOrientationPermissionPrompt() {
	if (WoExploreNearbyState.deviceOrientationPrompted || typeof window.DeviceOrientationEvent === 'undefined' || typeof window.DeviceOrientationEvent.requestPermission !== 'function') {
		return;
	}

	WoExploreNearbyState.deviceOrientationPrompted = true;
	$(document).one('click touchstart', function() {
		window.DeviceOrientationEvent.requestPermission().then(function(permissionState) {
			if (permissionState === 'granted') {
				Wo_ExploreNearbyBindDeviceOrientationTracking();
