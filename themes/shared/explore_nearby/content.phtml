function Wo_ExploreNearbyBuildUsersRequestData(offset) {
	var requestData = {
		f: 'nearby_users',
		s: 'load',
		distance: Wo_ExploreNearbyGetDistanceValue()
	};
	var searchValue = Wo_ExploreNearbyGetRequestSearchValue();

	if (searchValue) {
		requestData.name = searchValue;
	}

	if (Wo_ExploreNearbyHasSearchCenter()) {
		requestData.search_mode = 'location';
		requestData.center_lat = WoExploreNearbyState.searchCenterLat;
		requestData.center_lng = WoExploreNearbyState.searchCenterLng;
	}

	if (offset) {
		requestData.offset = offset;
	}

	return requestData;
}

function Wo_ExploreNearbyBuildShopsRequestData(offset) {
	var requestData = {
		f: 'nearby_shops',
		s: 'load',
		distance: Wo_ExploreNearbyGetDistanceValue()
	};
	var searchValue = Wo_ExploreNearbyGetRequestSearchValue();

	if (searchValue) {
		requestData.name = searchValue;
	}

	if (Wo_ExploreNearbyHasSearchCenter()) {
		requestData.search_mode = 'location';
		requestData.center_lat = WoExploreNearbyState.searchCenterLat;
		requestData.center_lng = WoExploreNearbyState.searchCenterLng;
	}

	if (offset) {
		requestData.offset = offset;
	}

	return requestData;
}

function Wo_ExploreNearbyGetUsersOffset() {
	var items = Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.usersItems || []);
	if (!items.length) {
		return 0;
	}

	return items[items.length - 1].offset_id || 0;
}

function Wo_ExploreNearbyGetShopsOffset() {
	var items = Wo_ExploreNearbyGetOrderedShopItems().filter(function(item) {
		return !item.is_pinned_only;
	});
	if (!items.length) {
		return 0;
	}

	return items[items.length - 1].offset_id || 0;
}

function Wo_ExploreNearbyApplyUsersResponse(data, append) {
	var responseItems = [];

	if (data && data.status == 200) {
		responseItems = data.items_info || data.users_info || [];
		WoExploreNearbyState.usersItems = append ? Wo_ExploreNearbyMergeUniqueItems(WoExploreNearbyState.usersItems || [], responseItems) : Wo_ExploreNearbyNormalizeDiscoveryItems(responseItems);
		WoExploreNearbyState.usersCount = parseInt(data.count || 0, 10);
	}
	else if (!append) {
		WoExploreNearbyState.usersItems = [];
		WoExploreNearbyState.usersCount = 0;
	}
}

function Wo_ExploreNearbyApplyShopsResponse(data, append) {
	var responseItems = [];

	if (data && data.status == 200) {
		responseItems = data.items_info || data.users_info || [];
		WoExploreNearbyState.shopsItems = append ? Wo_ExploreNearbyMergeUniqueItems(WoExploreNearbyState.shopsItems || [], responseItems) : Wo_ExploreNearbyNormalizeDiscoveryItems(responseItems);
		WoExploreNearbyState.shopsCount = parseInt(data.count || 0, 10);
	}
	else if (!append) {
		WoExploreNearbyState.shopsItems = [];
		WoExploreNearbyState.shopsCount = 0;
	}
}

function Wo_ExploreNearbyAbortPendingRequests() {
	if (WoExploreNearbyState.usersRequest && WoExploreNearbyState.usersRequest.readyState !== 4) {
		WoExploreNearbyState.usersRequest.abort();
	}
	if (WoExploreNearbyState.shopsRequest && WoExploreNearbyState.shopsRequest.readyState !== 4) {
		WoExploreNearbyState.shopsRequest.abort();
	}
}

function Wo_ExploreNearbyLoad(append, loaderTarget) {
	var pending = 0;

	if (append && Wo_ExploreNearbyIsPlaceSearchMode()) {
		return;
	}

	if (append && WoExploreNearbyState.appendInProgress) {
		return;
	}

	var loadToken = ++WoExploreNearbyState.loadToken;

	if (!append) {
		WoExploreNearbyState.appendInProgress = false;
		Wo_ExploreNearbyAbortPendingRequests();
		WoExploreNearbyState.openPopupPointKey = null;
		Wo_ExploreNearbyCloseInfoPopup();
		Wo_ExploreNearbyHideMobileSheet();
	}
	else {
		WoExploreNearbyState.appendInProgress = true;
		Wo_ExploreNearbyUpdateInfiniteScrollState();
	}

	if (loaderTarget) {
		Wo_progressIconLoader($(loaderTarget));
	}
	else if (!append) {
		Wo_StartBar();
	}

	function finishWithoutRequests() {
		if (loadToken !== WoExploreNearbyState.loadToken) {
			return;
		}

		WoExploreNearbyState.appendInProgress = false;
		Wo_ExploreNearbyUpdateInfiniteScrollState();
		Wo_ExploreNearbyUpdateUi();
		Wo_ExploreNearbyRenderCurrentMap(WoExploreNearbyState.openPopupPointKey || null);
		Wo_ExploreNearbyRefreshDynamicUserLocations(true);
		if (loaderTarget) {
			Wo_progressIconLoader($(loaderTarget));
		}
		else if (!append) {
			Wo_FinishBar();
		}
	}

	function finishOne() {
		if (loadToken !== WoExploreNearbyState.loadToken) {
			return;
		}

		pending--;
		if (pending <= 0) {
			WoExploreNearbyState.appendInProgress = false;
			Wo_ExploreNearbyUpdateUi();
			Wo_ExploreNearbyRenderCurrentMap(WoExploreNearbyState.openPopupPointKey || null);
			Wo_ExploreNearbyRefreshDynamicUserLocations(true);
			if (loaderTarget) {
				Wo_progressIconLoader($(loaderTarget));
			}
			else if (!append) {
				Wo_FinishBar();
			}
		}
	}

	function loadUsers() {
		pending++;
		WoExploreNearbyState.usersRequest = $.ajax({
			url: Wo_Ajax_Requests_File(),
			type: 'GET',
			dataType: 'json',
			data: Wo_ExploreNearbyBuildUsersRequestData(append ? Wo_ExploreNearbyGetUsersOffset() : 0)
		}).done(function(data) {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return;
			}
			Wo_ExploreNearbyApplyUsersResponse(data, append);
		}).fail(function(xhr, status) {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return;
			}
			if (status !== 'abort' && !append) {
				Wo_ExploreNearbyApplyUsersResponse(null, false);
			}
		}).always(finishOne);
	}

	function loadShops() {
		pending++;
		WoExploreNearbyState.shopsRequest = $.ajax({
			url: Wo_Ajax_Requests_File(),
			type: 'GET',
			dataType: 'json',
			data: Wo_ExploreNearbyBuildShopsRequestData(append ? Wo_ExploreNearbyGetShopsOffset() : 0)
		}).done(function(data) {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return;
			}
			Wo_ExploreNearbyApplyShopsResponse(data, append);
		}).fail(function(xhr, status) {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return;
			}
			if (status !== 'abort' && !append) {
				Wo_ExploreNearbyApplyShopsResponse(null, false);
			}
		}).always(finishOne);
	}

	function startRequests() {
		if (loadToken !== WoExploreNearbyState.loadToken) {
			return;
		}

		if (WoExploreNearbyState.usersEnabled) {
			loadUsers();
		}
		if (WoExploreNearbyState.shopsEnabled) {
			loadShops();
		}

		if (pending === 0) {
			finishWithoutRequests();
		}
	}

	if (!append) {
		Wo_ExploreNearbyResolveSearchPlace(loadToken).then(function(resolution) {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return;
			}

			if (resolution && resolution.skipNearby) {
				finishWithoutRequests();
				return;
			}

			startRequests();
		});
		return;
	}

	startRequests();
}

