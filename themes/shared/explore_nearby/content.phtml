function Wo_ExploreNearbyFindNearestGoogleMarkerByClientPosition(clientX, clientY) {
	var mapElement = document.getElementById('map');
	if (!mapElement || typeof clientX !== 'number' || typeof clientY !== 'number') {
		return null;
	}

	var mapRect = mapElement.getBoundingClientRect();
	var localX = clientX - mapRect.left;
	var localY = clientY - mapRect.top;
	var nearestMarker = null;
	var nearestDistance = Number.MAX_VALUE;
	var thresholdPx = Wo_ExploreNearbyGetMapSelectionFallbackThresholdPx();

	for (var markerKey in WoExploreNearbyMapState.googleMarkerLookup) {
		if (!Object.prototype.hasOwnProperty.call(WoExploreNearbyMapState.googleMarkerLookup, markerKey)) {
			continue;
		}

		var marker = WoExploreNearbyMapState.googleMarkerLookup[markerKey];
		var point = marker ? marker.woNearbyPoint : null;
		var containerPoint = Wo_ExploreNearbyGetGoogleMarkerContainerPoint(marker);
		if (!point || !containerPoint || point.isSelf) {
			continue;
		}

		var deltaX = containerPoint.x - localX;
		var deltaY = containerPoint.y - localY;
		var distancePx = Math.sqrt((deltaX * deltaX) + (deltaY * deltaY));
		if (distancePx < nearestDistance) {
			nearestDistance = distancePx;
			nearestMarker = marker;
		}
	}

	return nearestDistance <= thresholdPx ? nearestMarker : null;
}

function Wo_ExploreNearbyFindGoogleMarkerByClientPosition(clientX, clientY) {
	if (typeof clientX !== 'number' || typeof clientY !== 'number' || typeof document.elementsFromPoint !== 'function') {
		return null;
	}

	var hitElements = document.elementsFromPoint(clientX, clientY) || [];
	for (var i = 0; i < hitElements.length; i++) {
		var currentElement = hitElements[i];
		if (!currentElement) {
			continue;
		}

		var markerElement = null;
		if (currentElement.classList && currentElement.classList.contains('wo-nearby-google-marker')) {
			markerElement = currentElement;
		}
		else if (typeof currentElement.closest === 'function') {
			markerElement = currentElement.closest('.wo-nearby-google-marker');
		}

		if (!markerElement) {
			continue;
		}

		var pointKey = markerElement.getAttribute('data-point-key') || '';
		if (!pointKey) {
			continue;
		}

		var marker = WoExploreNearbyMapState.googleMarkerLookup[pointKey] || null;
		if (marker) {
			return marker;
		}
	}

	return null;
}

