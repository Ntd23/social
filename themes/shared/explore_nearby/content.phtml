function Wo_ExploreNearbyGetDistanceKm(firstPoint, secondPoint) {
	var earthRadiusKm = 6371;
	var latDistance = (secondPoint.lat - firstPoint.lat) * (Math.PI / 180);
	var lngDistance = (secondPoint.lng - firstPoint.lng) * (Math.PI / 180);
	var firstLatitude = firstPoint.lat * (Math.PI / 180);
	var secondLatitude = secondPoint.lat * (Math.PI / 180);
	var haversine = Math.sin(latDistance / 2) * Math.sin(latDistance / 2) +
		Math.cos(firstLatitude) * Math.cos(secondLatitude) *
		Math.sin(lngDistance / 2) * Math.sin(lngDistance / 2);

	return earthRadiusKm * (2 * Math.atan2(Math.sqrt(haversine), Math.sqrt(1 - haversine)));
}

function Wo_ExploreNearbyNormalizePoints(points) {
	var normalizedPoints = [];
	if (!Array.isArray(points)) {
		return normalizedPoints;
	}

	for (var i = 0; i < points.length; i++) {
		var point = points[i] || {};
		var lat = parseFloat(point.lat);
		var lng = parseFloat(point.lng);
		if (isNaN(lat) || isNaN(lng) || (lat === 0 && lng === 0)) {
			continue;
		}

		normalizedPoints.push({
			item_key: Wo_ExploreNearbyGetItemKey(point),
			name: point.name || point.title || '',
			lat: lat,
			lng: lng,
			avatar: point.avatar || '',
			url: point.url || '',
			location: point.location || '',
			type: point.type || 'user',
			type_label: point.type_label || (point.type === 'shop' ? defaultShopTypeLabel : defaultUserTypeLabel),
			isSelf: point.isSelf === true || point.is_self === true || point.is_self === 1,
			heading: Wo_ExploreNearbyNormalizeHeading(point.heading) || 0
		});
	}

	return normalizedPoints;
}

function Wo_ExploreNearbyIsSamePoint(firstPoint, secondPoint) {
	if (!firstPoint || !secondPoint) {
		return false;
	}

	if (Wo_ExploreNearbyGetItemKey(firstPoint) && Wo_ExploreNearbyGetItemKey(secondPoint)) {
		return Wo_ExploreNearbyGetItemKey(firstPoint) === Wo_ExploreNearbyGetItemKey(secondPoint);
	}

	if (firstPoint.url && secondPoint.url) {
		return firstPoint.url === secondPoint.url;
	}

	return parseFloat(firstPoint.lat) === parseFloat(secondPoint.lat) && parseFloat(firstPoint.lng) === parseFloat(secondPoint.lng);
}

function Wo_ExploreNearbyGetCombinedPoints(points) {
	var normalizedPoints = Wo_ExploreNearbyNormalizePoints(points);
	var combinedPoints = [];
	var normalizedCurrentUserPoint = Wo_ExploreNearbyNormalizePoints([currentUserMapPoint]);

	if (normalizedCurrentUserPoint.length > 0) {
		combinedPoints.push(normalizedCurrentUserPoint[0]);
	}

	for (var i = 0; i < normalizedPoints.length; i++) {
		var point = normalizedPoints[i];
		var duplicatedPoint = false;

		for (var j = 0; j < combinedPoints.length; j++) {
			if (Wo_ExploreNearbyIsSamePoint(combinedPoints[j], point)) {
				duplicatedPoint = true;
				break;
			}
		}

		if (!duplicatedPoint) {
			combinedPoints.push(point);
		}
	}

	return combinedPoints;
}

function Wo_ExploreNearbyGetBoundsDiagonalKm(points) {
	var normalizedPoints = Wo_ExploreNearbyNormalizePoints(points);
	if (normalizedPoints.length <= 1) {
		return 0;
	}

	var minLat = normalizedPoints[0].lat;
	var maxLat = normalizedPoints[0].lat;
	var minLng = normalizedPoints[0].lng;
	var maxLng = normalizedPoints[0].lng;

	for (var i = 1; i < normalizedPoints.length; i++) {
		minLat = Math.min(minLat, normalizedPoints[i].lat);
		maxLat = Math.max(maxLat, normalizedPoints[i].lat);
		minLng = Math.min(minLng, normalizedPoints[i].lng);
		maxLng = Math.max(maxLng, normalizedPoints[i].lng);
	}

	return Wo_ExploreNearbyGetDistanceKm({lat: minLat, lng: minLng}, {lat: maxLat, lng: maxLng});
}

function Wo_ExploreNearbyGetZoomFloor(points) {
	var normalizedPoints = Wo_ExploreNearbyNormalizePoints(points);
	if (!normalizedPoints.length) {
		return 7;
	}

	if (normalizedPoints.length === 1) {
		return 15;
	}

	var diagonalDistanceKm = Wo_ExploreNearbyGetBoundsDiagonalKm(normalizedPoints);
	if (diagonalDistanceKm < 1) {
		return 16;
	}
	if (diagonalDistanceKm <= 5) {
		return 14;
	}

	return 4;
}

