}

function Wo_ExploreNearbyIsRelatedPlacePoint(item) {
	return !!(item && (item.is_related_place || item.isRelatedPlace));
}

function Wo_ExploreNearbyIsTruthyFlag(value) {
	return value === true || value === 1 || value === '1' || value === 'true';
}

function Wo_ExploreNearbyIsPinnedPoint(item) {
	return !!(item && (
		Wo_ExploreNearbyIsTruthyFlag(item.is_pinned) ||
		Wo_ExploreNearbyIsTruthyFlag(item.isPinned) ||
		Wo_ExploreNearbyIsTruthyFlag(item.is_pinned_only) ||
		Wo_ExploreNearbyIsTruthyFlag(item.isPinnedOnly)
	));
}

function Wo_ExploreNearbyUsesPlaceIconMarker(item) {
