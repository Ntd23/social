}

function Wo_ExploreNearbyFitRouteViewport(path, fallbackPoints) {
	var normalizedPath = [];
	var points = Array.isArray(path) ? path : [];
	for (var i = 0; i < points.length; i++) {
		var lat = parseFloat(points[i].lat);
		var lng = parseFloat(points[i].lng);
		if (isNaN(lat) || isNaN(lng)) {
			continue;
		}

		normalizedPath.push({lat: lat, lng: lng});
	}

	if (!normalizedPath.length && Array.isArray(fallbackPoints)) {
		for (var j = 0; j < fallbackPoints.length; j++) {
			var fallbackLat = parseFloat(fallbackPoints[j].lat);
			var fallbackLng = parseFloat(fallbackPoints[j].lng);
			if (isNaN(fallbackLat) || isNaN(fallbackLng)) {
				continue;
			}

			normalizedPath.push({lat: fallbackLat, lng: fallbackLng});
		}
	}

	if (!normalizedPath.length) {
		return;
	}

	if (WoExploreNearbyMapState.provider === 'google' && WoExploreNearbyMapState.map) {
		var googleBounds = new google.maps.LatLngBounds();
		for (var g = 0; g < normalizedPath.length; g++) {
			googleBounds.extend(normalizedPath[g]);
		}
		WoExploreNearbyMapState.map.fitBounds(googleBounds, 72);
		google.maps.event.addListenerOnce(WoExploreNearbyMapState.map, 'idle', function() {
			var currentZoom = WoExploreNearbyMapState.map.getZoom() || 7;
			var minZoom = Wo_ExploreNearbyGetZoomFloor(normalizedPath);
			var targetZoom = currentZoom;
			if (targetZoom > 16) {
				targetZoom = 16;
			}
			if (targetZoom < minZoom) {
				targetZoom = minZoom;
			}
			if (targetZoom !== currentZoom) {
				WoExploreNearbyMapState.map.setZoom(targetZoom);
			}
		});
		return;
	}

	if (WoExploreNearbyMapState.provider === 'leaflet' && WoExploreNearbyMapState.map) {
		var bounds = [];
		for (var l = 0; l < normalizedPath.length; l++) {
			bounds.push([normalizedPath[l].lat, normalizedPath[l].lng]);
		}
		WoExploreNearbyMapState.map.fitBounds(bounds, {
			padding: [56, 56],
			maxZoom: 16
		});
		var leafletZoom = WoExploreNearbyMapState.map.getZoom() || 7;
		var leafletMinZoom = Wo_ExploreNearbyGetZoomFloor(normalizedPath);
		if (leafletZoom < leafletMinZoom) {
			WoExploreNearbyMapState.map.setZoom(leafletMinZoom);
		}
	}
}

function Wo_ExploreNearbyGetRouteCacheKey(provider, fromPoint, toPoint) {
	return [
		provider,
		parseFloat(fromPoint.lat).toFixed(6),
		parseFloat(fromPoint.lng).toFixed(6),
		parseFloat(toPoint.lat).toFixed(6),
		parseFloat(toPoint.lng).toFixed(6)
	].join('|');
}

function Wo_ExploreNearbyRequestGoogleRoute(fromPoint, toPoint) {
	if (!WoExploreNearbyMapState.map || typeof google === 'undefined' || !google.maps || typeof google.maps.DirectionsService === 'undefined') {
		return Wo_ExploreNearbyRequestLeafletRoute(fromPoint, toPoint);
	}

	var cacheKey = Wo_ExploreNearbyGetRouteCacheKey('google', fromPoint, toPoint);
	if (WoExploreNearbyState.routeCache.hasOwnProperty(cacheKey)) {
		return Promise.resolve(WoExploreNearbyState.routeCache[cacheKey]);
	}

	if (!WoExploreNearbyMapState.googleDirectionsService) {
		WoExploreNearbyMapState.googleDirectionsService = new google.maps.DirectionsService();
	}

	return new Promise(function(resolve) {
		WoExploreNearbyMapState.googleDirectionsService.route({
			origin: {lat: fromPoint.lat, lng: fromPoint.lng},
			destination: {lat: toPoint.lat, lng: toPoint.lng},
			travelMode: google.maps.TravelMode.DRIVING,
			provideRouteAlternatives: false
		}, function(result, status) {
			if (status === 'OK' && result && result.routes && result.routes[0]) {
				var overviewPath = result.routes[0].overview_path || [];
				var normalizedPath = [];
				for (var i = 0; i < overviewPath.length; i++) {
					normalizedPath.push({
						lat: overviewPath[i].lat(),
						lng: overviewPath[i].lng()
					});
				}

				if (normalizedPath.length > 1) {
					var routeData = {path: normalizedPath};
					WoExploreNearbyState.routeCache[cacheKey] = routeData;
					resolve(routeData);
					return;
				}
			}

			Wo_ExploreNearbyRequestLeafletRoute(fromPoint, toPoint).then(resolve).catch(function() {
				resolve(null);
			});
		});
	});
}

function Wo_ExploreNearbyRequestLeafletRoute(fromPoint, toPoint) {
	var cacheKey = Wo_ExploreNearbyGetRouteCacheKey('leaflet', fromPoint, toPoint);
	if (WoExploreNearbyState.routeCache.hasOwnProperty(cacheKey)) {
		return Promise.resolve(WoExploreNearbyState.routeCache[cacheKey]);
	}

	var routeUrl = 'https://router.project-osrm.org/route/v1/driving/' +
		encodeURIComponent(fromPoint.lng + ',' + fromPoint.lat) + ';' +
		encodeURIComponent(toPoint.lng + ',' + toPoint.lat) +
		'?overview=full&geometries=geojson';

	return fetch(routeUrl, {
		headers: {
			'Accept': 'application/json'
		}
	}).then(function(response) {
		if (!response.ok) {
			throw new Error('Routing request failed');
		}
		return response.json();
	}).then(function(result) {
		if (result && Array.isArray(result.routes) && result.routes[0] && result.routes[0].geometry && Array.isArray(result.routes[0].geometry.coordinates)) {
			var coordinates = result.routes[0].geometry.coordinates;
			var normalizedPath = [];
			for (var i = 0; i < coordinates.length; i++) {
				if (!Array.isArray(coordinates[i]) || coordinates[i].length < 2) {
					continue;
				}

				normalizedPath.push({
					lat: parseFloat(coordinates[i][1]),
					lng: parseFloat(coordinates[i][0])
				});
			}

			if (normalizedPath.length > 1) {
				var routeData = {path: normalizedPath};
				WoExploreNearbyState.routeCache[cacheKey] = routeData;
				return routeData;
			}
		}

		return null;
	}).catch(function() {
		return null;
	});
}

function Wo_ExploreNearbyRequestRoute(fromPoint, toPoint) {
	if (WoExploreNearbyMapState.provider === 'google') {
		return Wo_ExploreNearbyRequestGoogleRoute(fromPoint, toPoint);
	}

	if (WoExploreNearbyMapState.provider === 'leaflet') {
		return Wo_ExploreNearbyRequestLeafletRoute(fromPoint, toPoint);
	}

	return Promise.resolve(null);
}

function Wo_ExploreNearbyDrawGoogleRouteLine(path, toPoint) {
	if (!WoExploreNearbyMapState.map) {
		return;
	}

	var routeColor = Wo_ExploreNearbyGetRouteColor(toPoint);
	var routePath = Array.isArray(path) ? path : [];

	WoExploreNearbyMapState.googleRouteGlow = new google.maps.Polyline({
		path: routePath,
		geodesic: false,
		strokeColor: routeColor,
		strokeOpacity: 0.18,
		strokeWeight: 12,
		zIndex: 1
	});
	WoExploreNearbyMapState.googleRouteGlow.setMap(WoExploreNearbyMapState.map);

	WoExploreNearbyMapState.googleRouteLine = new google.maps.Polyline({
		path: routePath,
		geodesic: false,
		strokeColor: routeColor,
		strokeOpacity: 0.94,
		strokeWeight: 5,
		zIndex: 2
	});
	WoExploreNearbyMapState.googleRouteLine.setMap(WoExploreNearbyMapState.map);
}

function Wo_ExploreNearbyDrawLeafletRouteLine(path, toPoint) {
	if (!WoExploreNearbyMapState.map || typeof L === 'undefined') {
		return;
	}

	var routeColor = Wo_ExploreNearbyGetRouteColor(toPoint);
	var routePoints = [];
	for (var i = 0; i < (path || []).length; i++) {
		routePoints.push([path[i].lat, path[i].lng]);
	}

	WoExploreNearbyMapState.leafletRouteLine = L.polyline(routePoints, {
		color: routeColor,
		weight: 5,
		opacity: 0.9,
		lineCap: 'round',
		lineJoin: 'round'
	}).addTo(WoExploreNearbyMapState.map);

	if (typeof WoExploreNearbyMapState.leafletRouteLine.bringToBack === 'function') {
		WoExploreNearbyMapState.leafletRouteLine.bringToBack();
	}
}

function Wo_ExploreNearbySyncRouteLine() {
	var routeToken = ++WoExploreNearbyState.routeRenderToken;
	Wo_ExploreNearbyClearRouteLine();

	var selfPoint = Wo_ExploreNearbyGetCurrentUserPoint();
	var activePointKey = WoExploreNearbyState.activePointKey;
	if (!selfPoint || !activePointKey || activePointKey === Wo_ExploreNearbyGetItemKey(selfPoint)) {
		return;
	}

	var targetPoint = Wo_ExploreNearbyGetRenderedPointByKey(activePointKey);
	var normalizedTarget = Wo_ExploreNearbyNormalizePoints(targetPoint ? [targetPoint] : []);
	if (!normalizedTarget.length || Wo_ExploreNearbyIsSamePoint(selfPoint, normalizedTarget[0])) {
		return;
	}

	targetPoint = normalizedTarget[0];
	Wo_ExploreNearbyRequestRoute(selfPoint, targetPoint).then(function(routeData) {
		if (routeToken !== WoExploreNearbyState.routeRenderToken) {
			return;
		}

		var routePath = (routeData && Array.isArray(routeData.path) && routeData.path.length > 1) ? routeData.path : [];
		if (routePath.length > 1 && WoExploreNearbyMapState.provider === 'google') {
			Wo_ExploreNearbyDrawGoogleRouteLine(routePath, targetPoint);
		}
		else if (routePath.length > 1 && WoExploreNearbyMapState.provider === 'leaflet') {
			Wo_ExploreNearbyDrawLeafletRouteLine(routePath, targetPoint);
		}

		Wo_ExploreNearbyFitRouteViewport(routePath, [selfPoint, targetPoint]);
	}).catch(function() {
		if (routeToken !== WoExploreNearbyState.routeRenderToken) {
			return;
		}

		Wo_ExploreNearbyFitRouteViewport([], [selfPoint, targetPoint]);
	});
}

function Wo_ExploreNearbyApplyGoogleViewport(points) {
	var normalizedPoints = Wo_ExploreNearbyNormalizePoints(points);
	if (!WoExploreNearbyMapState.map) {
		return;
	}

	if (!normalizedPoints.length) {
		WoExploreNearbyMapState.map.setCenter(nearbyMapCenter);
		WoExploreNearbyMapState.map.setZoom(7);
		return;
	}

	if (normalizedPoints.length === 1) {
		WoExploreNearbyMapState.map.setCenter({lat: normalizedPoints[0].lat, lng: normalizedPoints[0].lng});
		WoExploreNearbyMapState.map.setZoom(15);
		return;
	}

	var bounds = new google.maps.LatLngBounds();
	for (var i = 0; i < normalizedPoints.length; i++) {
		bounds.extend({lat: normalizedPoints[i].lat, lng: normalizedPoints[i].lng});
	}

	WoExploreNearbyMapState.map.fitBounds(bounds);
	google.maps.event.addListenerOnce(WoExploreNearbyMapState.map, 'idle', function() {
		var currentZoom = WoExploreNearbyMapState.map.getZoom() || 4;
		var targetZoom = currentZoom;
		var zoomFloor = Wo_ExploreNearbyGetZoomFloor(normalizedPoints);
		if (targetZoom < 4) {
			targetZoom = 4;
		}
		if (zoomFloor > 4 && targetZoom < zoomFloor) {
			targetZoom = zoomFloor;
		}
		if (targetZoom !== currentZoom) {
			WoExploreNearbyMapState.map.setZoom(targetZoom);
		}
	});
}

function Wo_ExploreNearbyApplyLeafletViewport(points) {
	var normalizedPoints = Wo_ExploreNearbyNormalizePoints(points);
	if (!WoExploreNearbyMapState.map) {
		return;
	}

	if (!normalizedPoints.length) {
		WoExploreNearbyMapState.map.setView([nearbyMapCenter.lat, nearbyMapCenter.lng], 7);
		return;
	}

	if (normalizedPoints.length === 1) {
		WoExploreNearbyMapState.map.setView([normalizedPoints[0].lat, normalizedPoints[0].lng], 15);
		return;
	}

	var bounds = [];
	for (var i = 0; i < normalizedPoints.length; i++) {
		bounds.push([normalizedPoints[i].lat, normalizedPoints[i].lng]);
	}

	WoExploreNearbyMapState.map.fitBounds(bounds, {padding: [30, 30]});
}

function Wo_ExploreNearbyResetMapMarkers() {
	Wo_ExploreNearbyClearRouteLine();
	Wo_ExploreNearbyCloseInfoPopup();

	if (WoExploreNearbyMapState.provider === 'google') {
		for (var i = 0; i < WoExploreNearbyMapState.googleMarkers.length; i++) {
			WoExploreNearbyMapState.googleMarkers[i].setMap(null);
		}
		WoExploreNearbyMapState.googleMarkers = [];
		WoExploreNearbyMapState.googleMarkerLookup = {};
		if (WoExploreNearbyMapState.googleInfoWindow) {
			WoExploreNearbyMapState.googleInfoWindow.close();
		}
	}

	if (WoExploreNearbyMapState.provider === 'leaflet' && WoExploreNearbyMapState.leafletMarkersLayer) {
		WoExploreNearbyMapState.leafletMarkersLayer.clearLayers();
		WoExploreNearbyMapState.leafletMarkerLookup = {};
	}

	WoExploreNearbyMapState.renderedPoints = [];
}

function Wo_ExploreNearbyHighlightCard(pointKey, scrollIntoView) {
	$('.wo_explore_discovery_card').removeClass('is-active');
	if (!pointKey) {
		return;
	}

	WoExploreNearbyState.activePointKey = pointKey;
	var card = $('.wo_explore_discovery_card[data-point-key="' + String(pointKey).replace(/"/g, '\\"') + '"]');
	if (!card.length) {
		return;
	}

	card.addClass('is-active');
	if (scrollIntoView) {
		card.get(0).scrollIntoView({
			behavior: 'smooth',
			block: 'nearest'
		});
	}
}

function Wo_ExploreNearbyOpenGoogleMarker(marker, focusCard, openPopup) {
	if (!marker) {
		return;
	}

	if (!WoExploreNearbyMapState.googleInfoWindow) {
		WoExploreNearbyMapState.googleInfoWindow = new google.maps.InfoWindow();
	}

	WoExploreNearbyMapState.map.panTo(marker.getPosition());
	if (openPopup !== false) {
		WoExploreNearbyMapState.googleInfoWindow.setContent(Wo_ExploreNearbyGetPopupHtml(marker.woNearbyPoint));
		WoExploreNearbyMapState.googleInfoWindow.open(WoExploreNearbyMapState.map, marker);
	}
	else {
		WoExploreNearbyMapState.googleInfoWindow.close();
	}

	if (focusCard) {
		WoExploreNearbyState.activePointKey = Wo_ExploreNearbyGetItemKey(marker.woNearbyPoint);
		WoExploreNearbyState.openPopupPointKey = (openPopup === false) ? null : Wo_ExploreNearbyGetItemKey(marker.woNearbyPoint);
		Wo_ExploreNearbySyncRouteLine();
	}

	if (focusCard) {
		Wo_ExploreNearbyHighlightCard(Wo_ExploreNearbyGetItemKey(marker.woNearbyPoint), false);
	}
}

function Wo_ExploreNearbyRenderGoogleMarkers(points, options) {
	var resultPoints = Wo_ExploreNearbyNormalizePoints(points);
	var normalizedPoints = Wo_ExploreNearbyGetCombinedPoints(resultPoints);
	var coordinateCounts = {};
	var targetMarker = null;
	var openPointKey = options && options.openPointKey ? options.openPointKey : null;

	Wo_ExploreNearbyResetMapMarkers();

	for (var i = 0; i < normalizedPoints.length; i++) {
		var point = normalizedPoints[i];
		var markerPosition = Wo_ExploreNearbyGetMarkerPosition(point, coordinateCounts);
		if (!markerPosition) {
			continue;
		}

		var marker = new google.maps.Marker({
			position: markerPosition,
			map: WoExploreNearbyMapState.map,
			title: point.name || '',
			icon: Wo_ExploreNearbyCreateGoogleMarkerIcon(point)
		});
		marker.woNearbyPoint = point;
		marker.addListener('click', function() {
			Wo_ExploreNearbyOpenGoogleMarker(this, true, true);
		});
		WoExploreNearbyMapState.googleMarkers.push(marker);
		WoExploreNearbyMapState.googleMarkerLookup[Wo_ExploreNearbyGetItemKey(point)] = marker;

		if (openPointKey && Wo_ExploreNearbyGetItemKey(point) === openPointKey) {
			targetMarker = marker;
		}
	}

	WoExploreNearbyMapState.renderedPoints = normalizedPoints;

	if (!options || options.fit !== false) {
		Wo_ExploreNearbyApplyGoogleViewport(normalizedPoints);
	}

	if (targetMarker) {
		Wo_ExploreNearbyOpenGoogleMarker(targetMarker, false, true);
	}
}

function Wo_ExploreNearbyRenderLeafletMarkers(points, options) {
	var resultPoints = Wo_ExploreNearbyNormalizePoints(points);
	var normalizedPoints = Wo_ExploreNearbyGetCombinedPoints(resultPoints);
	var coordinateCounts = {};
	var targetMarker = null;
	var openPointKey = options && options.openPointKey ? options.openPointKey : null;

	Wo_ExploreNearbyResetMapMarkers();

	for (var i = 0; i < normalizedPoints.length; i++) {
		var point = normalizedPoints[i];
		var markerPosition = Wo_ExploreNearbyGetMarkerPosition(point, coordinateCounts);
		if (!markerPosition) {
			continue;
		}

		var marker = L.marker([markerPosition.lat, markerPosition.lng], {
			icon: Wo_ExploreNearbyCreateLeafletMarkerIcon(point)
		}).bindPopup(Wo_ExploreNearbyGetPopupHtml(point), {
			maxWidth: 280
		});

		marker.on('click', (function(pointKey) {
			return function() {
				WoExploreNearbyState.activePointKey = pointKey;
				WoExploreNearbyState.openPopupPointKey = pointKey;
				Wo_ExploreNearbySyncRouteLine();
				Wo_ExploreNearbyHighlightCard(pointKey, false);
			};
		})(Wo_ExploreNearbyGetItemKey(point)));

		marker.addTo(WoExploreNearbyMapState.leafletMarkersLayer);
		WoExploreNearbyMapState.leafletMarkerLookup[Wo_ExploreNearbyGetItemKey(point)] = marker;

		if (openPointKey && Wo_ExploreNearbyGetItemKey(point) === openPointKey) {
			targetMarker = marker;
		}
	}

	WoExploreNearbyMapState.renderedPoints = normalizedPoints;

	if (!options || options.fit !== false) {
		Wo_ExploreNearbyApplyLeafletViewport(normalizedPoints);
	}

	if (targetMarker) {
		targetMarker.openPopup();
		WoExploreNearbyState.openPopupPointKey = openPointKey;
		Wo_ExploreNearbyHighlightCard(openPointKey, false);
	}
}

function Wo_ExploreNearbyRenderMap(points, options) {
	if (WoExploreNearbyMapState.provider === 'google') {
		Wo_ExploreNearbyRenderGoogleMarkers(points, options || {});
	}
	else if (WoExploreNearbyMapState.provider === 'leaflet') {
		Wo_ExploreNearbyRenderLeafletMarkers(points, options || {});
	}

	Wo_ExploreNearbySyncRouteLine();
	$('#map').removeClass('wo_ui_map_state_loading');
}

function Wo_ExploreNearbyDestroyMap() {
	Wo_ExploreNearbyResetMapMarkers();

	if (WoExploreNearbyMapState.provider === 'leaflet' && WoExploreNearbyMapState.map) {
		WoExploreNearbyMapState.map.remove();
	}

	WoExploreNearbyMapState.provider = null;
	WoExploreNearbyMapState.map = null;
	WoExploreNearbyMapState.leafletMarkersLayer = null;
	WoExploreNearbyMapState.googleMarkers = [];
	WoExploreNearbyMapState.googleInfoWindow = null;
	WoExploreNearbyMapState.googleDirectionsService = null;
	WoExploreNearbyMapState.leafletMarkerLookup = {};
	WoExploreNearbyMapState.googleMarkerLookup = {};
	WoExploreNearbyMapState.googleRouteLine = null;
	WoExploreNearbyMapState.googleRouteGlow = null;
	WoExploreNearbyMapState.leafletRouteLine = null;
	WoExploreNearbyMapState.renderedPoints = [];
	$('#map').html('').addClass('wo_ui_map_state_loading');
}

function Wo_ExploreNearbyCreateGoogleMap() {
	if (typeof google === 'undefined' || !google.maps || !google.maps.Map || !$('#map').length) {
		return false;
	}

	Wo_ExploreNearbyDestroyMap();
	WoExploreNearbyMapState.provider = 'google';
	WoExploreNearbyMapState.map = new google.maps.Map(document.getElementById('map'), {
		center: nearbyMapCenter,
		zoom: 7,
		mapTypeId: google.maps.MapTypeId.ROADMAP
	});
	WoExploreNearbyMapState.googleInfoWindow = new google.maps.InfoWindow();
	WoExploreNearbyMapState.googleDirectionsService = (typeof google.maps.DirectionsService !== 'undefined') ? new google.maps.DirectionsService() : null;
	return true;
}

function Wo_ExploreNearbyCreateLeafletMap() {
	if (typeof L === 'undefined' || !$('#map').length) {
		return false;
	}

	Wo_ExploreNearbyDestroyMap();
	WoExploreNearbyMapState.provider = 'leaflet';
	WoExploreNearbyMapState.map = L.map('map').setView([nearbyMapCenter.lat, nearbyMapCenter.lng], 7);
	WoExploreNearbyMapState.leafletMarkersLayer = L.layerGroup().addTo(WoExploreNearbyMapState.map);

	var tileConfig = window.WoLeafletMutedMapConfig || {};
	L.tileLayer(
		tileConfig.tileUrl || 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
		$.extend({
			attribution: '',
			maxZoom: 18
		}, tileConfig.tileOptions || {})
	).addTo(WoExploreNearbyMapState.map);

	return true;
}

function Wo_ExploreNearbyEnsureLeaflet(callback) {
	if (typeof L !== 'undefined') {
		callback();
		return;
	}

	$.getScript('<?php echo $wo['config']['theme_url']; ?>/javascript/leaflet.js?version=<?php echo $wo['config']['version']; ?>', callback);
}

function Wo_ExploreNearbyNeedsShopGeocode(point) {
	if (!point || point.type !== 'shop' || !point.location) {
		return false;
	}

	var lat = parseFloat(point.lat);
	var lng = parseFloat(point.lng);

	return isNaN(lat) || isNaN(lng) || (lat === 0 && lng === 0);
}

function Wo_ExploreNearbyGeocodeShopLocation(location) {
	var normalizedLocation = $.trim(location || '');
	if (!normalizedLocation) {
		return Promise.resolve(null);
	}

	if (WoExploreNearbyState.shopGeocodeCache.hasOwnProperty(normalizedLocation)) {
		return Promise.resolve(WoExploreNearbyState.shopGeocodeCache[normalizedLocation]);
	}

	return fetch('https://nominatim.openstreetmap.org/search?format=jsonv2&limit=1&q=' + encodeURIComponent(normalizedLocation), {
		headers: {
			'Accept': 'application/json'
		}
	})
		.then(function(response) {
			if (!response.ok) {
				throw new Error('Geocoding request failed');
			}
			return response.json();
		})
		.then(function(results) {
			var geocodedLocation = null;
			if (Array.isArray(results) && results.length > 0) {
				var match = results[0];
				var lat = parseFloat(match.lat);
				var lng = parseFloat(match.lon);
				if (!isNaN(lat) && !isNaN(lng)) {
					geocodedLocation = {
						lat: lat,
						lng: lng
					};
				}
			}

			WoExploreNearbyState.shopGeocodeCache[normalizedLocation] = geocodedLocation;
			return geocodedLocation;
		})
		.catch(function() {
			WoExploreNearbyState.shopGeocodeCache[normalizedLocation] = null;
			return null;
		});
}

function Wo_ExploreNearbyResolveVisiblePoints(points) {
	if (!Array.isArray(points) || points.length === 0) {
		return Promise.resolve(points || []);
	}

	return Promise.all(points.map(function(point) {
		if (!Wo_ExploreNearbyNeedsShopGeocode(point)) {
			return Promise.resolve(point);
		}

		return Wo_ExploreNearbyGeocodeShopLocation(point.location).then(function(geocodedLocation) {
			if (!geocodedLocation) {
				return point;
			}

			return $.extend({}, point, {
				lat: geocodedLocation.lat,
				lng: geocodedLocation.lng
			});
		});
	}));
}

function Wo_ExploreNearbyRenderCurrentMap(openPointKey) {
	var visiblePoints = Wo_ExploreNearbyGetVisiblePoints();
	var renderToken = ++WoExploreNearbyState.mapRenderToken;
	var targetOpenPointKey = openPointKey || WoExploreNearbyState.openPopupPointKey || Wo_ExploreNearbyGetDefaultOpenPointKey();
	$('#map').addClass('wo_ui_map_state_loading');

	Wo_ExploreNearbyResolveVisiblePoints(visiblePoints).then(function(resolvedPoints) {
		if (renderToken !== WoExploreNearbyState.mapRenderToken) {
			return;
		}

		Wo_ExploreNearbyRenderMap(resolvedPoints, {
			fit: true,
			openPointKey: targetOpenPointKey || null
		});
	});
}

function Wo_ExploreNearbyFocusOnMapByKey(pointKey, shouldScrollCard) {
	if (!pointKey) {
		return;
	}

	WoExploreNearbyState.activePointKey = pointKey;
	WoExploreNearbyState.openPopupPointKey = null;
	Wo_ExploreNearbyCloseInfoPopup();
	var marker = null;

	if (WoExploreNearbyMapState.provider === 'google') {
		marker = WoExploreNearbyMapState.googleMarkerLookup[pointKey] || null;
		if (marker) {
			WoExploreNearbyMapState.map.panTo(marker.getPosition());
			Wo_ExploreNearbySyncRouteLine();
		}
	}
	else if (WoExploreNearbyMapState.provider === 'leaflet') {
		marker = WoExploreNearbyMapState.leafletMarkerLookup[pointKey] || null;
		if (marker && WoExploreNearbyMapState.map) {
			WoExploreNearbyMapState.map.panTo(marker.getLatLng());
			Wo_ExploreNearbySyncRouteLine();
		}
	}

	if (!marker) {
		Wo_ExploreNearbyRenderCurrentMap(null);
	}

	Wo_ExploreNearbyHighlightCard(pointKey, shouldScrollCard);
}

function Wo_ExploreNearbyUpdateUi() {
	var totalResults = Wo_ExploreNearbyGetTotalResultsCount();
	var loadedResults = Wo_ExploreNearbyGetLoadedResultsCount();
	var uiMetaText = Wo_ExploreNearbyGetUiMetaText();
	var showLoadMore = false;

	$('#explore-nearby-results-count').text(totalResults);
	$('#explore-nearby-loaded-count').text(loadedResults);
	$('#explore-nearby-distance-value').text(Wo_ExploreNearbyGetDistanceValue() + ' km');
	$('#explore-nearby-summary-text, #explore-nearby-list-note').text(uiMetaText);

	if (WoExploreNearbyState.usersEnabled && (WoExploreNearbyState.usersItems || []).length < (WoExploreNearbyState.usersCount || 0)) {
		showLoadMore = true;
	}
	if (WoExploreNearbyState.shopsEnabled && (WoExploreNearbyState.shopsItems || []).length < (WoExploreNearbyState.shopsCount || 0)) {
		showLoadMore = true;
	}

	Wo_ExploreNearbyRenderList();
	$('#load_more_explore_nearby').closest('.wo_explore_discovery_load_more').toggle(showLoadMore);
}

function Wo_ExploreNearbyBuildUsersRequestData(offset) {
	var requestData = {
		f: 'nearby_users',
		s: 'load',
		name: Wo_ExploreNearbyGetSearchValue(),
		distance: Wo_ExploreNearbyGetDistanceValue()
	};

	if (offset) {
		requestData.offset = offset;
	}

	return requestData;
}

function Wo_ExploreNearbyBuildShopsRequestData(offset) {
	var requestData = {
		f: 'nearby_shops',
		s: 'load',
		name: Wo_ExploreNearbyGetSearchValue(),
		distance: Wo_ExploreNearbyGetDistanceValue()
	};

	if (offset) {
		requestData.offset = offset;
	}

	return requestData;
}

function Wo_ExploreNearbyGetUsersOffset() {
	var items = Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.usersItems || []);
	if (!items.length) {
		return 0;
	}

	return items[items.length - 1].offset_id || 0;
}

function Wo_ExploreNearbyGetShopsOffset() {
	var items = Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.shopsItems || []);
	if (!items.length) {
		return 0;
	}

	return items[items.length - 1].offset_id || 0;
}

function Wo_ExploreNearbyApplyUsersResponse(data, append) {
	var responseItems = [];

	if (data && data.status == 200) {
		responseItems = data.items_info || data.users_info || [];
		WoExploreNearbyState.usersItems = append ? Wo_ExploreNearbyMergeUniqueItems(WoExploreNearbyState.usersItems || [], responseItems) : Wo_ExploreNearbyNormalizeDiscoveryItems(responseItems);
		WoExploreNearbyState.usersCount = parseInt(data.count || 0, 10);
	}
	else if (!append) {
		WoExploreNearbyState.usersItems = [];
		WoExploreNearbyState.usersCount = 0;
	}
}

function Wo_ExploreNearbyApplyShopsResponse(data, append) {
	var responseItems = [];

	if (data && data.status == 200) {
		responseItems = data.items_info || data.users_info || [];
		WoExploreNearbyState.shopsItems = append ? Wo_ExploreNearbyMergeUniqueItems(WoExploreNearbyState.shopsItems || [], responseItems) : Wo_ExploreNearbyNormalizeDiscoveryItems(responseItems);
		WoExploreNearbyState.shopsCount = parseInt(data.count || 0, 10);
	}
	else if (!append) {
		WoExploreNearbyState.shopsItems = [];
		WoExploreNearbyState.shopsCount = 0;
	}
}

function Wo_ExploreNearbyAbortPendingRequests() {
	if (WoExploreNearbyState.usersRequest && WoExploreNearbyState.usersRequest.readyState !== 4) {
		WoExploreNearbyState.usersRequest.abort();
	}
	if (WoExploreNearbyState.shopsRequest && WoExploreNearbyState.shopsRequest.readyState !== 4) {
		WoExploreNearbyState.shopsRequest.abort();
	}
}

function Wo_ExploreNearbyLoad(append, loaderTarget) {
	var pending = 0;
	var loadToken = ++WoExploreNearbyState.loadToken;

	if (!append) {
		Wo_ExploreNearbyAbortPendingRequests();
		WoExploreNearbyState.openPopupPointKey = null;
		Wo_ExploreNearbyCloseInfoPopup();
	}

	if (loaderTarget) {
		Wo_progressIconLoader($(loaderTarget));
	}
	else {
		Wo_StartBar();
	}

	function finishOne() {
		if (loadToken !== WoExploreNearbyState.loadToken) {
			return;
		}

		pending--;
		if (pending <= 0) {
			Wo_ExploreNearbyUpdateUi();
			Wo_ExploreNearbyRenderCurrentMap(WoExploreNearbyState.openPopupPointKey || null);
			if (loaderTarget) {
				Wo_progressIconLoader($(loaderTarget));
			}
			else {
				Wo_FinishBar();
			}
		}
	}

	function loadUsers() {
		pending++;
		WoExploreNearbyState.usersRequest = $.ajax({
			url: Wo_Ajax_Requests_File(),
			type: 'GET',
			dataType: 'json',
			data: Wo_ExploreNearbyBuildUsersRequestData(append ? Wo_ExploreNearbyGetUsersOffset() : 0)
		}).done(function(data) {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return;
			}
			Wo_ExploreNearbyApplyUsersResponse(data, append);
		}).fail(function(xhr, status) {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return;
			}
			if (status !== 'abort' && !append) {
				Wo_ExploreNearbyApplyUsersResponse(null, false);
			}
		}).always(finishOne);
	}

	function loadShops() {
		pending++;
		WoExploreNearbyState.shopsRequest = $.ajax({
			url: Wo_Ajax_Requests_File(),
			type: 'GET',
			dataType: 'json',
			data: Wo_ExploreNearbyBuildShopsRequestData(append ? Wo_ExploreNearbyGetShopsOffset() : 0)
		}).done(function(data) {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return;
			}
			Wo_ExploreNearbyApplyShopsResponse(data, append);
		}).fail(function(xhr, status) {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return;
			}
			if (status !== 'abort' && !append) {
				Wo_ExploreNearbyApplyShopsResponse(null, false);
			}
		}).always(finishOne);
	}

	if (WoExploreNearbyState.usersEnabled) {
		loadUsers();
	}
	if (WoExploreNearbyState.shopsEnabled) {
		loadShops();
	}

	if (pending === 0) {
		if (loaderTarget) {
			Wo_progressIconLoader($(loaderTarget));
		}
		else {
			Wo_FinishBar();
		}
	}
}

function Wo_ExploreNearbyLoadMore() {
	Wo_ExploreNearbyLoad(true, '#load_more_explore_nearby');
}

jQuery(document).ready(function($) {
	function initMap() {
		if (<?php echo ($wo['config']['google_map'] == 1) ? 'true' : 'false'; ?> && Wo_ExploreNearbyCreateGoogleMap()) {
			Wo_ExploreNearbyRenderCurrentMap();
			return;
		}

		Wo_ExploreNearbyEnsureLeaflet(function() {
			if (Wo_ExploreNearbyCreateLeafletMap()) {
				Wo_ExploreNearbyRenderCurrentMap();
			}
		});
	}

	Wo_ExploreNearbyInitOrientationTracking();
	initMap();
	Wo_ExploreNearbyUpdateUi();

	$('#nearby-username').on('input', function() {
		clearTimeout(WoExploreNearbyState.searchTimer);
		WoExploreNearbyState.searchTimer = setTimeout(function() {
			Wo_ExploreNearbyLoad(false);
		}, 300);
	});

	$('#nearby-username').on('keypress', function(e) {
		if (e.which == 13) {
			e.preventDefault();
			$(this).blur();
			Wo_ExploreNearbyLoad(false);
		}
	});

	$('#nearby-users-distance').on('input', function() {
		$('#explore-nearby-distance-value').text(Wo_ExploreNearbyGetDistanceValue() + ' km');
		$('#explore-nearby-summary-text, #explore-nearby-list-note').text(Wo_ExploreNearbyGetUiMetaText());
	});

	$('#nearby-users-distance').on('change', function() {
		Wo_ExploreNearbyLoad(false);
	});

	$(document).on('click', '.wo_explore_discovery_card', function(e) {
		if ($(e.target).closest('a,button').length) {
			return;
		}

		Wo_ExploreNearbyFocusOnMapByKey($(this).attr('data-point-key'), true);
	});

	$(document).on('click', '.wo_explore_discovery_focus', function(e) {
		e.preventDefault();
		e.stopPropagation();
		if ($(this).is(':disabled')) {
			return;
		}
		Wo_ExploreNearbyFocusOnMapByKey($(this).attr('data-point-key'), true);
	});
});
</script>
