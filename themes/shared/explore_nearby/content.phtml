	if (source === 'screen' && WoExploreNearbyState.deviceHeadingSource === 'device') {
		return;
	}

	if (WoExploreNearbyState.deviceHeadingSource === source && WoExploreNearbyState.deviceHeading !== null && Math.abs(WoExploreNearbyState.deviceHeading - normalizedHeading) < 1) {
		return;
