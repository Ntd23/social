function Wo_ExploreNearbyResolveSelectedSuggestionAnchor(item, query) {
	var suggestion = $.extend({}, item || {});
	var itemType = $.trim(suggestion.type || '');
	var normalizedQuery = $.trim(query || suggestion.search_value || suggestion.location || suggestion.title || '');
	var cacheKey = [itemType || 'item', $.trim(suggestion.place_id || suggestion.id || suggestion.url || normalizedQuery).toLowerCase(), normalizedQuery.toLowerCase()].join('|');

	if (!itemType) {
		return Promise.resolve(null);
	}

	if (Object.prototype.hasOwnProperty.call(WoExploreNearbyState.searchPlaceCache, cacheKey)) {
		return Promise.resolve(WoExploreNearbyState.searchPlaceCache[cacheKey]);
	}

	if (WoExploreNearbyState.searchPlacePending[cacheKey]) {
		return WoExploreNearbyState.searchPlacePending[cacheKey];
	}

	WoExploreNearbyState.searchPlacePending[cacheKey] = Promise.resolve().then(function() {
		if (itemType === 'user') {
			if (parseInt(suggestion.share_my_location || 0, 10) !== 1 || !Wo_ExploreNearbyHasValidCoordinates(suggestion.lat, suggestion.lng)) {
				return null;
			}

			return Wo_ExploreNearbyBuildAnchorItem('user', suggestion);
		}

		if (itemType === 'page') {
			if (Wo_ExploreNearbyHasValidCoordinates(suggestion.lat, suggestion.lng)) {
				return Wo_ExploreNearbyBuildAnchorItem('page', suggestion);
			}

			var pageAddress = $.trim(suggestion.address || suggestion.location || '');
			if (!pageAddress || !Wo_ExploreNearbyGetGoogleGeocoder()) {
				return null;
			}

			return new Promise(function(resolve) {
				Wo_ExploreNearbyGetGoogleGeocoder().geocode({
					address: pageAddress
				}, function(results, status) {
					var geocodeResult = null;
					if (status === 'OK' && Array.isArray(results) && results[0] && results[0].geometry && results[0].geometry.location) {
						geocodeResult = {
							lat: results[0].geometry.location.lat(),
							lng: results[0].geometry.location.lng(),
							location: $.trim(results[0].formatted_address || pageAddress),
							title: $.trim(suggestion.title || suggestion.name || '')
						};
					}

					resolve(Wo_ExploreNearbyBuildAnchorItem('page', suggestion, geocodeResult));
				});
			});
		}

		if (itemType === 'place') {
			if (suggestion.place_item) {
				return $.extend({}, suggestion.place_item, {
					place_id: $.trim(suggestion.place_id || (suggestion.place_item && suggestion.place_item.place_id) || '')
				});
			}

			return Wo_ExploreNearbyGeocodeSearchPlace(normalizedQuery, suggestion.place_id || '', suggestion.place_prediction || null).then(function(placeItem) {
				if (!placeItem) {
					return null;
				}

				return $.extend({}, placeItem, {
					place_id: $.trim(suggestion.place_id || placeItem.place_id || '')
				});
			});
		}

		return null;
	}).then(function(anchorItem) {
		WoExploreNearbyState.searchPlaceCache[cacheKey] = anchorItem;
		delete WoExploreNearbyState.searchPlacePending[cacheKey];
		return anchorItem;
	}).catch(function() {
		WoExploreNearbyState.searchPlaceCache[cacheKey] = null;
		delete WoExploreNearbyState.searchPlacePending[cacheKey];
		return null;
	});

	return WoExploreNearbyState.searchPlacePending[cacheKey];
}

function Wo_ExploreNearbyApplyRelatedPlaceItems(items, shouldRefreshView) {
	var normalizedItems = Wo_ExploreNearbyResolveCanonicalPlaceItems(items || [], Wo_ExploreNearbyGetOrderedShopItems(), {
		dropMatchedDuplicates: true
	});
	var dedupedItems = [];
	var currentItems = Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.relatedPlaceItems || []);
	var currentKeys = [];
	var nextKeys = [];
	var hasChanged = false;
	var i = 0;

	dedupedItems = Wo_ExploreNearbyMergeUniqueItems([], normalizedItems);
	for (i = 0; i < dedupedItems.length; i++) {
		nextKeys.push(Wo_ExploreNearbyGetDiscoveryDedupKey(dedupedItems[i]));
	}

	for (i = 0; i < currentItems.length; i++) {
		currentKeys.push(Wo_ExploreNearbyGetDiscoveryDedupKey(currentItems[i]));
	}

	hasChanged = currentKeys.length !== nextKeys.length || currentKeys.join('|') !== nextKeys.join('|');
	WoExploreNearbyState.relatedPlaceItems = dedupedItems;

	if (hasChanged && shouldRefreshView !== false) {
		Wo_ExploreNearbyUpdateUi();
		Wo_ExploreNearbyRenderCurrentMap(WoExploreNearbyState.openPopupPointKey || null);
	}

	return hasChanged;
}

function Wo_ExploreNearbyEnsurePlacePointCard(point, scrollIntoView) {
	var normalizedItems = Wo_ExploreNearbyNormalizeDiscoveryItems(point ? [point] : []);
	var placePoint = normalizedItems.length ? normalizedItems[0] : null;
	var relatedPlaceItems = [];
	var placePointKey = '';
	var hasChanged = false;

	if (!placePoint || placePoint.type !== 'place') {
		return '';
	}

	relatedPlaceItems = Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.relatedPlaceItems || []);
	hasChanged = Wo_ExploreNearbyApplyRelatedPlaceItems(relatedPlaceItems.concat([placePoint]), false);
	placePointKey = Wo_ExploreNearbyGetItemKey(placePoint);

	if (hasChanged) {
		Wo_ExploreNearbyUpdateUi();
	}

	Wo_ExploreNearbyHighlightCard(placePointKey, scrollIntoView === true);
	return placePointKey;
}

function Wo_ExploreNearbyGetRelatedPlacesCacheKey(anchorItem) {
	if (!anchorItem) {
		return '';
	}

	return [
		Wo_ExploreNearbyGetDiscoveryDedupKey(anchorItem),
		Math.max(1500, Math.min((Wo_ExploreNearbyGetDistanceValue() || defaultDistanceValue) * 1000, 50000))
	].join('|');
}

function Wo_ExploreNearbyFetchRelatedPlaces(anchorItem) {
	var searchRadius = Math.max(1500, Math.min((Wo_ExploreNearbyGetDistanceValue() || defaultDistanceValue) * 1000, 50000));

	if (!anchorItem || !Wo_ExploreNearbyHasValidCoordinates(anchorItem.lat, anchorItem.lng)) {
		return Promise.resolve([]);
	}

	return Wo_ExploreNearbyEnsureGooglePlacesLibrary().then(function(placesLibrary) {
		if (!placesLibrary || !placesLibrary.Place || typeof placesLibrary.Place.searchNearby !== 'function' || !placesLibrary.SearchNearbyRankPreference) {
			return null;
		}

		return placesLibrary.Place.searchNearby({
			fields: ['displayName', 'formattedAddress', 'location', 'googleMapsURI', 'id', 'primaryType', 'primaryTypeDisplayName', 'svgIconMaskURI', 'iconBackgroundColor'],
			locationRestriction: {
				center: {
					lat: parseFloat(anchorItem.lat),
					lng: parseFloat(anchorItem.lng)
				},
				radius: searchRadius
			},
			includedPrimaryTypes: ['restaurant', 'cafe', 'store', 'shopping_mall', 'hospital', 'school', 'atm', 'lodging'],
			maxResultCount: 12,
			rankPreference: placesLibrary.SearchNearbyRankPreference.DISTANCE
		});
	}).then(function(response) {
		var places = (response && Array.isArray(response.places)) ? response.places : [];
		var relatedItems = [];

		if (!places.length) {
			return [];
		}

		for (var i = 0; i < places.length; i++) {
			var place = places[i] || {};
			var lat = Wo_ExploreNearbyGetGoogleLatLngValue(place.location, 'lat');
			var lng = Wo_ExploreNearbyGetGoogleLatLngValue(place.location, 'lng');
			var placeTitle = Wo_ExploreNearbyGetGooglePlaceText(place.displayName);
			var placeSubtitle = Wo_ExploreNearbyGetGooglePlaceText(place.primaryTypeDisplayName) || $.trim(place.primaryType || '') || defaultPlaceTypeLabel;
			var anchorDistance = 0;

			if (!Wo_ExploreNearbyHasValidCoordinates(lat, lng) || !placeTitle) {
				continue;
			}

			anchorDistance = Wo_ExploreNearbyGetDistanceKm(anchorItem, {lat: lat, lng: lng});

			relatedItems.push({
				item_key: $.trim(place.id || '') ? ('place|' + $.trim(place.id || '')) : ('place|nearby|' + encodeURIComponent(placeTitle.toLowerCase()) + '|' + lat.toFixed(5) + ',' + lng.toFixed(5)),
				offset_id: 0,
				type: 'place',
				type_label: defaultPlaceTypeLabel,
				title: $.trim(placeTitle),
				subtitle: $.trim(placeSubtitle),
				description: '',
				avatar: '',
				url: $.trim(place.googleMapsURI || ''),
				ajax_url: '',
				place_id: $.trim(place.id || ''),
				primary_type: $.trim(place.primaryType || ''),
				primary_type_label: $.trim(placeSubtitle),
				svg_icon_mask_uri: $.trim(place.svgIconMaskURI || ''),
				icon_background_color: $.trim(place.iconBackgroundColor || ''),
				is_related_place: true,
				location: $.trim(place.formattedAddress || ''),
				location_dynamic: '',
				distance_value: anchorDistance,
				distance_text: Wo_ExploreNearbyFormatDistance(anchorDistance),
				lat: lat,
				lng: lng,
				is_self: false
			});
		}

		return relatedItems;
	}).catch(function() {
		return [];
	});
}

function Wo_ExploreNearbySyncRelatedPlaces(shouldRefreshView) {
	var anchorItem = Wo_ExploreNearbyGetSelectedAnchorItem();
	var requestToken = ++WoExploreNearbyState.relatedPlacesToken;
	var cacheKey = '';

	if (!anchorItem || !Wo_ExploreNearbyHasValidCoordinates(anchorItem.lat, anchorItem.lng)) {
		Wo_ExploreNearbyApplyRelatedPlaceItems([], shouldRefreshView);
		return Promise.resolve([]);
	}

	cacheKey = Wo_ExploreNearbyGetRelatedPlacesCacheKey(anchorItem);
	if (cacheKey && Object.prototype.hasOwnProperty.call(WoExploreNearbyState.relatedPlacesCache, cacheKey)) {
		Wo_ExploreNearbyApplyRelatedPlaceItems(WoExploreNearbyState.relatedPlacesCache[cacheKey] || [], shouldRefreshView);
		return Promise.resolve(WoExploreNearbyState.relatedPlacesCache[cacheKey] || []);
	}

	return Wo_ExploreNearbyFetchRelatedPlaces(anchorItem).then(function(relatedItems) {
		if (requestToken !== WoExploreNearbyState.relatedPlacesToken) {
			return [];
		}

		WoExploreNearbyState.relatedPlacesCache[cacheKey] = relatedItems || [];
		Wo_ExploreNearbyApplyRelatedPlaceItems(relatedItems || [], shouldRefreshView);
		return relatedItems || [];
	}).catch(function() {
		if (requestToken !== WoExploreNearbyState.relatedPlacesToken) {
			return [];
		}

		WoExploreNearbyState.relatedPlacesCache[cacheKey] = [];
		Wo_ExploreNearbyApplyRelatedPlaceItems([], shouldRefreshView);
		return [];
	});
}

function Wo_ExploreNearbySetSearchPlaceItem(item) {
	var currentKey = Wo_ExploreNearbyGetDiscoveryDedupKey(Wo_ExploreNearbyGetSelectedAnchorItem());
	var nextItems = Wo_ExploreNearbyNormalizeDiscoveryItems(item ? [item] : []);
	var nextItem = nextItems.length ? nextItems[0] : null;
	var nextKey = Wo_ExploreNearbyGetDiscoveryDedupKey(nextItem);
	var currentLocation = Wo_ExploreNearbyNormalizeTextValue((Wo_ExploreNearbyGetSelectedAnchorItem() && Wo_ExploreNearbyGetSelectedAnchorItem().location) || '');
	var nextLocation = Wo_ExploreNearbyNormalizeTextValue((nextItem && nextItem.location) || '');
	var hasChanged = currentKey !== nextKey || currentLocation !== nextLocation;

	WoExploreNearbyState.selectedAnchorItem = nextItem || null;

	return hasChanged;
}

function Wo_ExploreNearbySetSearchContext(mode, item) {
	var nextMode = (mode === 'location') ? 'location' : 'text';
	var nextItem = item || null;
	var nextLat = null;
	var nextLng = null;
	var nextLabel = '';
	var anchorChanged = false;
	var hasChanged = false;

	if (nextMode === 'location' && nextItem && Wo_ExploreNearbyHasValidCoordinates(nextItem.lat, nextItem.lng)) {
		nextLat = parseFloat(nextItem.lat);
		nextLng = parseFloat(nextItem.lng);
		nextLabel = Wo_ExploreNearbyNormalizeTextValue(nextItem.location || nextItem.title || '');
	}
	else {
		nextMode = 'text';
		nextItem = null;
	}

	anchorChanged = Wo_ExploreNearbySetSearchPlaceItem(nextItem);
	hasChanged = anchorChanged || hasChanged;
	if (WoExploreNearbyState.searchMode !== nextMode) {
		hasChanged = true;
	}
	if (WoExploreNearbyState.searchCenterLat !== nextLat) {
		hasChanged = true;
	}
	if (WoExploreNearbyState.searchCenterLng !== nextLng) {
		hasChanged = true;
	}
	if ((WoExploreNearbyState.searchCenterLabel || '') !== nextLabel) {
		hasChanged = true;
	}

	WoExploreNearbyState.searchMode = nextMode;
	WoExploreNearbyState.searchCenterLat = nextLat;
	WoExploreNearbyState.searchCenterLng = nextLng;
	WoExploreNearbyState.searchCenterLabel = nextLabel;
	if (nextMode !== 'location' && (WoExploreNearbyState.relatedPlaceItems || []).length) {
		WoExploreNearbyState.relatedPlacesToken++;
		WoExploreNearbyState.relatedPlaceItems = [];
		hasChanged = true;
	}
	else if (anchorChanged) {
		WoExploreNearbyState.relatedPlacesToken++;
		WoExploreNearbyState.relatedPlaceItems = [];
	}
	if (nextMode === 'location' && Wo_ExploreNearbyHasValidCoordinates(nextLat, nextLng)) {
		nearbyMapCenter.lat = parseFloat(nextLat);
		nearbyMapCenter.lng = parseFloat(nextLng);
	}
	else if (!Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng) && WoExploreNearbyState.locationBootstrapState !== 'denied') {
		WoExploreNearbyState.locationBootstrapState = 'waiting';
	}
	Wo_ExploreNearbySyncLocationAnchorState();

	return hasChanged;
}

function Wo_ExploreNearbyClearSearchPlaceSelection() {
	var selectedAnchorPointKey = Wo_ExploreNearbyGetSelectedAnchorPointKey();
	var hasChanged = Wo_ExploreNearbySetSearchContext('text', null);
	if (Wo_ExploreNearbyExitPlaceSearchMode()) {
		hasChanged = true;
	}
	if (WoExploreNearbyState.pendingFocusPointKey) {
		hasChanged = true;
	}
	WoExploreNearbyState.pendingFocusPointKey = null;
	if (selectedAnchorPointKey && WoExploreNearbyState.activePointKey === selectedAnchorPointKey) {
		WoExploreNearbyState.activePointKey = null;
		WoExploreNearbyState.activePointData = null;
		hasChanged = true;
	}
	if (WoExploreNearbyState.previewPointKey || WoExploreNearbyState.previewPointData) {
		WoExploreNearbyState.previewPointKey = null;
		WoExploreNearbyState.previewPointData = null;
		hasChanged = true;
	}
	if (selectedAnchorPointKey && WoExploreNearbyState.openPopupPointKey === selectedAnchorPointKey) {
		WoExploreNearbyState.openPopupPointKey = null;
		hasChanged = true;
	}

	return hasChanged;
}

function Wo_ExploreNearbyRenderResolvedSearchPlace() {
	Wo_ExploreNearbyUpdateUi();
	Wo_ExploreNearbyRenderCurrentMap(WoExploreNearbyState.openPopupPointKey || null);
	if (!Wo_ExploreNearbyIsPlaceSearchMode()) {
		Wo_ExploreNearbySyncRelatedPlaces(true);
	}
}

function Wo_ExploreNearbyResolveSearchPlace(loadToken) {
	var query = Wo_ExploreNearbyGetSearchValue();
	var normalizedQuery = $.trim(query).toLowerCase();
	var selectedSuggestionItem = null;

	Wo_ExploreNearbySyncSearchSelectionHint();
	selectedSuggestionItem = WoExploreNearbyState.searchSelectionHintItemData || null;

	function resolveAndApplyEntityAnchor(anchorPromise) {
		return anchorPromise.then(function(placeItem) {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return {skipNearby: false};
			}

			if (placeItem) {
				Wo_ExploreNearbyExitPlaceSearchMode();
				Wo_ExploreNearbySetSearchContext('location', placeItem);
				WoExploreNearbyState.activePointKey = Wo_ExploreNearbyGetItemKey(placeItem);
				WoExploreNearbyState.activePointData = placeItem;
				WoExploreNearbyState.openPopupPointKey = null;
				WoExploreNearbyState.pendingFocusPointKey = WoExploreNearbyState.activePointKey;
				WoExploreNearbyState.previewPointKey = null;
				WoExploreNearbyState.previewPointData = null;
				Wo_ExploreNearbyClearRouteTarget();
				Wo_ExploreNearbyRenderResolvedSearchPlace();
				return {skipNearby: false};
			}

			if (Wo_ExploreNearbyClearSearchPlaceSelection()) {
				Wo_ExploreNearbyRenderResolvedSearchPlace();
			}
			return {skipNearby: false};
		}).catch(function() {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return {skipNearby: false};
			}

			if (Wo_ExploreNearbyClearSearchPlaceSelection()) {
				Wo_ExploreNearbyRenderResolvedSearchPlace();
			}
			return {skipNearby: false};
		});
	}

	function resolveAndApplyPlaceSearch(anchorPromise) {
		return Promise.resolve(anchorPromise).then(function(anchorItem) {
			var centerPoint = null;
			var previousPreviewPointKey = $.trim(WoExploreNearbyState.previewPointKey || '');
			var previousRoutePointKey = $.trim(WoExploreNearbyState.routeTargetPointKey || '');
			var restoredPreviewPoint = null;
			var restoredRoutePoint = null;

			if (loadToken !== WoExploreNearbyState.loadToken) {
				return {skipNearby: true};
			}

			if (anchorItem) {
				Wo_ExploreNearbySetSearchContext('location', anchorItem);
			}

			centerPoint = Wo_ExploreNearbyGetPlaceSearchCenterPoint(anchorItem);
			return Wo_ExploreNearbySearchPlacesByText(query, centerPoint).then(function(placeResults) {
				if (loadToken !== WoExploreNearbyState.loadToken) {
					return {skipNearby: true};
				}

				if (placeResults === null) {
					Wo_ExploreNearbyExitPlaceSearchMode();
					return {skipNearby: false};
				}

				WoExploreNearbyState.isPlaceSearchMode = true;
				WoExploreNearbyState.placeSearchQuery = query;
				WoExploreNearbyState.placeSearchResults = Wo_ExploreNearbyNormalizeDiscoveryItems(placeResults || []);
				restoredPreviewPoint = previousPreviewPointKey ? Wo_ExploreNearbyGetMergedItemByKey(previousPreviewPointKey) : null;
				restoredRoutePoint = previousRoutePointKey ? Wo_ExploreNearbyGetMergedItemByKey(previousRoutePointKey) : null;
				WoExploreNearbyState.previewPointKey = null;
				WoExploreNearbyState.previewPointData = null;
				WoExploreNearbyState.activePointKey = null;
				WoExploreNearbyState.activePointData = null;
				WoExploreNearbyState.openPopupPointKey = null;
				WoExploreNearbyState.pendingFocusPointKey = null;
				Wo_ExploreNearbyClearRouteTarget();
				if (restoredPreviewPoint) {
					Wo_ExploreNearbySetPreviewPoint(restoredPreviewPoint);
				}
				if (restoredRoutePoint) {
					Wo_ExploreNearbySetRouteTargetPoint(restoredRoutePoint);
				}
				return {skipNearby: true};
			});
		});
	}

	if (!normalizedQuery) {
		if (Wo_ExploreNearbyClearSearchPlaceSelection()) {
			Wo_ExploreNearbyRenderResolvedSearchPlace();
		}
		return Promise.resolve({skipNearby: false});
	}

	if (normalizedQuery && normalizedQuery === WoExploreNearbyState.searchSelectionHintQuery && WoExploreNearbyState.searchSelectionHintMode === 'anchor' && selectedSuggestionItem) {
		if (selectedSuggestionItem.type === 'user' || selectedSuggestionItem.type === 'page') {
			return resolveAndApplyEntityAnchor(Wo_ExploreNearbyResolveSelectedSuggestionAnchor(selectedSuggestionItem, query));
		}

		return resolveAndApplyPlaceSearch(Wo_ExploreNearbyResolveSelectedSuggestionAnchor(selectedSuggestionItem, query));
	}

	if (!Wo_ExploreNearbyShouldUsePlaceSearchQuery(query, selectedSuggestionItem)) {
		if (Wo_ExploreNearbyExitPlaceSearchMode()) {
			Wo_ExploreNearbyRenderResolvedSearchPlace();
		}
		return Promise.resolve({skipNearby: false});
	}

	return resolveAndApplyPlaceSearch(null);
}

function Wo_ExploreNearbyRefreshCurrentUserDynamicLocation() {
	if (!Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng)) {
		return;
	}

	Wo_ExploreNearbyReverseGeocodeCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng).then(function(addressText) {
		if (!addressText) {
			return;
		}

		currentUserMapPoint.location = addressText;
		currentUserMapPoint.location_dynamic = addressText;
	});
}

function Wo_ExploreNearbyRefreshDynamicUserLocations(shouldRefreshMap) {
	var normalizedUsers = Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.usersItems || []);
	var refreshToken = ++WoExploreNearbyState.dynamicLocationRefreshToken;
	var requests = [];

	for (var i = 0; i < normalizedUsers.length; i++) {
		if (normalizedUsers[i].type !== 'user' || !Wo_ExploreNearbyHasValidCoordinates(normalizedUsers[i].lat, normalizedUsers[i].lng)) {
			continue;
		}

		(function(itemKey, lat, lng) {
			requests.push(Wo_ExploreNearbyReverseGeocodeCoordinates(lat, lng).then(function(addressText) {
				return {
					item_key: itemKey,
					location: addressText
				};
			}));
		})(normalizedUsers[i].item_key, normalizedUsers[i].lat, normalizedUsers[i].lng);
	}

	if (!requests.length) {
		Wo_ExploreNearbyRefreshCurrentUserDynamicLocation();
		return;
	}

	Promise.all(requests).then(function(results) {
		if (refreshToken !== WoExploreNearbyState.dynamicLocationRefreshToken) {
			return;
		}

		var locationLookup = {};
		var hasChanged = false;
		for (var resultIndex = 0; resultIndex < results.length; resultIndex++) {
			if (results[resultIndex] && results[resultIndex].item_key && results[resultIndex].location) {
				locationLookup[results[resultIndex].item_key] = results[resultIndex].location;
			}
		}

		WoExploreNearbyState.usersItems = normalizedUsers.map(function(item) {
			var nextLocation = locationLookup[item.item_key] || item.location;
			if (nextLocation && item.location !== nextLocation) {
				hasChanged = true;
			}

			return $.extend({}, item, {
				location: nextLocation,
				location_dynamic: nextLocation || item.location_dynamic || ''
			});
		});

		Wo_ExploreNearbyRefreshCurrentUserDynamicLocation();
		if (!hasChanged) {
			return;
		}

		Wo_ExploreNearbyRenderList();
		if (shouldRefreshMap !== false) {
			Wo_ExploreNearbyRenderCurrentMap(WoExploreNearbyState.openPopupPointKey || null);
		}
	});
}

function Wo_ExploreNearbyGetDirectionsUrl(point) {
	var location = $.trim((point && point.location) || '');
	var lat = parseFloat(point && point.lat);
	var lng = parseFloat(point && point.lng);

	if (!isNaN(lat) && !isNaN(lng) && (lat !== 0 || lng !== 0)) {
		return 'https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(lat + ',' + lng) + '&travelmode=driving';
	}
	if (location) {
		return 'https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(location) + '&travelmode=driving';
	}

	return 'https://www.google.com/maps/dir/?api=1';
}

function Wo_ExploreNearbyGetShareUrl(point) {
	var directUrl = $.trim((point && point.url) || '');

	if (directUrl) {
		return directUrl;
	}

	if (Wo_ExploreNearbyCanGetDirections(point)) {
		return Wo_ExploreNearbyGetDirectionsUrl(point);
	}

	return '';
}

function Wo_ExploreNearbyCopyTextToClipboard(text) {
	var normalizedText = String(text || '');

	if (!normalizedText) {
		return Promise.reject(new Error('No text to copy'));
	}

	if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function' && window.isSecureContext) {
		return navigator.clipboard.writeText(normalizedText);
	}

	return new Promise(function(resolve, reject) {
		var textarea = document.createElement('textarea');

		textarea.value = normalizedText;
		textarea.setAttribute('readonly', 'readonly');
		textarea.style.position = 'fixed';
		textarea.style.opacity = '0';
		textarea.style.pointerEvents = 'none';
		document.body.appendChild(textarea);
		textarea.focus();
		textarea.select();
		textarea.setSelectionRange(0, normalizedText.length);

		try {
			if (document.execCommand('copy')) {
				resolve();
			}
			else {
				reject(new Error('Copy command failed'));
			}
		}
		catch (error) {
			reject(error);
		}
		finally {
			document.body.removeChild(textarea);
		}
	});
}

function Wo_ExploreNearbySetTemporaryActionLabel(button, label) {
	var triggerButton = $(button);
	var defaultLabel = '';
	var activeTimer = null;

	if (!triggerButton.length || !label) {
		return;
	}

	defaultLabel = triggerButton.data('defaultLabel') || $.trim(triggerButton.text());
	activeTimer = triggerButton.data('labelResetTimer') || null;

	if (!triggerButton.data('defaultLabel')) {
		triggerButton.data('defaultLabel', defaultLabel);
	}
	if (activeTimer) {
		clearTimeout(activeTimer);
	}

	triggerButton.text(label);
	triggerButton.data('labelResetTimer', setTimeout(function() {
		triggerButton.text(defaultLabel);
		triggerButton.removeData('labelResetTimer');
	}, 1600));
}

function Wo_ExploreNearbySharePointByKey(pointKey, button) {
	var point = Wo_ExploreNearbyResolvePointByKey(pointKey, false);
	var shareUrl = Wo_ExploreNearbyGetShareUrl(point);
	var shareTitle = $.trim((point && (point.title || point.name)) || '');

	if (!shareUrl) {
		return;
	}

	if (navigator.share && typeof navigator.share === 'function') {
		navigator.share({
			title: shareTitle || cardShareLabel,
			text: shareTitle || '',
			url: shareUrl
		}).catch(function(error) {
			if (error && error.name === 'AbortError') {
				return;
			}

			Wo_ExploreNearbyCopyTextToClipboard(shareUrl).then(function() {
				Wo_ExploreNearbySetTemporaryActionLabel(button, cardShareCopiedLabel);
			}).catch(function() {});
		});
		return;
	}

	Wo_ExploreNearbyCopyTextToClipboard(shareUrl).then(function() {
