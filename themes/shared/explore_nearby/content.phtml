function Wo_ExploreNearbyCanHandleMapSelection(event, source) {
	var pointerType = Wo_ExploreNearbyGetInteractionPointerType(event) || WoExploreNearbyState.mapPointerType || WoExploreNearbyState.mapLastPointerType || '';
	var touchCount = Wo_ExploreNearbyGetInteractionTouchCount(event);
	var sourceLabel = String(source || '');

	if (Date.now() < (WoExploreNearbyState.mapSelectionCooldownUntil || 0)) {
