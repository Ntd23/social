	var markerPosition = Wo_ExploreNearbyGoogleMarkerGetPosition(marker);
	if (!projection || !markerPosition || !projection.fromLatLngToContainerPixel) {
		return null;
	}

	var lat = Wo_ExploreNearbyGetGoogleLatLngValue(markerPosition, 'lat');
	var lng = Wo_ExploreNearbyGetGoogleLatLngValue(markerPosition, 'lng');
	if (!Wo_ExploreNearbyHasValidCoordinates(lat, lng)) {
