	var primaryType = $.trim(result.primaryType || ((Array.isArray(result.types) && result.types[0]) ? result.types[0] : ''));
	var primaryTypeLabel = Wo_ExploreNearbyGetGooglePlaceText(result.primaryTypeDisplayName) || Wo_ExploreNearbyFormatPrimaryTypeLabel(primaryType);
	var locationText = $.trim(result.formattedAddress || result.vicinity || '');
	var googleMapsUrl = $.trim(result.googleMapsURI || '');
