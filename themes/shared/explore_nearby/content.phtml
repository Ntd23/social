		Wo_ExploreNearbySetMapSelectionCooldown(360);
	}

	if (!point || WoExploreNearbyState.mapPointerDownClientX === null || WoExploreNearbyState.mapPointerDownClientY === null) {
		return;
	}

	if (Math.abs(point.clientX - WoExploreNearbyState.mapPointerDownClientX) > moveThreshold || Math.abs(point.clientY - WoExploreNearbyState.mapPointerDownClientY) > moveThreshold) {
