$nearby_shops = !empty($explore_nearby['nearby_shops']) ? $explore_nearby['nearby_shops'] : array();
$nearby_users_count = isset($explore_nearby['nearby_users_count']) ? (int) $explore_nearby['nearby_users_count'] : 0;
$nearby_shops_count = isset($explore_nearby['nearby_shops_count']) ? (int) $explore_nearby['nearby_shops_count'] : 0;
