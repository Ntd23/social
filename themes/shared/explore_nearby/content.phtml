	var thresholdKm = Wo_ExploreNearbyGetMapSelectionFallbackThresholdKm();

	if (!Wo_ExploreNearbyHasValidCoordinates(clickLat, clickLng)) {
		return null;
	}

	for (var markerKey in WoExploreNearbyMapState.googleMarkerLookup) {
		if (!Object.prototype.hasOwnProperty.call(WoExploreNearbyMapState.googleMarkerLookup, markerKey)) {
			continue;
		}

		var marker = WoExploreNearbyMapState.googleMarkerLookup[markerKey];
		var point = marker ? marker.woNearbyPoint : null;
		var markerPosition = Wo_ExploreNearbyGoogleMarkerGetPosition(marker);
		var markerLat = Wo_ExploreNearbyGetGoogleLatLngValue(markerPosition, 'lat');
		var markerLng = Wo_ExploreNearbyGetGoogleLatLngValue(markerPosition, 'lng');
		if (!point || !Wo_ExploreNearbyHasValidCoordinates(markerLat, markerLng)) {
			continue;
		}

		var distanceKm = Wo_ExploreNearbyGetDistanceKm(
			{lat: clickLat, lng: clickLng},
			{lat: markerLat, lng: markerLng}
		);
		if (distanceKm < nearestDistance) {
