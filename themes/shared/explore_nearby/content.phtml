	}

	return WoExploreNearbyState.userGoogleGeocoder;
}

function Wo_ExploreNearbyBuildTextSearchPlaceItem(placeResult, centerPoint, query) {
	var result = placeResult || {};
	var geometryLocation = result.location || (result.geometry ? result.geometry.location : null);
	var lat = Wo_ExploreNearbyGetGoogleLatLngValue(geometryLocation, 'lat');
	var lng = Wo_ExploreNearbyGetGoogleLatLngValue(geometryLocation, 'lng');
	var placeId = $.trim(result.id || result.place_id || '');
