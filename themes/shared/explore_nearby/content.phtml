function Wo_ExploreNearbyFormatDistance(distance) {
	var numericDistance = parseFloat(distance);
	if (isNaN(numericDistance) || numericDistance <= 0) {
		return '';
	}

	if (numericDistance < 10) {
		var precise = numericDistance.toFixed(1).replace(/\.0$/, '');
		return precise + ' km';
	}

	return Math.round(numericDistance) + ' km';
}

function Wo_ExploreNearbyHasValidCoordinates(lat, lng) {
	var numericLat = parseFloat(lat);
	var numericLng = parseFloat(lng);

	return !isNaN(numericLat) && !isNaN(numericLng) && (numericLat !== 0 || numericLng !== 0);
}

function Wo_ExploreNearbyBuildCoordinateText(lat, lng) {
	if (!Wo_ExploreNearbyHasValidCoordinates(lat, lng)) {
		return '';
	}

	return parseFloat(lat).toFixed(6) + ', ' + parseFloat(lng).toFixed(6);
}

function Wo_ExploreNearbyGetItemKey(item) {
	if (!item) {
		return '';
	}

	if (item.item_key) {
		return item.item_key;
	}

	return (item.type || 'item') + '|' + (item.url || item.location || item.title || item.name || '');
}

function Wo_ExploreNearbyIsPlacePointKey(pointKey) {
	return String(pointKey || '').indexOf('place|') === 0;
}

function Wo_ExploreNearbyGetDiscoveryPlaceId(item) {
	if (!item) {
		return '';
	}

	return $.trim(item.place_id || item.google_place_id || item.external_place_id || '');
}

function Wo_ExploreNearbyGetDiscoveryDedupKey(item) {
	var normalizedItem = item || {};
	var itemType = String(normalizedItem.type || 'item');
	var placeId = Wo_ExploreNearbyGetDiscoveryPlaceId(normalizedItem);
	var url = $.trim(normalizedItem.url || '');
	var ajaxUrl = $.trim(normalizedItem.ajax_url || '');
	var title = Wo_ExploreNearbyNormalizeTextValue(normalizedItem.title || normalizedItem.name || '');
	var location = Wo_ExploreNearbyNormalizeTextValue(normalizedItem.location || '');
	var lat = parseFloat(normalizedItem.lat);
	var lng = parseFloat(normalizedItem.lng);

	if (placeId) {
		return 'place_id|' + placeId.toLowerCase();
	}

	if (url) {
		if (itemType === 'shop' || itemType === 'page') {
			return 'pageish|url|' + url.toLowerCase();
		}

		return itemType + '|url|' + url.toLowerCase();
	}

	if (ajaxUrl) {
		if (itemType === 'shop' || itemType === 'page') {
			return 'pageish|ajax|' + ajaxUrl.toLowerCase();
		}

		return itemType + '|ajax|' + ajaxUrl.toLowerCase();
	}

	if (!isNaN(lat) && !isNaN(lng) && (lat !== 0 || lng !== 0)) {
		return itemType + '|coord|' + lat.toFixed(5) + ',' + lng.toFixed(5) + '|' + title.toLowerCase();
	}

	if (normalizedItem.item_key) {
		return 'key|' + normalizedItem.item_key;
	}

	return itemType + '|fallback|' + (location || title || '').toLowerCase();
}

function Wo_ExploreNearbyGetDiscoveryItemFamily(item) {
	var itemType = $.trim((item && item.type) || '');

	if (itemType === 'shop' || itemType === 'page') {
		return 'pageish';
	}

	return itemType || 'item';
}

function Wo_ExploreNearbyNormalizeComparableText(text) {
	var value = Wo_ExploreNearbyNormalizeTextValue(text || '').toLowerCase();

	if (!value) {
		return '';
	}

	if (typeof value.normalize === 'function') {
		value = value.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
	}

	value = value.replace(/đ/g, 'd');
	value = value.replace(/[^a-z0-9\s]/g, ' ');
	value = value.replace(/\s+/g, ' ').trim();

	return value;
}

function Wo_ExploreNearbyGetDiscoveryComparableTitle(item) {
	return Wo_ExploreNearbyNormalizeComparableText((item && (item.title || item.name || item.search_value)) || '');
}

function Wo_ExploreNearbyGetDiscoveryComparableLocation(item) {
	return Wo_ExploreNearbyNormalizeComparableText((item && (item.location || item.address || item.formatted_address)) || '');
}

function Wo_ExploreNearbyGetDiscoveryComparableCoreTitle(item) {
	var normalizedTitle = Wo_ExploreNearbyGetDiscoveryComparableTitle(item);
	var stopWords = {
		cafe: true,
		coffee: true,
		shop: true,
		store: true,
		restaurant: true,
		quan: true,
		page: true,
		official: true
	};

	if (!normalizedTitle) {
		return '';
	}

	var coreTokens = normalizedTitle.split(' ').filter(function(token) {
		return !!token && !stopWords[token];
	});

	return coreTokens.length ? coreTokens.join(' ') : normalizedTitle;
}

function Wo_ExploreNearbyHasComparableCoreTitleMatch(firstItem, secondItem) {
	var firstTitle = Wo_ExploreNearbyGetDiscoveryComparableCoreTitle(firstItem);
	var secondTitle = Wo_ExploreNearbyGetDiscoveryComparableCoreTitle(secondItem);

	return !!firstTitle && firstTitle === secondTitle;
}

function Wo_ExploreNearbyHasComparableLocationMatch(firstItem, secondItem) {
	var firstLocation = Wo_ExploreNearbyGetDiscoveryComparableLocation(firstItem);
	var secondLocation = Wo_ExploreNearbyGetDiscoveryComparableLocation(secondItem);

	return !!firstLocation && firstLocation === secondLocation;
}

function Wo_ExploreNearbyGetDiscoveryDistanceMeters(firstItem, secondItem) {
	var firstLat = parseFloat(firstItem && firstItem.lat);
	var firstLng = parseFloat(firstItem && firstItem.lng);
	var secondLat = parseFloat(secondItem && secondItem.lat);
	var secondLng = parseFloat(secondItem && secondItem.lng);

	if (!Wo_ExploreNearbyHasValidCoordinates(firstLat, firstLng) || !Wo_ExploreNearbyHasValidCoordinates(secondLat, secondLng)) {
		return null;
	}

	return Wo_ExploreNearbyGetDistanceKm(
		{lat: firstLat, lng: firstLng},
		{lat: secondLat, lng: secondLng}
	) * 1000;
}

function Wo_ExploreNearbyCanSoftMatchDiscoveryItems(firstItem, secondItem) {
	var firstFamily = Wo_ExploreNearbyGetDiscoveryItemFamily(firstItem);
	var secondFamily = Wo_ExploreNearbyGetDiscoveryItemFamily(secondItem);

	return (firstFamily === 'pageish' && secondFamily === 'place') ||
		(firstFamily === 'place' && secondFamily === 'pageish');
}

function Wo_ExploreNearbyAreItemsDuplicate(firstItem, secondItem, options) {
	var firstPlaceId = Wo_ExploreNearbyGetDiscoveryPlaceId(firstItem);
	var secondPlaceId = Wo_ExploreNearbyGetDiscoveryPlaceId(secondItem);
	var firstUrl = $.trim((firstItem && firstItem.url) || '');
	var secondUrl = $.trim((secondItem && secondItem.url) || '');
	var firstAjaxUrl = $.trim((firstItem && firstItem.ajax_url) || '');
	var secondAjaxUrl = $.trim((secondItem && secondItem.ajax_url) || '');
	var firstItemKey = $.trim((firstItem && firstItem.item_key) || '');
	var secondItemKey = $.trim((secondItem && secondItem.item_key) || '');
	var firstCoreTitle = '';
	var secondCoreTitle = '';
	var hasTitleMatch = false;
	var hasLocationMatch = false;
	var distanceMeters = null;

	options = options || {};

	if (!firstItem || !secondItem) {
		return false;
	}

	if (firstPlaceId && secondPlaceId && firstPlaceId.toLowerCase() === secondPlaceId.toLowerCase()) {
		return true;
	}

	if (firstUrl && secondUrl && firstUrl.toLowerCase() === secondUrl.toLowerCase()) {
		return true;
	}

	if (firstAjaxUrl && secondAjaxUrl && firstAjaxUrl.toLowerCase() === secondAjaxUrl.toLowerCase()) {
		return true;
	}

	if (firstItemKey && secondItemKey && firstItemKey === secondItemKey) {
		return true;
	}

	if (!Wo_ExploreNearbyCanSoftMatchDiscoveryItems(firstItem, secondItem)) {
		return false;
	}

	firstCoreTitle = Wo_ExploreNearbyGetDiscoveryComparableCoreTitle(firstItem);
	secondCoreTitle = Wo_ExploreNearbyGetDiscoveryComparableCoreTitle(secondItem);
	hasTitleMatch = !!firstCoreTitle && !!secondCoreTitle && firstCoreTitle === secondCoreTitle;
	hasLocationMatch = Wo_ExploreNearbyHasComparableLocationMatch(firstItem, secondItem);
	if (options.strictAutocomplete === true) {
		return hasTitleMatch && hasLocationMatch;
	}

	distanceMeters = Wo_ExploreNearbyGetDiscoveryDistanceMeters(firstItem, secondItem);
	if (distanceMeters === null || distanceMeters > 30) {
		return false;
	}

	if (hasTitleMatch) {
		return true;
	}

	if (!hasLocationMatch) {
		return false;
	}

	// Avoid collapsing different businesses that share the same building address.
	return !firstCoreTitle || !secondCoreTitle;
}

function Wo_ExploreNearbyGetItemDataRichnessScore(item) {
	var score = 0;

	if (!item) {
		return score;
	}

	if ($.trim(item.avatar || '')) {
		score += 4;
	}
	if ($.trim(item.url || '')) {
		score += 4;
	}
	if ($.trim(item.description || '')) {
		score += 3;
	}
	if ($.trim(item.location || item.address || '')) {
		score += 2;
	}
	if (Wo_ExploreNearbyGetDiscoveryPlaceId(item)) {
		score += 2;
	}
	if ($.trim(item.primary_type_label || '')) {
		score += 1;
	}

	return score;
}

function Wo_ExploreNearbyGetSelectedAnchorItem() {
	var anchorItems = Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.selectedAnchorItem ? [WoExploreNearbyState.selectedAnchorItem] : []);
	return anchorItems.length ? anchorItems[0] : null;
}

function Wo_ExploreNearbyGetSelectedAnchorPointKey() {
