function Wo_ExploreNearbyEscapeHtml(text) {
	return String(text || '')
		.replace(/&/g, '&amp;')
		.replace(/</g, '&lt;')
		.replace(/>/g, '&gt;')
		.replace(/"/g, '&quot;')
		.replace(/'/g, '&#039;');
}

function Wo_ExploreNearbyDecodeHtmlEntities(text) {
	var value = String(text || '');
	var textarea = Wo_ExploreNearbyDecodeHtmlEntities.textarea;
	if (!textarea) {
		textarea = document.createElement('textarea');
		Wo_ExploreNearbyDecodeHtmlEntities.textarea = textarea;
	}

	textarea.innerHTML = value;
	return textarea.value;
}

function Wo_ExploreNearbyNormalizeTextValue(text) {
	return $.trim(Wo_ExploreNearbyDecodeHtmlEntities(text));
}

function Wo_ExploreNearbyFormatDistance(distance) {
	var numericDistance = parseFloat(distance);
	if (isNaN(numericDistance) || numericDistance <= 0) {
		return '';
	}

	if (numericDistance < 10) {
		var precise = numericDistance.toFixed(1).replace(/\.0$/, '');
		return precise + ' km';
	}

	return Math.round(numericDistance) + ' km';
}

function Wo_ExploreNearbyHasValidCoordinates(lat, lng) {
	var numericLat = parseFloat(lat);
	var numericLng = parseFloat(lng);

	return !isNaN(numericLat) && !isNaN(numericLng) && (numericLat !== 0 || numericLng !== 0);
}

function Wo_ExploreNearbyBuildCoordinateText(lat, lng) {
	if (!Wo_ExploreNearbyHasValidCoordinates(lat, lng)) {
		return '';
	}

	return parseFloat(lat).toFixed(6) + ', ' + parseFloat(lng).toFixed(6);
}

function Wo_ExploreNearbyGetItemKey(item) {
	if (!item) {
		return '';
	}

	if (item.item_key) {
		return item.item_key;
	}

	return (item.type || 'item') + '|' + (item.url || item.location || item.title || item.name || '');
}

function Wo_ExploreNearbyIsPlacePointKey(pointKey) {
	return String(pointKey || '').indexOf('place|') === 0;
}

function Wo_ExploreNearbyNormalizeDiscoveryItems(items) {
	var normalizedItems = [];
	if (!Array.isArray(items)) {
		return normalizedItems;
	}

	for (var i = 0; i < items.length; i++) {
		var item = items[i] || {};
		var lat = item.lat;
		var lng = item.lng;
		var itemType = 'user';
		if (item.type === 'shop') {
			itemType = 'shop';
		}
		else if (item.type === 'place') {
			itemType = 'place';
		}
		var parsedLat = (lat !== null && lat !== undefined && lat !== '') ? parseFloat(lat) : null;
		var parsedLng = (lng !== null && lng !== undefined && lng !== '') ? parseFloat(lng) : null;
		var hasCoordinates = Wo_ExploreNearbyHasValidCoordinates(parsedLat, parsedLng);
		var dynamicLocation = Wo_ExploreNearbyNormalizeTextValue(item.location_dynamic || item.dynamic_location || '');
		var itemLocation = Wo_ExploreNearbyNormalizeTextValue(item.location || '');
		var distanceValue = null;

		if (item.distance_value !== null && item.distance_value !== undefined && item.distance_value !== '' && !isNaN(parseFloat(item.distance_value))) {
			distanceValue = parseFloat(item.distance_value);
		}
		else if (hasCoordinates) {
			var hasCurrentUserLocation = Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng);
			if (hasCurrentUserLocation) {
				distanceValue = Wo_ExploreNearbyGetDistanceKm(
					{lat: parseFloat(currentUserMapPoint.lat), lng: parseFloat(currentUserMapPoint.lng)},
					{lat: parsedLat, lng: parsedLng}
				);
			}
		}

		if (itemType === 'user' && hasCoordinates) {
			itemLocation = dynamicLocation || Wo_ExploreNearbyBuildCoordinateText(parsedLat, parsedLng);
		}

		normalizedItems.push({
			item_key: Wo_ExploreNearbyGetItemKey(item),
			offset_id: item.offset_id ? parseInt(item.offset_id, 10) : 0,
			type: itemType,
			type_label: Wo_ExploreNearbyNormalizeTextValue(item.type_label || (itemType === 'shop' ? defaultShopTypeLabel : (itemType === 'place' ? defaultPlaceTypeLabel : defaultUserTypeLabel))),
			title: Wo_ExploreNearbyNormalizeTextValue(item.title || item.name || ''),
			subtitle: Wo_ExploreNearbyNormalizeTextValue(item.subtitle || ''),
			description: Wo_ExploreNearbyNormalizeTextValue(item.description || ''),
			avatar: item.avatar || '',
			url: item.url || '',
			ajax_url: item.ajax_url || '',
			location: itemLocation,
			location_dynamic: dynamicLocation || (itemType === 'user' && hasCoordinates ? Wo_ExploreNearbyBuildCoordinateText(parsedLat, parsedLng) : ''),
			distance_value: distanceValue,
			distance_text: item.distance_text || Wo_ExploreNearbyFormatDistance(distanceValue),
			lat: hasCoordinates ? parsedLat : null,
			lng: hasCoordinates ? parsedLng : null,
			is_self: !!(item.is_self || item.isSelf)
		});
	}

	return normalizedItems;
}

function Wo_ExploreNearbyMergeUniqueItems(existingItems, incomingItems) {
	var lookup = {};
	var mergedItems = [];
	var normalizedExisting = Wo_ExploreNearbyNormalizeDiscoveryItems(existingItems);
	var normalizedIncoming = Wo_ExploreNearbyNormalizeDiscoveryItems(incomingItems);
	var combinedItems = normalizedExisting.concat(normalizedIncoming);

	for (var i = 0; i < combinedItems.length; i++) {
		var item = combinedItems[i];
		var itemKey = Wo_ExploreNearbyGetItemKey(item);
		if (lookup[itemKey]) {
			continue;
		}

		lookup[itemKey] = true;
		mergedItems.push(item);
	}

	return mergedItems;
}

function Wo_ExploreNearbySortItems(items) {
	return items.sort(function(firstItem, secondItem) {
		var firstHasDistance = firstItem.distance_value !== null && firstItem.distance_value !== undefined && !isNaN(firstItem.distance_value);
		var secondHasDistance = secondItem.distance_value !== null && secondItem.distance_value !== undefined && !isNaN(secondItem.distance_value);

		if (firstHasDistance && secondHasDistance) {
			if (firstItem.distance_value === secondItem.distance_value) {
				return String(firstItem.title || '').localeCompare(String(secondItem.title || ''));
			}

			return firstItem.distance_value - secondItem.distance_value;
		}

		if (firstHasDistance) {
			return -1;
		}

		if (secondHasDistance) {
			return 1;
		}

		return String(firstItem.title || '').localeCompare(String(secondItem.title || ''));
	});
}

function Wo_ExploreNearbyGetMergedItems() {
	var mergedItems = [];

	if (WoExploreNearbyState.usersEnabled) {
		mergedItems = mergedItems.concat(Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.usersItems || []));
	}
	if (WoExploreNearbyState.shopsEnabled) {
		mergedItems = mergedItems.concat(Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.shopsItems || []));
	}

	var dedupedLookup = {};
	var dedupedItems = [];
	for (var i = 0; i < mergedItems.length; i++) {
		var itemKey = Wo_ExploreNearbyGetItemKey(mergedItems[i]);
		if (dedupedLookup[itemKey]) {
			continue;
		}

		dedupedLookup[itemKey] = true;
		dedupedItems.push(mergedItems[i]);
	}

	dedupedItems = Wo_ExploreNearbySortItems(dedupedItems);

	var searchPlaceItems = Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.searchPlaceItem ? [WoExploreNearbyState.searchPlaceItem] : []);
	if (searchPlaceItems.length) {
		var searchPlaceItem = searchPlaceItems[0];
		var searchPlaceKey = Wo_ExploreNearbyGetItemKey(searchPlaceItem);
		dedupedItems = dedupedItems.filter(function(item) {
			return Wo_ExploreNearbyGetItemKey(item) !== searchPlaceKey;
		});
		dedupedItems.unshift(searchPlaceItem);
	}

	return dedupedItems;
}

function Wo_ExploreNearbyGetVisiblePoints() {
	var items = Wo_ExploreNearbyGetMergedItems();
	var points = [];

	for (var i = 0; i < items.length; i++) {
		points.push({
			item_key: items[i].item_key,
			name: items[i].title,
			lat: items[i].lat,
			lng: items[i].lng,
			avatar: items[i].avatar,
			url: items[i].url,
			location: items[i].location,
			type: items[i].type,
			type_label: items[i].type_label,
			is_self: items[i].is_self,
			isSelf: items[i].is_self
		});
	}

	return points;
}

function Wo_ExploreNearbyGetTotalResultsCount() {
	return (WoExploreNearbyState.usersEnabled ? (WoExploreNearbyState.usersCount || 0) : 0) +
		(WoExploreNearbyState.shopsEnabled ? (WoExploreNearbyState.shopsCount || 0) : 0);
}

function Wo_ExploreNearbyGetLoadedResultsCount() {
	return Wo_ExploreNearbyGetMergedItems().length;
}

function Wo_ExploreNearbyGetDistanceValue() {
	return parseInt($('#nearby-users-distance').val(), 10) || defaultDistanceValue;
}

function Wo_ExploreNearbyGetSearchValue() {
	return $.trim($('#nearby-username').val() || '');
}

function Wo_ExploreNearbyGetNormalizedSearchValue() {
	return Wo_ExploreNearbyGetSearchValue().toLowerCase();
}

function Wo_ExploreNearbyCanUseGooglePlacesAutocomplete() {
	return typeof google !== 'undefined' &&
		google.maps &&
		google.maps.places &&
		typeof google.maps.places.AutocompleteService === 'function';
}

function Wo_ExploreNearbyCanUseGooglePlacesImportLibrary() {
	return typeof google !== 'undefined' &&
		google.maps &&
		typeof google.maps.importLibrary === 'function';
}

function Wo_ExploreNearbyEnsureGooglePlacesLibrary() {
	if (!Wo_ExploreNearbyCanUseGooglePlacesImportLibrary()) {
		return Promise.resolve(null);
	}

	if (WoExploreNearbyState.userGooglePlacesLibrary === false) {
		return Promise.resolve(null);
	}

	if (WoExploreNearbyState.userGooglePlacesLibrary) {
		return Promise.resolve(WoExploreNearbyState.userGooglePlacesLibrary);
	}

	if (WoExploreNearbyState.userGooglePlacesLibraryPromise) {
		return WoExploreNearbyState.userGooglePlacesLibraryPromise;
	}

	WoExploreNearbyState.userGooglePlacesLibraryPromise = google.maps.importLibrary('places').then(function(placesLibrary) {
		WoExploreNearbyState.userGooglePlacesLibrary = placesLibrary || {};
		WoExploreNearbyState.userGooglePlacesLibraryPromise = null;
		return WoExploreNearbyState.userGooglePlacesLibrary;
	}).catch(function() {
		WoExploreNearbyState.userGooglePlacesLibrary = false;
		WoExploreNearbyState.userGooglePlacesLibraryPromise = null;
		return null;
	});

	return WoExploreNearbyState.userGooglePlacesLibraryPromise;
}

function Wo_ExploreNearbyGetGooglePlaceText(textValue) {
	if (!textValue) {
		return '';
	}

	if (typeof textValue === 'string') {
		return $.trim(textValue);
	}

	if (typeof textValue.text === 'string') {
		return $.trim(textValue.text);
	}

	if (typeof textValue.toString === 'function') {
		return $.trim(textValue.toString());
	}

	return '';
}

function Wo_ExploreNearbyGetSuggestionTypeLabel(item) {
	if (item && item.type_label) {
		return item.type_label;
	}
	if (item && item.type === 'page') {
		return defaultPageTypeLabel;
	}
	if (item && item.type === 'place') {
		return defaultPlaceTypeLabel;
	}

	return defaultUserTypeLabel;
}

function Wo_ExploreNearbyGetSearchPlaceCacheKey(query, placeId) {
	var normalizedPlaceId = $.trim(placeId || '');
	var normalizedQuery = $.trim(query || '').toLowerCase();

	if (normalizedPlaceId) {
		return 'place_id|' + normalizedPlaceId;
	}

	return 'query|' + normalizedQuery;
}

function Wo_ExploreNearbyResetSearchSelectionHint() {
	WoExploreNearbyState.searchSelectionHintMode = '';
	WoExploreNearbyState.searchSelectionHintQuery = '';
	WoExploreNearbyState.searchSelectionHintPlaceId = '';
	WoExploreNearbyState.searchSelectionHintPlacePrediction = null;
}

function Wo_ExploreNearbySyncSearchSelectionHint() {
	if (!WoExploreNearbyState.searchSelectionHintQuery) {
		return;
	}
	if (Wo_ExploreNearbyGetNormalizedSearchValue() !== WoExploreNearbyState.searchSelectionHintQuery) {
		Wo_ExploreNearbyResetSearchSelectionHint();
	}
}

function Wo_ExploreNearbyAbortSuggestionRequest() {
	if (WoExploreNearbyState.searchSuggestionRequest && WoExploreNearbyState.searchSuggestionRequest.readyState !== 4) {
		WoExploreNearbyState.searchSuggestionRequest.abort();
	}

	WoExploreNearbyState.searchSuggestionRequest = null;
}

function Wo_ExploreNearbyCloseSuggestions() {
	WoExploreNearbyState.searchSuggestionToken++;
	Wo_ExploreNearbyAbortSuggestionRequest();
	WoExploreNearbyState.searchSuggestionItems = [];
	WoExploreNearbyState.searchSuggestionActiveIndex = -1;
	$('#explore-nearby-search-suggestions').empty().addClass('wo_explore_nearby_hidden');
}

function Wo_ExploreNearbyDeduplicateSuggestions(items) {
	var uniqueItems = [];
	var lookup = {};

	for (var i = 0; i < items.length; i++) {
		var item = items[i] || {};
		var uniqueKey = [
			item.type || '',
			String(item.search_value || item.location || item.title || '').toLowerCase(),
			String(item.subtitle || '').toLowerCase()
		].join('|');

		if (!uniqueKey || lookup[uniqueKey]) {
			continue;
		}

		lookup[uniqueKey] = true;
		uniqueItems.push(item);
	}

	return uniqueItems;
}

function Wo_ExploreNearbyRenderSuggestionHtml(item, index) {
	var safeType = Wo_ExploreNearbyEscapeHtml(item.type || 'user');
	var decodedTitle = Wo_ExploreNearbyNormalizeTextValue(item.title || '');
	var decodedSubtitle = Wo_ExploreNearbyNormalizeTextValue(item.subtitle || '');
	var decodedLocation = Wo_ExploreNearbyNormalizeTextValue(item.location || '');
	var decodedTypeLabel = Wo_ExploreNearbyNormalizeTextValue(Wo_ExploreNearbyGetSuggestionTypeLabel(item));
	var safeTitle = Wo_ExploreNearbyEscapeHtml(decodedTitle);
	var safeSubtitle = Wo_ExploreNearbyEscapeHtml(decodedSubtitle);
	var safeLocation = Wo_ExploreNearbyEscapeHtml(decodedLocation);
	var safeTypeLabel = Wo_ExploreNearbyEscapeHtml(decodedTypeLabel);
	var avatarHtml = '<span>' + Wo_ExploreNearbyEscapeHtml(Wo_ExploreNearbyGetInitials(decodedTitle || decodedTypeLabel)) + '</span>';
	var activeClass = (index === WoExploreNearbyState.searchSuggestionActiveIndex) ? ' is-active' : '';

	if (item.avatar) {
		avatarHtml = '<img src="' + Wo_ExploreNearbyEscapeHtml(item.avatar) + '" alt="' + safeTitle + '">';
	}
	else if (item.type === 'place') {
		avatarHtml = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2a7 7 0 0 1 7 7c0 4.97-5.06 11.13-6.25 12.52a1 1 0 0 1-1.5 0C10.06 20.13 5 13.97 5 9a7 7 0 0 1 7-7m0 9.5A2.5 2.5 0 1 0 12 6a2.5 2.5 0 0 0 0 5.5"/></svg>';
	}

	return '<button type="button" class="wo_explore_discovery_search_suggestion type-' + safeType + activeClass + '" data-index="' + index + '" onpointerdown="Wo_ExploreNearbyHandleSuggestionSelection(' + index + '); return false;" onmousedown="Wo_ExploreNearbyHandleSuggestionSelection(' + index + '); return false;" ontouchstart="Wo_ExploreNearbyHandleSuggestionSelection(' + index + '); return false;" onclick="return false;">' +
		'<span class="wo_explore_discovery_search_suggestion_media">' + avatarHtml + '</span>' +
		'<span class="wo_explore_discovery_search_suggestion_body">' +
			'<span class="wo_explore_discovery_search_suggestion_title">' + safeTitle + '</span>' +
			(safeSubtitle ? '<span class="wo_explore_discovery_search_suggestion_subtitle">' + safeSubtitle + '</span>' : '') +
			(safeLocation ? '<span class="wo_explore_discovery_search_suggestion_location">' + safeLocation + '</span>' : '') +
		'</span>' +
		'<span class="wo_explore_discovery_search_suggestion_badge">' + safeTypeLabel + '</span>' +
	'</button>';
}

function Wo_ExploreNearbyRenderSuggestions() {
	var container = $('#explore-nearby-search-suggestions');
	var items = WoExploreNearbyState.searchSuggestionItems || [];
	var html = '';

	if (!items.length) {
		container.empty().addClass('wo_explore_nearby_hidden');
		return;
	}

	for (var i = 0; i < items.length; i++) {
		html += Wo_ExploreNearbyRenderSuggestionHtml(items[i], i);
	}

	container.html(html).removeClass('wo_explore_nearby_hidden');
}

function Wo_ExploreNearbySetSuggestionItems(items) {
	var normalizedItems = Wo_ExploreNearbyDeduplicateSuggestions(items || []).slice(0, 8);

	WoExploreNearbyState.searchSuggestionItems = normalizedItems;
	WoExploreNearbyState.searchSuggestionActiveIndex = -1;
	Wo_ExploreNearbyRenderSuggestions();
}

function Wo_ExploreNearbyEnsureSuggestionVisible(index) {
	var container = $('#explore-nearby-search-suggestions');
	var activeItem = container.find('.wo_explore_discovery_search_suggestion').eq(index);

	if (!activeItem.length || typeof activeItem[0].scrollIntoView !== 'function') {
		return;
	}

	activeItem[0].scrollIntoView({
		block: 'nearest'
	});
}

function Wo_ExploreNearbyMoveSuggestion(step) {
	var items = WoExploreNearbyState.searchSuggestionItems || [];
	var nextIndex = 0;

	if (!items.length) {
		return;
	}

	if (WoExploreNearbyState.searchSuggestionActiveIndex < 0) {
		nextIndex = (step < 0) ? (items.length - 1) : 0;
	}
	else {
		nextIndex = WoExploreNearbyState.searchSuggestionActiveIndex + step;
		if (nextIndex < 0) {
			nextIndex = items.length - 1;
		}
		if (nextIndex >= items.length) {
			nextIndex = 0;
		}
	}

	WoExploreNearbyState.searchSuggestionActiveIndex = nextIndex;
	Wo_ExploreNearbyRenderSuggestions();
	Wo_ExploreNearbyEnsureSuggestionVisible(nextIndex);
}

function Wo_ExploreNearbyFetchEntitySuggestions(query) {
	var normalizedQuery = $.trim(query || '');

	if (normalizedQuery.length < 1) {
		return Promise.resolve([]);
	}

	Wo_ExploreNearbyAbortSuggestionRequest();
	WoExploreNearbyState.searchSuggestionRequest = $.ajax({
		url: Wo_Ajax_Requests_File(),
		type: 'GET',
		dataType: 'json',
		data: {
			f: 'explore_nearby_suggestions',
			query: normalizedQuery,
			limit: 4
		}
	});

	return new Promise(function(resolve) {
		WoExploreNearbyState.searchSuggestionRequest.done(function(data) {
			resolve((data && data.status === 200 && Array.isArray(data.items)) ? data.items : []);
		}).fail(function(xhr, status) {
			if (status === 'abort') {
				resolve([]);
				return;
			}

			resolve([]);
		});
	});
}

function Wo_ExploreNearbyFetchLocationSuggestions(query) {
	var normalizedQuery = $.trim(query || '');

	if (normalizedQuery.length < 3) {
		return Promise.resolve([]);
	}

	return Wo_ExploreNearbyEnsureGooglePlacesLibrary().then(function(placesLibrary) {
		var request = {
			input: normalizedQuery
		};

		if (Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng)) {
			request.origin = {
				lat: parseFloat(currentUserMapPoint.lat),
				lng: parseFloat(currentUserMapPoint.lng)
			};
		}

		if (!placesLibrary || !placesLibrary.AutocompleteSuggestion || typeof placesLibrary.AutocompleteSuggestion.fetchAutocompleteSuggestions !== 'function') {
			return null;
		}

		return placesLibrary.AutocompleteSuggestion.fetchAutocompleteSuggestions(request).then(function(response) {
			var items = [];
			var suggestionList = (response && Array.isArray(response.suggestions)) ? response.suggestions : [];

			if (!suggestionList.length) {
				return items;
			}

			items = suggestionList.map(function(suggestion) {
				var placePrediction = suggestion && suggestion.placePrediction ? suggestion.placePrediction : null;
				var fullText = '';
				var mainText = '';
				var secondaryText = '';

				if (!placePrediction) {
					return null;
				}

				fullText = Wo_ExploreNearbyGetGooglePlaceText(placePrediction.text);
				mainText = Wo_ExploreNearbyGetGooglePlaceText(placePrediction.mainText);
				secondaryText = Wo_ExploreNearbyGetGooglePlaceText(placePrediction.secondaryText);

				return {
					type: 'place',
					type_label: defaultPlaceTypeLabel,
					title: $.trim(mainText || fullText || normalizedQuery),
					subtitle: $.trim(secondaryText || ''),
					location: $.trim(fullText || normalizedQuery),
					avatar: '',
					search_value: $.trim(fullText || normalizedQuery),
					place_id: placePrediction.placeId || '',
					place_prediction: placePrediction
				};
			}).filter(function(item) {
				return !!item;
			}).slice(0, 4);

			return items;
		}).catch(function() {
			return null;
		});
	}).then(function(items) {
		if (items !== null) {
			return items;
		}

		if (Wo_ExploreNearbyCanUseGooglePlacesAutocomplete()) {
			if (!WoExploreNearbyState.userGooglePlacesAutocompleteService) {
				WoExploreNearbyState.userGooglePlacesAutocompleteService = new google.maps.places.AutocompleteService();
			}

			return new Promise(function(resolve) {
				WoExploreNearbyState.userGooglePlacesAutocompleteService.getPlacePredictions({
					input: normalizedQuery
				}, function(predictions, status) {
					var legacyItems = [];
					var predictionList = Array.isArray(predictions) ? predictions : [];

					if (status === google.maps.places.PlacesServiceStatus.OK && predictionList.length > 0) {
						legacyItems = predictionList.slice(0, 4).map(function(prediction) {
							return {
								type: 'place',
								type_label: defaultPlaceTypeLabel,
								title: $.trim((prediction.structured_formatting && prediction.structured_formatting.main_text) || prediction.description || normalizedQuery),
								subtitle: '',
								location: $.trim(prediction.description || normalizedQuery),
								avatar: '',
								search_value: $.trim(prediction.description || normalizedQuery),
								place_id: prediction.place_id || ''
							};
						});
					}

					resolve(legacyItems);
				});
			});
		}

		if (Wo_ExploreNearbyCanUseGoogleGeocoder()) {
			if (!WoExploreNearbyState.userGoogleGeocoder) {
				WoExploreNearbyState.userGoogleGeocoder = new google.maps.Geocoder();
			}

			return new Promise(function(resolve) {
				WoExploreNearbyState.userGoogleGeocoder.geocode({
					address: normalizedQuery
				}, function(results, status) {
					var geocodeItems = [];
					var geocodeResults = Array.isArray(results) ? results : [];

					if (status === 'OK' && geocodeResults.length > 0) {
						geocodeItems = geocodeResults.slice(0, 4).map(function(result) {
							var placeItem = null;
							if (result.geometry && result.geometry.location) {
								placeItem = Wo_ExploreNearbyBuildSearchPlaceItem(normalizedQuery, {
									lat: result.geometry.location.lat(),
									lng: result.geometry.location.lng(),
									title: $.trim((result.address_components && result.address_components[0] && result.address_components[0].long_name) || normalizedQuery),
									location: $.trim(result.formatted_address || normalizedQuery)
								});
							}

							return {
								type: 'place',
								type_label: defaultPlaceTypeLabel,
								title: $.trim((result.address_components && result.address_components[0] && result.address_components[0].long_name) || normalizedQuery),
								subtitle: '',
								location: $.trim(result.formatted_address || normalizedQuery),
								avatar: '',
								search_value: $.trim(result.formatted_address || normalizedQuery),
								place_item: placeItem
							};
						});
					}

					resolve(geocodeItems);
				});
			});
		}

		return [];
	});
}

function Wo_ExploreNearbyRequestSuggestions() {
	var query = Wo_ExploreNearbyGetSearchValue();
	var requestToken = ++WoExploreNearbyState.searchSuggestionToken;

	if (query.length < 1) {
		Wo_ExploreNearbyCloseSuggestions();
		return;
	}

	Promise.all([
		Wo_ExploreNearbyFetchEntitySuggestions(query),
		Wo_ExploreNearbyFetchLocationSuggestions(query)
	]).then(function(results) {
		var currentQuery = Wo_ExploreNearbyGetSearchValue();
		var items = [];

		if (requestToken !== WoExploreNearbyState.searchSuggestionToken || currentQuery !== query) {
			return;
		}

		items = items.concat(results[0] || [], results[1] || []);
		Wo_ExploreNearbySetSuggestionItems(items);
	}).catch(function() {
		if (requestToken !== WoExploreNearbyState.searchSuggestionToken) {
			return;
		}

		Wo_ExploreNearbyCloseSuggestions();
	});
}

function Wo_ExploreNearbySelectSuggestion(item) {
	var nextValue = $.trim((item && (item.search_value || item.location || item.title)) || '');
	var normalizedValue = nextValue.toLowerCase();

	if (!item || !nextValue) {
		return;
	}

	clearTimeout(WoExploreNearbyState.searchTimer);
	clearTimeout(WoExploreNearbyState.searchSuggestionTimer);
	$('#nearby-username').val(nextValue);

	if (item.type === 'user' || item.type === 'page') {
		WoExploreNearbyState.searchSelectionHintMode = 'text';
		WoExploreNearbyState.searchSelectionHintQuery = normalizedValue;
		WoExploreNearbyState.searchSelectionHintPlaceId = '';
		WoExploreNearbyState.searchSelectionHintPlacePrediction = null;
	}
	else if (item.type === 'place') {
		WoExploreNearbyState.searchSelectionHintMode = 'location';
		WoExploreNearbyState.searchSelectionHintQuery = normalizedValue;
		WoExploreNearbyState.searchSelectionHintPlaceId = $.trim(item.place_id || '');
		WoExploreNearbyState.searchSelectionHintPlacePrediction = item.place_prediction || null;
	}
	else {
		Wo_ExploreNearbyResetSearchSelectionHint();
	}

	if (item.type === 'place' && item.place_item) {
		WoExploreNearbyState.searchPlaceCache[Wo_ExploreNearbyGetSearchPlaceCacheKey(normalizedValue, item.place_id || '')] = item.place_item;
	}

	Wo_ExploreNearbyCloseSuggestions();
	Wo_ExploreNearbyLoad(false);
}

function Wo_ExploreNearbySelectSuggestionByIndex(index) {
	var items = WoExploreNearbyState.searchSuggestionItems || [];

	if (index < 0 || index >= items.length) {
		return;
	}

	Wo_ExploreNearbySelectSuggestion(items[index]);
}

function Wo_ExploreNearbyHandleSuggestionSelection(index) {
	if (isNaN(index)) {
		return;
	}

	clearTimeout(WoExploreNearbyState.searchSuggestionTimer);
	WoExploreNearbyState.isSuggestionInteraction = true;
	setTimeout(function() {
		WoExploreNearbyState.isSuggestionInteraction = false;
	}, 260);
	WoExploreNearbyState.lastSuggestionSelectionAt = Date.now();
	Wo_ExploreNearbySelectSuggestionByIndex(index);
}

function Wo_ExploreNearbyQueryHasLocationHint(query) {
	var normalizedQuery = $.trim((query || '').toLowerCase());
	var compactQuery = '';
	var locationTokens = [
		' street ',
		' road ',
		' avenue ',
		' boulevard ',
		' lane ',
		' route ',
		' block ',
		' building ',
		' apartment ',
		' floor ',
		' tower ',
		' highway ',
		' thanh pho '
	];
	var i = 0;

	if (normalizedQuery.length < 3 || normalizedQuery.charAt(0) === '@') {
		return false;
	}

	if (/[,#]/.test(normalizedQuery) || /\/\d+/.test(normalizedQuery)) {
		return true;
	}

	if (/(^|\s)\d+[A-Za-z0-9-]*(\s|$)/.test(normalizedQuery) || /\d+\s+[A-Za-z]/.test(normalizedQuery)) {
		return true;
	}

	compactQuery = ' ' + normalizedQuery.replace(/\s+/g, ' ') + ' ';
	for (i = 0; i < locationTokens.length; i++) {
		if (compactQuery.indexOf(locationTokens[i]) !== -1) {
			return true;
		}
	}

	return false;
}

function Wo_ExploreNearbyHasSearchCenter() {
	return WoExploreNearbyState.searchMode === 'location' &&
		Wo_ExploreNearbyHasValidCoordinates(WoExploreNearbyState.searchCenterLat, WoExploreNearbyState.searchCenterLng);
}

function Wo_ExploreNearbyHasLocationAnchor() {
	return Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng) || Wo_ExploreNearbyHasSearchCenter();
}

function Wo_ExploreNearbySyncLocationAnchorState() {
	var hasAnchor = Wo_ExploreNearbyHasLocationAnchor();
	WoExploreNearbyState.hasLocationAnchor = hasAnchor;
	if (hasAnchor) {
		WoExploreNearbyState.locationBootstrapState = 'ready';
	}
	else if (WoExploreNearbyState.locationBootstrapState !== 'denied' && WoExploreNearbyState.locationBootstrapState !== 'waiting') {
		WoExploreNearbyState.locationBootstrapState = 'waiting';
	}

	return hasAnchor;
}

function Wo_ExploreNearbyGetMapPromptTitle() {
	if (WoExploreNearbyState.locationBootstrapState === 'denied') {
		return locationDeniedPromptText;
	}

	return locationEnablePromptText;
}

function Wo_ExploreNearbyGetMapPromptHtml() {
	return '<div class="wo_explore_discovery_map_prompt_card">' +
		'<div class="wo_explore_discovery_map_prompt_icon">' +
			'<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2a7 7 0 0 1 7 7c0 5.25-7 13-7 13S5 14.25 5 9a7 7 0 0 1 7-7m0 4.5A2.5 2.5 0 1 0 12 11.5A2.5 2.5 0 0 0 12 6.5"/></svg>' +
		'</div>' +
		'<div class="wo_explore_discovery_map_prompt_title">' + Wo_ExploreNearbyEscapeHtml(Wo_ExploreNearbyGetMapPromptTitle()) + '</div>' +
		'<div class="wo_explore_discovery_map_prompt_text">' + Wo_ExploreNearbyEscapeHtml(locationSearchHintText) + '</div>' +
		'<button type="button" class="wo_explore_discovery_map_prompt_action" id="explore-nearby-map-prompt-action">' +
			'<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M11 2v2.07A8.001 8.001 0 0 0 4.07 11H2v2h2.07A8.001 8.001 0 0 0 11 19.93V22h2v-2.07A8.001 8.001 0 0 0 19.93 13H22v-2h-2.07A8.001 8.001 0 0 0 13 4.07V2zm1 4a6 6 0 1 1 0 12a6 6 0 0 1 0-12m0 3a3 3 0 1 0 0 6a3 3 0 0 0 0-6"/></svg>' +
			'<span>' + Wo_ExploreNearbyEscapeHtml(useMyLocationLabel) + '</span>' +
		'</button>' +
	'</div>';
}

function Wo_ExploreNearbyUpdateMapPrompt() {
	var prompt = $('#explore-nearby-map-prompt');
	var map = $('#map');
	if (!prompt.length || !map.length) {
		return;
	}

	if (Wo_ExploreNearbySyncLocationAnchorState()) {
		map.removeClass('is-awaiting-location');
		prompt.empty().addClass('wo_explore_nearby_hidden');
		return;
	}

	map.addClass('is-awaiting-location');
	prompt.html(Wo_ExploreNearbyGetMapPromptHtml()).removeClass('wo_explore_nearby_hidden');
}

function Wo_ExploreNearbyGetRequestSearchValue() {
	return Wo_ExploreNearbyHasSearchCenter() ? '' : Wo_ExploreNearbyGetSearchValue();
}

function Wo_ExploreNearbyGetUiMetaText() {
	var metaParts = [];
	var searchValue = Wo_ExploreNearbyGetSearchValue();
	var totalResults = Wo_ExploreNearbyGetTotalResultsCount();

	if (searchValue) {
		metaParts.push('"' + searchValue + '"');
	}

	metaParts.push(totalResults > 0 ? (totalResults + ' nearby') : 'Nearby people and shops');

	return metaParts.join(' - ');
}

function Wo_ExploreNearbyIsCompactViewport() {
	if (window.matchMedia) {
		return window.matchMedia('(max-width: 767px)').matches;
	}

	return $(window).width() <= 767;
}

function Wo_ExploreNearbyGetStageAvailableHeight() {
	return Math.max(460, window.innerHeight - Wo_ExploreNearbyGetStickyHeaderOffset() - 10);
}

function Wo_ExploreNearbyUpdateViewportHeight() {
	var container = $('.wo_explore_discovery').get(0);
	var shellHeight = Wo_ExploreNearbyGetStageAvailableHeight();

	if (container) {
		container.style.setProperty('--wo-nearby-shell-height', shellHeight + 'px');
	}

	return shellHeight;
}

function Wo_ExploreNearbyGetSheetSnapHeights() {
	var stageHeight = $('#explore-nearby-stage').outerHeight() || Wo_ExploreNearbyGetStageAvailableHeight();
	var ratios = Wo_ExploreNearbyIsCompactViewport() ?
		{collapsed: 0.18, medium: 0.44, expanded: 0.78} :
		{collapsed: 0.20, medium: 0.42, expanded: 0.70};
	var heights = {
		collapsed: Math.round(stageHeight * ratios.collapsed),
		medium: Math.round(stageHeight * ratios.medium),
		expanded: Math.round(stageHeight * ratios.expanded)
	};

	heights.expanded = Math.max(320, Math.min(stageHeight - 6, heights.expanded));
	heights.medium = Math.max(240, Math.min(heights.expanded - 72, heights.medium));
	heights.collapsed = Math.max(152, Math.min(heights.medium - 72, heights.collapsed));

	return heights;
}

function Wo_ExploreNearbyGetSheetSnapIndex(mode) {
	return ['collapsed', 'medium', 'expanded'].indexOf(mode);
}

function Wo_ExploreNearbyApplySheetHeight(height, animate) {
	var sheet = $('#explore-nearby-sheet');
	var nextHeight = Math.round(height || 0);

	if (!sheet.length) {
		return;
	}

	if (animate === false) {
		sheet.removeClass('is-animating');
	}
	else {
		sheet.addClass('is-animating');
	}

	sheet.get(0).style.setProperty('--wo-nearby-sheet-height', nextHeight + 'px');
	WoExploreNearbyState.sheetCurrentHeight = nextHeight;
}

function Wo_ExploreNearbyUpdateSheetScrollableState() {
	$('#explore-nearby-sheet-body').toggleClass('is-scrollable', WoExploreNearbyState.sheetSnap !== 'collapsed');
}

function Wo_ExploreNearbySetSheetSnap(mode, animate) {
	var snapHeights = Wo_ExploreNearbyGetSheetSnapHeights();
	var nextMode = snapHeights[mode] ? mode : 'medium';

	WoExploreNearbyState.sheetSnapHeights = snapHeights;
	WoExploreNearbyState.sheetSnap = nextMode;
	$('#explore-nearby-sheet').attr('data-snap', nextMode);
	Wo_ExploreNearbyApplySheetHeight(snapHeights[nextMode], animate);
	Wo_ExploreNearbyUpdateSheetScrollableState();

	if (nextMode === 'collapsed') {
		$('#explore-nearby-sheet-body').scrollTop(0);
	}
}

function Wo_ExploreNearbyEnsureSheetAtLeast(targetMode) {
	if (Wo_ExploreNearbyGetSheetSnapIndex(WoExploreNearbyState.sheetSnap) < Wo_ExploreNearbyGetSheetSnapIndex(targetMode)) {
		Wo_ExploreNearbySetSheetSnap(targetMode, true);
	}
}

function Wo_ExploreNearbyClampSheetHeight(height) {
	var snapHeights = Wo_ExploreNearbyGetSheetSnapHeights();

	return Math.max(snapHeights.collapsed, Math.min(snapHeights.expanded, Math.round(height)));
}

function Wo_ExploreNearbySnapSheetToNearest(height) {
	var snapHeights = Wo_ExploreNearbyGetSheetSnapHeights();
	var nearestMode = 'collapsed';
	var nearestDistance = Number.MAX_VALUE;

	$.each(snapHeights, function(mode, snapHeight) {
		var distance = Math.abs(snapHeight - height);
		if (distance < nearestDistance) {
			nearestDistance = distance;
			nearestMode = mode;
		}
	});

	Wo_ExploreNearbySetSheetSnap(nearestMode, true);
}

function Wo_ExploreNearbyGetPointerClientY(event) {
	var originalEvent = event.originalEvent || event;

	if (originalEvent.touches && originalEvent.touches[0]) {
		return originalEvent.touches[0].clientY;
	}
	if (originalEvent.changedTouches && originalEvent.changedTouches[0]) {
		return originalEvent.changedTouches[0].clientY;
	}
	if (typeof originalEvent.clientY === 'number') {
		return originalEvent.clientY;
	}

	return null;
}

function Wo_ExploreNearbyStartSheetDrag(event) {
	var pointerY = Wo_ExploreNearbyGetPointerClientY(event);

	if ($(event.target).closest('input, textarea, button, a').length || pointerY === null) {
		return;
	}

	WoExploreNearbyState.sheetDragging = true;
	WoExploreNearbyState.sheetDragStartY = pointerY;
	WoExploreNearbyState.sheetDragStartHeight = WoExploreNearbyState.sheetCurrentHeight || Wo_ExploreNearbyGetSheetSnapHeights()[WoExploreNearbyState.sheetSnap] || 0;
	$('body').addClass('wo_explore_discovery_dragging');
	event.preventDefault();
}

function Wo_ExploreNearbyMoveSheetDrag(event) {
	var pointerY = Wo_ExploreNearbyGetPointerClientY(event);
	var delta = 0;

	if (!WoExploreNearbyState.sheetDragging || pointerY === null) {
		return;
	}

	delta = WoExploreNearbyState.sheetDragStartY - pointerY;
	Wo_ExploreNearbyApplySheetHeight(Wo_ExploreNearbyClampSheetHeight(WoExploreNearbyState.sheetDragStartHeight + delta), false);
	event.preventDefault();
}

function Wo_ExploreNearbyEndSheetDrag() {
	if (!WoExploreNearbyState.sheetDragging) {
		return;
	}

	WoExploreNearbyState.sheetDragging = false;
	$('body').removeClass('wo_explore_discovery_dragging');
	Wo_ExploreNearbySnapSheetToNearest(WoExploreNearbyState.sheetCurrentHeight || Wo_ExploreNearbyGetSheetSnapHeights()[WoExploreNearbyState.sheetSnap] || 0);
}

function Wo_ExploreNearbyBindSheetInteractions() {
	if (WoExploreNearbyState.sheetBindingsReady) {
		return;
	}

	$(document).on('mousedown touchstart', '#explore-nearby-sheet-handle, #explore-nearby-sheet-header', Wo_ExploreNearbyStartSheetDrag);
	$(document).on('mousemove touchmove', Wo_ExploreNearbyMoveSheetDrag);
	$(document).on('mouseup touchend touchcancel', Wo_ExploreNearbyEndSheetDrag);
	WoExploreNearbyState.sheetBindingsReady = true;
}

function Wo_ExploreNearbyHasMoreResults() {
	return (WoExploreNearbyState.usersEnabled && (WoExploreNearbyState.usersItems || []).length < (WoExploreNearbyState.usersCount || 0)) ||
		(WoExploreNearbyState.shopsEnabled && (WoExploreNearbyState.shopsItems || []).length < (WoExploreNearbyState.shopsCount || 0));
}

function Wo_ExploreNearbyUpdateInfiniteScrollState() {
	var sentinel = $('#explore-nearby-load-sentinel');
	var hasMore = Wo_ExploreNearbyHasMoreResults();

	WoExploreNearbyState.hasMoreResults = hasMore;
	sentinel.toggleClass('is-loading', !!WoExploreNearbyState.appendInProgress);
	sentinel.toggleClass('is-hidden', !hasMore && !WoExploreNearbyState.appendInProgress);
	sentinel.text(WoExploreNearbyState.appendInProgress ? 'Loading more nearby results' : (hasMore ? 'Drag up or scroll for more results' : ''));
}

function Wo_ExploreNearbyMaybeLoadMore() {
	if (WoExploreNearbyState.sheetSnap === 'collapsed' || !WoExploreNearbyState.hasMoreResults || WoExploreNearbyState.appendInProgress) {
		return;
	}

	Wo_ExploreNearbyLoadMore();
}

function Wo_ExploreNearbyBindInfiniteScroll() {
	var body = document.getElementById('explore-nearby-sheet-body');
	var sentinel = document.getElementById('explore-nearby-load-sentinel');

	if (WoExploreNearbyState.sheetObserverReady || !body || !sentinel) {
		return;
	}

	if ('IntersectionObserver' in window) {
		WoExploreNearbyState.sheetObserver = new IntersectionObserver(function(entries) {
			if (entries[0] && entries[0].isIntersecting) {
				Wo_ExploreNearbyMaybeLoadMore();
			}
		}, {
			root: body,
			rootMargin: '160px 0px 220px 0px'
		});
		WoExploreNearbyState.sheetObserver.observe(sentinel);
	}

	$(body).on('scroll.exploreNearby', function() {
		if ('IntersectionObserver' in window) {
			return;
		}

		if (this.scrollTop + this.clientHeight >= this.scrollHeight - 160) {
			Wo_ExploreNearbyMaybeLoadMore();
		}
	});

	WoExploreNearbyState.sheetObserverReady = true;
}

function Wo_ExploreNearbyRefreshMapSize() {
	if (WoExploreNearbyMapState.provider === 'leaflet' && WoExploreNearbyMapState.map && typeof WoExploreNearbyMapState.map.invalidateSize === 'function') {
		WoExploreNearbyMapState.map.invalidateSize();
		return;
	}

	if (WoExploreNearbyMapState.provider === 'google' && WoExploreNearbyMapState.map && typeof google !== 'undefined' && google.maps && google.maps.event) {
		google.maps.event.trigger(WoExploreNearbyMapState.map, 'resize');
	}
}

function Wo_ExploreNearbyGetInitials(title) {
	var text = $.trim(title || '');
	if (!text) {
		return '?';
	}

	var parts = text.split(/\s+/);
	if (parts.length === 1) {
		return parts[0].slice(0, 1).toUpperCase();
	}

	return (parts[0].slice(0, 1) + parts[1].slice(0, 1)).toUpperCase();
}

function Wo_ExploreNearbyFormatCoordinateText(text) {
	var value = $.trim(text || '');
	var coordinateMatch = value.match(/^(-?\d+(?:\.\d+)?)\s*,\s*(-?\d+(?:\.\d+)?)(?:\s*,.*)?$/);
	if (!coordinateMatch) {
		return value;
	}

	return coordinateMatch[1].slice(0, 10) + ',' + coordinateMatch[2].slice(0, 10) + '...';
}

function Wo_ExploreNearbyCanUseGoogleGeocoder() {
	return typeof google !== 'undefined' &&
		google.maps &&
		typeof google.maps.Geocoder === 'function';
}

function Wo_ExploreNearbyGetGoogleGeocoder() {
	if (!Wo_ExploreNearbyCanUseGoogleGeocoder()) {
		return null;
	}

	if (!WoExploreNearbyState.userGoogleGeocoder) {
		WoExploreNearbyState.userGoogleGeocoder = new google.maps.Geocoder();
	}

	return WoExploreNearbyState.userGoogleGeocoder;
}

function Wo_ExploreNearbyCanUseLegacyPlacesService() {
	return typeof google !== 'undefined' &&
		google.maps &&
		google.maps.places &&
		typeof google.maps.places.PlacesService === 'function';
}

function Wo_ExploreNearbyGetLegacyPlacesService() {
	if (!Wo_ExploreNearbyCanUseLegacyPlacesService()) {
		return null;
	}

	if (WoExploreNearbyState.userGooglePlacesService) {
		return WoExploreNearbyState.userGooglePlacesService;
	}

	if (WoExploreNearbyMapState.provider === 'google' && WoExploreNearbyMapState.map) {
		WoExploreNearbyState.userGooglePlacesService = new google.maps.places.PlacesService(WoExploreNearbyMapState.map);
		return WoExploreNearbyState.userGooglePlacesService;
	}

	if (!WoExploreNearbyState.userGooglePlacesServiceNode) {
		WoExploreNearbyState.userGooglePlacesServiceNode = document.createElement('div');
	}

	WoExploreNearbyState.userGooglePlacesService = new google.maps.places.PlacesService(WoExploreNearbyState.userGooglePlacesServiceNode);
	return WoExploreNearbyState.userGooglePlacesService;
}

function Wo_ExploreNearbyGetGoogleLatLngValue(value, axis) {
	if (!value) {
		return null;
	}

	if (typeof value[axis] === 'function') {
		return parseFloat(value[axis]());
	}

	if (value[axis] !== undefined && value[axis] !== null && value[axis] !== '') {
		return parseFloat(value[axis]);
	}

	return null;
}

function Wo_ExploreNearbyResolvePlacePrediction(placePrediction, query, fallbackLocation) {
	var normalizedQuery = $.trim(query || '');
	var fallbackLabel = $.trim(fallbackLocation || normalizedQuery);
	var predictionText = Wo_ExploreNearbyGetGooglePlaceText(placePrediction && placePrediction.text);
	var predictionMainText = Wo_ExploreNearbyGetGooglePlaceText(placePrediction && placePrediction.mainText);

	if (!placePrediction || typeof placePrediction.toPlace !== 'function') {
		return Promise.resolve(null);
	}

	try {
		var predictedPlace = placePrediction.toPlace();
		if (!predictedPlace || typeof predictedPlace.fetchFields !== 'function') {
			return Promise.resolve(null);
		}

		return predictedPlace.fetchFields({
			fields: ['displayName', 'formattedAddress', 'location']
		}).then(function() {
			var lat = Wo_ExploreNearbyGetGoogleLatLngValue(predictedPlace.location, 'lat');
			var lng = Wo_ExploreNearbyGetGoogleLatLngValue(predictedPlace.location, 'lng');

			return Wo_ExploreNearbyBuildSearchPlaceItem(normalizedQuery, {
				lat: lat,
				lng: lng,
				title: Wo_ExploreNearbyGetGooglePlaceText(predictedPlace.displayName) || predictionMainText || fallbackLabel || normalizedQuery,
				location: $.trim(predictedPlace.formattedAddress || predictionText || fallbackLabel || normalizedQuery)
			});
		}).catch(function() {
			return null;
		});
	}
	catch (error) {
		return Promise.resolve(null);
	}
}

function Wo_ExploreNearbyResolvePlaceById(placeId, query, fallbackLocation, placePrediction) {
	var normalizedPlaceId = $.trim(placeId || '');
	var normalizedQuery = $.trim(query || '');
	var fallbackLabel = $.trim(fallbackLocation || normalizedQuery);

	if (!normalizedPlaceId) {
		return Wo_ExploreNearbyResolvePlacePrediction(placePrediction, normalizedQuery, fallbackLabel);
	}

	return Wo_ExploreNearbyResolvePlacePrediction(placePrediction, normalizedQuery, fallbackLabel).then(function(placeItem) {
		if (placeItem) {
			return placeItem;
		}

		return Wo_ExploreNearbyEnsureGooglePlacesLibrary().then(function(placesLibrary) {
		if (!placesLibrary || typeof placesLibrary.Place !== 'function') {
			return null;
		}

		var modernPlace = null;

		try {
			modernPlace = new placesLibrary.Place({
				id: normalizedPlaceId
			});
		}
		catch (error) {
			modernPlace = null;
		}

		if (!modernPlace || typeof modernPlace.fetchFields !== 'function') {
			return null;
		}

		return modernPlace.fetchFields({
			fields: ['displayName', 'formattedAddress', 'location']
		}).then(function() {
			var lat = Wo_ExploreNearbyGetGoogleLatLngValue(modernPlace.location, 'lat');
			var lng = Wo_ExploreNearbyGetGoogleLatLngValue(modernPlace.location, 'lng');

			return Wo_ExploreNearbyBuildSearchPlaceItem(normalizedQuery, {
				lat: lat,
				lng: lng,
				title: Wo_ExploreNearbyGetGooglePlaceText(modernPlace.displayName) || fallbackLabel || normalizedQuery,
				location: $.trim(modernPlace.formattedAddress || fallbackLabel || normalizedQuery)
			});
		}).catch(function() {
			return null;
		});
		});
	}).then(function(placeItem) {
		if (placeItem) {
			return placeItem;
		}

		var legacyPlacesService = Wo_ExploreNearbyGetLegacyPlacesService();
		if (!legacyPlacesService) {
			return null;
		}

		return new Promise(function(resolve) {
			legacyPlacesService.getDetails({
				placeId: normalizedPlaceId,
				fields: ['name', 'formatted_address', 'geometry']
			}, function(result, status) {
				var geometryLocation = result && result.geometry ? result.geometry.location : null;
				var lat = Wo_ExploreNearbyGetGoogleLatLngValue(geometryLocation, 'lat');
				var lng = Wo_ExploreNearbyGetGoogleLatLngValue(geometryLocation, 'lng');

				if (status !== google.maps.places.PlacesServiceStatus.OK || !result || !geometryLocation) {
					resolve(null);
					return;
				}

				resolve(Wo_ExploreNearbyBuildSearchPlaceItem(normalizedQuery, {
					lat: lat,
					lng: lng,
					title: $.trim(result.name || fallbackLabel || normalizedQuery),
					location: $.trim(result.formatted_address || fallbackLabel || normalizedQuery)
				}));
			});
		});
	}).catch(function() {
		return null;
	});
}

function Wo_ExploreNearbyReverseGeocodeCoordinates(lat, lng) {
	if (!Wo_ExploreNearbyHasValidCoordinates(lat, lng)) {
		return Promise.resolve('');
	}

	var numericLat = parseFloat(lat);
	var numericLng = parseFloat(lng);
	var cacheKey = numericLat.toFixed(6) + ',' + numericLng.toFixed(6);
	var fallbackText = Wo_ExploreNearbyBuildCoordinateText(numericLat, numericLng);

	if (Object.prototype.hasOwnProperty.call(WoExploreNearbyState.userReverseGeocodeCache, cacheKey)) {
		return Promise.resolve(WoExploreNearbyState.userReverseGeocodeCache[cacheKey] || fallbackText);
	}

	if (WoExploreNearbyState.userReverseGeocodePending[cacheKey]) {
		return WoExploreNearbyState.userReverseGeocodePending[cacheKey];
	}

	var resolvePromise = null;
	if (Wo_ExploreNearbyGetGoogleGeocoder()) {
		resolvePromise = new Promise(function(resolve) {
			Wo_ExploreNearbyGetGoogleGeocoder().geocode({
				location: {
					lat: numericLat,
					lng: numericLng
				}
			}, function(results, status) {
				var addressText = '';
				if (status === 'OK' && Array.isArray(results) && results[0]) {
					addressText = $.trim(results[0].formatted_address || '');
				}
				resolve(addressText);
			});
		});
	}
	else {
		resolvePromise = Promise.resolve('');
	}

	WoExploreNearbyState.userReverseGeocodePending[cacheKey] = resolvePromise.then(function(addressText) {
		var normalizedAddress = $.trim(addressText || '') || fallbackText;
		WoExploreNearbyState.userReverseGeocodeCache[cacheKey] = normalizedAddress;
		delete WoExploreNearbyState.userReverseGeocodePending[cacheKey];
		return normalizedAddress;
	}).catch(function() {
		WoExploreNearbyState.userReverseGeocodeCache[cacheKey] = fallbackText;
		delete WoExploreNearbyState.userReverseGeocodePending[cacheKey];
		return fallbackText;
	});

	return WoExploreNearbyState.userReverseGeocodePending[cacheKey];
}

function Wo_ExploreNearbyBuildSearchPlaceItem(query, result) {
	if (!result) {
		return null;
	}

	var lat = parseFloat(result.lat);
	var lng = parseFloat(result.lng);
	if (!Wo_ExploreNearbyHasValidCoordinates(lat, lng)) {
		return null;
	}

	var title = $.trim(result.title || result.name || query || '');
	var location = $.trim(result.location || result.formatted_address || query || '');
	var distanceValue = null;

	if (Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng)) {
		distanceValue = Wo_ExploreNearbyGetDistanceKm(
			{lat: parseFloat(currentUserMapPoint.lat), lng: parseFloat(currentUserMapPoint.lng)},
			{lat: lat, lng: lng}
		);
	}

	return {
		item_key: 'place|' + encodeURIComponent((query || location || title).toLowerCase()) + '|' + lat.toFixed(5) + ',' + lng.toFixed(5),
		offset_id: 0,
		type: 'place',
		type_label: defaultPlaceTypeLabel,
		title: title || location || query || defaultPlaceTypeLabel,
		subtitle: defaultPlaceTypeLabel,
		description: '',
		avatar: '',
		url: '',
		ajax_url: '',
		location: location || title || query || '',
		location_dynamic: '',
		distance_value: distanceValue,
		distance_text: Wo_ExploreNearbyFormatDistance(distanceValue),
		lat: lat,
		lng: lng,
		is_self: false
	};
}

function Wo_ExploreNearbyGeocodeSearchPlace(query, placeId, placePrediction) {
	var normalizedQuery = $.trim(query || '');
	var normalizedPlaceId = $.trim(placeId || '');
	var cacheKey = Wo_ExploreNearbyGetSearchPlaceCacheKey(normalizedQuery, normalizedPlaceId);

	if (normalizedQuery.length < 3) {
		return Promise.resolve(null);
	}

	if (Object.prototype.hasOwnProperty.call(WoExploreNearbyState.searchPlaceCache, cacheKey)) {
		return Promise.resolve(WoExploreNearbyState.searchPlaceCache[cacheKey]);
	}

	if (WoExploreNearbyState.searchPlacePending[cacheKey]) {
		return WoExploreNearbyState.searchPlacePending[cacheKey];
	}

	var geocodePromise = null;
	if (normalizedPlaceId) {
		geocodePromise = Wo_ExploreNearbyResolvePlaceById(normalizedPlaceId, normalizedQuery, normalizedQuery, placePrediction).then(function(placeItem) {
			if (placeItem) {
				return placeItem;
			}

			if (!Wo_ExploreNearbyGetGoogleGeocoder()) {
				return null;
			}

			return new Promise(function(resolve) {
				Wo_ExploreNearbyGetGoogleGeocoder().geocode({
					placeId: normalizedPlaceId
				}, function(results, status) {
					var geocodeResult = null;
					if (status === 'OK' && Array.isArray(results) && results[0] && results[0].geometry && results[0].geometry.location) {
						geocodeResult = {
							lat: results[0].geometry.location.lat(),
							lng: results[0].geometry.location.lng(),
							title: $.trim((results[0].address_components && results[0].address_components[0] && results[0].address_components[0].long_name) || normalizedQuery),
							location: $.trim(results[0].formatted_address || normalizedQuery)
						};
					}
					resolve(Wo_ExploreNearbyBuildSearchPlaceItem(normalizedQuery, geocodeResult));
				});
			});
		});
	}
	else if (placePrediction) {
		geocodePromise = Wo_ExploreNearbyResolvePlacePrediction(placePrediction, normalizedQuery, normalizedQuery).then(function(placeItem) {
			if (placeItem) {
				return placeItem;
			}

			if (!Wo_ExploreNearbyGetGoogleGeocoder()) {
				return null;
			}

			return new Promise(function(resolve) {
				Wo_ExploreNearbyGetGoogleGeocoder().geocode({
					address: normalizedQuery
				}, function(results, status) {
					var geocodeResult = null;
					if (status === 'OK' && Array.isArray(results) && results[0] && results[0].geometry && results[0].geometry.location) {
						geocodeResult = {
							lat: results[0].geometry.location.lat(),
							lng: results[0].geometry.location.lng(),
							title: $.trim((results[0].address_components && results[0].address_components[0] && results[0].address_components[0].long_name) || normalizedQuery),
							location: $.trim(results[0].formatted_address || normalizedQuery)
						};
					}
					resolve(Wo_ExploreNearbyBuildSearchPlaceItem(normalizedQuery, geocodeResult));
				});
			});
		});
	}
	else if (Wo_ExploreNearbyGetGoogleGeocoder()) {
		geocodePromise = new Promise(function(resolve) {
			Wo_ExploreNearbyGetGoogleGeocoder().geocode({
				address: normalizedQuery
			}, function(results, status) {
				var geocodeResult = null;
				if (status === 'OK' && Array.isArray(results) && results[0] && results[0].geometry && results[0].geometry.location) {
					geocodeResult = {
						lat: results[0].geometry.location.lat(),
						lng: results[0].geometry.location.lng(),
						title: $.trim((results[0].address_components && results[0].address_components[0] && results[0].address_components[0].long_name) || normalizedQuery),
						location: $.trim(results[0].formatted_address || normalizedQuery)
					};
				}
				resolve(Wo_ExploreNearbyBuildSearchPlaceItem(normalizedQuery, geocodeResult));
			});
		});
	}
	else {
		geocodePromise = Promise.resolve(null);
	}

	WoExploreNearbyState.searchPlacePending[cacheKey] = geocodePromise.then(function(placeItem) {
		WoExploreNearbyState.searchPlaceCache[cacheKey] = placeItem;
		delete WoExploreNearbyState.searchPlacePending[cacheKey];
		return placeItem;
	}).catch(function() {
		WoExploreNearbyState.searchPlaceCache[cacheKey] = null;
		delete WoExploreNearbyState.searchPlacePending[cacheKey];
		return null;
	});

	return WoExploreNearbyState.searchPlacePending[cacheKey];
}

function Wo_ExploreNearbySetSearchPlaceItem(item) {
	var currentKey = Wo_ExploreNearbyGetItemKey(WoExploreNearbyState.searchPlaceItem);
	var nextKey = Wo_ExploreNearbyGetItemKey(item);
	var currentLocation = Wo_ExploreNearbyNormalizeTextValue((WoExploreNearbyState.searchPlaceItem && WoExploreNearbyState.searchPlaceItem.location) || '');
	var nextLocation = Wo_ExploreNearbyNormalizeTextValue((item && item.location) || '');
	var hasChanged = currentKey !== nextKey || currentLocation !== nextLocation;

	WoExploreNearbyState.searchPlaceItem = item || null;

	return hasChanged;
}

function Wo_ExploreNearbySetSearchContext(mode, item) {
	var nextMode = (mode === 'location') ? 'location' : 'text';
	var nextItem = item || null;
	var nextLat = null;
	var nextLng = null;
	var nextLabel = '';
	var hasChanged = false;

	if (nextMode === 'location' && nextItem && Wo_ExploreNearbyHasValidCoordinates(nextItem.lat, nextItem.lng)) {
		nextLat = parseFloat(nextItem.lat);
		nextLng = parseFloat(nextItem.lng);
		nextLabel = Wo_ExploreNearbyNormalizeTextValue(nextItem.location || nextItem.title || '');
	}
	else {
		nextMode = 'text';
		nextItem = null;
	}

	hasChanged = Wo_ExploreNearbySetSearchPlaceItem(nextItem) || hasChanged;
	if (WoExploreNearbyState.searchMode !== nextMode) {
		hasChanged = true;
	}
	if (WoExploreNearbyState.searchCenterLat !== nextLat) {
		hasChanged = true;
	}
	if (WoExploreNearbyState.searchCenterLng !== nextLng) {
		hasChanged = true;
	}
	if ((WoExploreNearbyState.searchCenterLabel || '') !== nextLabel) {
		hasChanged = true;
	}

	WoExploreNearbyState.searchMode = nextMode;
	WoExploreNearbyState.searchCenterLat = nextLat;
	WoExploreNearbyState.searchCenterLng = nextLng;
	WoExploreNearbyState.searchCenterLabel = nextLabel;
	if (nextMode === 'location' && Wo_ExploreNearbyHasValidCoordinates(nextLat, nextLng)) {
		nearbyMapCenter.lat = parseFloat(nextLat);
		nearbyMapCenter.lng = parseFloat(nextLng);
	}
	else if (!Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng) && WoExploreNearbyState.locationBootstrapState !== 'denied') {
		WoExploreNearbyState.locationBootstrapState = 'waiting';
	}
	Wo_ExploreNearbySyncLocationAnchorState();

	return hasChanged;
}

function Wo_ExploreNearbyClearSearchPlaceSelection() {
	var hasChanged = Wo_ExploreNearbySetSearchContext('text', null);
	if (WoExploreNearbyState.pendingFocusPointKey) {
		hasChanged = true;
	}
	WoExploreNearbyState.pendingFocusPointKey = null;
	if (Wo_ExploreNearbyIsPlacePointKey(WoExploreNearbyState.activePointKey)) {
		WoExploreNearbyState.activePointKey = null;
		hasChanged = true;
	}
	if (Wo_ExploreNearbyIsPlacePointKey(WoExploreNearbyState.openPopupPointKey)) {
		WoExploreNearbyState.openPopupPointKey = null;
		hasChanged = true;
	}

	return hasChanged;
}

function Wo_ExploreNearbyRenderResolvedSearchPlace() {
	Wo_ExploreNearbyUpdateUi();
	Wo_ExploreNearbyRenderCurrentMap(WoExploreNearbyState.openPopupPointKey || null);
}

function Wo_ExploreNearbyResolveSearchPlace(loadToken) {
	var query = Wo_ExploreNearbyGetSearchValue();
	var normalizedQuery = $.trim(query).toLowerCase();
	var selectedPlaceId = '';
	var selectedPlacePrediction = null;

	Wo_ExploreNearbySyncSearchSelectionHint();
	selectedPlaceId = $.trim(WoExploreNearbyState.searchSelectionHintPlaceId || '');
	selectedPlacePrediction = WoExploreNearbyState.searchSelectionHintPlacePrediction || null;

	function resolveAndApplyPlace(placePromise) {
		return placePromise.then(function(placeItem) {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return null;
			}

			if (placeItem) {
				Wo_ExploreNearbySetSearchContext('location', placeItem);
				WoExploreNearbyState.activePointKey = Wo_ExploreNearbyGetItemKey(placeItem);
				WoExploreNearbyState.openPopupPointKey = null;
				WoExploreNearbyState.pendingFocusPointKey = WoExploreNearbyState.activePointKey;
				Wo_ExploreNearbyRenderResolvedSearchPlace();
				return placeItem;
			}

			if (Wo_ExploreNearbyClearSearchPlaceSelection()) {
				Wo_ExploreNearbyRenderResolvedSearchPlace();
			}
			return null;
		}).catch(function() {
			if (loadToken !== WoExploreNearbyState.loadToken) {
				return null;
			}

			if (Wo_ExploreNearbyClearSearchPlaceSelection()) {
				Wo_ExploreNearbyRenderResolvedSearchPlace();
			}
			return null;
		});
	}

	if (normalizedQuery && normalizedQuery === WoExploreNearbyState.searchSelectionHintQuery && WoExploreNearbyState.searchSelectionHintMode === 'text') {
		if (Wo_ExploreNearbyClearSearchPlaceSelection()) {
			Wo_ExploreNearbyRenderResolvedSearchPlace();
		}
		return Promise.resolve(null);
	}

	if (normalizedQuery && normalizedQuery === WoExploreNearbyState.searchSelectionHintQuery && WoExploreNearbyState.searchSelectionHintMode === 'location') {
		return resolveAndApplyPlace(Wo_ExploreNearbyGeocodeSearchPlace(query, selectedPlaceId, selectedPlacePrediction));
	}

	if ($.trim(query).length < 3 || !Wo_ExploreNearbyQueryHasLocationHint(query)) {
		if (Wo_ExploreNearbyClearSearchPlaceSelection()) {
			Wo_ExploreNearbyRenderResolvedSearchPlace();
		}
		return Promise.resolve(null);
	}

	return resolveAndApplyPlace(Wo_ExploreNearbyGeocodeSearchPlace(query));
}

function Wo_ExploreNearbyRefreshCurrentUserDynamicLocation() {
	if (!Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng)) {
		return;
	}

	Wo_ExploreNearbyReverseGeocodeCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng).then(function(addressText) {
		if (!addressText) {
			return;
		}

		currentUserMapPoint.location = addressText;
		currentUserMapPoint.location_dynamic = addressText;
	});
}

function Wo_ExploreNearbyRefreshDynamicUserLocations(shouldRefreshMap) {
	var normalizedUsers = Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.usersItems || []);
	var refreshToken = ++WoExploreNearbyState.dynamicLocationRefreshToken;
	var requests = [];

	for (var i = 0; i < normalizedUsers.length; i++) {
		if (normalizedUsers[i].type !== 'user' || !Wo_ExploreNearbyHasValidCoordinates(normalizedUsers[i].lat, normalizedUsers[i].lng)) {
			continue;
		}

		(function(itemKey, lat, lng) {
			requests.push(Wo_ExploreNearbyReverseGeocodeCoordinates(lat, lng).then(function(addressText) {
				return {
					item_key: itemKey,
					location: addressText
				};
			}));
		})(normalizedUsers[i].item_key, normalizedUsers[i].lat, normalizedUsers[i].lng);
	}

	if (!requests.length) {
		Wo_ExploreNearbyRefreshCurrentUserDynamicLocation();
		return;
	}

	Promise.all(requests).then(function(results) {
		if (refreshToken !== WoExploreNearbyState.dynamicLocationRefreshToken) {
			return;
		}

		var locationLookup = {};
		var hasChanged = false;
		for (var resultIndex = 0; resultIndex < results.length; resultIndex++) {
			if (results[resultIndex] && results[resultIndex].item_key && results[resultIndex].location) {
				locationLookup[results[resultIndex].item_key] = results[resultIndex].location;
			}
		}

		WoExploreNearbyState.usersItems = normalizedUsers.map(function(item) {
			var nextLocation = locationLookup[item.item_key] || item.location;
			if (nextLocation && item.location !== nextLocation) {
				hasChanged = true;
			}

			return $.extend({}, item, {
				location: nextLocation,
				location_dynamic: nextLocation || item.location_dynamic || ''
			});
		});

		Wo_ExploreNearbyRefreshCurrentUserDynamicLocation();
		if (!hasChanged) {
			return;
		}

		Wo_ExploreNearbyRenderList();
		if (shouldRefreshMap !== false) {
			Wo_ExploreNearbyRenderCurrentMap(WoExploreNearbyState.openPopupPointKey || null);
		}
	});
}

function Wo_ExploreNearbyGetDirectionsUrl(point) {
	var location = $.trim((point && point.location) || '');
	var lat = parseFloat(point && point.lat);
	var lng = parseFloat(point && point.lng);

	if (!isNaN(lat) && !isNaN(lng) && (lat !== 0 || lng !== 0)) {
		return 'https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(lat + ',' + lng) + '&travelmode=driving';
	}
	if (location) {
		return 'https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(location) + '&travelmode=driving';
	}

	return 'https://www.google.com/maps/dir/?api=1';
}

function Wo_ExploreNearbyIsMobileSheetViewport() {
	return Wo_ExploreNearbyIsCompactViewport();
}

function Wo_ExploreNearbyShouldUseMobileSheet(point) {
	return false;
}

function Wo_ExploreNearbyShouldOpenMarkerPopup(point) {
	return !Wo_ExploreNearbyIsCompactViewport() && point && !point.isSelf;
}

function Wo_ExploreNearbyNormalizeHeading(heading) {
	var numericHeading = parseFloat(heading);
	if (isNaN(numericHeading)) {
		return null;
	}

	numericHeading = numericHeading % 360;
	if (numericHeading < 0) {
		numericHeading += 360;
	}

	return numericHeading;
}

function Wo_ExploreNearbyGetScreenRotationAngle() {
	if (window.screen && window.screen.orientation && typeof window.screen.orientation.angle === 'number') {
		return Wo_ExploreNearbyNormalizeHeading(window.screen.orientation.angle) || 0;
	}

	if (typeof window.orientation === 'number') {
		return Wo_ExploreNearbyNormalizeHeading(window.orientation) || 0;
	}

	return 0;
}

function Wo_ExploreNearbyExtractDeviceHeading(event) {
	if (!event) {
		return null;
	}

	if (typeof event.webkitCompassHeading === 'number' && !isNaN(event.webkitCompassHeading)) {
		return Wo_ExploreNearbyNormalizeHeading(event.webkitCompassHeading);
	}

	if (typeof event.alpha === 'number' && !isNaN(event.alpha)) {
		return Wo_ExploreNearbyNormalizeHeading(360 - event.alpha);
	}

	return null;
}

function Wo_ExploreNearbyGetCurrentUserPoint() {
	var normalizedPoints = Wo_ExploreNearbyNormalizePoints([currentUserMapPoint]);
	return normalizedPoints.length ? normalizedPoints[0] : null;
}

function Wo_ExploreNearbyGetRenderedPointByKey(pointKey) {
	var renderedPoints = WoExploreNearbyMapState.renderedPoints || [];
	for (var i = 0; i < renderedPoints.length; i++) {
		if (Wo_ExploreNearbyGetItemKey(renderedPoints[i]) === pointKey) {
			return renderedPoints[i];
		}
	}

	return null;
}

function Wo_ExploreNearbyRefreshSelfMarker() {
	var selfPoint = Wo_ExploreNearbyGetCurrentUserPoint();
	if (!selfPoint) {
		return;
	}

	var selfPointKey = Wo_ExploreNearbyGetItemKey(selfPoint);
	if (WoExploreNearbyMapState.provider === 'google') {
		var googleMarker = WoExploreNearbyMapState.googleMarkerLookup[selfPointKey] || null;
		if (googleMarker) {
			googleMarker.woNearbyPoint = selfPoint;
			googleMarker.setPosition({
				lat: selfPoint.lat,
				lng: selfPoint.lng
			});
			googleMarker.setIcon(Wo_ExploreNearbyCreateGoogleMarkerIcon(selfPoint));
			return;
		}
	}

	if (WoExploreNearbyMapState.provider === 'leaflet') {
		var leafletMarker = WoExploreNearbyMapState.leafletMarkerLookup[selfPointKey] || null;
		if (leafletMarker) {
			leafletMarker.woNearbyPoint = selfPoint;
			leafletMarker.setLatLng([selfPoint.lat, selfPoint.lng]);
			leafletMarker.setIcon(Wo_ExploreNearbyCreateLeafletMarkerIcon(selfPoint));
		}
	}
}

function Wo_ExploreNearbySetDeviceHeading(heading, source) {
	var normalizedHeading = Wo_ExploreNearbyNormalizeHeading(heading);
	if (normalizedHeading === null) {
		return;
	}

	if (source === 'screen' && WoExploreNearbyState.deviceHeadingSource === 'device') {
		return;
	}

	if (WoExploreNearbyState.deviceHeadingSource === source && WoExploreNearbyState.deviceHeading !== null && Math.abs(WoExploreNearbyState.deviceHeading - normalizedHeading) < 1) {
		return;
	}

	WoExploreNearbyState.deviceHeading = normalizedHeading;
	WoExploreNearbyState.deviceHeadingSource = source || 'screen';
	currentUserMapPoint.heading = normalizedHeading;
	Wo_ExploreNearbyRefreshSelfMarker();
}

function Wo_ExploreNearbyBindDeviceOrientationTracking() {
	if (WoExploreNearbyState.deviceOrientationBound || typeof window.DeviceOrientationEvent === 'undefined') {
		return;
	}

	window.addEventListener('deviceorientation', function(event) {
		var heading = Wo_ExploreNearbyExtractDeviceHeading(event);
		if (heading !== null) {
			Wo_ExploreNearbySetDeviceHeading(heading, 'device');
		}
	}, true);
	WoExploreNearbyState.deviceOrientationBound = true;
}

function Wo_ExploreNearbyBindScreenOrientationTracking() {
	if (WoExploreNearbyState.screenOrientationBound) {
		return;
	}

	var handleScreenRotationChange = function() {
		if (WoExploreNearbyState.deviceHeadingSource === 'device') {
			Wo_ExploreNearbyRefreshSelfMarker();
			return;
		}

		Wo_ExploreNearbySetDeviceHeading(Wo_ExploreNearbyGetScreenRotationAngle(), 'screen');
	};

	window.addEventListener('orientationchange', handleScreenRotationChange, true);
	if (window.screen && window.screen.orientation && typeof window.screen.orientation.addEventListener === 'function') {
		window.screen.orientation.addEventListener('change', handleScreenRotationChange);
	}

	WoExploreNearbyState.screenOrientationBound = true;
	handleScreenRotationChange();
}

function Wo_ExploreNearbyEnsureOrientationPermissionPrompt() {
	if (WoExploreNearbyState.deviceOrientationPrompted || typeof window.DeviceOrientationEvent === 'undefined' || typeof window.DeviceOrientationEvent.requestPermission !== 'function') {
		return;
	}

	WoExploreNearbyState.deviceOrientationPrompted = true;
	$(document).one('click touchstart', function() {
		window.DeviceOrientationEvent.requestPermission().then(function(permissionState) {
			if (permissionState === 'granted') {
				Wo_ExploreNearbyBindDeviceOrientationTracking();
			}
		}).catch(function() {});
	});
}

function Wo_ExploreNearbyInitOrientationTracking() {
	Wo_ExploreNearbyBindScreenOrientationTracking();

	if (typeof window.DeviceOrientationEvent === 'undefined') {
		return;
	}

	if (typeof window.DeviceOrientationEvent.requestPermission === 'function') {
		Wo_ExploreNearbyEnsureOrientationPermissionPrompt();
		return;
	}

	Wo_ExploreNearbyBindDeviceOrientationTracking();
}

function Wo_ExploreNearbySetCurrentUserCoordinates(lat, lng) {
	if (!Wo_ExploreNearbyHasValidCoordinates(lat, lng)) {
		return false;
	}

	var numericLat = parseFloat(lat);
	var numericLng = parseFloat(lng);
	var hadPreviousCoordinates = Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng);
	var hasMeaningfulChange = !hadPreviousCoordinates;

	if (hadPreviousCoordinates) {
		hasMeaningfulChange = Wo_ExploreNearbyGetDistanceKm(
			{lat: parseFloat(currentUserMapPoint.lat), lng: parseFloat(currentUserMapPoint.lng)},
			{lat: numericLat, lng: numericLng}
		) >= 0.005;
	}

	currentUserMapPoint.lat = numericLat;
	currentUserMapPoint.lng = numericLng;
	currentUserMapPoint.location_dynamic = Wo_ExploreNearbyBuildCoordinateText(numericLat, numericLng);
	currentUserMapPoint.location = currentUserMapPoint.location_dynamic;
	nearbyMapCenter.lat = numericLat;
	nearbyMapCenter.lng = numericLng;
	WoExploreNearbyState.locationBootstrapState = 'ready';
	Wo_ExploreNearbySyncLocationAnchorState();
	Wo_ExploreNearbyRefreshSelfMarker();

	return hasMeaningfulChange;
}

function Wo_ExploreNearbyPersistCurrentUserLocation(lat, lng) {
	if (!Wo_ExploreNearbyHasValidCoordinates(lat, lng)) {
		return;
	}

	var nextPosition = {
		lat: parseFloat(lat),
		lng: parseFloat(lng)
	};
	if (WoExploreNearbyState.lastSavedLivePosition && Wo_ExploreNearbyGetDistanceKm(WoExploreNearbyState.lastSavedLivePosition, nextPosition) < 0.02) {
		return;
	}

	WoExploreNearbyState.lastSavedLivePosition = nextPosition;
	$.post(Wo_Ajax_Requests_File(), {
		f: 'save_user_location',
		lat: nextPosition.lat,
		lng: nextPosition.lng
	});
}

function Wo_ExploreNearbyScheduleLiveReload() {
	clearTimeout(WoExploreNearbyState.liveLocationReloadTimer);
	WoExploreNearbyState.liveLocationReloadTimer = setTimeout(function() {
		Wo_ExploreNearbyLoad(false);
	}, 350);
}

function Wo_ExploreNearbyHandleLiveLocation(position) {
	if (!position || !position.coords) {
		return;
	}

	var lat = parseFloat(position.coords.latitude);
	var lng = parseFloat(position.coords.longitude);
	if (!Wo_ExploreNearbyHasValidCoordinates(lat, lng)) {
		return;
	}

	var locationChanged = Wo_ExploreNearbySetCurrentUserCoordinates(lat, lng);
	var nextPosition = {
		lat: lat,
		lng: lng
	};

	Wo_ExploreNearbyPersistCurrentUserLocation(lat, lng);
	Wo_ExploreNearbyRefreshCurrentUserDynamicLocation();
	Wo_ExploreNearbyUpdateMapPrompt();

	if (!WoExploreNearbyState.lastReloadLivePosition || Wo_ExploreNearbyGetDistanceKm(WoExploreNearbyState.lastReloadLivePosition, nextPosition) >= 0.08) {
		WoExploreNearbyState.lastReloadLivePosition = nextPosition;
		Wo_ExploreNearbyScheduleLiveReload();
		return;
	}

	if (locationChanged) {
		if (WoExploreNearbyState.activePointKey) {
			Wo_ExploreNearbySyncRouteLine();
		}
		else {
			Wo_ExploreNearbyRenderCurrentMap(WoExploreNearbyState.openPopupPointKey || null);
		}
	}
}

function Wo_ExploreNearbyHandleLocationError(error) {
	if (!Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng) && !Wo_ExploreNearbyHasSearchCenter()) {
		if (error && error.code === 1) {
			WoExploreNearbyState.locationBootstrapState = 'denied';
		}
		else {
			WoExploreNearbyState.locationBootstrapState = 'waiting';
		}
	}

	Wo_ExploreNearbyUpdateMapPrompt();
}

function Wo_ExploreNearbyRequestCurrentUserLocation() {
	if (!navigator.geolocation) {
		if (!Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng) && !Wo_ExploreNearbyHasSearchCenter()) {
			WoExploreNearbyState.locationBootstrapState = 'denied';
		}
		Wo_ExploreNearbyUpdateMapPrompt();
		return;
	}

	navigator.geolocation.getCurrentPosition(Wo_ExploreNearbyHandleLiveLocation, Wo_ExploreNearbyHandleLocationError, {
		enableHighAccuracy: true,
		maximumAge: 30000,
		timeout: 12000
	});
}

function Wo_ExploreNearbyStartLiveLocationTracking() {
	if (WoExploreNearbyState.liveLocationWatchId !== null || !navigator.geolocation) {
		return;
	}

	var watchOptions = {
		enableHighAccuracy: true,
		maximumAge: 30000,
		timeout: 12000
	};

	Wo_ExploreNearbyRequestCurrentUserLocation();
	WoExploreNearbyState.liveLocationWatchId = navigator.geolocation.watchPosition(Wo_ExploreNearbyHandleLiveLocation, Wo_ExploreNearbyHandleLocationError, watchOptions);
}

function Wo_ExploreNearbyHasCurrentUserPoint() {
	return Wo_ExploreNearbyNormalizePoints([currentUserMapPoint]).length > 0;
}

function Wo_ExploreNearbyGetDefaultOpenPointKey() {
	return null;
