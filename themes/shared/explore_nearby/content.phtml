function Wo_ExploreNearbyEscapeHtml(text) {
	return String(text || '')
		.replace(/&/g, '&amp;')
		.replace(/</g, '&lt;')
		.replace(/>/g, '&gt;')
		.replace(/"/g, '&quot;')
		.replace(/'/g, '&#039;');
}

function Wo_ExploreNearbyDecodeHtmlEntities(text) {
	var value = String(text || '');
	var textarea = Wo_ExploreNearbyDecodeHtmlEntities.textarea;
	if (!textarea) {
		textarea = document.createElement('textarea');
		Wo_ExploreNearbyDecodeHtmlEntities.textarea = textarea;
	}

	textarea.innerHTML = value;
	return textarea.value;
}

function Wo_ExploreNearbyNormalizeTextValue(text) {
	return $.trim(Wo_ExploreNearbyDecodeHtmlEntities(text));
}

function Wo_ExploreNearbyFormatDebugCoordinate(lat, lng) {
	if (!Wo_ExploreNearbyHasValidCoordinates(lat, lng)) {
		return 'no-coords';
	}

	return parseFloat(lat).toFixed(5) + ', ' + parseFloat(lng).toFixed(5);
}

function Wo_ExploreNearbyDescribeDebugPoint(point) {
	if (!point) {
		return 'none';
	}

	var pointTitle = $.trim(point.name || point.title || point.item_key || 'point');
	var pointType = $.trim(point.type || '');
	return pointTitle + (pointType ? ' [' + pointType + ']' : '') + ' @ ' + Wo_ExploreNearbyFormatDebugCoordinate(point.lat, point.lng);
}

function Wo_ExploreNearbyRenderDebugPanel() {
	return;
}

