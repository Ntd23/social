if (defined('JSON_UNESCAPED_UNICODE')) {
	$json_flags = JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES;
}

$format_distance = function($distance) {
	if ($distance === '' || $distance === null || !is_numeric($distance) || (float) $distance <= 0) {
		return '';
	}

	$distance = (float) $distance;
	if ($distance < 10) {
		$text = number_format($distance, 1, '.', '');
		$text = rtrim(rtrim($text, '0'), '.');
		return $text . ' km';
	}

	return number_format($distance, 0, '.', ',') . ' km';
};

$trim_text = function($text, $length = 120) {
	$text = trim(strip_tags((string) $text));
	if ($text === '') {
		return '';
	}

	if (function_exists('mb_strlen') && function_exists('mb_substr')) {
		return (mb_strlen($text, 'UTF-8') > $length) ? mb_substr($text, 0, $length - 1, 'UTF-8') . '…' : $text;
	}

	return (strlen($text) > $length) ? substr($text, 0, $length - 1) . '…' : $text;
};

$trim_text = function($text, $length = 120) {
	$text = trim(strip_tags((string) $text));
	if ($text === '') {
		return '';
	}

	if (function_exists('mb_strlen') && function_exists('mb_substr')) {
		return (mb_strlen($text, 'UTF-8') > $length) ? mb_substr($text, 0, $length - 1, 'UTF-8') . '...' : $text;
	}

	return (strlen($text) > $length) ? substr($text, 0, $length - 1) . '...' : $text;
};

$build_item_key = function($type, $primary, $fallback = '') {
	$base = !empty($primary) ? (string) $primary : (string) $fallback;
	if ($base === '') {
		$base = uniqid($type . '_', true);
	}

	return $type . '|' . md5($base);
};

$sort_items = function(array &$items) {
	usort($items, function($a, $b) {
		$a_has_distance = isset($a['distance_value']) && is_numeric($a['distance_value']);
		$b_has_distance = isset($b['distance_value']) && is_numeric($b['distance_value']);

		if ($a_has_distance && $b_has_distance) {
			$a_distance = (float) $a['distance_value'];
			$b_distance = (float) $b['distance_value'];
			if ($a_distance == $b_distance) {
				return strnatcasecmp((string) $a['title'], (string) $b['title']);
			}
			return ($a_distance < $b_distance) ? -1 : 1;
		}

		if ($a_has_distance) {
			return -1;
		}

		if ($b_has_distance) {
			return 1;
		}

		return strnatcasecmp((string) $a['title'], (string) $b['title']);
	});
};

$initial_user_items = array();
$initial_shop_items = array();

if (!empty($nearby_users)) {
	foreach ($nearby_users as $user) {
		$user_location = '';
		if (!empty($user['user_data']['address'])) {
			$user_location = trim($user['user_data']['address']);
		}
		elseif (!empty($user['user_geoinfo'])) {
			$user_location = trim($user['user_geoinfo']);
		}

		$user_distance = (isset($user['distance']) && is_numeric($user['distance'])) ? round((float) $user['distance'], 2) : null;
		$initial_user_items[] = array(
			'item_key' => $build_item_key('user', (!empty($user['user_data']['url']) ? $user['user_data']['url'] : ''), (!empty($user['user_data']['user_id']) ? $user['user_data']['user_id'] : '')),
			'offset_id' => !empty($user['user_data']['id']) ? (int) $user['user_data']['id'] : 0,
			'type' => 'user',
			'type_label' => $user_type_label,
			'title' => !empty($user['user_data']['name']) ? $user['user_data']['name'] : '',
			'subtitle' => (!empty($user['user_data']['username']) ? '@' . $user['user_data']['username'] : $user_type_label),
			'description' => '',
			'avatar' => !empty($user['user_data']['avatar']) ? $user['user_data']['avatar'] : '',
			'url' => !empty($user['user_data']['url']) ? $user['user_data']['url'] : '',
			'ajax_url' => (!empty($user['user_data']['username']) ? '?link1=timeline&u=' . $user['user_data']['username'] : ''),
			'location' => $user_location,
			'distance_value' => $user_distance,
			'distance_text' => $format_distance($user_distance),
			'lat' => !empty($user['user_data']['lat']) ? (float) $user['user_data']['lat'] : null,
			'lng' => !empty($user['user_data']['lng']) ? (float) $user['user_data']['lng'] : null,
			'is_self' => (!empty($user['user_data']['user_id']) && (int) $user['user_data']['user_id'] === $current_user_id)
		);
	}
}

if (!empty($nearby_shops)) {
	foreach ($nearby_shops as $shop) {
		$shop_location = (!empty($shop['product']['location'])) ? $shop['product']['location'] : (!empty($shop['page_data']['address']) ? $shop['page_data']['address'] : '');
		$shop_distance = (isset($shop['distance']) && is_numeric($shop['distance'])) ? round((float) $shop['distance'], 2) : null;
		$shop_subtitle = '';
		if (!empty($shop['page_data']['category'])) {
			$shop_subtitle = $shop['page_data']['category'];
		}
		elseif (!empty($shop['page_data']['page_sub_category'])) {
			$shop_subtitle = $shop['page_data']['page_sub_category'];
		}
		else {
			$shop_subtitle = $shop_type_label;
		}

		$initial_shop_items[] = array(
			'item_key' => $build_item_key('shop', (!empty($shop['page_data']['url']) ? $shop['page_data']['url'] : ''), (!empty($shop['page_data']['page_id']) ? $shop['page_data']['page_id'] : '')),
			'offset_id' => !empty($shop['page_data']['page_id']) ? (int) $shop['page_data']['page_id'] : 0,
			'type' => 'shop',
			'type_label' => $shop_type_label,
			'title' => !empty($shop['page_data']['name']) ? $shop['page_data']['name'] : '',
			'subtitle' => $shop_subtitle,
			'description' => $trim_text(!empty($shop['page_data']['page_description']) ? $shop['page_data']['page_description'] : '', 130),
			'avatar' => !empty($shop['page_data']['avatar']) ? $shop['page_data']['avatar'] : '',
			'url' => !empty($shop['page_data']['url']) ? $shop['page_data']['url'] : '',
			'ajax_url' => (!empty($shop['page_data']['username']) ? '?link1=timeline&u=' . $shop['page_data']['username'] : ''),
			'location' => $shop_location,
			'distance_value' => $shop_distance,
			'distance_text' => $format_distance($shop_distance),
			'lat' => !empty($shop['product']['lat']) ? (float) $shop['product']['lat'] : null,
			'lng' => !empty($shop['product']['lng']) ? (float) $shop['product']['lng'] : null,
			'is_self' => false
		);
	}
}

$initial_discovery_items = array_merge($initial_user_items, $initial_shop_items);
$sort_items($initial_discovery_items);
$initial_total_count = ($users_enabled ? $nearby_users_count : 0) + ($shops_enabled ? $nearby_shops_count : 0);
