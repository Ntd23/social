function Wo_ExploreNearbyBindGoogleMarkerInteraction(marker) {
	if (!marker) {
		return;
	}

	var lastTriggeredAt = 0;
	var handleSelection = function(event) {
		if (!Wo_ExploreNearbyCanHandleMapSelection(event, 'marker:google')) {
			return;
		}

		var now = Date.now();
		if ((now - lastTriggeredAt) < 140) {
			return;
		}
		lastTriggeredAt = now;
		Wo_ExploreNearbyRememberMapPointerPosition(event);
		Wo_ExploreNearbyRememberPointSelection();
		var effectiveMarker = marker;
		if (typeof WoExploreNearbyState.lastMapPointerClientX === 'number' && typeof WoExploreNearbyState.lastMapPointerClientY === 'number') {
			var hitMarker = Wo_ExploreNearbyFindGoogleMarkerByClientPosition(
				WoExploreNearbyState.lastMapPointerClientX,
				WoExploreNearbyState.lastMapPointerClientY
			);
			var nearestMarker = hitMarker || Wo_ExploreNearbyFindNearestGoogleMarkerByClientPosition(
				WoExploreNearbyState.lastMapPointerClientX,
				WoExploreNearbyState.lastMapPointerClientY
			);
			if (nearestMarker) {
				effectiveMarker = nearestMarker;
			}
		}
		Wo_ExploreNearbyOpenGoogleMarker(effectiveMarker, true, true);
	};

	if (Wo_ExploreNearbyIsGoogleAdvancedMarker(marker) && typeof marker.addEventListener === 'function') {
		marker.addEventListener('gmp-click', function(event) {
			if (event && typeof event.preventDefault === 'function') {
				event.preventDefault();
			}
			if (event && typeof event.stopPropagation === 'function') {
				event.stopPropagation();
			}
			handleSelection(event);
		});
	}

	if (Wo_ExploreNearbyIsGoogleAdvancedMarker(marker) && marker.content && typeof marker.content.addEventListener === 'function') {
		marker.content.addEventListener('click', function(event) {
			if (event) {
				event.preventDefault();
				event.stopPropagation();
			}
			handleSelection(event);
		});
		marker.content.addEventListener('touchend', function(event) {
			if (event) {
				event.preventDefault();
				event.stopPropagation();
			}
			handleSelection(event);
		}, {passive: false});
	}

	if (typeof marker.addListener === 'function') {
		marker.addListener('click', handleSelection);
	}
}

function Wo_ExploreNearbyShouldPreferMarkerAnchor(candidatePoint, existingPoint) {
	var candidateFamily = Wo_ExploreNearbyGetDiscoveryItemFamily(candidatePoint);
	var existingFamily = Wo_ExploreNearbyGetDiscoveryItemFamily(existingPoint);
	var candidatePinned = Wo_ExploreNearbyIsPinnedPoint(candidatePoint);
	var existingPinned = Wo_ExploreNearbyIsPinnedPoint(existingPoint);

	if (!existingPoint) {
		return true;
	}

	if (candidatePinned !== existingPinned) {
		return candidatePinned;
	}

	if (candidateFamily === 'pageish' && existingFamily !== 'pageish') {
		return true;
	}

	if (existingFamily === 'pageish' && candidateFamily !== 'pageish') {
		return false;
	}

	if (Wo_ExploreNearbyShouldPreferItem(candidatePoint, existingPoint)) {
		return true;
	}

	if (Wo_ExploreNearbyShouldPreferItem(existingPoint, candidatePoint)) {
		return false;
	}

	return false;
}

function Wo_ExploreNearbyCreateMarkerCoordinateState(points) {
	var normalizedPoints = Wo_ExploreNearbyNormalizePoints(points);
	var coordinateState = {
		groups: {}
	};

	for (var i = 0; i < normalizedPoints.length; i++) {
		var coordinateKey = normalizedPoints[i].lat.toFixed(6) + ',' + normalizedPoints[i].lng.toFixed(6);
		if (!coordinateState.groups[coordinateKey]) {
			coordinateState.groups[coordinateKey] = {
				points: [],
				anchorPointKey: '',
				offsetCursor: 0
			};
		}

		coordinateState.groups[coordinateKey].points.push(normalizedPoints[i]);
	}

	for (var groupKey in coordinateState.groups) {
		if (!Object.prototype.hasOwnProperty.call(coordinateState.groups, groupKey)) {
			continue;
		}

		var group = coordinateState.groups[groupKey];
		var anchorPoint = null;
		for (var groupIndex = 0; groupIndex < group.points.length; groupIndex++) {
			if (Wo_ExploreNearbyShouldPreferMarkerAnchor(group.points[groupIndex], anchorPoint)) {
				anchorPoint = group.points[groupIndex];
			}
		}

		group.anchorPointKey = anchorPoint ? Wo_ExploreNearbyGetItemKey(anchorPoint) : '';
	}

	return coordinateState;
}

function Wo_ExploreNearbyGetMarkerPosition(point, coordinateState) {
	var lat = parseFloat(point.lat);
	var lng = parseFloat(point.lng);
	var pointKey = Wo_ExploreNearbyGetItemKey(point);
	if (isNaN(lat) || isNaN(lng)) {
		return null;
	}

	var key = lat.toFixed(6) + ',' + lng.toFixed(6);
	var coordinateGroup = coordinateState && coordinateState.groups ? coordinateState.groups[key] : null;

	if (!coordinateGroup || coordinateGroup.points.length <= 1 || (coordinateGroup.anchorPointKey && coordinateGroup.anchorPointKey === pointKey)) {
		return {lat: lat, lng: lng};
	}

	var duplicateIndex = coordinateGroup.offsetCursor || 0;
	coordinateGroup.offsetCursor = duplicateIndex + 1;
	var angle = duplicateIndex * (Math.PI / 3);
	var radius = 0.00012 * (Math.floor(duplicateIndex / 6) + 1);

	return {
		lat: lat + (Math.sin(angle) * radius),
		lng: lng + (Math.cos(angle) * radius)
	};
}

function Wo_ExploreNearbyGetRouteColor(point) {
	if (point && point.type === 'shop') {
		return '#17a673';
	}
	if (point && point.type === 'page') {
		return '#17a673';
	}
	if (point && point.type === 'place') {
		return '#f59e0b';
	}

	return '#2f6df6';
}

function Wo_ExploreNearbyCloseInfoPopup() {
	if (WoExploreNearbyMapState.googleInfoWindow) {
		WoExploreNearbyMapState.googleInfoWindow.close();
	}

	if (WoExploreNearbyMapState.provider === 'leaflet' && WoExploreNearbyMapState.map && typeof WoExploreNearbyMapState.map.closePopup === 'function') {
		WoExploreNearbyMapState.map.closePopup();
	}

	Wo_ExploreNearbyHideMobileSheet();
}

function Wo_ExploreNearbyOpenGoogleInfoPopupAtPoint(point, position) {
	var popupPoint = point || null;
	var popupPosition = position || null;

	if (!popupPoint || WoExploreNearbyMapState.provider !== 'google' || !WoExploreNearbyMapState.map) {
		return;
	}

	if (!WoExploreNearbyMapState.googleInfoWindow) {
		WoExploreNearbyMapState.googleInfoWindow = new google.maps.InfoWindow();
	}

	if (!popupPosition || !Wo_ExploreNearbyHasValidCoordinates(popupPosition.lat, popupPosition.lng)) {
		popupPosition = Wo_ExploreNearbyHasValidCoordinates(popupPoint.lat, popupPoint.lng) ? {
			lat: parseFloat(popupPoint.lat),
			lng: parseFloat(popupPoint.lng)
		} : null;
	}

	if (!popupPosition) {
		return;
	}

	WoExploreNearbyMapState.googleInfoWindow.setContent(Wo_ExploreNearbyGetPopupHtml(popupPoint));
	WoExploreNearbyMapState.googleInfoWindow.setPosition(popupPosition);
	WoExploreNearbyMapState.googleInfoWindow.open({
		map: WoExploreNearbyMapState.map,
		shouldFocus: false
	});
}

function Wo_ExploreNearbyClearRouteLine() {
	if (WoExploreNearbyMapState.googleRouteLine) {
		WoExploreNearbyMapState.googleRouteLine.setMap(null);
		WoExploreNearbyMapState.googleRouteLine = null;
	}

	if (WoExploreNearbyMapState.googleRouteGlow) {
		WoExploreNearbyMapState.googleRouteGlow.setMap(null);
		WoExploreNearbyMapState.googleRouteGlow = null;
	}

	if (WoExploreNearbyMapState.leafletRouteLine) {
		WoExploreNearbyMapState.leafletRouteLine.remove();
		WoExploreNearbyMapState.leafletRouteLine = null;
	}
}

function Wo_ExploreNearbyFitRouteViewport(path, fallbackPoints) {
	var normalizedPath = [];
	var points = Array.isArray(path) ? path : [];
	var viewportPadding = Wo_ExploreNearbyGetMapViewportPadding();
	for (var i = 0; i < points.length; i++) {
		var lat = parseFloat(points[i].lat);
		var lng = parseFloat(points[i].lng);
		if (isNaN(lat) || isNaN(lng)) {
			continue;
		}

		normalizedPath.push({lat: lat, lng: lng});
	}

	if (!normalizedPath.length && Array.isArray(fallbackPoints)) {
		for (var j = 0; j < fallbackPoints.length; j++) {
			var fallbackLat = parseFloat(fallbackPoints[j].lat);
			var fallbackLng = parseFloat(fallbackPoints[j].lng);
			if (isNaN(fallbackLat) || isNaN(fallbackLng)) {
				continue;
			}

			normalizedPath.push({lat: fallbackLat, lng: fallbackLng});
		}
	}

	if (!normalizedPath.length) {
		return;
	}

	if (WoExploreNearbyMapState.provider === 'google' && WoExploreNearbyMapState.map) {
		var googleBounds = new google.maps.LatLngBounds();
		for (var g = 0; g < normalizedPath.length; g++) {
			googleBounds.extend(normalizedPath[g]);
		}
		WoExploreNearbyMapState.map.fitBounds(googleBounds, viewportPadding);
		google.maps.event.addListenerOnce(WoExploreNearbyMapState.map, 'idle', function() {
			var currentZoom = WoExploreNearbyMapState.map.getZoom() || 7;
			var targetZoom = currentZoom;
			if (targetZoom > 16) {
				targetZoom = 16;
			}
			if (targetZoom !== currentZoom) {
				WoExploreNearbyMapState.map.setZoom(targetZoom);
			}
		});
		return;
	}

	if (WoExploreNearbyMapState.provider === 'leaflet' && WoExploreNearbyMapState.map) {
		var bounds = [];
		for (var l = 0; l < normalizedPath.length; l++) {
			bounds.push([normalizedPath[l].lat, normalizedPath[l].lng]);
		}
		WoExploreNearbyMapState.map.fitBounds(bounds, {
			paddingTopLeft: [viewportPadding.left, viewportPadding.top],
			paddingBottomRight: [viewportPadding.right, viewportPadding.bottom],
			maxZoom: 16
		});
	}
}

function Wo_ExploreNearbyGetRouteCacheKey(provider, fromPoint, toPoint) {
	return [
		provider,
		parseFloat(fromPoint.lat).toFixed(6),
		parseFloat(fromPoint.lng).toFixed(6),
		parseFloat(toPoint.lat).toFixed(6),
		parseFloat(toPoint.lng).toFixed(6)
	].join('|');
}

function Wo_ExploreNearbyRequestGoogleRoute(fromPoint, toPoint) {
	if (!WoExploreNearbyMapState.map || typeof google === 'undefined' || !google.maps || typeof google.maps.DirectionsService === 'undefined') {
		return Wo_ExploreNearbyRequestLeafletRoute(fromPoint, toPoint);
	}

	var cacheKey = Wo_ExploreNearbyGetRouteCacheKey('google', fromPoint, toPoint);
	if (WoExploreNearbyState.routeCache.hasOwnProperty(cacheKey)) {
		return Promise.resolve(WoExploreNearbyState.routeCache[cacheKey]);
	}

	if (!WoExploreNearbyMapState.googleDirectionsService) {
		WoExploreNearbyMapState.googleDirectionsService = new google.maps.DirectionsService();
	}

	return new Promise(function(resolve) {
		WoExploreNearbyMapState.googleDirectionsService.route({
			origin: {lat: fromPoint.lat, lng: fromPoint.lng},
			destination: {lat: toPoint.lat, lng: toPoint.lng},
			travelMode: google.maps.TravelMode.DRIVING,
			provideRouteAlternatives: false
		}, function(result, status) {
			if (status === 'OK' && result && result.routes && result.routes[0]) {
				var overviewPath = result.routes[0].overview_path || [];
				var normalizedPath = [];
				for (var i = 0; i < overviewPath.length; i++) {
					normalizedPath.push({
						lat: overviewPath[i].lat(),
						lng: overviewPath[i].lng()
					});
				}

				if (normalizedPath.length > 1) {
					var routeData = {path: normalizedPath};
					WoExploreNearbyState.routeCache[cacheKey] = routeData;
					resolve(routeData);
					return;
				}
			}

			Wo_ExploreNearbyRequestLeafletRoute(fromPoint, toPoint).then(resolve).catch(function() {
				resolve(null);
			});
		});
	});
}

function Wo_ExploreNearbyRequestLeafletRoute(fromPoint, toPoint) {
	var cacheKey = Wo_ExploreNearbyGetRouteCacheKey('leaflet', fromPoint, toPoint);
	if (WoExploreNearbyState.routeCache.hasOwnProperty(cacheKey)) {
		return Promise.resolve(WoExploreNearbyState.routeCache[cacheKey]);
	}

	var routeUrl = 'https://router.project-osrm.org/route/v1/driving/' +
		encodeURIComponent(fromPoint.lng + ',' + fromPoint.lat) + ';' +
		encodeURIComponent(toPoint.lng + ',' + toPoint.lat) +
		'?overview=full&geometries=geojson';

	return fetch(routeUrl, {
		headers: {
			'Accept': 'application/json'
		}
	}).then(function(response) {
		if (!response.ok) {
			throw new Error('Routing request failed');
		}
		return response.json();
	}).then(function(result) {
		if (result && Array.isArray(result.routes) && result.routes[0] && result.routes[0].geometry && Array.isArray(result.routes[0].geometry.coordinates)) {
			var coordinates = result.routes[0].geometry.coordinates;
			var normalizedPath = [];
			for (var i = 0; i < coordinates.length; i++) {
				if (!Array.isArray(coordinates[i]) || coordinates[i].length < 2) {
					continue;
				}

				normalizedPath.push({
					lat: parseFloat(coordinates[i][1]),
					lng: parseFloat(coordinates[i][0])
				});
			}

			if (normalizedPath.length > 1) {
				var routeData = {path: normalizedPath};
				WoExploreNearbyState.routeCache[cacheKey] = routeData;
				return routeData;
			}
		}

		return null;
	}).catch(function() {
		return null;
	});
}

function Wo_ExploreNearbyRequestRoute(fromPoint, toPoint) {
	if (WoExploreNearbyMapState.provider === 'google') {
		return Wo_ExploreNearbyRequestGoogleRoute(fromPoint, toPoint);
	}

	if (WoExploreNearbyMapState.provider === 'leaflet') {
		return Wo_ExploreNearbyRequestLeafletRoute(fromPoint, toPoint);
	}

	return Promise.resolve(null);
}

function Wo_ExploreNearbyDrawGoogleRouteLine(path, toPoint) {
	if (!WoExploreNearbyMapState.map) {
		return;
	}

	var routeColor = Wo_ExploreNearbyGetRouteColor(toPoint);
	var routePath = Array.isArray(path) ? path : [];

	WoExploreNearbyMapState.googleRouteGlow = new google.maps.Polyline({
		path: routePath,
		geodesic: false,
		strokeColor: routeColor,
		strokeOpacity: 0.18,
		strokeWeight: 12,
		zIndex: 1
	});
	WoExploreNearbyMapState.googleRouteGlow.setMap(WoExploreNearbyMapState.map);

	WoExploreNearbyMapState.googleRouteLine = new google.maps.Polyline({
		path: routePath,
		geodesic: false,
		strokeColor: routeColor,
		strokeOpacity: 0.94,
		strokeWeight: 5,
		zIndex: 2
	});
	WoExploreNearbyMapState.googleRouteLine.setMap(WoExploreNearbyMapState.map);
}

function Wo_ExploreNearbyDrawLeafletRouteLine(path, toPoint) {
	if (!WoExploreNearbyMapState.map || typeof L === 'undefined') {
		return;
	}

	var routeColor = Wo_ExploreNearbyGetRouteColor(toPoint);
	var routePoints = [];
	for (var i = 0; i < (path || []).length; i++) {
		routePoints.push([path[i].lat, path[i].lng]);
	}

	WoExploreNearbyMapState.leafletRouteLine = L.polyline(routePoints, {
		color: routeColor,
		weight: 5,
		opacity: 0.9,
		lineCap: 'round',
		lineJoin: 'round'
	}).addTo(WoExploreNearbyMapState.map);

	if (typeof WoExploreNearbyMapState.leafletRouteLine.bringToBack === 'function') {
		WoExploreNearbyMapState.leafletRouteLine.bringToBack();
	}
}

function Wo_ExploreNearbySyncRouteLine() {
	Wo_ExploreNearbyClearRouteLine();

	var routeToken = ++WoExploreNearbyState.routeRenderToken;
	var selfPoint = Wo_ExploreNearbyGetCurrentUserPoint();
	var routePointKey = $.trim(WoExploreNearbyState.routeTargetPointKey || '');
	if (!selfPoint || !routePointKey) {
		return;
	}
	if (routePointKey === Wo_ExploreNearbyGetItemKey(selfPoint)) {
		return;
	}

	var candidateTargetPoint = Wo_ExploreNearbyResolvePointByKey(routePointKey, true);
	var normalizedTarget = Wo_ExploreNearbyNormalizePoints(candidateTargetPoint ? [candidateTargetPoint] : []);
	if (!normalizedTarget.length) {
		return;
	}
	if (Wo_ExploreNearbyIsSamePoint(selfPoint, normalizedTarget[0])) {
		return;
	}

	var targetPoint = normalizedTarget[0];
	var fallbackPath = [
		{lat: selfPoint.lat, lng: selfPoint.lng},
		{lat: targetPoint.lat, lng: targetPoint.lng}
	];

	WoExploreNearbyState.routeTargetPointData = targetPoint;

	if (WoExploreNearbyMapState.provider === 'google') {
		Wo_ExploreNearbyDrawGoogleRouteLine(fallbackPath, targetPoint);
	}
	else if (WoExploreNearbyMapState.provider === 'leaflet') {
		Wo_ExploreNearbyDrawLeafletRouteLine(fallbackPath, targetPoint);
	}

	Wo_ExploreNearbyFitRouteViewport(fallbackPath, [selfPoint, targetPoint]);

	Wo_ExploreNearbyRequestRoute(selfPoint, targetPoint).then(function(routeData) {
		if (routeToken !== WoExploreNearbyState.routeRenderToken) {
			return;
		}

		var routePath = (routeData && Array.isArray(routeData.path) && routeData.path.length > 1) ? routeData.path : fallbackPath;
		Wo_ExploreNearbyClearRouteLine();

		if (routePath.length > 1 && WoExploreNearbyMapState.provider === 'google') {
			Wo_ExploreNearbyDrawGoogleRouteLine(routePath, targetPoint);
		}
		else if (routePath.length > 1 && WoExploreNearbyMapState.provider === 'leaflet') {
			Wo_ExploreNearbyDrawLeafletRouteLine(routePath, targetPoint);
		}

		Wo_ExploreNearbyFitRouteViewport(routePath, [selfPoint, targetPoint]);
	}).catch(function() {
		if (routeToken !== WoExploreNearbyState.routeRenderToken) {
			return;
		}

		Wo_ExploreNearbyClearRouteLine();
		if (WoExploreNearbyMapState.provider === 'google') {
			Wo_ExploreNearbyDrawGoogleRouteLine(fallbackPath, targetPoint);
		}
		else if (WoExploreNearbyMapState.provider === 'leaflet') {
			Wo_ExploreNearbyDrawLeafletRouteLine(fallbackPath, targetPoint);
		}

		Wo_ExploreNearbyFitRouteViewport(fallbackPath, [selfPoint, targetPoint]);
	});
}

function Wo_ExploreNearbyGetViewportTargetPoints(points) {
	var normalizedPoints = Wo_ExploreNearbyNormalizePoints(points);
	var viewportPoints = [];

	for (var i = 0; i < normalizedPoints.length; i++) {
		if (!normalizedPoints[i].is_pinned_only) {
			viewportPoints.push(normalizedPoints[i]);
		}
	}

	return viewportPoints.length ? viewportPoints : normalizedPoints;
}

function Wo_ExploreNearbyGetViewportRadiusBounds(centerPoint, radiusKm) {
	var centerLat = parseFloat(centerPoint && centerPoint.lat);
	var centerLng = parseFloat(centerPoint && centerPoint.lng);
	var safeRadiusKm = Math.max(0.5, parseFloat(radiusKm) || defaultNearbyViewportRadiusKm);
	var degreesPerKm = 1 / 111.32;
	var latDelta = safeRadiusKm * degreesPerKm;
	var lngDivider = Math.cos(centerLat * (Math.PI / 180));
	var lngDelta = safeRadiusKm * degreesPerKm;

	if (!Wo_ExploreNearbyHasValidCoordinates(centerLat, centerLng)) {
		return null;
	}

	if (Math.abs(lngDivider) > 0.00001) {
		lngDelta = safeRadiusKm * degreesPerKm / Math.abs(lngDivider);
	}

	return {
		south: centerLat - latDelta,
		west: centerLng - lngDelta,
		north: centerLat + latDelta,
		east: centerLng + lngDelta
	};
}

function Wo_ExploreNearbyShouldUseDefaultCurrentUserViewport() {
	var selfPoint = Wo_ExploreNearbyGetCurrentUserPoint();

	if (!selfPoint) {
		return false;
	}
	if (Wo_ExploreNearbyIsPlaceSearchMode() || Wo_ExploreNearbyGetSearchValue() || Wo_ExploreNearbyHasSearchCenter()) {
		return false;
	}
	if (Wo_ExploreNearbyGetSelectedAnchorPointKey()) {
		return false;
	}
	if (WoExploreNearbyState.routeTargetPointKey || WoExploreNearbyState.routeTargetPointData) {
		return false;
	}
	if (WoExploreNearbyState.pendingFocusPointKey || WoExploreNearbyState.previewPointKey || WoExploreNearbyState.previewPointData || WoExploreNearbyState.openPopupPointKey) {
		return false;
	}
	if (WoExploreNearbyState.activePointKey && WoExploreNearbyState.activePointKey !== Wo_ExploreNearbyGetItemKey(selfPoint)) {
		return false;
	}

	return true;
}

function Wo_ExploreNearbyApplyGoogleViewport(points) {
	var normalizedPoints = Wo_ExploreNearbyGetViewportTargetPoints(points);
	var viewportPadding = Wo_ExploreNearbyGetMapViewportPadding();
	var selfPoint = Wo_ExploreNearbyGetCurrentUserPoint();
	var defaultBounds = Wo_ExploreNearbyShouldUseDefaultCurrentUserViewport() ? Wo_ExploreNearbyGetViewportRadiusBounds(selfPoint, defaultNearbyViewportRadiusKm) : null;
	if (!WoExploreNearbyMapState.map) {
		return;
	}

	if (defaultBounds) {
		var defaultGoogleBounds = new google.maps.LatLngBounds(
			{lat: defaultBounds.south, lng: defaultBounds.west},
			{lat: defaultBounds.north, lng: defaultBounds.east}
		);
		WoExploreNearbyMapState.map.fitBounds(defaultGoogleBounds, viewportPadding);
		return;
	}

	if (!normalizedPoints.length) {
		WoExploreNearbyMapState.map.setCenter(nearbyMapCenter);
		WoExploreNearbyMapState.map.setZoom(7);
		return;
	}

	if (normalizedPoints.length === 1) {
		WoExploreNearbyMapState.map.setCenter({lat: normalizedPoints[0].lat, lng: normalizedPoints[0].lng});
		WoExploreNearbyMapState.map.setZoom(15);
		return;
	}

	var bounds = new google.maps.LatLngBounds();
	for (var i = 0; i < normalizedPoints.length; i++) {
		bounds.extend({lat: normalizedPoints[i].lat, lng: normalizedPoints[i].lng});
	}

	WoExploreNearbyMapState.map.fitBounds(bounds, viewportPadding);
	google.maps.event.addListenerOnce(WoExploreNearbyMapState.map, 'idle', function() {
		var currentZoom = WoExploreNearbyMapState.map.getZoom() || 4;
		var targetZoom = currentZoom;
		var zoomFloor = Wo_ExploreNearbyGetZoomFloor(normalizedPoints);
		if (targetZoom < 4) {
			targetZoom = 4;
		}
		if (zoomFloor > 4 && targetZoom < zoomFloor) {
			targetZoom = zoomFloor;
		}
		if (targetZoom !== currentZoom) {
			WoExploreNearbyMapState.map.setZoom(targetZoom);
		}
	});
}

function Wo_ExploreNearbyApplyLeafletViewport(points) {
	var normalizedPoints = Wo_ExploreNearbyGetViewportTargetPoints(points);
	var viewportPadding = Wo_ExploreNearbyGetMapViewportPadding();
	var selfPoint = Wo_ExploreNearbyGetCurrentUserPoint();
	var defaultBounds = Wo_ExploreNearbyShouldUseDefaultCurrentUserViewport() ? Wo_ExploreNearbyGetViewportRadiusBounds(selfPoint, defaultNearbyViewportRadiusKm) : null;
	if (!WoExploreNearbyMapState.map) {
		return;
	}

	if (defaultBounds) {
		WoExploreNearbyMapState.map.fitBounds([
			[defaultBounds.south, defaultBounds.west],
			[defaultBounds.north, defaultBounds.east]
		], {
			paddingTopLeft: [viewportPadding.left, viewportPadding.top],
			paddingBottomRight: [viewportPadding.right, viewportPadding.bottom]
		});
		return;
	}

	if (!normalizedPoints.length) {
		WoExploreNearbyMapState.map.setView([nearbyMapCenter.lat, nearbyMapCenter.lng], 7);
		return;
	}

	if (normalizedPoints.length === 1) {
		WoExploreNearbyMapState.map.setView([normalizedPoints[0].lat, normalizedPoints[0].lng], 15);
		return;
	}

	var bounds = [];
	for (var i = 0; i < normalizedPoints.length; i++) {
		bounds.push([normalizedPoints[i].lat, normalizedPoints[i].lng]);
	}

	WoExploreNearbyMapState.map.fitBounds(bounds, {
		paddingTopLeft: [viewportPadding.left, viewportPadding.top],
		paddingBottomRight: [viewportPadding.right, viewportPadding.bottom]
	});
}

function Wo_ExploreNearbyResetMapMarkers() {
	Wo_ExploreNearbyClearRouteLine();
	Wo_ExploreNearbyCloseInfoPopup();

	if (WoExploreNearbyMapState.provider === 'google') {
		for (var i = 0; i < WoExploreNearbyMapState.googleMarkers.length; i++) {
			Wo_ExploreNearbyGoogleMarkerSetMap(WoExploreNearbyMapState.googleMarkers[i], null);
		}
		WoExploreNearbyMapState.googleMarkers = [];
		WoExploreNearbyMapState.googleMarkerLookup = {};
		if (WoExploreNearbyMapState.googleInfoWindow) {
			WoExploreNearbyMapState.googleInfoWindow.close();
		}
	}

	if (WoExploreNearbyMapState.provider === 'leaflet' && WoExploreNearbyMapState.leafletMarkersLayer) {
		WoExploreNearbyMapState.leafletMarkersLayer.clearLayers();
		WoExploreNearbyMapState.leafletMarkerLookup = {};
	}

	WoExploreNearbyMapState.renderedPoints = [];
}

function Wo_ExploreNearbyHighlightCard(pointKey, scrollIntoView) {
	$('.wo_explore_discovery_card').removeClass('is-active');
	if (!pointKey) {
		return;
	}

	var resolvedPoint = Wo_ExploreNearbyResolveCanonicalPointByKey(pointKey, false);
	var activePointKey = resolvedPoint ? Wo_ExploreNearbyGetItemKey(resolvedPoint) : $.trim(pointKey || '');

	WoExploreNearbyState.activePointKey = activePointKey;
	if (resolvedPoint) {
		WoExploreNearbyState.activePointData = resolvedPoint;
	}

	var card = $('.wo_explore_discovery_card[data-point-key="' + String(activePointKey).replace(/"/g, '\\"') + '"]');
	if (!card.length) {
		return;
	}

	card.addClass('is-active');
	if (scrollIntoView) {
		card.get(0).scrollIntoView({
			behavior: 'smooth',
			block: 'nearest'
		});
	}
}

function Wo_ExploreNearbyGetStickyHeaderOffset() {
	var offset = 50;
	var header = $('.navbar-fixed-top:visible, .header-container:visible').first();
	if (header.length) {
		offset += header.outerHeight() || 0;
	}

	return offset;
}

function Wo_ExploreNearbyScrollToMap() {
	var mapShell = $('#explore-nearby-map-shell');
	if (!mapShell.length) {
		return;
	}

	var targetTop = Math.max(0, mapShell.offset().top - Wo_ExploreNearbyGetStickyHeaderOffset());
	$('html, body').stop(true).animate({
		scrollTop: targetTop
	}, 280);
}

function Wo_ExploreNearbyStartRouteToPointByKey(pointKey, shouldScrollMap) {
	var requestedPointKey = $.trim(pointKey || '');
	var initialTargetPoint = Wo_ExploreNearbyResolvePointByKey(requestedPointKey, false) || Wo_ExploreNearbyResolveCanonicalPointByKey(requestedPointKey, false);

	if (!requestedPointKey || !initialTargetPoint) {
		return;
	}

	Wo_ExploreNearbyResolvePointCoordinates(initialTargetPoint).then(function(resolvedTargetPoint) {
		var canonicalTargetPoint = null;
		var targetPoint = null;
		var targetPointKey = requestedPointKey;
		var marker = null;

		if (!resolvedTargetPoint || !Wo_ExploreNearbyHasValidCoordinates(resolvedTargetPoint.lat, resolvedTargetPoint.lng)) {
			return;
		}

		canonicalTargetPoint = Wo_ExploreNearbyResolveCanonicalDisplayItem(resolvedTargetPoint) || null;
		targetPoint = $.extend({}, canonicalTargetPoint || {}, resolvedTargetPoint || {});
		targetPointKey = targetPoint ? Wo_ExploreNearbyGetItemKey(targetPoint) : requestedPointKey;

		Wo_ExploreNearbyRememberPointSelection();
		Wo_ExploreNearbySetRouteTargetPoint(targetPoint);
		WoExploreNearbyState.openPopupPointKey = null;

		if (WoExploreNearbyMapState.provider === 'google') {
			marker = WoExploreNearbyMapState.googleMarkerLookup[targetPointKey] || WoExploreNearbyMapState.googleMarkerLookup[requestedPointKey] || null;
			if (marker && WoExploreNearbyMapState.map) {
				WoExploreNearbyMapState.map.panTo(Wo_ExploreNearbyGoogleMarkerGetPosition(marker));
			}
		}
		else if (WoExploreNearbyMapState.provider === 'leaflet') {
			marker = WoExploreNearbyMapState.leafletMarkerLookup[targetPointKey] || WoExploreNearbyMapState.leafletMarkerLookup[requestedPointKey] || null;
			if (marker && WoExploreNearbyMapState.map) {
				WoExploreNearbyMapState.map.panTo(marker.getLatLng());
			}
		}

		Wo_ExploreNearbyEnsureSheetAtLeast('medium');
		Wo_ExploreNearbyHighlightCard(targetPointKey, true);
		Wo_ExploreNearbySyncRouteLine();
		Wo_ExploreNearbyScheduleRouteViewportResync(targetPointKey);
		if (shouldScrollMap) {
			Wo_ExploreNearbyScrollToMap();
		}
	}).catch(function() {});
}

function Wo_ExploreNearbyOpenGoogleMarker(marker, focusCard, openPopup) {
	if (!marker) {
		return;
	}

	Wo_ExploreNearbyRememberPointSelection();

	if (!WoExploreNearbyMapState.googleInfoWindow) {
		WoExploreNearbyMapState.googleInfoWindow = new google.maps.InfoWindow();
	}

	var point = marker.woNearbyPoint || null;
	var selectedPoint = Wo_ExploreNearbyResolveCanonicalDisplayItem(point) || point;
	var pointKey = Wo_ExploreNearbyGetItemKey(selectedPoint);
	var shouldOpenPopup = openPopup !== false && Wo_ExploreNearbyShouldOpenMarkerPopup(selectedPoint);
	var markerSelection = null;

	WoExploreNearbyMapState.map.panTo(Wo_ExploreNearbyGoogleMarkerGetPosition(marker));
	Wo_ExploreNearbyEnsureMapSelectionZoom(selectedPoint);
	if (shouldOpenPopup) {
		WoExploreNearbyMapState.googleInfoWindow.setContent(Wo_ExploreNearbyGetPopupHtml(selectedPoint));
		WoExploreNearbyMapState.googleInfoWindow.open({
			map: WoExploreNearbyMapState.map,
			anchor: marker,
			shouldFocus: false
		});
	}
	else {
		WoExploreNearbyMapState.googleInfoWindow.close();
	}

	if (focusCard) {
		var preservedSource = 'marker:google';
		if (WoExploreNearbyState.routeDebug && $.trim(WoExploreNearbyState.routeDebug.status || '') === 'point-selected' && $.trim(WoExploreNearbyState.routeDebug.activePointKey || '') === pointKey && $.trim(WoExploreNearbyState.routeDebug.source || '')) {
			preservedSource = $.trim(WoExploreNearbyState.routeDebug.source);
		}
		markerSelection = Wo_ExploreNearbyApplyMarkerSelection(selectedPoint, {
			allowRoute: true,
			syncRoute: false
		});
		selectedPoint = markerSelection.point || selectedPoint;
		pointKey = markerSelection.pointKey || pointKey;
		WoExploreNearbyState.openPopupPointKey = shouldOpenPopup ? pointKey : null;
		Wo_ExploreNearbySetRouteDebug('point-selected', 'Google marker selected for preview', {
			source: preservedSource,
			provider: WoExploreNearbyMapState.provider || 'google',
			selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
			targetPoint: Wo_ExploreNearbyDescribeDebugPoint(selectedPoint),
			activePointKey: pointKey
		});
		Wo_ExploreNearbyEnsureSheetAtLeast('medium');
		Wo_ExploreNearbyHighlightCard(pointKey, true);
		if (markerSelection && markerSelection.routed) {
			Wo_ExploreNearbySyncRouteLine();
			Wo_ExploreNearbyScheduleRouteViewportResync(pointKey);
		}
	}
}

function Wo_ExploreNearbyBuildGoogleNativePlacePoint(placeId, latLng, placeItem) {
	var resolvedPlace = placeItem || {};
	var resolvedLat = Wo_ExploreNearbyGetGoogleLatLngValue(latLng, 'lat');
	var resolvedLng = Wo_ExploreNearbyGetGoogleLatLngValue(latLng, 'lng');
	var fallbackTitle = Wo_ExploreNearbyNormalizeTextValue(resolvedPlace.title || resolvedPlace.name || defaultPlaceTypeLabel);
	var fallbackLocation = Wo_ExploreNearbyNormalizeTextValue(resolvedPlace.location || '');

	if (Wo_ExploreNearbyHasValidCoordinates(resolvedPlace.lat, resolvedPlace.lng)) {
		resolvedLat = parseFloat(resolvedPlace.lat);
		resolvedLng = parseFloat(resolvedPlace.lng);
	}

	if (!Wo_ExploreNearbyHasValidCoordinates(resolvedLat, resolvedLng)) {
		return null;
	}

	return {
		item_key: $.trim(placeId || resolvedPlace.place_id || '') ? ('place|' + $.trim(placeId || resolvedPlace.place_id || '')) : ('place|google-poi|' + resolvedLat.toFixed(5) + ',' + resolvedLng.toFixed(5)),
		offset_id: 0,
		type: 'place',
		type_label: defaultPlaceTypeLabel,
		title: fallbackTitle || defaultPlaceTypeLabel,
		subtitle: Wo_ExploreNearbyNormalizeTextValue(resolvedPlace.subtitle || resolvedPlace.primary_type_label || defaultPlaceTypeLabel),
		description: '',
		avatar: '',
		url: resolvedPlace.url || Wo_ExploreNearbyBuildGooglePlaceUrl(placeId || $.trim(resolvedPlace.place_id || ''), fallbackTitle, resolvedLat, resolvedLng),
		ajax_url: '',
		place_id: $.trim(placeId || resolvedPlace.place_id || ''),
		location: fallbackLocation,
		location_dynamic: '',
		distance_value: null,
		distance_text: '',
		lat: resolvedLat,
		lng: resolvedLng,
		is_self: false
	};
}

function Wo_ExploreNearbyHandleGoogleNativePlaceSelection(event) {
	var placeId = $.trim((event && event.placeId) || '');
	var clickPosition = {
		lat: Wo_ExploreNearbyGetGoogleLatLngValue(event && event.latLng, 'lat'),
		lng: Wo_ExploreNearbyGetGoogleLatLngValue(event && event.latLng, 'lng')
	};
	var fallbackPoint = Wo_ExploreNearbyBuildGoogleNativePlacePoint(placeId, clickPosition, null);

	if (!placeId && !Wo_ExploreNearbyHasValidCoordinates(clickPosition.lat, clickPosition.lng)) {
		return false;
	}

	if (event && typeof event.stop === 'function') {
		event.stop();
	}

	Wo_ExploreNearbyRememberMapPointerPosition(event);
	Wo_ExploreNearbyRememberPointSelection();
	Wo_ExploreNearbyCloseInfoPopup();

	if (!fallbackPoint) {
		return false;
	}

	Wo_ExploreNearbySetRouteDebug('point-selected', 'Google base-map place selected', {
		source: 'map:google-place',
		provider: WoExploreNearbyMapState.provider || 'google',
		selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
		targetPoint: Wo_ExploreNearbyDescribeDebugPoint(fallbackPoint),
		activePointKey: Wo_ExploreNearbyGetItemKey(fallbackPoint)
	});

	Promise.resolve(placeId ? Wo_ExploreNearbyResolvePlaceById(placeId, fallbackPoint.title || placeId, fallbackPoint.location || fallbackPoint.title || placeId, null) : null).then(function(placeItem) {
		var resolvedPoint = Wo_ExploreNearbyBuildGoogleNativePlacePoint(placeId, clickPosition, placeItem || fallbackPoint) || fallbackPoint;
		var resolvedPointKey = Wo_ExploreNearbyGetItemKey(resolvedPoint);

		Wo_ExploreNearbySetRouteTargetPoint(resolvedPoint);
		WoExploreNearbyState.openPopupPointKey = null;
		Wo_ExploreNearbyEnsureSheetAtLeast('medium');
		Wo_ExploreNearbyEnsurePlacePointCard(resolvedPoint, true);
		Wo_ExploreNearbyEnsureMapSelectionZoom(resolvedPoint);
		if (WoExploreNearbyMapState.map && typeof WoExploreNearbyMapState.map.panTo === 'function') {
			WoExploreNearbyMapState.map.panTo({
				lat: resolvedPoint.lat,
				lng: resolvedPoint.lng
			});
		}
		Wo_ExploreNearbySyncRouteLine();
		Wo_ExploreNearbyScheduleRouteViewportResync(resolvedPointKey);
	}).catch(function() {
		var fallbackPointKey = Wo_ExploreNearbyGetItemKey(fallbackPoint);

		Wo_ExploreNearbySetRouteTargetPoint(fallbackPoint);
		WoExploreNearbyState.openPopupPointKey = null;
		Wo_ExploreNearbyEnsureSheetAtLeast('medium');
		Wo_ExploreNearbyEnsurePlacePointCard(fallbackPoint, true);
		Wo_ExploreNearbySyncRouteLine();
		Wo_ExploreNearbyScheduleRouteViewportResync(fallbackPointKey);
	});

	return true;
}

function Wo_ExploreNearbyHandleGoogleMarkerDomSelection(pointKey) {
	var normalizedPointKey = $.trim(pointKey || '');
	if (!normalizedPointKey) {
		return false;
	}

	var marker = WoExploreNearbyMapState.googleMarkerLookup[normalizedPointKey] || null;
	if (!marker) {
		Wo_ExploreNearbySetRouteDebug('blocked', 'Marker DOM event fired but marker lookup was not found', {
			source: 'marker:dom',
			provider: WoExploreNearbyMapState.provider || 'google',
			selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
			targetPoint: '',
			activePointKey: normalizedPointKey
		});
		return false;
	}

	if (!Wo_ExploreNearbyCanHandleMapSelection(null, 'marker:dom')) {
		return false;
	}

	Wo_ExploreNearbyRememberPointSelection();
	Wo_ExploreNearbySetRouteDebug('point-selected', 'Marker DOM event matched Google marker', {
		source: 'marker:dom',
		provider: WoExploreNearbyMapState.provider || 'google',
		selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
		targetPoint: Wo_ExploreNearbyDescribeDebugPoint(marker.woNearbyPoint || null),
		activePointKey: normalizedPointKey
	});
	Wo_ExploreNearbyOpenGoogleMarker(marker, true, true);
	return true;
}

function Wo_ExploreNearbyHandleGoogleMapPixelSelection(event) {
	if (!event || WoExploreNearbyMapState.provider !== 'google' || Wo_ExploreNearbyWasPointSelectionHandledRecently()) {
		return false;
	}

	if (!Wo_ExploreNearbyCanHandleMapSelection(event, 'map:pixel-fallback')) {
		return false;
	}

	if (Wo_ExploreNearbyIsPageScrollFirstGestureMode()) {
		var originalEvent = event.originalEvent || event;
		var eventType = String(event.type || '').toLowerCase();
		if ((originalEvent && originalEvent.pointerType === 'touch') || eventType.indexOf('touch') === 0) {
			return false;
		}
	}

	var clientX = null;
	var clientY = null;
	if (typeof event.clientX === 'number' && typeof event.clientY === 'number') {
		clientX = event.clientX;
		clientY = event.clientY;
	}
	else if (event.changedTouches && event.changedTouches[0]) {
		clientX = event.changedTouches[0].clientX;
		clientY = event.changedTouches[0].clientY;
	}
	else if (event.touches && event.touches[0]) {
		clientX = event.touches[0].clientX;
		clientY = event.touches[0].clientY;
	}

	var matchedMarker = Wo_ExploreNearbyFindGoogleMarkerByClientPosition(clientX, clientY) || Wo_ExploreNearbyFindNearestGoogleMarkerByClientPosition(clientX, clientY);
	if (!matchedMarker) {
		return false;
	}

	Wo_ExploreNearbyRememberPointSelection();
	Wo_ExploreNearbySetRouteDebug('point-selected', 'Map pixel fallback matched nearest Google marker', {
		source: 'map:pixel-fallback',
		provider: 'google',
		selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
		targetPoint: Wo_ExploreNearbyDescribeDebugPoint(matchedMarker.woNearbyPoint || null),
		activePointKey: Wo_ExploreNearbyGetItemKey(matchedMarker.woNearbyPoint || null)
	});
	Wo_ExploreNearbyOpenGoogleMarker(matchedMarker, true, true);
	return true;
}

function Wo_ExploreNearbyRenderGoogleMarkers(points, options) {
	var resultPoints = Wo_ExploreNearbyNormalizePoints(points);
	var normalizedPoints = Wo_ExploreNearbyGetCombinedPoints(resultPoints);
	var coordinateState = Wo_ExploreNearbyCreateMarkerCoordinateState(normalizedPoints);
	var targetMarker = null;
	var openPointKey = options && options.openPointKey ? options.openPointKey : null;

	Wo_ExploreNearbyResetMapMarkers();

	for (var i = 0; i < normalizedPoints.length; i++) {
		var point = normalizedPoints[i];
		var markerPosition = Wo_ExploreNearbyGetMarkerPosition(point, coordinateState);
		if (!markerPosition) {
			continue;
		}

		var marker = Wo_ExploreNearbyCreateGoogleMapMarker(point, markerPosition);
		Wo_ExploreNearbyBindGoogleMarkerInteraction(marker);
		WoExploreNearbyMapState.googleMarkers.push(marker);
		WoExploreNearbyMapState.googleMarkerLookup[Wo_ExploreNearbyGetItemKey(point)] = marker;

		if (openPointKey && Wo_ExploreNearbyGetItemKey(point) === openPointKey) {
			targetMarker = marker;
		}
	}

	WoExploreNearbyMapState.renderedPoints = normalizedPoints;

	if (!options || options.fit !== false) {
		Wo_ExploreNearbyApplyGoogleViewport(normalizedPoints);
	}

	if (targetMarker) {
		Wo_ExploreNearbyOpenGoogleMarker(targetMarker, false, true);
	}
}

function Wo_ExploreNearbyRenderLeafletMarkers(points, options) {
	var resultPoints = Wo_ExploreNearbyNormalizePoints(points);
	var normalizedPoints = Wo_ExploreNearbyGetCombinedPoints(resultPoints);
	var coordinateState = Wo_ExploreNearbyCreateMarkerCoordinateState(normalizedPoints);
	var targetMarker = null;
	var openPointKey = options && options.openPointKey ? options.openPointKey : null;

	Wo_ExploreNearbyResetMapMarkers();

	for (var i = 0; i < normalizedPoints.length; i++) {
		var point = normalizedPoints[i];
		var markerPosition = Wo_ExploreNearbyGetMarkerPosition(point, coordinateState);
		if (!markerPosition) {
			continue;
		}

		var marker = L.marker([markerPosition.lat, markerPosition.lng], {
			icon: Wo_ExploreNearbyCreateLeafletMarkerIcon(point)
		});
		marker.woNearbyPoint = point;
		if (Wo_ExploreNearbyShouldOpenMarkerPopup(point)) {
			marker.bindPopup(Wo_ExploreNearbyGetPopupHtml(point), {
				maxWidth: 280
			});
		}

		marker.on('click', (function(point, pointKey, marker) {
			return function(event) {
				if (!Wo_ExploreNearbyCanHandleMapSelection(event, 'marker:leaflet') || Wo_ExploreNearbyWasPointSelectionHandledRecently()) {
					return;
				}

				Wo_ExploreNearbyRememberPointSelection();
				var selectedPoint = Wo_ExploreNearbyResolveCanonicalDisplayItem(point) || point;
				var markerSelection = Wo_ExploreNearbyApplyMarkerSelection(selectedPoint, {
					allowRoute: true,
					syncRoute: false
				});
				var selectedPointKey = markerSelection.pointKey || Wo_ExploreNearbyGetItemKey(selectedPoint);
				selectedPoint = markerSelection.point || selectedPoint;
				Wo_ExploreNearbySetRouteDebug('point-selected', 'Leaflet marker selected for preview', {
					source: 'marker:leaflet',
					provider: WoExploreNearbyMapState.provider || 'leaflet',
					selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
					targetPoint: Wo_ExploreNearbyDescribeDebugPoint(selectedPoint),
					activePointKey: selectedPointKey
				});
				Wo_ExploreNearbyEnsureSheetAtLeast('medium');
				WoExploreNearbyMapState.map.panTo(marker.getLatLng());
				Wo_ExploreNearbyEnsureMapSelectionZoom(selectedPoint);
				if (Wo_ExploreNearbyShouldOpenMarkerPopup(selectedPoint)) {
					if (typeof marker.setPopupContent === 'function') {
						marker.setPopupContent(Wo_ExploreNearbyGetPopupHtml(selectedPoint));
					}
					WoExploreNearbyState.openPopupPointKey = selectedPointKey;
					marker.openPopup();
				}
				else {
					WoExploreNearbyState.openPopupPointKey = null;
					if (typeof marker.closePopup === 'function') {
						marker.closePopup();
					}
				}
				Wo_ExploreNearbyHighlightCard(selectedPointKey, true);
				if (markerSelection && markerSelection.routed) {
					Wo_ExploreNearbySyncRouteLine();
					Wo_ExploreNearbyScheduleRouteViewportResync(selectedPointKey);
				}
			};
		})(point, Wo_ExploreNearbyGetItemKey(point), marker));

		marker.addTo(WoExploreNearbyMapState.leafletMarkersLayer);
		Wo_ExploreNearbySetLeafletMarkerZIndex(marker, point);
		WoExploreNearbyMapState.leafletMarkerLookup[Wo_ExploreNearbyGetItemKey(point)] = marker;

		if (openPointKey && Wo_ExploreNearbyGetItemKey(point) === openPointKey) {
			targetMarker = marker;
		}
	}

	WoExploreNearbyMapState.renderedPoints = normalizedPoints;

	if (!options || options.fit !== false) {
		Wo_ExploreNearbyApplyLeafletViewport(normalizedPoints);
	}

	if (targetMarker) {
		Wo_ExploreNearbyEnsureMapSelectionZoom(targetMarker.woNearbyPoint || null);
		if (Wo_ExploreNearbyShouldOpenMarkerPopup(targetMarker.woNearbyPoint)) {
			targetMarker.openPopup();
			WoExploreNearbyState.openPopupPointKey = openPointKey;
		}
		else {
			WoExploreNearbyState.openPopupPointKey = null;
		}
		Wo_ExploreNearbyHighlightCard(openPointKey, true);
	}
}

function Wo_ExploreNearbyRenderMap(points, options) {
	if (WoExploreNearbyMapState.provider === 'google') {
		Wo_ExploreNearbyRenderGoogleMarkers(points, options || {});
	}
	else if (WoExploreNearbyMapState.provider === 'leaflet') {
		Wo_ExploreNearbyRenderLeafletMarkers(points, options || {});
	}

	Wo_ExploreNearbySyncRouteLine();
	$('#map').removeClass('wo_ui_map_state_loading');
	Wo_ExploreNearbyUpdateMapPrompt();
}

function Wo_ExploreNearbyDestroyMap() {
	Wo_ExploreNearbyResetMapMarkers();

	if (WoExploreNearbyMapState.provider === 'leaflet' && WoExploreNearbyMapState.map) {
		WoExploreNearbyMapState.map.remove();
	}

	WoExploreNearbyMapState.provider = null;
	WoExploreNearbyMapState.map = null;
	WoExploreNearbyMapState.leafletMarkersLayer = null;
	WoExploreNearbyMapState.googleMarkers = [];
	WoExploreNearbyMapState.googleInfoWindow = null;
	WoExploreNearbyMapState.googleDirectionsService = null;
	WoExploreNearbyMapState.googleProjectionOverlay = null;
	WoExploreNearbyMapState.leafletMarkerLookup = {};
	WoExploreNearbyMapState.googleMarkerLookup = {};
	WoExploreNearbyMapState.googleRouteLine = null;
	WoExploreNearbyMapState.googleRouteGlow = null;
	WoExploreNearbyMapState.leafletRouteLine = null;
	WoExploreNearbyMapState.renderedPoints = [];
	$('#map').html('').addClass('wo_ui_map_state_loading');
}

function Wo_ExploreNearbyCreateGoogleMap() {
	if (typeof google === 'undefined' || !google.maps || !google.maps.Map || !$('#map').length) {
		return false;
	}

	Wo_ExploreNearbyDestroyMap();
	Wo_ExploreNearbyUpdateMapGestureClass();
	WoExploreNearbyMapState.provider = 'google';
	WoExploreNearbyMapState.map = new google.maps.Map(document.getElementById('map'), {
		center: nearbyMapCenter,
		zoom: 7,
		mapTypeId: google.maps.MapTypeId.ROADMAP,
		mapTypeControl: false,
		gestureHandling: 'greedy',
		fullscreenControl: false,
		mapId: 'vnseea_map_maker'
	});
	Wo_ExploreNearbySetRouteDebug('map-ready', 'Google map initialized', {
		provider: 'google',
		selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
		targetPoint: '',
		activePointKey: WoExploreNearbyState.activePointKey || ''
	});
	WoExploreNearbyMapState.map.addListener('dragstart', function() {
		Wo_ExploreNearbyMarkMapInteractionStart('drag');
	});
	WoExploreNearbyMapState.map.addListener('dragend', function() {
		Wo_ExploreNearbyMarkMapInteractionEnd('drag');
	});
	WoExploreNearbyMapState.map.addListener('zoom_changed', function() {
		Wo_ExploreNearbyMarkMapInteractionStart('zoom');
	});
	WoExploreNearbyMapState.map.addListener('idle', function() {
		Wo_ExploreNearbyHandleMapInteractionSettled();
	});
	Wo_ExploreNearbyEnsureGoogleProjectionOverlay();
	var mapElement = document.getElementById('map');
	if (mapElement && !WoExploreNearbyState.googleMapDomSelectionBound) {
		var mapDomSelectionHandler = function(event) {
			Wo_ExploreNearbyHandleGoogleMapPixelSelection(event);
		};
		var mapPointerCaptureHandler = function(event) {
			Wo_ExploreNearbyHandleMapPointerStart(event);
		};
		mapElement.addEventListener('pointerdown', mapPointerCaptureHandler, true);
		mapElement.addEventListener('mousedown', mapPointerCaptureHandler, true);
		mapElement.addEventListener('touchstart', mapPointerCaptureHandler, true);
		mapElement.addEventListener('pointermove', Wo_ExploreNearbyHandleMapPointerMove, true);
		mapElement.addEventListener('mousemove', Wo_ExploreNearbyHandleMapPointerMove, true);
		mapElement.addEventListener('touchmove', Wo_ExploreNearbyHandleMapPointerMove, true);
		mapElement.addEventListener('pointerup', Wo_ExploreNearbyHandleMapPointerEnd, true);
		mapElement.addEventListener('mouseup', Wo_ExploreNearbyHandleMapPointerEnd, true);
		mapElement.addEventListener('touchend', Wo_ExploreNearbyHandleMapPointerEnd, true);
		mapElement.addEventListener('touchcancel', Wo_ExploreNearbyHandleMapPointerEnd, true);
		mapElement.addEventListener('click', mapDomSelectionHandler, true);
		mapElement.addEventListener('touchend', mapDomSelectionHandler, true);
		WoExploreNearbyState.googleMapDomSelectionBound = true;
	}
	WoExploreNearbyMapState.map.addListener('click', function(event) {
		if (!event || Wo_ExploreNearbyWasPointSelectionHandledRecently() || !Wo_ExploreNearbyCanHandleMapSelection(event, 'map:click-fallback')) {
			return;
		}

		if (event.placeId) {
			Wo_ExploreNearbyHandleGoogleNativePlaceSelection(event);
			return;
		}

		if (!event.latLng) {
			return;
		}

		var nearestMarker = Wo_ExploreNearbyFindNearestGoogleMarkerByLatLng(event.latLng);
		if (!nearestMarker) {
			return;
		}

		Wo_ExploreNearbySetRouteDebug('point-selected', 'Map click matched nearest Google marker', {
			source: 'map:click-fallback',
			provider: 'google',
			selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
			targetPoint: Wo_ExploreNearbyDescribeDebugPoint(nearestMarker.woNearbyPoint || null),
			activePointKey: Wo_ExploreNearbyGetItemKey(nearestMarker.woNearbyPoint || null)
		});
		Wo_ExploreNearbyOpenGoogleMarker(nearestMarker, true, true);
	});
	Wo_ExploreNearbyEnsureGoogleMarkerLibrary().then(function(markerLibrary) {
		if (!markerLibrary || WoExploreNearbyMapState.provider !== 'google' || !WoExploreNearbyMapState.map) {
			return;
		}

		Wo_ExploreNearbyRenderCurrentMap(WoExploreNearbyState.openPopupPointKey || null);
	});
	WoExploreNearbyMapState.googleInfoWindow = new google.maps.InfoWindow();
	WoExploreNearbyMapState.googleDirectionsService = (typeof google.maps.DirectionsService !== 'undefined') ? new google.maps.DirectionsService() : null;
	Wo_ExploreNearbySyncMapGestureMode();
	Wo_ExploreNearbyUpdateMapPrompt();
	return true;
}

function Wo_ExploreNearbyCreateLeafletMap() {
	if (typeof L === 'undefined' || !$('#map').length) {
		return false;
	}

	Wo_ExploreNearbyDestroyMap();
	Wo_ExploreNearbyUpdateMapGestureClass();
	WoExploreNearbyMapState.provider = 'leaflet';
	WoExploreNearbyMapState.map = L.map('map', {
		dragging: true,
		touchZoom: true,
		doubleClickZoom: true,
		boxZoom: false,
		keyboard: false,
		tap: true,
		tapTolerance: 15
	}).setView([nearbyMapCenter.lat, nearbyMapCenter.lng], 7);
	Wo_ExploreNearbySetRouteDebug('map-ready', 'Leaflet map initialized', {
		provider: 'leaflet',
		selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
		targetPoint: '',
		activePointKey: WoExploreNearbyState.activePointKey || ''
	});
	WoExploreNearbyMapState.map.on('dragstart', function() {
		Wo_ExploreNearbyMarkMapInteractionStart('drag');
	});
	WoExploreNearbyMapState.map.on('dragend', function() {
		Wo_ExploreNearbyMarkMapInteractionEnd('drag');
	});
	WoExploreNearbyMapState.map.on('zoomstart', function() {
		Wo_ExploreNearbyMarkMapInteractionStart('zoom');
	});
	WoExploreNearbyMapState.map.on('zoomend', function() {
		Wo_ExploreNearbyMarkMapInteractionEnd('zoom');
		Wo_ExploreNearbyHandleMapInteractionSettled();
	});
	WoExploreNearbyMapState.map.on('click', function(event) {
		if (!event || !event.latlng || Wo_ExploreNearbyWasPointSelectionHandledRecently() || !Wo_ExploreNearbyCanHandleMapSelection(event, 'map:click-fallback')) {
			return;
		}

		var nearestMarker = Wo_ExploreNearbyFindNearestLeafletMarkerByLatLng(event.latlng);
		if (!nearestMarker) {
			return;
		}

		if (typeof nearestMarker.fire === 'function') {
			nearestMarker.fire('click', {
				originalEvent: event.originalEvent || event
			});
		}
	});
	Wo_ExploreNearbySyncMapGestureMode();
	WoExploreNearbyMapState.leafletMarkersLayer = L.layerGroup().addTo(WoExploreNearbyMapState.map);

	var tileConfig = window.WoLeafletMutedMapConfig || {};
	L.tileLayer(
		tileConfig.tileUrl || 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
		$.extend({
			attribution: '',
			maxZoom: 18
		}, tileConfig.tileOptions || {})
	).addTo(WoExploreNearbyMapState.map);

	Wo_ExploreNearbyUpdateMapPrompt();
	return true;
}

function Wo_ExploreNearbyEnsureLeaflet(callback) {
	if (typeof L !== 'undefined') {
		callback();
		return;
	}

	$.getScript('<?php echo $wo['config']['theme_url']; ?>/javascript/leaflet.js?version=<?php echo $wo['config']['version']; ?>', callback);
}

function Wo_ExploreNearbyNeedsShopGeocode(point) {
	if (!point || (point.type !== 'shop' && point.type !== 'page') || !point.location) {
		return false;
	}

	var lat = parseFloat(point.lat);
	var lng = parseFloat(point.lng);

	return isNaN(lat) || isNaN(lng) || (lat === 0 && lng === 0);
}

function Wo_ExploreNearbyGeocodeShopLocation(location) {
	var normalizedLocation = $.trim(location || '');
	if (!normalizedLocation) {
		return Promise.resolve(null);
	}

	if (WoExploreNearbyState.shopGeocodeCache.hasOwnProperty(normalizedLocation)) {
		return Promise.resolve(WoExploreNearbyState.shopGeocodeCache[normalizedLocation]);
	}

	if (!Wo_ExploreNearbyGetGoogleGeocoder()) {
		WoExploreNearbyState.shopGeocodeCache[normalizedLocation] = null;
		return Promise.resolve(null);
	}

	return new Promise(function(resolve) {
		Wo_ExploreNearbyGetGoogleGeocoder().geocode({
			address: normalizedLocation
		}, function(results, status) {
			var geocodedLocation = null;
			if (status === 'OK' && Array.isArray(results) && results[0] && results[0].geometry && results[0].geometry.location) {
				geocodedLocation = {
					lat: results[0].geometry.location.lat(),
					lng: results[0].geometry.location.lng()
				};
			}

			WoExploreNearbyState.shopGeocodeCache[normalizedLocation] = geocodedLocation;
			resolve(geocodedLocation);
		});
	}).catch(function() {
		WoExploreNearbyState.shopGeocodeCache[normalizedLocation] = null;
		return null;
	});
}

function Wo_ExploreNearbySupportsShopCoordinateResolution(point) {
	return !!(point && (point.type === 'shop' || point.type === 'page'));
}

function Wo_ExploreNearbyResolveShopPlaceCoordinatesByPlaceId(placeId, fallbackLocation) {
	var normalizedPlaceId = $.trim(placeId || '');
	var fallbackLabel = $.trim(fallbackLocation || '');
	var cacheKey = normalizedPlaceId ? ('place_id|' + normalizedPlaceId) : '';

	if (!cacheKey) {
		return Promise.resolve(null);
	}

	if (Object.prototype.hasOwnProperty.call(WoExploreNearbyState.shopPlaceCoordinateCache, cacheKey)) {
		return Promise.resolve(WoExploreNearbyState.shopPlaceCoordinateCache[cacheKey]);
	}

	if (WoExploreNearbyState.shopPlaceCoordinatePending[cacheKey]) {
		return WoExploreNearbyState.shopPlaceCoordinatePending[cacheKey];
	}

	WoExploreNearbyState.shopPlaceCoordinatePending[cacheKey] = Wo_ExploreNearbyResolvePlaceById(normalizedPlaceId, fallbackLabel || normalizedPlaceId, fallbackLabel || normalizedPlaceId, null).then(function(placeItem) {
		if (placeItem && Wo_ExploreNearbyHasValidCoordinates(placeItem.lat, placeItem.lng)) {
			return {
				lat: parseFloat(placeItem.lat),
				lng: parseFloat(placeItem.lng),
				location: $.trim(placeItem.location || fallbackLabel)
			};
		}

		if (!Wo_ExploreNearbyGetGoogleGeocoder()) {
			return null;
		}

		return new Promise(function(resolve) {
			Wo_ExploreNearbyGetGoogleGeocoder().geocode({
				placeId: normalizedPlaceId
			}, function(results, status) {
				var resolvedLocation = null;
				if (status === 'OK' && Array.isArray(results) && results[0] && results[0].geometry && results[0].geometry.location) {
					resolvedLocation = {
						lat: results[0].geometry.location.lat(),
						lng: results[0].geometry.location.lng(),
						location: $.trim(results[0].formatted_address || fallbackLabel)
					};
				}

				resolve(resolvedLocation);
			});
		});
	}).catch(function() {
		return null;
	}).then(function(resolvedLocation) {
		WoExploreNearbyState.shopPlaceCoordinateCache[cacheKey] = resolvedLocation;
		delete WoExploreNearbyState.shopPlaceCoordinatePending[cacheKey];
		return resolvedLocation;
	}).catch(function() {
		WoExploreNearbyState.shopPlaceCoordinateCache[cacheKey] = null;
		delete WoExploreNearbyState.shopPlaceCoordinatePending[cacheKey];
		return null;
	});

	return WoExploreNearbyState.shopPlaceCoordinatePending[cacheKey];
}

function Wo_ExploreNearbyResolveShopPointCoordinates(point) {
	var currentPoint = point || null;
	var pointLocation = $.trim((currentPoint && currentPoint.location) || '');
	var fallbackLocation = pointLocation || $.trim((currentPoint && (currentPoint.title || currentPoint.name)) || '');
	var hasCurrentCoordinates = Wo_ExploreNearbyHasValidCoordinates(currentPoint && currentPoint.lat, currentPoint && currentPoint.lng);
	var placeId = Wo_ExploreNearbyGetDiscoveryPlaceId(currentPoint);

	if (!Wo_ExploreNearbySupportsShopCoordinateResolution(currentPoint)) {
		return Promise.resolve(currentPoint);
	}

	return Wo_ExploreNearbyResolveShopPlaceCoordinatesByPlaceId(placeId, fallbackLocation).then(function(placeCoordinates) {
		if (placeCoordinates && Wo_ExploreNearbyHasValidCoordinates(placeCoordinates.lat, placeCoordinates.lng)) {
			return $.extend({}, currentPoint, {
				lat: placeCoordinates.lat,
				lng: placeCoordinates.lng,
				location: pointLocation || $.trim(placeCoordinates.location || '')
			});
		}

		if (hasCurrentCoordinates || !fallbackLocation) {
			return currentPoint;
		}

		return Wo_ExploreNearbyGeocodeShopLocation(fallbackLocation).then(function(geocodedLocation) {
			if (!geocodedLocation) {
				return currentPoint;
			}

			return $.extend({}, currentPoint, {
				lat: geocodedLocation.lat,
				lng: geocodedLocation.lng
			});
		});
	}).catch(function() {
		return currentPoint;
	});
}

function Wo_ExploreNearbyResolvePlacePointCoordinates(point) {
	var currentPoint = point || null;
	var pointLocation = $.trim((currentPoint && currentPoint.location) || '');
	var fallbackTitle = $.trim((currentPoint && (currentPoint.title || currentPoint.name)) || '');
	var fallbackQuery = fallbackTitle || pointLocation;
	var hasCurrentCoordinates = Wo_ExploreNearbyHasValidCoordinates(currentPoint && currentPoint.lat, currentPoint && currentPoint.lng);
	var placeId = Wo_ExploreNearbyGetDiscoveryPlaceId(currentPoint);

	if (!currentPoint || currentPoint.type !== 'place' || hasCurrentCoordinates) {
		return Promise.resolve(currentPoint);
	}

	if (placeId) {
		return Wo_ExploreNearbyResolvePlaceById(placeId, fallbackQuery || placeId, pointLocation || fallbackQuery || placeId, null).then(function(placeItem) {
			if (!placeItem || !Wo_ExploreNearbyHasValidCoordinates(placeItem.lat, placeItem.lng)) {
				return currentPoint;
			}

			return $.extend({}, currentPoint, {
				lat: parseFloat(placeItem.lat),
				lng: parseFloat(placeItem.lng),
				location: pointLocation || $.trim(placeItem.location || fallbackQuery || ''),
				url: currentPoint.url || placeItem.url || Wo_ExploreNearbyBuildGooglePlaceUrl(placeId, fallbackTitle || placeItem.title || fallbackQuery, placeItem.lat, placeItem.lng),
				place_id: placeId || $.trim(placeItem.place_id || '')
			});
		}).catch(function() {
			return currentPoint;
		});
	}

	if (!fallbackQuery) {
		return Promise.resolve(currentPoint);
	}

	return Wo_ExploreNearbyGeocodeSearchPlace(fallbackQuery, '', null).then(function(placeItem) {
		if (!placeItem || !Wo_ExploreNearbyHasValidCoordinates(placeItem.lat, placeItem.lng)) {
			return currentPoint;
		}

		return $.extend({}, currentPoint, {
			lat: parseFloat(placeItem.lat),
			lng: parseFloat(placeItem.lng),
			location: pointLocation || $.trim(placeItem.location || fallbackQuery || '')
		});
	}).catch(function() {
		return currentPoint;
	});
}

function Wo_ExploreNearbyResolvePointCoordinates(point) {
	var currentPoint = point || null;

	if (!currentPoint) {
		return Promise.resolve(null);
	}

	if (Wo_ExploreNearbyHasValidCoordinates(currentPoint.lat, currentPoint.lng)) {
		return Promise.resolve(currentPoint);
	}

	if (Wo_ExploreNearbySupportsShopCoordinateResolution(currentPoint)) {
		return Wo_ExploreNearbyResolveShopPointCoordinates(currentPoint);
	}

	if (currentPoint.type === 'place') {
		return Wo_ExploreNearbyResolvePlacePointCoordinates(currentPoint);
	}

	return Promise.resolve(currentPoint);
}

function Wo_ExploreNearbyResolveVisiblePoints(points) {
	if (!Array.isArray(points) || points.length === 0) {
		return Promise.resolve(points || []);
	}

	return Promise.all(points.map(function(point) {
		return Wo_ExploreNearbyResolveShopPointCoordinates(point);
	}));
}

function Wo_ExploreNearbyRenderCurrentMap(openPointKey) {
	var visiblePoints = Wo_ExploreNearbyGetVisiblePoints();
	var renderToken = ++WoExploreNearbyState.mapRenderToken;
	var pendingFocusPointKey = WoExploreNearbyState.pendingFocusPointKey || null;
	var targetOpenPointKey = openPointKey || WoExploreNearbyState.openPopupPointKey || Wo_ExploreNearbyGetDefaultOpenPointKey();

	if (targetOpenPointKey) {
		var resolvedOpenPoint = Wo_ExploreNearbyResolveCanonicalPointByKey(targetOpenPointKey, false);
		targetOpenPointKey = resolvedOpenPoint ? Wo_ExploreNearbyGetItemKey(resolvedOpenPoint) : targetOpenPointKey;
	}

	$('#map').addClass('wo_ui_map_state_loading');
	if (!Wo_ExploreNearbySyncLocationAnchorState()) {
		Wo_ExploreNearbyResetMapMarkers();
		$('#map').removeClass('wo_ui_map_state_loading');
		Wo_ExploreNearbyUpdateMapPrompt();
		return;
	}

	Wo_ExploreNearbyResolveVisiblePoints(visiblePoints).then(function(resolvedPoints) {
		if (renderToken !== WoExploreNearbyState.mapRenderToken) {
			return;
		}

		Wo_ExploreNearbyRenderMap(resolvedPoints, {
			fit: true,
			openPointKey: targetOpenPointKey || null
		});

		if (pendingFocusPointKey) {
			WoExploreNearbyState.pendingFocusPointKey = null;
			Wo_ExploreNearbyFocusOnMapByKey(pendingFocusPointKey, true);
		}

		Wo_ExploreNearbyUpdateMapPrompt();
	});
}

function Wo_ExploreNearbyFocusOnMapByKey(pointKey, shouldScrollMap) {
	var requestedPointKey = $.trim(pointKey || '');
	var canonicalPoint = Wo_ExploreNearbyResolveCanonicalPointByKey(requestedPointKey, false);
	var targetPointKey = canonicalPoint ? Wo_ExploreNearbyGetItemKey(canonicalPoint) : requestedPointKey;

	if (!requestedPointKey) {
		return;
	}

	Wo_ExploreNearbyRememberPointSelection();
	WoExploreNearbyState.pendingFocusPointKey = null;
	WoExploreNearbyState.activePointKey = targetPointKey;
	WoExploreNearbyState.activePointData = canonicalPoint || null;
	WoExploreNearbyState.openPopupPointKey = null;
	Wo_ExploreNearbySetRouteDebug('point-selected', 'List/card requested focus on map point', {
		source: 'list:focus',
		provider: WoExploreNearbyMapState.provider || 'none',
		selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
		targetPoint: '',
		activePointKey: targetPointKey
	});
	Wo_ExploreNearbyCloseInfoPopup();
	Wo_ExploreNearbyClearRouteTarget();
	var marker = null;
	var targetPoint = canonicalPoint || null;

	if (WoExploreNearbyMapState.provider === 'google') {
		marker = WoExploreNearbyMapState.googleMarkerLookup[targetPointKey] || WoExploreNearbyMapState.googleMarkerLookup[requestedPointKey] || null;
		if (marker) {
			targetPoint = canonicalPoint || marker.woNearbyPoint || null;
			Wo_ExploreNearbyPreparePointPreview(targetPoint || null);
			Wo_ExploreNearbySetRouteDebug('point-selected', 'Google marker focused from list', {
				source: 'list:focus',
				provider: WoExploreNearbyMapState.provider || 'google',
				selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
				targetPoint: Wo_ExploreNearbyDescribeDebugPoint(targetPoint),
				activePointKey: targetPointKey
			});
			WoExploreNearbyMapState.map.panTo(Wo_ExploreNearbyGoogleMarkerGetPosition(marker));
			Wo_ExploreNearbyEnsureMapSelectionZoom(targetPoint);
			if (Wo_ExploreNearbyShouldOpenMarkerPopup(targetPoint)) {
				if (!WoExploreNearbyMapState.googleInfoWindow) {
					WoExploreNearbyMapState.googleInfoWindow = new google.maps.InfoWindow();
				}
				WoExploreNearbyMapState.googleInfoWindow.setContent(Wo_ExploreNearbyGetPopupHtml(targetPoint));
				WoExploreNearbyMapState.googleInfoWindow.open({
					map: WoExploreNearbyMapState.map,
					anchor: marker,
					shouldFocus: false
				});
				WoExploreNearbyState.openPopupPointKey = targetPointKey;
			}
		}
	}
	else if (WoExploreNearbyMapState.provider === 'leaflet') {
		marker = WoExploreNearbyMapState.leafletMarkerLookup[targetPointKey] || WoExploreNearbyMapState.leafletMarkerLookup[requestedPointKey] || null;
		if (marker && WoExploreNearbyMapState.map) {
			targetPoint = canonicalPoint || marker.woNearbyPoint || null;
			Wo_ExploreNearbyPreparePointPreview(targetPoint || null);
			Wo_ExploreNearbySetRouteDebug('point-selected', 'Leaflet marker focused from list', {
				source: 'list:focus',
				provider: WoExploreNearbyMapState.provider || 'leaflet',
				selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
				targetPoint: Wo_ExploreNearbyDescribeDebugPoint(targetPoint),
				activePointKey: targetPointKey
			});
			WoExploreNearbyMapState.map.panTo(marker.getLatLng());
			Wo_ExploreNearbyEnsureMapSelectionZoom(targetPoint);
			if (Wo_ExploreNearbyShouldOpenMarkerPopup(targetPoint) && typeof marker.openPopup === 'function') {
				if (typeof marker.setPopupContent === 'function') {
					marker.setPopupContent(Wo_ExploreNearbyGetPopupHtml(targetPoint));
				}
				marker.openPopup();
				WoExploreNearbyState.openPopupPointKey = targetPointKey;
			}
		}
	}

	if (marker && targetPoint && Wo_ExploreNearbyHasValidCoordinates(targetPoint.lat, targetPoint.lng)) {
		var selfPoint = Wo_ExploreNearbyGetCurrentUserPoint();
		if (selfPoint && !Wo_ExploreNearbyIsSamePoint(selfPoint, targetPoint) && !Wo_ExploreNearbyShouldEnforceSelectionZoom(targetPoint)) {
			Wo_ExploreNearbyFitRouteViewport([], [selfPoint, targetPoint]);
		}
	}

	if (!marker) {
		Wo_ExploreNearbySetRouteDebug('blocked', 'Requested point key is not rendered on the current map yet', {
			source: 'list:focus',
			provider: WoExploreNearbyMapState.provider || 'none',
			selfPoint: Wo_ExploreNearbyDescribeDebugPoint(Wo_ExploreNearbyGetCurrentUserPoint() || currentUserMapPoint),
			targetPoint: '',
			activePointKey: targetPointKey
		});
		Wo_ExploreNearbyRenderCurrentMap(null);
	}

	Wo_ExploreNearbyEnsureSheetAtLeast('medium');
	Wo_ExploreNearbyHighlightCard(targetPointKey, true);
	if (shouldScrollMap) {
		Wo_ExploreNearbyScrollToMap();
	}
}

function Wo_ExploreNearbyUpdateUi() {
	var totalResults = Wo_ExploreNearbyGetTotalResultsCount();
