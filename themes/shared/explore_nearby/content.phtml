}

function Wo_ExploreNearbyShouldPreferItem(candidateItem, existingItem) {
	var candidateFamily = Wo_ExploreNearbyGetDiscoveryItemFamily(candidateItem);
	var existingFamily = Wo_ExploreNearbyGetDiscoveryItemFamily(existingItem);
	var candidateRelated = Wo_ExploreNearbyIsRelatedPlacePoint(candidateItem);
	var existingRelated = Wo_ExploreNearbyIsRelatedPlacePoint(existingItem);
	var candidateRichness = 0;
	var existingRichness = 0;

	if (!existingItem) {
		return true;
	}

	if (candidateFamily !== existingFamily) {
		if (candidateFamily === 'pageish' && existingFamily === 'place') {
			return true;
		}

		if (candidateFamily === 'place' && existingFamily === 'pageish') {
			return false;
		}
	}

	if (candidateRelated !== existingRelated) {
		return !candidateRelated;
	}

	var candidatePinned = Wo_ExploreNearbyIsPinnedPoint(candidateItem);
	var existingPinned = Wo_ExploreNearbyIsPinnedPoint(existingItem);
	if (candidatePinned !== existingPinned) {
		return candidatePinned;
	}

	var candidatePinnedOnly = !!(candidateItem && (Wo_ExploreNearbyIsTruthyFlag(candidateItem.is_pinned_only) || Wo_ExploreNearbyIsTruthyFlag(candidateItem.isPinnedOnly)));
	var existingPinnedOnly = !!(existingItem && (Wo_ExploreNearbyIsTruthyFlag(existingItem.is_pinned_only) || Wo_ExploreNearbyIsTruthyFlag(existingItem.isPinnedOnly)));
	if (candidatePinnedOnly !== existingPinnedOnly) {
		return candidatePinnedOnly;
	}

	var candidateHasCoords = Wo_ExploreNearbyHasValidCoordinates(parseFloat(candidateItem && candidateItem.lat), parseFloat(candidateItem && candidateItem.lng));
	var existingHasCoords = Wo_ExploreNearbyHasValidCoordinates(parseFloat(existingItem && existingItem.lat), parseFloat(existingItem && existingItem.lng));
	if (candidateHasCoords !== existingHasCoords) {
		return candidateHasCoords;
	}

	candidateRichness = Wo_ExploreNearbyGetItemDataRichnessScore(candidateItem);
	existingRichness = Wo_ExploreNearbyGetItemDataRichnessScore(existingItem);
	if (candidateRichness !== existingRichness) {
		return candidateRichness > existingRichness;
	}

	return false;
}

function Wo_ExploreNearbyNormalizeDiscoveryItems(items) {
	var normalizedItems = [];
	if (!Array.isArray(items)) {
		return normalizedItems;
	}

	for (var i = 0; i < items.length; i++) {
		var item = items[i] || {};
		var lat = item.lat;
		var lng = item.lng;
		var itemType = 'user';
		if (item.type === 'shop') {
			itemType = 'shop';
		}
		else if (item.type === 'page') {
			itemType = 'page';
		}
		else if (item.type === 'place') {
			itemType = 'place';
		}
		var parsedLat = (lat !== null && lat !== undefined && lat !== '') ? parseFloat(lat) : null;
		var parsedLng = (lng !== null && lng !== undefined && lng !== '') ? parseFloat(lng) : null;
		var hasCoordinates = Wo_ExploreNearbyHasValidCoordinates(parsedLat, parsedLng);
		var dynamicLocation = Wo_ExploreNearbyNormalizeTextValue(item.location_dynamic || item.dynamic_location || '');
		var itemLocation = Wo_ExploreNearbyNormalizeTextValue(item.location || '');
		var distanceValue = null;

		if (item.distance_value !== null && item.distance_value !== undefined && item.distance_value !== '' && !isNaN(parseFloat(item.distance_value))) {
			distanceValue = parseFloat(item.distance_value);
		}
		else if (hasCoordinates) {
			var hasCurrentUserLocation = Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng);
			if (hasCurrentUserLocation) {
				distanceValue = Wo_ExploreNearbyGetDistanceKm(
					{lat: parseFloat(currentUserMapPoint.lat), lng: parseFloat(currentUserMapPoint.lng)},
					{lat: parsedLat, lng: parsedLng}
				);
			}
		}

		if (itemType === 'user' && hasCoordinates) {
			itemLocation = dynamicLocation || Wo_ExploreNearbyBuildCoordinateText(parsedLat, parsedLng);
		}

		normalizedItems.push({
			item_key: Wo_ExploreNearbyGetItemKey(item),
			offset_id: item.offset_id ? parseInt(item.offset_id, 10) : 0,
			type: itemType,
			type_label: Wo_ExploreNearbyNormalizeTextValue(item.type_label || (itemType === 'shop' ? defaultShopTypeLabel : (itemType === 'page' ? defaultPageTypeLabel : (itemType === 'place' ? defaultPlaceTypeLabel : defaultUserTypeLabel)))),
			title: Wo_ExploreNearbyNormalizeTextValue(item.title || item.name || ''),
			subtitle: Wo_ExploreNearbyNormalizeTextValue(item.subtitle || ''),
			description: Wo_ExploreNearbyNormalizeTextValue(item.description || ''),
			avatar: item.avatar || '',
			url: item.url || '',
			ajax_url: item.ajax_url || '',
			place_id: Wo_ExploreNearbyGetDiscoveryPlaceId(item),
			primary_type: $.trim(item.primary_type || ''),
			primary_type_label: Wo_ExploreNearbyNormalizeTextValue(item.primary_type_label || ''),
			svg_icon_mask_uri: $.trim(item.svg_icon_mask_uri || ''),
			icon_background_color: $.trim(item.icon_background_color || ''),
			is_related_place: Wo_ExploreNearbyIsRelatedPlacePoint(item),
			is_pinned: Wo_ExploreNearbyIsPinnedPoint(item),
			is_pinned_only: Wo_ExploreNearbyIsTruthyFlag(item.is_pinned_only) || Wo_ExploreNearbyIsTruthyFlag(item.isPinnedOnly),
			location: itemLocation,
			location_dynamic: dynamicLocation || (itemType === 'user' && hasCoordinates ? Wo_ExploreNearbyBuildCoordinateText(parsedLat, parsedLng) : ''),
			distance_value: distanceValue,
			distance_text: item.distance_text || Wo_ExploreNearbyFormatDistance(distanceValue),
			lat: hasCoordinates ? parsedLat : null,
			lng: hasCoordinates ? parsedLng : null,
			is_self: !!(item.is_self || item.isSelf)
		});
	}

	return normalizedItems;
}

function Wo_ExploreNearbyFindDuplicateItemIndex(items, candidateItem, options) {
	var candidateKey = Wo_ExploreNearbyGetDiscoveryDedupKey(candidateItem);
	var i = 0;

	for (i = 0; i < items.length; i++) {
		var existingItem = items[i];
		var existingKey = Wo_ExploreNearbyGetDiscoveryDedupKey(existingItem);

		if (candidateKey && existingKey && candidateKey === existingKey) {
			return i;
		}

		if (Wo_ExploreNearbyAreItemsDuplicate(candidateItem, existingItem, options)) {
			return i;
		}
	}

	return -1;
}

function Wo_ExploreNearbyFindPreferredDuplicateItem(candidateItem, candidateItems, options) {
	var matchedItem = null;
	var i = 0;

	for (i = 0; i < candidateItems.length; i++) {
		if (!Wo_ExploreNearbyAreItemsDuplicate(candidateItem, candidateItems[i], options)) {
			continue;
		}

		if (!matchedItem || Wo_ExploreNearbyShouldPreferItem(candidateItems[i], matchedItem)) {
			matchedItem = candidateItems[i];
		}
	}

	return matchedItem;
}

function Wo_ExploreNearbyMergeUniqueItems(existingItems, incomingItems, options) {
	var mergedItems = [];
	var normalizedExisting = Wo_ExploreNearbyNormalizeDiscoveryItems(existingItems);
	var normalizedIncoming = Wo_ExploreNearbyNormalizeDiscoveryItems(incomingItems);
	var combinedItems = normalizedExisting.concat(normalizedIncoming);

	for (var i = 0; i < combinedItems.length; i++) {
		var item = combinedItems[i];
		var duplicateIndex = Wo_ExploreNearbyFindDuplicateItemIndex(mergedItems, item, options);

		if (duplicateIndex !== -1) {
			if (Wo_ExploreNearbyShouldPreferItem(item, mergedItems[duplicateIndex])) {
				mergedItems[duplicateIndex] = item;
			}

			continue;
		}

		mergedItems.push(item);
	}

	return mergedItems;
}

function Wo_ExploreNearbyResolveCanonicalPlaceItems(items, canonicalItems, options) {
	var mergeOptions = $.extend({}, options || {});
	var dropMatchedDuplicates = !!mergeOptions.dropMatchedDuplicates;
	var normalizedItems = Wo_ExploreNearbyNormalizeDiscoveryItems(items || []);
	var normalizedCanonicalItems = Wo_ExploreNearbyNormalizeDiscoveryItems(canonicalItems || []);
	var resolvedItems = [];
	var i = 0;

	delete mergeOptions.dropMatchedDuplicates;

	for (i = 0; i < normalizedItems.length; i++) {
		var nextItem = normalizedItems[i];
		var canonicalMatch = null;

		if (Wo_ExploreNearbyGetDiscoveryItemFamily(nextItem) === 'place') {
			canonicalMatch = Wo_ExploreNearbyFindPreferredDuplicateItem(nextItem, normalizedCanonicalItems, mergeOptions);
		}

		if (canonicalMatch) {
			if (!dropMatchedDuplicates) {
				resolvedItems.push($.extend({}, canonicalMatch));
			}
			continue;
		}

		resolvedItems.push(nextItem);
	}

	return Wo_ExploreNearbyMergeUniqueItems([], resolvedItems, mergeOptions);
}

function Wo_ExploreNearbySortItems(items) {
	return items.sort(function(firstItem, secondItem) {
		var firstHasDistance = firstItem.distance_value !== null && firstItem.distance_value !== undefined && !isNaN(firstItem.distance_value);
		var secondHasDistance = secondItem.distance_value !== null && secondItem.distance_value !== undefined && !isNaN(secondItem.distance_value);

		if (firstHasDistance && secondHasDistance) {
			if (firstItem.distance_value === secondItem.distance_value) {
				return String(firstItem.title || '').localeCompare(String(secondItem.title || ''));
			}

			return firstItem.distance_value - secondItem.distance_value;
		}

		if (firstHasDistance) {
			return -1;
		}

		if (secondHasDistance) {
			return 1;
		}

		return String(firstItem.title || '').localeCompare(String(secondItem.title || ''));
	});
}

function Wo_ExploreNearbyGetOrderedShopItems() {
	var normalizedItems = Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.shopsItems || []);
	var regularItems = [];
	var pinnedOnlyItems = [];

	for (var i = 0; i < normalizedItems.length; i++) {
		if (normalizedItems[i].is_pinned_only) {
			pinnedOnlyItems.push(normalizedItems[i]);
			continue;
		}

		regularItems.push(normalizedItems[i]);
	}

	return regularItems.concat(pinnedOnlyItems);
}

function Wo_ExploreNearbyGetPinnedMapItems() {
	var orderedShopItems = Wo_ExploreNearbyGetOrderedShopItems();
	var pinnedItems = [];

	for (var i = 0; i < orderedShopItems.length; i++) {
		if (orderedShopItems[i].type === 'shop' && orderedShopItems[i].is_pinned) {
			pinnedItems.push(orderedShopItems[i]);
		}
	}

	return pinnedItems;
}

function Wo_ExploreNearbyMovePinnedOnlyToEnd(items) {
	var regularItems = [];
	var pinnedOnlyItems = [];

	for (var i = 0; i < items.length; i++) {
		if (items[i] && items[i].is_pinned_only) {
			pinnedOnlyItems.push(items[i]);
			continue;
		}

		regularItems.push(items[i]);
	}

	return regularItems.concat(pinnedOnlyItems);
}

function Wo_ExploreNearbyGetPlaceSearchDisplayItems() {
	return Wo_ExploreNearbyResolveCanonicalPlaceItems(
		WoExploreNearbyState.placeSearchResults || [],
		Wo_ExploreNearbyGetOrderedShopItems(),
		{}
	);
}

function Wo_ExploreNearbyGetMergedItems() {
	if (Wo_ExploreNearbyIsPlaceSearchMode()) {
		return Wo_ExploreNearbySortItems(Wo_ExploreNearbyGetPlaceSearchDisplayItems());
	}

	var mergedItems = [];

	if (WoExploreNearbyState.usersEnabled) {
		mergedItems = mergedItems.concat(Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.usersItems || []));
	}
	if (WoExploreNearbyState.shopsEnabled) {
		mergedItems = mergedItems.concat(Wo_ExploreNearbyGetOrderedShopItems());
	}
	mergedItems = mergedItems.concat(Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.relatedPlaceItems || []));

	var dedupedItems = Wo_ExploreNearbyMergeUniqueItems([], mergedItems);

	dedupedItems = Wo_ExploreNearbySortItems(dedupedItems);
	dedupedItems = Wo_ExploreNearbyMovePinnedOnlyToEnd(dedupedItems);

	var selectedAnchorItems = Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.selectedAnchorItem ? [WoExploreNearbyState.selectedAnchorItem] : []);
	if (selectedAnchorItems.length) {
		var selectedAnchorItem = selectedAnchorItems[0];
		var selectedAnchorDuplicateIndex = Wo_ExploreNearbyFindDuplicateItemIndex(dedupedItems, selectedAnchorItem);
		if (selectedAnchorDuplicateIndex !== -1) {
			dedupedItems.splice(selectedAnchorDuplicateIndex, 1);
		}
		dedupedItems.unshift(selectedAnchorItem);
	}

	return dedupedItems;
}

function Wo_ExploreNearbyGetVisiblePoints() {
	var items = [];
	if (Wo_ExploreNearbyIsPlaceSearchMode()) {
		items = Wo_ExploreNearbyMergeUniqueItems(Wo_ExploreNearbyGetMergedItems(), Wo_ExploreNearbyGetPinnedMapItems());
	}
	else {
		items = Wo_ExploreNearbyGetMergedItems();
	}
	var points = [];

	for (var i = 0; i < items.length; i++) {
		points.push({
			item_key: items[i].item_key,
			name: items[i].title,
			lat: items[i].lat,
			lng: items[i].lng,
			avatar: items[i].avatar,
			url: items[i].url,
			ajax_url: items[i].ajax_url,
			place_id: items[i].place_id,
			primary_type: items[i].primary_type,
			primary_type_label: items[i].primary_type_label,
			svg_icon_mask_uri: items[i].svg_icon_mask_uri,
			icon_background_color: items[i].icon_background_color,
			location: items[i].location,
			type: items[i].type,
			type_label: items[i].type_label,
			is_related_place: items[i].is_related_place,
			is_pinned: items[i].is_pinned,
			is_pinned_only: items[i].is_pinned_only,
			is_self: items[i].is_self,
			isSelf: items[i].is_self
		});
	}

	return points;
}

function Wo_ExploreNearbyGetTotalResultsCount() {
	if (Wo_ExploreNearbyIsPlaceSearchMode()) {
		return Wo_ExploreNearbyGetMergedItems().length;
	}

	return (WoExploreNearbyState.usersEnabled ? (WoExploreNearbyState.usersCount || 0) : 0) +
		(WoExploreNearbyState.shopsEnabled ? (WoExploreNearbyState.shopsCount || 0) : 0) +
		Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.relatedPlaceItems || []).length;
}

function Wo_ExploreNearbyGetLoadedResultsCount() {
	if (Wo_ExploreNearbyIsPlaceSearchMode()) {
		return Wo_ExploreNearbyGetMergedItems().length;
	}

	return Wo_ExploreNearbyGetMergedItems().length;
}

function Wo_ExploreNearbyGetMergedItemByKey(pointKey) {
	var normalizedPointKey = $.trim(pointKey || '');
	var items = Wo_ExploreNearbyGetMergedItems();
	for (var i = 0; i < items.length; i++) {
		if (Wo_ExploreNearbyGetItemKey(items[i]) === normalizedPointKey) {
			return items[i];
		}
	}

	return null;
}

function Wo_ExploreNearbyClearRouteTarget(skipClearRouteLine) {
	var hadRouteTarget = !!($.trim(WoExploreNearbyState.routeTargetPointKey || '') || WoExploreNearbyState.routeTargetPointData);
	WoExploreNearbyState.routeTargetPointKey = null;
	WoExploreNearbyState.routeTargetPointData = null;

	if (hadRouteTarget) {
		WoExploreNearbyState.routeRenderToken++;
		if (skipClearRouteLine !== true) {
			Wo_ExploreNearbyClearRouteLine();
		}
	}
}

function Wo_ExploreNearbySetPreviewPoint(point) {
	var normalizedItems = Wo_ExploreNearbyNormalizeDiscoveryItems(point ? [point] : []);
	var previewPoint = normalizedItems.length ? normalizedItems[0] : null;

	previewPoint = Wo_ExploreNearbyResolveCanonicalDisplayItem(previewPoint) || previewPoint;
	var previewPointKey = previewPoint ? Wo_ExploreNearbyGetItemKey(previewPoint) : null;

	WoExploreNearbyState.previewPointKey = previewPointKey;
	WoExploreNearbyState.previewPointData = previewPoint;
	WoExploreNearbyState.activePointKey = previewPointKey;
	WoExploreNearbyState.activePointData = previewPoint;
}

function Wo_ExploreNearbySetRouteTargetPoint(point) {
	var normalizedItems = Wo_ExploreNearbyNormalizeDiscoveryItems(point ? [point] : []);
	var routePoint = normalizedItems.length ? normalizedItems[0] : null;

	routePoint = Wo_ExploreNearbyResolveCanonicalDisplayItem(routePoint) || routePoint;
	var routePointKey = routePoint ? Wo_ExploreNearbyGetItemKey(routePoint) : null;

	WoExploreNearbyState.routeTargetPointKey = routePointKey;
	WoExploreNearbyState.routeTargetPointData = routePoint;
	Wo_ExploreNearbySetPreviewPoint(routePoint);
}

function Wo_ExploreNearbyApplyMarkerSelection(point, options) {
	var normalizedItems = Wo_ExploreNearbyNormalizeDiscoveryItems(point ? [point] : []);
	var selectedPoint = normalizedItems.length ? normalizedItems[0] : null;
	var pointKey = selectedPoint ? Wo_ExploreNearbyGetItemKey(selectedPoint) : '';
	var selectionOptions = options || {};
	var shouldRoute = false;

	if (!selectedPoint) {
		return {
			point: null,
			pointKey: '',
			routed: false
		};
	}

	shouldRoute = selectionOptions.forceRoute === true || (selectionOptions.allowRoute !== false && Wo_ExploreNearbyCanRouteToItem(selectedPoint));
	if (shouldRoute) {
		Wo_ExploreNearbySetRouteTargetPoint(selectedPoint);
		if (selectionOptions.syncRoute !== false) {
			Wo_ExploreNearbySyncRouteLine();
			Wo_ExploreNearbyScheduleRouteViewportResync(pointKey);
		}
	}
	else {
		Wo_ExploreNearbyPreparePointPreview(selectedPoint);
	}

	return {
		point: selectedPoint,
		pointKey: pointKey,
		routed: shouldRoute
	};
}

function Wo_ExploreNearbyExitPlaceSearchMode() {
	var hadChanges = Wo_ExploreNearbyIsPlaceSearchMode() ||
		Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.placeSearchResults || []).length > 0 ||
		!!WoExploreNearbyState.previewPointKey ||
		!!WoExploreNearbyState.previewPointData ||
		!!WoExploreNearbyState.routeTargetPointKey ||
		!!WoExploreNearbyState.routeTargetPointData;

	WoExploreNearbyState.isPlaceSearchMode = false;
	WoExploreNearbyState.placeSearchQuery = '';
	WoExploreNearbyState.placeSearchResults = [];
	WoExploreNearbyState.previewPointKey = null;
	WoExploreNearbyState.previewPointData = null;
	Wo_ExploreNearbyClearRouteTarget();

	return hadChanges;
}

function Wo_ExploreNearbyShouldUsePlaceSearchQuery(query, selectedSuggestionItem) {
	var normalizedQuery = $.trim(query || '');
	var suggestionType = $.trim((selectedSuggestionItem && selectedSuggestionItem.type) || '');

	if (normalizedQuery.length < 2) {
		return false;
	}

	if (normalizedQuery.charAt(0) === '@') {
		return false;
	}

	if (suggestionType === 'user' || suggestionType === 'page') {
		return false;
	}

	return true;
}

function Wo_ExploreNearbyGetPlaceSearchCenterPoint(anchorItem) {
	var normalizedAnchor = Wo_ExploreNearbyNormalizeDiscoveryItems(anchorItem ? [anchorItem] : []);
	if (normalizedAnchor.length && Wo_ExploreNearbyHasValidCoordinates(normalizedAnchor[0].lat, normalizedAnchor[0].lng)) {
		return normalizedAnchor[0];
	}

	if (Wo_ExploreNearbyHasSearchCenter()) {
		return {
			item_key: 'place-search-center',
			type: 'place',
			type_label: defaultPlaceTypeLabel,
			title: WoExploreNearbyState.searchCenterLabel || defaultPlaceTypeLabel,
			location: WoExploreNearbyState.searchCenterLabel || '',
			lat: parseFloat(WoExploreNearbyState.searchCenterLat),
			lng: parseFloat(WoExploreNearbyState.searchCenterLng)
		};
	}

	return Wo_ExploreNearbyGetCurrentUserPoint();
}

function Wo_ExploreNearbyFormatPrimaryTypeLabel(primaryType) {
	var normalizedType = $.trim(primaryType || '');
	if (!normalizedType) {
		return defaultPlaceTypeLabel;
	}

	return normalizedType.replace(/_/g, ' ').replace(/\b\w/g, function(letter) {
		return letter.toUpperCase();
	});
}

function Wo_ExploreNearbyBuildGooglePlaceUrl(placeId, title, lat, lng) {
	var normalizedPlaceId = $.trim(placeId || '');
	if (normalizedPlaceId) {
		return 'https://www.google.com/maps/place/?q=place_id:' + encodeURIComponent(normalizedPlaceId);
	}

	if (Wo_ExploreNearbyHasValidCoordinates(lat, lng)) {
		return 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(parseFloat(lat) + ',' + parseFloat(lng));
	}

	return title ? ('https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(title)) : '';
}

function Wo_ExploreNearbyGetDistanceValue() {
	return parseInt($('#nearby-users-distance').val(), 10) || defaultDistanceValue;
}

function Wo_ExploreNearbyGetSearchValue() {
	return $.trim($('#nearby-username').val() || '');
}

function Wo_ExploreNearbyGetNormalizedSearchValue() {
	return Wo_ExploreNearbyGetSearchValue().toLowerCase();
}

function Wo_ExploreNearbyCanUseGooglePlacesAutocomplete() {
	return typeof google !== 'undefined' &&
		google.maps &&
		google.maps.places &&
		typeof google.maps.places.AutocompleteService === 'function';
}

function Wo_ExploreNearbyCanUseGooglePlacesImportLibrary() {
	return typeof google !== 'undefined' &&
		google.maps &&
		typeof google.maps.importLibrary === 'function';
}

function Wo_ExploreNearbyCanUseGoogleMarkerImportLibrary() {
	return typeof google !== 'undefined' &&
		google.maps &&
		typeof google.maps.importLibrary === 'function';
}

function Wo_ExploreNearbyEnsureGoogleMarkerLibrary() {
	if (!Wo_ExploreNearbyCanUseGoogleMarkerImportLibrary()) {
		return Promise.resolve(null);
	}

	if (WoExploreNearbyState.userGoogleMarkerLibrary === false) {
		return Promise.resolve(null);
	}

	if (WoExploreNearbyState.userGoogleMarkerLibrary) {
		return Promise.resolve(WoExploreNearbyState.userGoogleMarkerLibrary);
	}

	if (WoExploreNearbyState.userGoogleMarkerLibraryPromise) {
		return WoExploreNearbyState.userGoogleMarkerLibraryPromise;
	}

	WoExploreNearbyState.userGoogleMarkerLibraryPromise = google.maps.importLibrary('marker').then(function(markerLibrary) {
		WoExploreNearbyState.userGoogleMarkerLibrary = markerLibrary || {};
		WoExploreNearbyState.userGoogleMarkerLibraryPromise = null;
		return WoExploreNearbyState.userGoogleMarkerLibrary;
	}).catch(function() {
		WoExploreNearbyState.userGoogleMarkerLibrary = false;
		WoExploreNearbyState.userGoogleMarkerLibraryPromise = null;
		return null;
	});

	return WoExploreNearbyState.userGoogleMarkerLibraryPromise;
}

function Wo_ExploreNearbyEnsureGooglePlacesLibrary() {
	if (!Wo_ExploreNearbyCanUseGooglePlacesImportLibrary()) {
		return Promise.resolve(null);
	}

	if (WoExploreNearbyState.userGooglePlacesLibrary === false) {
		return Promise.resolve(null);
	}

	if (WoExploreNearbyState.userGooglePlacesLibrary) {
		return Promise.resolve(WoExploreNearbyState.userGooglePlacesLibrary);
	}

	if (WoExploreNearbyState.userGooglePlacesLibraryPromise) {
		return WoExploreNearbyState.userGooglePlacesLibraryPromise;
	}

	WoExploreNearbyState.userGooglePlacesLibraryPromise = google.maps.importLibrary('places').then(function(placesLibrary) {
		WoExploreNearbyState.userGooglePlacesLibrary = placesLibrary || {};
		WoExploreNearbyState.userGooglePlacesLibraryPromise = null;
		return WoExploreNearbyState.userGooglePlacesLibrary;
	}).catch(function() {
		WoExploreNearbyState.userGooglePlacesLibrary = false;
		WoExploreNearbyState.userGooglePlacesLibraryPromise = null;
		return null;
	});

	return WoExploreNearbyState.userGooglePlacesLibraryPromise;
}

function Wo_ExploreNearbyGetGooglePlaceText(textValue) {
	if (!textValue) {
		return '';
	}

	if (typeof textValue === 'string') {
		return $.trim(textValue);
	}

	if (typeof textValue.text === 'string') {
		return $.trim(textValue.text);
	}

	if (typeof textValue.toString === 'function') {
		return $.trim(textValue.toString());
	}

	return '';
}

function Wo_ExploreNearbyGetSuggestionTypeLabel(item) {
	if (item && item.type_label) {
		return item.type_label;
	}
	if (item && item.type === 'page') {
		return defaultPageTypeLabel;
	}
	if (item && item.type === 'place') {
		return defaultPlaceTypeLabel;
	}

	return defaultUserTypeLabel;
}

function Wo_ExploreNearbyGetSearchPlaceCacheKey(query, placeId) {
	var normalizedPlaceId = $.trim(placeId || '');
	var normalizedQuery = $.trim(query || '').toLowerCase();

	if (normalizedPlaceId) {
		return 'place_id|' + normalizedPlaceId;
	}

	return 'query|' + normalizedQuery;
}

function Wo_ExploreNearbyResetSearchSelectionHint() {
	WoExploreNearbyState.searchSelectionHintMode = '';
	WoExploreNearbyState.searchSelectionHintQuery = '';
	WoExploreNearbyState.searchSelectionHintItemType = '';
	WoExploreNearbyState.searchSelectionHintItemData = null;
	WoExploreNearbyState.searchSelectionHintPlaceId = '';
	WoExploreNearbyState.searchSelectionHintPlacePrediction = null;
}

function Wo_ExploreNearbySyncSearchSelectionHint() {
	if (!WoExploreNearbyState.searchSelectionHintQuery) {
		return;
	}
	if (Wo_ExploreNearbyGetNormalizedSearchValue() !== WoExploreNearbyState.searchSelectionHintQuery) {
		Wo_ExploreNearbyResetSearchSelectionHint();
	}
}

function Wo_ExploreNearbyAbortSuggestionRequest() {
	if (WoExploreNearbyState.searchSuggestionRequest && WoExploreNearbyState.searchSuggestionRequest.readyState !== 4) {
		WoExploreNearbyState.searchSuggestionRequest.abort();
	}

	WoExploreNearbyState.searchSuggestionRequest = null;
}

function Wo_ExploreNearbyCloseSuggestions() {
	WoExploreNearbyState.searchSuggestionToken++;
	Wo_ExploreNearbyAbortSuggestionRequest();
	WoExploreNearbyState.searchSuggestionItems = [];
	WoExploreNearbyState.searchSuggestionActiveIndex = -1;
	Wo_ExploreNearbyResetSuggestionPointerTracking();
	$('#explore-nearby-search-suggestions').empty().addClass('wo_explore_nearby_hidden');
}

function Wo_ExploreNearbyDeduplicateSuggestions(items) {
	var uniqueItems = [];

	for (var i = 0; i < items.length; i++) {
		var item = items[i] || {};
		var duplicateIndex = Wo_ExploreNearbyFindDuplicateItemIndex(uniqueItems, item, {
			strictAutocomplete: true
		});

		if (duplicateIndex !== -1) {
			if (Wo_ExploreNearbyShouldPreferItem(item, uniqueItems[duplicateIndex])) {
				uniqueItems[duplicateIndex] = $.extend({}, uniqueItems[duplicateIndex], item);
			}
			continue;
		}

		uniqueItems.push(item);
	}

	return uniqueItems;
}

function Wo_ExploreNearbyGetSuggestionOriginPoint() {
	if (Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng)) {
		return {
			lat: parseFloat(currentUserMapPoint.lat),
			lng: parseFloat(currentUserMapPoint.lng)
		};
	}

	if (Wo_ExploreNearbyHasValidCoordinates(nearbyMapCenter.lat, nearbyMapCenter.lng)) {
		return {
			lat: parseFloat(nearbyMapCenter.lat),
			lng: parseFloat(nearbyMapCenter.lng)
		};
	}

	return null;
}

function Wo_ExploreNearbyGetSuggestionDistanceKm(item) {
	var suggestion = item || {};
	var distanceMeters = parseFloat(suggestion.distance_meters);
	var distanceKm = parseFloat(suggestion.distance_km);
	var lat = parseFloat(suggestion.lat);
	var lng = parseFloat(suggestion.lng);
	var originPoint = Wo_ExploreNearbyGetSuggestionOriginPoint();

	if (!isNaN(distanceMeters) && distanceMeters >= 0) {
		return distanceMeters / 1000;
	}

	if (!isNaN(distanceKm) && distanceKm >= 0) {
		return distanceKm;
	}

	if (!originPoint || !Wo_ExploreNearbyHasValidCoordinates(lat, lng)) {
		return null;
	}

	return Wo_ExploreNearbyGetDistanceKm(originPoint, {
		lat: lat,
		lng: lng
	});
}

function Wo_ExploreNearbySortSuggestions(items) {
	return (items || []).slice().sort(function(firstItem, secondItem) {
		var firstDistance = Wo_ExploreNearbyGetSuggestionDistanceKm(firstItem);
		var secondDistance = Wo_ExploreNearbyGetSuggestionDistanceKm(secondItem);
		var firstHasDistance = firstDistance !== null && !isNaN(firstDistance);
		var secondHasDistance = secondDistance !== null && !isNaN(secondDistance);
		var firstType = String((firstItem && firstItem.type) || '');
		var secondType = String((secondItem && secondItem.type) || '');

		if (firstHasDistance && secondHasDistance) {
			if (Math.abs(firstDistance - secondDistance) > 0.01) {
				return firstDistance - secondDistance;
			}
		}
		else if (firstHasDistance) {
			return -1;
		}
		else if (secondHasDistance) {
			return 1;
		}

		if (firstType === 'place' && secondType !== 'place') {
			return -1;
		}
		if (secondType === 'place' && firstType !== 'place') {
			return 1;
		}

		return String((firstItem && (firstItem.title || firstItem.search_value || '')) || '').localeCompare(
			String((secondItem && (secondItem.title || secondItem.search_value || '')) || '')
		);
	});
}

function Wo_ExploreNearbyRenderSuggestionHtml(item, index) {
	var safeType = Wo_ExploreNearbyEscapeHtml(item.type || 'user');
	var decodedTitle = Wo_ExploreNearbyNormalizeTextValue(item.title || '');
	var decodedSubtitle = Wo_ExploreNearbyNormalizeTextValue(item.subtitle || '');
	var decodedLocation = Wo_ExploreNearbyNormalizeTextValue(item.location || '');
	var decodedTypeLabel = Wo_ExploreNearbyNormalizeTextValue(Wo_ExploreNearbyGetSuggestionTypeLabel(item));
	var safeTitle = Wo_ExploreNearbyEscapeHtml(decodedTitle);
	var safeSubtitle = Wo_ExploreNearbyEscapeHtml(decodedSubtitle);
	var safeLocation = Wo_ExploreNearbyEscapeHtml(decodedLocation);
	var safeTypeLabel = Wo_ExploreNearbyEscapeHtml(decodedTypeLabel);
	var avatarHtml = '<span>' + Wo_ExploreNearbyEscapeHtml(Wo_ExploreNearbyGetInitials(decodedTitle || decodedTypeLabel)) + '</span>';
	var activeClass = (index === WoExploreNearbyState.searchSuggestionActiveIndex) ? ' is-active' : '';

	if (item.avatar) {
		avatarHtml = '<img src="' + Wo_ExploreNearbyEscapeHtml(item.avatar) + '" alt="' + safeTitle + '">';
	}
	else if (item.type === 'place') {
		avatarHtml = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2a7 7 0 0 1 7 7c0 4.97-5.06 11.13-6.25 12.52a1 1 0 0 1-1.5 0C10.06 20.13 5 13.97 5 9a7 7 0 0 1 7-7m0 9.5A2.5 2.5 0 1 0 12 6a2.5 2.5 0 0 0 0 5.5"/></svg>';
	}

	return '<button type="button" class="wo_explore_discovery_search_suggestion type-' + safeType + activeClass + '" data-index="' + index + '">' +
		'<span class="wo_explore_discovery_search_suggestion_media">' + avatarHtml + '</span>' +
		'<span class="wo_explore_discovery_search_suggestion_body">' +
			'<span class="wo_explore_discovery_search_suggestion_title">' + safeTitle + '</span>' +
			(safeSubtitle ? '<span class="wo_explore_discovery_search_suggestion_subtitle">' + safeSubtitle + '</span>' : '') +
			(safeLocation ? '<span class="wo_explore_discovery_search_suggestion_location">' + safeLocation + '</span>' : '') +
		'</span>' +
		'<span class="wo_explore_discovery_search_suggestion_badge">' + safeTypeLabel + '</span>' +
	'</button>';
}

function Wo_ExploreNearbyRenderSuggestions() {
	var container = $('#explore-nearby-search-suggestions');
	var items = WoExploreNearbyState.searchSuggestionItems || [];
	var html = '';

	if (!items.length) {
		container.empty().addClass('wo_explore_nearby_hidden');
		return;
	}

	for (var i = 0; i < items.length; i++) {
		html += Wo_ExploreNearbyRenderSuggestionHtml(items[i], i);
	}

	container.html(html).removeClass('wo_explore_nearby_hidden');
}

function Wo_ExploreNearbySetSuggestionItems(items) {
	var normalizedItems = Wo_ExploreNearbySortSuggestions(Wo_ExploreNearbyDeduplicateSuggestions(items || [])).slice(0, 8);

	WoExploreNearbyState.searchSuggestionItems = normalizedItems;
	WoExploreNearbyState.searchSuggestionActiveIndex = -1;
	Wo_ExploreNearbyRenderSuggestions();
}

function Wo_ExploreNearbyEnsureSuggestionVisible(index) {
	var container = $('#explore-nearby-search-suggestions');
	var activeItem = container.find('.wo_explore_discovery_search_suggestion').eq(index);

	if (!activeItem.length || typeof activeItem[0].scrollIntoView !== 'function') {
		return;
	}

	activeItem[0].scrollIntoView({
		block: 'nearest'
	});
}

function Wo_ExploreNearbyMoveSuggestion(step) {
	var items = WoExploreNearbyState.searchSuggestionItems || [];
	var nextIndex = 0;

	if (!items.length) {
		return;
	}

	if (WoExploreNearbyState.searchSuggestionActiveIndex < 0) {
		nextIndex = (step < 0) ? (items.length - 1) : 0;
	}
	else {
		nextIndex = WoExploreNearbyState.searchSuggestionActiveIndex + step;
		if (nextIndex < 0) {
			nextIndex = items.length - 1;
		}
		if (nextIndex >= items.length) {
			nextIndex = 0;
		}
	}

	WoExploreNearbyState.searchSuggestionActiveIndex = nextIndex;
	Wo_ExploreNearbyRenderSuggestions();
	Wo_ExploreNearbyEnsureSuggestionVisible(nextIndex);
}

function Wo_ExploreNearbyFetchEntitySuggestions(query) {
	var normalizedQuery = $.trim(query || '');
	var originPoint = Wo_ExploreNearbyGetSuggestionOriginPoint();
	var requestData = {
		f: 'explore_nearby_suggestions',
		query: normalizedQuery,
		limit: 8
	};

	if (normalizedQuery.length < 1) {
		return Promise.resolve([]);
	}

	if (originPoint) {
		requestData.origin_lat = originPoint.lat;
		requestData.origin_lng = originPoint.lng;
	}

	Wo_ExploreNearbyAbortSuggestionRequest();
	WoExploreNearbyState.searchSuggestionRequest = $.ajax({
		url: Wo_Ajax_Requests_File(),
		type: 'GET',
		dataType: 'json',
		data: requestData
	});

	return new Promise(function(resolve) {
		WoExploreNearbyState.searchSuggestionRequest.done(function(data) {
			resolve((data && data.status === 200 && Array.isArray(data.items)) ? data.items : []);
		}).fail(function(xhr, status) {
			if (status === 'abort') {
				resolve([]);
				return;
			}

			resolve([]);
		});
	});
}

function Wo_ExploreNearbyFetchLocationSuggestions(query) {
	var normalizedQuery = $.trim(query || '');
	var predictionLimit = 8;

	if (normalizedQuery.length < 3) {
		return Promise.resolve([]);
	}

	return Wo_ExploreNearbyEnsureGooglePlacesLibrary().then(function(placesLibrary) {
		var request = {
			input: normalizedQuery
		};
		var originPoint = Wo_ExploreNearbyGetSuggestionOriginPoint();

		if (originPoint) {
			request.origin = {
				lat: parseFloat(originPoint.lat),
				lng: parseFloat(originPoint.lng)
			};
		}

		if (!placesLibrary || !placesLibrary.AutocompleteSuggestion || typeof placesLibrary.AutocompleteSuggestion.fetchAutocompleteSuggestions !== 'function') {
			return null;
		}

		return placesLibrary.AutocompleteSuggestion.fetchAutocompleteSuggestions(request).then(function(response) {
			var items = [];
			var suggestionList = (response && Array.isArray(response.suggestions)) ? response.suggestions : [];

			if (!suggestionList.length) {
				return items;
			}

			items = suggestionList.map(function(suggestion) {
				var placePrediction = suggestion && suggestion.placePrediction ? suggestion.placePrediction : null;
				var fullText = '';
				var mainText = '';
				var secondaryText = '';

				if (!placePrediction) {
					return null;
				}

				fullText = Wo_ExploreNearbyGetGooglePlaceText(placePrediction.text);
				mainText = Wo_ExploreNearbyGetGooglePlaceText(placePrediction.mainText);
				secondaryText = Wo_ExploreNearbyGetGooglePlaceText(placePrediction.secondaryText);

				return {
					type: 'place',
					type_label: defaultPlaceTypeLabel,
					title: $.trim(mainText || fullText || normalizedQuery),
					subtitle: $.trim(secondaryText || ''),
					location: $.trim(fullText || normalizedQuery),
					avatar: '',
					search_value: $.trim(fullText || normalizedQuery),
					place_id: placePrediction.placeId || '',
					place_prediction: placePrediction,
					distance_meters: (placePrediction && typeof placePrediction.distanceMeters === 'number') ? placePrediction.distanceMeters : null
				};
			}).filter(function(item) {
				return !!item;
			});

			items = Wo_ExploreNearbySortSuggestions(items).slice(0, predictionLimit);

			return items;
		}).catch(function() {
			return null;
		});
	}).then(function(items) {
		if (items !== null) {
			return items;
		}

		if (Wo_ExploreNearbyCanUseGoogleGeocoder()) {
			if (!WoExploreNearbyState.userGoogleGeocoder) {
				WoExploreNearbyState.userGoogleGeocoder = new google.maps.Geocoder();
			}

			return new Promise(function(resolve) {
				WoExploreNearbyState.userGoogleGeocoder.geocode({
					address: normalizedQuery
				}, function(results, status) {
					var geocodeItems = [];
					var geocodeResults = Array.isArray(results) ? results : [];

					if (status === 'OK' && geocodeResults.length > 0) {
						geocodeItems = geocodeResults.slice(0, predictionLimit).map(function(result) {
							var placeItem = null;
							if (result.geometry && result.geometry.location) {
								placeItem = Wo_ExploreNearbyBuildSearchPlaceItem(normalizedQuery, {
									lat: result.geometry.location.lat(),
									lng: result.geometry.location.lng(),
									title: $.trim((result.address_components && result.address_components[0] && result.address_components[0].long_name) || normalizedQuery),
									location: $.trim(result.formatted_address || normalizedQuery)
								});
							}

							return {
								type: 'place',
								type_label: defaultPlaceTypeLabel,
								title: $.trim((result.address_components && result.address_components[0] && result.address_components[0].long_name) || normalizedQuery),
								subtitle: '',
								location: $.trim(result.formatted_address || normalizedQuery),
								avatar: '',
								search_value: $.trim(result.formatted_address || normalizedQuery),
								place_item: placeItem,
								lat: (placeItem && placeItem.lat) ? placeItem.lat : null,
								lng: (placeItem && placeItem.lng) ? placeItem.lng : null
							};
						});
					}

					resolve(Wo_ExploreNearbySortSuggestions(geocodeItems).slice(0, predictionLimit));
				});
			});
		}

		return [];
	});
}

function Wo_ExploreNearbyRequestSuggestions() {
	var query = Wo_ExploreNearbyGetSearchValue();
	var requestToken = ++WoExploreNearbyState.searchSuggestionToken;

	if (query.length < 1) {
		Wo_ExploreNearbyCloseSuggestions();
		return;
	}

	Promise.all([
		Wo_ExploreNearbyFetchEntitySuggestions(query),
		Wo_ExploreNearbyFetchLocationSuggestions(query)
	]).then(function(results) {
		var currentQuery = Wo_ExploreNearbyGetSearchValue();
		var items = [];
		var entityItems = results[0] || [];
		var locationItems = results[1] || [];

		if (requestToken !== WoExploreNearbyState.searchSuggestionToken || currentQuery !== query) {
			return;
		}

		items = items.concat(locationItems, entityItems);
		Wo_ExploreNearbySetSuggestionItems(items);
	}).catch(function() {
		if (requestToken !== WoExploreNearbyState.searchSuggestionToken) {
			return;
		}

		Wo_ExploreNearbyCloseSuggestions();
	});
}

function Wo_ExploreNearbySelectSuggestion(item) {
	var nextValue = $.trim((item && (item.search_value || item.location || item.title)) || '');
	var normalizedValue = nextValue.toLowerCase();

	if (!item || !nextValue) {
		return;
	}

	clearTimeout(WoExploreNearbyState.searchTimer);
	clearTimeout(WoExploreNearbyState.searchSuggestionTimer);
	$('#nearby-username').val(nextValue);

	if (item.type === 'user' || item.type === 'page' || item.type === 'place') {
		WoExploreNearbyState.searchSelectionHintMode = 'anchor';
		WoExploreNearbyState.searchSelectionHintQuery = normalizedValue;
		WoExploreNearbyState.searchSelectionHintItemType = item.type;
		WoExploreNearbyState.searchSelectionHintItemData = $.extend({}, item);
		WoExploreNearbyState.searchSelectionHintPlaceId = '';
		WoExploreNearbyState.searchSelectionHintPlacePrediction = null;
		if (item.type === 'place') {
			WoExploreNearbyState.searchSelectionHintPlaceId = $.trim(item.place_id || '');
			WoExploreNearbyState.searchSelectionHintPlacePrediction = item.place_prediction || null;
		}
	}
	else {
		Wo_ExploreNearbyResetSearchSelectionHint();
	}

	if (item.type === 'place' && item.place_item) {
		WoExploreNearbyState.searchPlaceCache[Wo_ExploreNearbyGetSearchPlaceCacheKey(normalizedValue, item.place_id || '')] = item.place_item;
	}

	Wo_ExploreNearbyCloseSuggestions();
	Wo_ExploreNearbyLoad(false);
}

function Wo_ExploreNearbySelectSuggestionByIndex(index) {
	var items = WoExploreNearbyState.searchSuggestionItems || [];

	if (index < 0 || index >= items.length) {
		return;
	}

	Wo_ExploreNearbySelectSuggestion(items[index]);
}

function Wo_ExploreNearbyGetSuggestionMoveThresholdPx() {
	return Wo_ExploreNearbyIsCompactViewport() ? 12 : 8;
}

function Wo_ExploreNearbyResetSuggestionPointerTracking() {
	WoExploreNearbyState.searchSuggestionPointerDownIndex = -1;
	WoExploreNearbyState.searchSuggestionPointerStartX = null;
	WoExploreNearbyState.searchSuggestionPointerStartY = null;
	WoExploreNearbyState.searchSuggestionPointerMoved = false;
}

function Wo_ExploreNearbyMarkSuggestionInteractionActive(event, index) {
	var point = Wo_ExploreNearbyGetInteractionClientPoint(event);
	clearTimeout(WoExploreNearbyState.searchSuggestionInteractionTimer);
	WoExploreNearbyState.isSuggestionInteraction = true;
	WoExploreNearbyState.searchSuggestionSuppressClickUntil = 0;
	WoExploreNearbyState.searchSuggestionPointerDownIndex = isNaN(index) ? -1 : index;
	WoExploreNearbyState.searchSuggestionPointerMoved = false;

	if (!point) {
		WoExploreNearbyState.searchSuggestionPointerStartX = null;
		WoExploreNearbyState.searchSuggestionPointerStartY = null;
		return;
	}

	WoExploreNearbyState.searchSuggestionPointerStartX = point.clientX;
	WoExploreNearbyState.searchSuggestionPointerStartY = point.clientY;
}

function Wo_ExploreNearbyTrackSuggestionPointerMove(event) {
	var point = Wo_ExploreNearbyGetInteractionClientPoint(event);
	var moveThreshold = Wo_ExploreNearbyGetSuggestionMoveThresholdPx();

	if (WoExploreNearbyState.searchSuggestionPointerDownIndex < 0 || WoExploreNearbyState.searchSuggestionPointerMoved) {
		return;
	}

	if (!point || WoExploreNearbyState.searchSuggestionPointerStartX === null || WoExploreNearbyState.searchSuggestionPointerStartY === null) {
		return;
	}

	if (Math.abs(point.clientX - WoExploreNearbyState.searchSuggestionPointerStartX) > moveThreshold || Math.abs(point.clientY - WoExploreNearbyState.searchSuggestionPointerStartY) > moveThreshold) {
		WoExploreNearbyState.searchSuggestionPointerMoved = true;
		WoExploreNearbyState.searchSuggestionSuppressClickUntil = Date.now() + 420;
	}
}

function Wo_ExploreNearbyShouldIgnoreSuggestionClick(index) {
	if (Date.now() < (WoExploreNearbyState.searchSuggestionSuppressClickUntil || 0)) {
		return true;
	}

	if (WoExploreNearbyState.searchSuggestionPointerDownIndex >= 0 && !isNaN(index) && WoExploreNearbyState.searchSuggestionPointerDownIndex !== index) {
		return true;
	}

	return false;
}

function Wo_ExploreNearbyShouldHandleSuggestionReleaseSelection(event) {
	var pointerType = Wo_ExploreNearbyGetInteractionPointerType(event);
	var eventType = String((Wo_ExploreNearbyGetInteractionEvent(event) && Wo_ExploreNearbyGetInteractionEvent(event).type) || (event && event.type) || '').toLowerCase();

	return pointerType === 'touch' || pointerType === 'pen' || eventType.indexOf('touch') === 0;
}

function Wo_ExploreNearbyScheduleSuggestionInteractionRelease() {
	clearTimeout(WoExploreNearbyState.searchSuggestionInteractionTimer);
	WoExploreNearbyState.searchSuggestionInteractionTimer = setTimeout(function() {
		WoExploreNearbyState.isSuggestionInteraction = false;
	}, 260);
}

function Wo_ExploreNearbyReleaseSuggestionInteraction() {
	if (WoExploreNearbyState.searchSuggestionPointerMoved) {
		WoExploreNearbyState.searchSuggestionSuppressClickUntil = Math.max(WoExploreNearbyState.searchSuggestionSuppressClickUntil || 0, Date.now() + 420);
	}

	Wo_ExploreNearbyResetSuggestionPointerTracking();
	Wo_ExploreNearbyScheduleSuggestionInteractionRelease();
}

function Wo_ExploreNearbyHandleSuggestionPointerRelease(event, index) {
	if (isNaN(index) || !Wo_ExploreNearbyShouldHandleSuggestionReleaseSelection(event)) {
		Wo_ExploreNearbyReleaseSuggestionInteraction();
		return;
	}

	if (Wo_ExploreNearbyShouldIgnoreSuggestionClick(index) || WoExploreNearbyState.searchSuggestionPointerMoved || WoExploreNearbyState.searchSuggestionPointerDownIndex !== index) {
		Wo_ExploreNearbyReleaseSuggestionInteraction();
		return;
	}

	Wo_ExploreNearbyHandleSuggestionSelection(index);
}

function Wo_ExploreNearbyHandleSuggestionSelection(index) {
	if (isNaN(index)) {
		return;
	}

	clearTimeout(WoExploreNearbyState.searchSuggestionInteractionTimer);
	clearTimeout(WoExploreNearbyState.searchSuggestionTimer);
	Wo_ExploreNearbyResetSuggestionPointerTracking();
	WoExploreNearbyState.isSuggestionInteraction = true;
	setTimeout(function() {
		WoExploreNearbyState.isSuggestionInteraction = false;
	}, 260);
	WoExploreNearbyState.lastSuggestionSelectionAt = Date.now();
	Wo_ExploreNearbySelectSuggestionByIndex(index);
}

function Wo_ExploreNearbyQueryHasLocationHint(query) {
	var normalizedQuery = $.trim((query || '').toLowerCase());
	var compactQuery = '';
	var locationTokens = [
		' street ',
		' road ',
		' avenue ',
		' boulevard ',
		' district ',
		' ward ',
		' city ',
		' province ',
		' lane ',
		' route ',
		' block ',
		' building ',
		' apartment ',
		' floor ',
		' tower ',
		' highway ',
		' thanh pho ',
		' quan ',
		' phuong ',
		' huyen ',
		' thi tran ',
		' thi xa ',
		' xa ',
		' duong ',
		' ngo ',
		' hem '
	];
	var i = 0;

	if (normalizedQuery.length < 3 || normalizedQuery.charAt(0) === '@') {
		return false;
	}

	if (/[,#]/.test(normalizedQuery) || /\/\d+/.test(normalizedQuery)) {
		return true;
	}

	if (/(^|\s)\d+[A-Za-z0-9-]*(\s|$)/.test(normalizedQuery) || /\d+\s+[A-Za-z]/.test(normalizedQuery)) {
		return true;
	}

	compactQuery = ' ' + normalizedQuery.replace(/\s+/g, ' ') + ' ';
	for (i = 0; i < locationTokens.length; i++) {
		if (compactQuery.indexOf(locationTokens[i]) !== -1) {
			return true;
		}
	}

	return false;
}

function Wo_ExploreNearbyHasSearchCenter() {
	return WoExploreNearbyState.searchMode === 'location' &&
		Wo_ExploreNearbyHasValidCoordinates(WoExploreNearbyState.searchCenterLat, WoExploreNearbyState.searchCenterLng);
}

function Wo_ExploreNearbyHasLocationAnchor() {
	return Wo_ExploreNearbyHasValidCoordinates(currentUserMapPoint.lat, currentUserMapPoint.lng) || Wo_ExploreNearbyHasSearchCenter();
}

function Wo_ExploreNearbySyncLocationAnchorState() {
	var hasAnchor = Wo_ExploreNearbyHasLocationAnchor();
	WoExploreNearbyState.hasLocationAnchor = hasAnchor;
	if (hasAnchor) {
		WoExploreNearbyState.locationBootstrapState = 'ready';
	}
	else if (WoExploreNearbyState.locationBootstrapState !== 'denied' && WoExploreNearbyState.locationBootstrapState !== 'waiting') {
		WoExploreNearbyState.locationBootstrapState = 'waiting';
	}

	return hasAnchor;
}

function Wo_ExploreNearbyGetMapPromptTitle() {
	if (WoExploreNearbyState.locationBootstrapState === 'denied') {
		return locationDeniedPromptText;
	}

	return locationEnablePromptText;
}

function Wo_ExploreNearbyGetMapPromptHtml() {
	var actionLabel = WoExploreNearbyState.locationRequestPending ? requestingLocationLabel : useMyLocationLabel;
	var actionDisabled = WoExploreNearbyState.locationRequestPending ? ' disabled aria-disabled="true"' : '';
	return '<div class="wo_explore_discovery_map_prompt_card">' +
		'<div class="wo_explore_discovery_map_prompt_icon">' +
			'<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2a7 7 0 0 1 7 7c0 5.25-7 13-7 13S5 14.25 5 9a7 7 0 0 1 7-7m0 4.5A2.5 2.5 0 1 0 12 11.5A2.5 2.5 0 0 0 12 6.5"/></svg>' +
		'</div>' +
		'<div class="wo_explore_discovery_map_prompt_title">' + Wo_ExploreNearbyEscapeHtml(Wo_ExploreNearbyGetMapPromptTitle()) + '</div>' +
		'<div class="wo_explore_discovery_map_prompt_text">' + Wo_ExploreNearbyEscapeHtml(locationSearchHintText) + '</div>' +
		'<button type="button" class="wo_explore_discovery_map_prompt_action" id="explore-nearby-map-prompt-action"' + actionDisabled + ' onpointerdown="Wo_ExploreNearbyHandleLocationPromptAction(); return false;" onmousedown="Wo_ExploreNearbyHandleLocationPromptAction(); return false;" ontouchstart="Wo_ExploreNearbyHandleLocationPromptAction(); return false;" onclick="return false;">' +
			'<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M11 2v2.07A8.001 8.001 0 0 0 4.07 11H2v2h2.07A8.001 8.001 0 0 0 11 19.93V22h2v-2.07A8.001 8.001 0 0 0 19.93 13H22v-2h-2.07A8.001 8.001 0 0 0 13 4.07V2zm1 4a6 6 0 1 1 0 12a6 6 0 0 1 0-12m0 3a3 3 0 1 0 0 6a3 3 0 0 0 0-6"/></svg>' +
			'<span>' + Wo_ExploreNearbyEscapeHtml(actionLabel) + '</span>' +
		'</button>' +
	'</div>';
}

function Wo_ExploreNearbyHandleLocationPromptAction() {
	var now = Date.now();
	if ((now - (WoExploreNearbyState.lastLocationPromptActionAt || 0)) < 450 || WoExploreNearbyState.locationRequestPending) {
		return false;
	}

	WoExploreNearbyState.lastLocationPromptActionAt = now;
	WoExploreNearbyState.locationBootstrapState = 'waiting';
	Wo_ExploreNearbyRequestCurrentUserLocation(true);
	return false;
}

function Wo_ExploreNearbyUpdateLocationTrigger() {
	var trigger = $('#explore-nearby-location-trigger');
	var mapTrigger = $('#explore-nearby-my-location');
	if (!trigger.length) {
		trigger = $();
	}

	var isPending = (WoExploreNearbyState.locationRequestPending === true);
	var nextLabel = isPending ? requestingLocationLabel : useMyLocationLabel;

	trigger.prop('disabled', isPending).attr('aria-disabled', isPending ? 'true' : 'false');
	trigger.find('.wo_explore_discovery_location_trigger_label').text(nextLabel);

	if (mapTrigger.length) {
		mapTrigger.prop('disabled', isPending).attr('aria-disabled', isPending ? 'true' : 'false').attr('title', nextLabel).attr('aria-label', nextLabel);
	}
}

function Wo_ExploreNearbyUpdateMapPrompt() {
	var prompt = $('#explore-nearby-map-prompt');
	var map = $('#map');
	var mapLocationButton = $('#explore-nearby-my-location');
	if (!prompt.length || !map.length) {
		return;
	}

	if (Wo_ExploreNearbySyncLocationAnchorState()) {
		map.removeClass('is-awaiting-location');
		prompt.empty().addClass('wo_explore_nearby_hidden');
		mapLocationButton.removeClass('wo_explore_nearby_hidden');
		Wo_ExploreNearbyUpdateLocationTrigger();
		Wo_ExploreNearbyMaybeAutoOpenSheetOnboarding();
		return;
	}

	map.addClass('is-awaiting-location');
	prompt.html(Wo_ExploreNearbyGetMapPromptHtml()).removeClass('wo_explore_nearby_hidden');
	mapLocationButton.addClass('wo_explore_nearby_hidden');
	Wo_ExploreNearbyUpdateLocationTrigger();
	Wo_ExploreNearbyMaybeAutoOpenSheetOnboarding();
}

function Wo_ExploreNearbyGetRequestSearchValue() {
	return Wo_ExploreNearbyHasSearchCenter() ? '' : Wo_ExploreNearbyGetSearchValue();
}

function Wo_ExploreNearbyGetUiMetaText() {
	var metaParts = [];
	var searchValue = Wo_ExploreNearbyGetSearchValue();
	var selectedAnchorItem = Wo_ExploreNearbyGetSelectedAnchorItem();
	if (Wo_ExploreNearbyIsPlaceSearchMode()) {
		var placeResultsCount = Wo_ExploreNearbyGetMergedItems().length;
		var centerLabel = selectedAnchorItem && selectedAnchorItem.title ? selectedAnchorItem.title : (WoExploreNearbyState.searchCenterLabel || '');

		if (WoExploreNearbyState.placeSearchQuery) {
			metaParts.push('"' + WoExploreNearbyState.placeSearchQuery + '"');
		}
		if (centerLabel) {
			metaParts.push(centerLabel);
		}

		metaParts.push(placeResultsCount > 0 ? (placeResultsCount + ' places') : 'No places found');
		return metaParts.join(' - ');
	}

	var localResults = (WoExploreNearbyState.usersEnabled ? (WoExploreNearbyState.usersCount || 0) : 0) +
		(WoExploreNearbyState.shopsEnabled ? (WoExploreNearbyState.shopsCount || 0) : 0);
	var relatedPlacesCount = Wo_ExploreNearbyNormalizeDiscoveryItems(WoExploreNearbyState.relatedPlaceItems || []).length;

	if (selectedAnchorItem && selectedAnchorItem.title) {
		metaParts.push('"' + selectedAnchorItem.title + '"');
	}
	else if (searchValue) {
		metaParts.push('"' + searchValue + '"');
	}

	if (localResults > 0) {
		metaParts.push(localResults + ' nearby');
	}
	else {
		metaParts.push('Nearby people and shops');
	}

	if (relatedPlacesCount > 0) {
		metaParts.push(relatedPlacesCount + ' related places');
	}

	return metaParts.join(' - ');
}

function Wo_ExploreNearbyIsCompactViewport() {
	if (window.matchMedia) {
		return window.matchMedia('(max-width: 767px)').matches;
	}

	return $(window).width() <= 767;
}

function Wo_ExploreNearbyGetStageAvailableHeight() {
	return Math.max(460, window.innerHeight - Wo_ExploreNearbyGetStickyHeaderOffset() - 10);
}

function Wo_ExploreNearbyUpdateViewportHeight() {
	var container = $('.wo_explore_discovery').get(0);
	var shellHeight = Wo_ExploreNearbyGetStageAvailableHeight();
	var topbar = document.getElementById('explore-nearby-map-shell') ? document.querySelector('#explore-nearby-map-shell .wo_explore_discovery_topbar') : null;
	var headerOffset = Wo_ExploreNearbyGetStickyHeaderOffset();
	var topbarHeight = topbar ? Math.ceil($(topbar).outerHeight() || 0) : 52;

	if (container) {
		container.style.setProperty('--wo-nearby-shell-height', shellHeight + 'px');
		container.style.setProperty('--wo-nearby-mobile-topbar-top', headerOffset + 'px');
		container.style.setProperty('--wo-nearby-mobile-topbar-height', topbarHeight + 'px');
	}

	return shellHeight;
}

function Wo_ExploreNearbyGetFullscreenStageElement() {
	return document.getElementById('explore-nearby-stage');
}

function Wo_ExploreNearbyGetFullscreenElement() {
	return document.fullscreenElement || document.webkitFullscreenElement || null;
}

function Wo_ExploreNearbyIsFullscreenActive() {
	var stage = Wo_ExploreNearbyGetFullscreenStageElement();
	return !!stage && Wo_ExploreNearbyGetFullscreenElement() === stage;
}

function Wo_ExploreNearbyUpdateFullscreenButton() {
	var button = $('#explore-nearby-fullscreen-toggle');
	var stage = $('#explore-nearby-stage');
	var isActive = Wo_ExploreNearbyIsFullscreenActive();

	if (!button.length || !stage.length) {
		return;
	}

	button.attr('title', isActive ? mapExitFullscreenLabel : mapFullscreenLabel);
	button.attr('aria-label', isActive ? mapExitFullscreenLabel : mapFullscreenLabel);
	stage.toggleClass('is-stage-fullscreen', isActive);
}

function Wo_ExploreNearbyUpdateMapZoomControls() {
	var zoomControls = $('#explore-nearby-map-zoom-controls');
	var sheetHeight = WoExploreNearbyState.sheetCurrentHeight || ($('#explore-nearby-sheet').outerHeight() || 0);
	var desiredBottomOffset = Math.max(14, Math.round(sheetHeight + 14));
	var stageHeight = $('#explore-nearby-stage').outerHeight() || Wo_ExploreNearbyGetStageAvailableHeight();
	var controlsHeight = Math.ceil(zoomControls.outerHeight() || 0);
	var viewportPadding = Wo_ExploreNearbyGetMapViewportPadding();
	var maxBottomOffset = Math.max(14, Math.round(stageHeight - viewportPadding.top - controlsHeight - 12));
	var bottomOffset = Math.min(desiredBottomOffset, maxBottomOffset);
	var myLocationLabel = WoExploreNearbyState.locationRequestPending ? requestingLocationLabel : useMyLocationLabel;

	if (!zoomControls.length) {
		return;
	}

	zoomControls.css('bottom', bottomOffset + 'px');
	zoomControls.find('[data-zoom-delta="1"]').attr('title', mapZoomInLabel).attr('aria-label', mapZoomInLabel);
	zoomControls.find('[data-zoom-delta="-1"]').attr('title', mapZoomOutLabel).attr('aria-label', mapZoomOutLabel);
	zoomControls.find('#explore-nearby-my-location').attr('title', myLocationLabel).attr('aria-label', myLocationLabel);
}

function Wo_ExploreNearbyZoomMap(delta) {
	var numericDelta = parseInt(delta, 10);
	var currentZoom = 0;
	var nextZoom = 0;

	if (!numericDelta || !WoExploreNearbyMapState.map) {
		return false;
	}

	Wo_ExploreNearbySetSheetSnap('collapsed', true);

	if (WoExploreNearbyMapState.provider === 'google' && typeof WoExploreNearbyMapState.map.getZoom === 'function' && typeof WoExploreNearbyMapState.map.setZoom === 'function') {
		currentZoom = WoExploreNearbyMapState.map.getZoom() || 7;
		nextZoom = Math.max(2, Math.min(21, currentZoom + numericDelta));
		WoExploreNearbyMapState.map.setZoom(nextZoom);
		return false;
	}

	if (WoExploreNearbyMapState.provider === 'leaflet') {
		if (numericDelta > 0 && typeof WoExploreNearbyMapState.map.zoomIn === 'function') {
			WoExploreNearbyMapState.map.zoomIn(1);
			return false;
		}
		if (numericDelta < 0 && typeof WoExploreNearbyMapState.map.zoomOut === 'function') {
			WoExploreNearbyMapState.map.zoomOut(1);
			return false;
		}
	}

	return false;
}

function Wo_ExploreNearbyCenterMapOnCurrentUser(exactCenter) {
	var selfPoint = Wo_ExploreNearbyGetCurrentUserPoint();
	var shouldExactCenter = exactCenter === true;
	var viewportPadding = Wo_ExploreNearbyGetMapViewportPadding();
	var selfBounds = selfPoint ? Wo_ExploreNearbyGetViewportRadiusBounds(selfPoint, defaultNearbyViewportRadiusKm) : null;
	var currentZoom = 0;
	var targetZoom = 15;

	if (!selfPoint) {
		Wo_ExploreNearbyHandleLocationPromptAction();
		return false;
	}

	Wo_ExploreNearbySetSheetSnap('collapsed', true);

	if (WoExploreNearbyMapState.provider === 'google' && WoExploreNearbyMapState.map) {
		if (shouldExactCenter) {
			if (typeof WoExploreNearbyMapState.map.panTo === 'function') {
				WoExploreNearbyMapState.map.panTo({
					lat: selfPoint.lat,
					lng: selfPoint.lng
				});
			}
			else {
				WoExploreNearbyMapState.map.setCenter({
					lat: selfPoint.lat,
					lng: selfPoint.lng
				});
			}

			if (typeof WoExploreNearbyMapState.map.getZoom === 'function' && typeof WoExploreNearbyMapState.map.setZoom === 'function') {
				currentZoom = WoExploreNearbyMapState.map.getZoom() || 0;
				if (currentZoom < targetZoom) {
					WoExploreNearbyMapState.map.setZoom(targetZoom);
				}
			}

			return false;
		}

		if (selfBounds) {
			WoExploreNearbyMapState.map.fitBounds(new google.maps.LatLngBounds(
				{lat: selfBounds.south, lng: selfBounds.west},
				{lat: selfBounds.north, lng: selfBounds.east}
			), viewportPadding);
		}
		else {
			WoExploreNearbyMapState.map.setCenter({
				lat: selfPoint.lat,
				lng: selfPoint.lng
			});
			WoExploreNearbyMapState.map.setZoom(15);
		}
		return false;
	}

	if (WoExploreNearbyMapState.provider === 'leaflet' && WoExploreNearbyMapState.map) {
		if (shouldExactCenter) {
			if (typeof WoExploreNearbyMapState.map.getZoom === 'function') {
				currentZoom = WoExploreNearbyMapState.map.getZoom() || 0;
			}
			if (typeof WoExploreNearbyMapState.map.setView === 'function') {
				WoExploreNearbyMapState.map.setView([selfPoint.lat, selfPoint.lng], Math.max(currentZoom, targetZoom), {
					animate: true
				});
			}
			else if (typeof WoExploreNearbyMapState.map.panTo === 'function') {
				WoExploreNearbyMapState.map.panTo([selfPoint.lat, selfPoint.lng]);
			}

			return false;
		}

		if (selfBounds) {
			WoExploreNearbyMapState.map.fitBounds([
				[selfBounds.south, selfBounds.west],
				[selfBounds.north, selfBounds.east]
			], {
				paddingTopLeft: [viewportPadding.left, viewportPadding.top],
				paddingBottomRight: [viewportPadding.right, viewportPadding.bottom]
			});
		}
		else {
			WoExploreNearbyMapState.map.setView([selfPoint.lat, selfPoint.lng], 15);
		}
	}

	return false;
}

function Wo_ExploreNearbyRefreshAfterFullscreenChange() {
	Wo_ExploreNearbyUpdateFullscreenButton();
	Wo_ExploreNearbySyncMapGestureMode();
	if (Wo_ExploreNearbyIsCompactViewport()) {
		Wo_ExploreNearbySetSheetSnap('collapsed', false);
	}
	setTimeout(function() {
		Wo_ExploreNearbyRefreshMapSize();
	}, 80);
}

function Wo_ExploreNearbyToggleFullscreen() {
	var stage = Wo_ExploreNearbyGetFullscreenStageElement();
	if (!stage) {
		return false;
	}

	if (!Wo_ExploreNearbyIsFullscreenActive()) {
		if (stage.requestFullscreen) {
			stage.requestFullscreen().catch(function() {});
			return false;
		}
		if (stage.webkitRequestFullscreen) {
			stage.webkitRequestFullscreen();
			return false;
		}
		return false;
	}

	if (document.exitFullscreen) {
		document.exitFullscreen().catch(function() {});
		return false;
	}
	if (document.webkitExitFullscreen) {
		document.webkitExitFullscreen();
	}
	return false;
}

function Wo_ExploreNearbyBindFullscreenToggle() {
	var eventNames = ['fullscreenchange', 'webkitfullscreenchange'];
	for (var i = 0; i < eventNames.length; i++) {
		document.addEventListener(eventNames[i], Wo_ExploreNearbyRefreshAfterFullscreenChange, false);
	}
	Wo_ExploreNearbyUpdateFullscreenButton();
}

function Wo_ExploreNearbyGetMapGestureMode() {
	return 'map-first';
}

function Wo_ExploreNearbyIsFixedSheetLayout() {
	return true;
}

function Wo_ExploreNearbyGetFixedSheetSnapMode() {
	return 'medium';
}

function Wo_ExploreNearbyIsPageScrollFirstGestureMode() {
	return Wo_ExploreNearbyGetMapGestureMode() === 'page-scroll-first';
}

function Wo_ExploreNearbyUpdateMapGestureClass() {
	var mapElement = $('#map');
	var gestureMode = Wo_ExploreNearbyGetMapGestureMode();

	WoExploreNearbyState.mapGestureMode = gestureMode;
	if (!mapElement.length) {
		return gestureMode;
	}

	mapElement.toggleClass('is-page-scroll-priority', gestureMode === 'page-scroll-first');
	return gestureMode;
}

function Wo_ExploreNearbySyncMapGestureMode() {
	var gestureMode = Wo_ExploreNearbyUpdateMapGestureClass();

	if (WoExploreNearbyMapState.provider === 'google' && WoExploreNearbyMapState.map && typeof WoExploreNearbyMapState.map.setOptions === 'function') {
		WoExploreNearbyMapState.map.setOptions({
			gestureHandling: 'greedy'
		});
	}

	if (WoExploreNearbyMapState.provider === 'leaflet' && WoExploreNearbyMapState.map && WoExploreNearbyMapState.map.dragging) {
		if (typeof WoExploreNearbyMapState.map.dragging.enable === 'function') {
			WoExploreNearbyMapState.map.dragging.enable();
		}
	}

	return gestureMode;
}

function Wo_ExploreNearbyGetSheetSnapHeights() {
	var stageHeight = $('#explore-nearby-stage').outerHeight() || Wo_ExploreNearbyGetStageAvailableHeight();
	var ratios = Wo_ExploreNearbyIsCompactViewport() ?
		{collapsed: 0.18, medium: 0.44, expanded: 0.78} :
		{collapsed: 0.20, medium: 0.42, expanded: 0.70};
	var heights = {
		collapsed: Math.round(stageHeight * ratios.collapsed),
		medium: Math.round(stageHeight * ratios.medium),
		expanded: Math.round(stageHeight * ratios.expanded)
	};

	heights.expanded = Math.max(320, Math.min(stageHeight - 6, heights.expanded));
	heights.medium = Math.max(240, Math.min(heights.expanded - 72, heights.medium));
	heights.collapsed = Math.max(152, Math.min(heights.medium - 72, heights.collapsed));

	return heights;
}

function Wo_ExploreNearbyGetSheetSnapIndex(mode) {
	return ['collapsed', 'medium', 'expanded'].indexOf(mode);
}

function Wo_ExploreNearbyApplySheetHeight(height, animate) {
	var sheet = $('#explore-nearby-sheet');
	var nextHeight = Math.round(height || 0);

	if (!sheet.length) {
		return;
	}

	if (animate === false) {
		sheet.removeClass('is-animating');
	}
	else {
		sheet.addClass('is-animating');
	}

	sheet.get(0).style.setProperty('--wo-nearby-sheet-height', nextHeight + 'px');
	WoExploreNearbyState.sheetCurrentHeight = nextHeight;
	Wo_ExploreNearbyUpdateMapZoomControls();
}

function Wo_ExploreNearbyUpdateSheetScrollableState() {
	$('#explore-nearby-sheet-body').toggleClass('is-scrollable', Wo_ExploreNearbyIsFixedSheetLayout() || WoExploreNearbyState.sheetSnap !== 'collapsed');
}

function Wo_ExploreNearbySetStoredSheetOnboardingSeen() {
	try {
		window.localStorage.setItem(sheetOnboardingStorageKey, '1');
	}
	catch (error) {}
}

function Wo_ExploreNearbyUpdateSheetHintState() {
	var sheet = $('#explore-nearby-sheet');
	var hint = $('#explore-nearby-sheet-hint');
	var floatingHint = $('#explore-nearby-sheet-floating-hint');

	if (!sheet.length) {
		return;
	}

	sheet.toggleClass('is-onboarding-pending', !WoExploreNearbyState.sheetOnboardingSeen);
	if (hint.length) {
		hint.attr('title', sheetHandleHintLabel);
	}
	if (floatingHint.length) {
		floatingHint.toggleClass('is-onboarding-pending', !WoExploreNearbyState.sheetOnboardingSeen);
	}
	$('#explore-nearby-sheet-floating-hint-button').attr('title', sheetHandleHintLabel).attr('aria-label', sheetHandleHintLabel);
	$('#explore-nearby-sheet-handle, #explore-nearby-sheet-header').attr('title', sheetHandleHintLabel);
}

function Wo_ExploreNearbyInitSheetOnboarding() {
	var hasSeenOnboarding = false;

	try {
		hasSeenOnboarding = window.localStorage.getItem(sheetOnboardingStorageKey) === '1';
	}
	catch (error) {
		hasSeenOnboarding = false;
	}

	WoExploreNearbyState.sheetOnboardingSeen = hasSeenOnboarding;
	WoExploreNearbyState.sheetOnboardingReady = true;
	Wo_ExploreNearbyUpdateSheetHintState();
}

function Wo_ExploreNearbyMarkSheetOnboardingSeen() {
	if (WoExploreNearbyState.sheetOnboardingSeen) {
		return;
	}

	WoExploreNearbyState.sheetOnboardingSeen = true;
	Wo_ExploreNearbySetStoredSheetOnboardingSeen();
	Wo_ExploreNearbyUpdateSheetHintState();
}

function Wo_ExploreNearbyHasSheetReadyContent() {
	var list = document.getElementById('explore_nearby_discovery_list');
	var emptyState = document.getElementById('explore_nearby_empty_state');
	var hasListItems = !!(list && list.children && list.children.length > 0);
	var hasVisibleEmptyState = !!(emptyState && !emptyState.classList.contains('wo_explore_nearby_hidden'));

	return hasListItems || hasVisibleEmptyState;
}

function Wo_ExploreNearbyCanAutoOpenSheetOnboarding() {
	return WoExploreNearbyState.sheetOnboardingReady === true &&
		WoExploreNearbyState.sheetOnboardingSeen !== true &&
		WoExploreNearbyState.sheetOnboardingAutoOpenAttempted !== true &&
		Wo_ExploreNearbySyncLocationAnchorState() === true &&
		Wo_ExploreNearbyHasSheetReadyContent();
}

function Wo_ExploreNearbyMaybeAutoOpenSheetOnboarding() {
	if (Wo_ExploreNearbyIsFixedSheetLayout()) {
		return;
	}

	if (WoExploreNearbyState.sheetOnboardingAutoOpenScheduled || !Wo_ExploreNearbyCanAutoOpenSheetOnboarding()) {
		return;
	}

	WoExploreNearbyState.sheetOnboardingAutoOpenScheduled = true;
	setTimeout(function() {
		WoExploreNearbyState.sheetOnboardingAutoOpenScheduled = false;
		if (!Wo_ExploreNearbyCanAutoOpenSheetOnboarding()) {
			return;
		}

		WoExploreNearbyState.sheetOnboardingAutoOpenAttempted = true;
		if (WoExploreNearbyState.sheetSnap === 'collapsed') {
			Wo_ExploreNearbySetSheetSnap('medium', true);
		}
	}, 140);
}

function Wo_ExploreNearbyShouldShowFloatingSheetHint() {
	if (Wo_ExploreNearbyIsFixedSheetLayout()) {
		return false;
	}

	return WoExploreNearbyState.sheetSnap === 'collapsed' && WoExploreNearbyState.sheetDragging !== true;
}

function Wo_ExploreNearbyGetFloatingSheetHintBottom() {
	var sheetHeight = WoExploreNearbyState.sheetCurrentHeight || ($('#explore-nearby-sheet').outerHeight() || 0);
	return Math.max(12, Math.round(sheetHeight - 12));
}

function Wo_ExploreNearbyUpdateFloatingSheetHint() {
	var floatingHint = $('#explore-nearby-sheet-floating-hint');

	if (!floatingHint.length) {
		return;
	}

	floatingHint.css('bottom', Wo_ExploreNearbyGetFloatingSheetHintBottom() + 'px');
	floatingHint.toggleClass('wo_explore_nearby_hidden', !Wo_ExploreNearbyShouldShowFloatingSheetHint());
}

function Wo_ExploreNearbySetSheetSnap(mode, animate) {
	var snapHeights = Wo_ExploreNearbyGetSheetSnapHeights();
	var nextMode = snapHeights[mode] ? mode : 'medium';

	if (Wo_ExploreNearbyIsFixedSheetLayout()) {
		nextMode = Wo_ExploreNearbyGetFixedSheetSnapMode();
	}

	WoExploreNearbyState.sheetSnapHeights = snapHeights;
	WoExploreNearbyState.sheetSnap = nextMode;
	$('#explore-nearby-sheet').attr('data-snap', nextMode);
	Wo_ExploreNearbyApplySheetHeight(snapHeights[nextMode], animate);
	Wo_ExploreNearbyUpdateSheetScrollableState();
	Wo_ExploreNearbyUpdateSheetHintState();
	Wo_ExploreNearbyUpdateFloatingSheetHint();

	if (nextMode === 'collapsed') {
		$('#explore-nearby-sheet-body').scrollTop(0);
	}
	else {
		Wo_ExploreNearbyMarkSheetOnboardingSeen();
	}
}

function Wo_ExploreNearbyEnsureSheetAtLeast(targetMode) {
	if (Wo_ExploreNearbyGetSheetSnapIndex(WoExploreNearbyState.sheetSnap) < Wo_ExploreNearbyGetSheetSnapIndex(targetMode)) {
		Wo_ExploreNearbySetSheetSnap(targetMode, true);
	}
}

function Wo_ExploreNearbyClampSheetHeight(height) {
	var snapHeights = Wo_ExploreNearbyGetSheetSnapHeights();

	if (Wo_ExploreNearbyIsFixedSheetLayout()) {
		return snapHeights[Wo_ExploreNearbyGetFixedSheetSnapMode()] || snapHeights.medium;
	}

	return Math.max(snapHeights.collapsed, Math.min(snapHeights.expanded, Math.round(height)));
}

function Wo_ExploreNearbySnapSheetToNearest(height) {
	var snapHeights = Wo_ExploreNearbyGetSheetSnapHeights();
	var nearestMode = 'collapsed';
	var nearestDistance = Number.MAX_VALUE;

	$.each(snapHeights, function(mode, snapHeight) {
		var distance = Math.abs(snapHeight - height);
		if (distance < nearestDistance) {
			nearestDistance = distance;
			nearestMode = mode;
		}
	});

	Wo_ExploreNearbySetSheetSnap(nearestMode, true);
}

function Wo_ExploreNearbyGetPointerClientY(event) {
	var originalEvent = event.originalEvent || event;

	if (originalEvent.touches && originalEvent.touches[0]) {
		return originalEvent.touches[0].clientY;
	}
	if (originalEvent.changedTouches && originalEvent.changedTouches[0]) {
		return originalEvent.changedTouches[0].clientY;
	}
	if (typeof originalEvent.clientY === 'number') {
		return originalEvent.clientY;
	}

	return null;
}

function Wo_ExploreNearbyGetSheetPointerClientPoint(event) {
	var originalEvent = event.originalEvent || event;

	if (originalEvent.touches && originalEvent.touches[0]) {
		return {
			clientX: originalEvent.touches[0].clientX,
			clientY: originalEvent.touches[0].clientY
		};
	}
	if (originalEvent.changedTouches && originalEvent.changedTouches[0]) {
		return {
			clientX: originalEvent.changedTouches[0].clientX,
			clientY: originalEvent.changedTouches[0].clientY
		};
	}
	if (typeof originalEvent.clientX === 'number' && typeof originalEvent.clientY === 'number') {
		return {
			clientX: originalEvent.clientX,
			clientY: originalEvent.clientY
		};
	}

	return null;
}

function Wo_ExploreNearbyGetSheetTapMoveThresholdPx() {
	return Wo_ExploreNearbyIsCompactViewport() ? 14 : 10;
}

function Wo_ExploreNearbyResetSheetTapGesture() {
	WoExploreNearbyState.sheetTapStartX = null;
	WoExploreNearbyState.sheetTapStartY = null;
	WoExploreNearbyState.sheetTapMoved = false;
	WoExploreNearbyState.sheetTapStartedCollapsed = false;
}

function Wo_ExploreNearbyTrackSheetTapGestureMove(event) {
	var point = Wo_ExploreNearbyGetSheetPointerClientPoint(event);
	var moveThreshold = Wo_ExploreNearbyGetSheetTapMoveThresholdPx();

	if (!point || WoExploreNearbyState.sheetTapStartX === null || WoExploreNearbyState.sheetTapStartY === null || WoExploreNearbyState.sheetTapMoved) {
		return;
	}

	if (Math.abs(point.clientX - WoExploreNearbyState.sheetTapStartX) > moveThreshold || Math.abs(point.clientY - WoExploreNearbyState.sheetTapStartY) > moveThreshold) {
		WoExploreNearbyState.sheetTapMoved = true;
	}
}

function Wo_ExploreNearbyShouldExpandSheetFromTap() {
	return WoExploreNearbyState.sheetTapStartedCollapsed === true && WoExploreNearbyState.sheetTapMoved !== true;
}

function Wo_ExploreNearbyHandleSheetTapExpand() {
	if (Wo_ExploreNearbyShouldExpandSheetFromTap()) {
		Wo_ExploreNearbySetSheetSnap('medium', true);
		return true;
	}

	return false;
}

function Wo_ExploreNearbyStartSheetDrag(event) {
	var pointerY = Wo_ExploreNearbyGetPointerClientY(event);
	var pointerPoint = Wo_ExploreNearbyGetSheetPointerClientPoint(event);
	var originalEvent = event.originalEvent || event;

	if (Wo_ExploreNearbyIsFixedSheetLayout()) {
		return;
	}

	if ($(event.target).closest('input, textarea, button, a').length || pointerY === null) {
		return;
	}
	if (typeof originalEvent.button === 'number' && originalEvent.button !== 0) {
		return;
	}

	WoExploreNearbyState.sheetDragging = true;
	WoExploreNearbyState.sheetDragStartY = pointerY;
	WoExploreNearbyState.sheetDragStartHeight = WoExploreNearbyState.sheetCurrentHeight || Wo_ExploreNearbyGetSheetSnapHeights()[WoExploreNearbyState.sheetSnap] || 0;
	WoExploreNearbyState.sheetTapStartedCollapsed = WoExploreNearbyState.sheetSnap === 'collapsed';
	WoExploreNearbyState.sheetTapMoved = false;
	WoExploreNearbyState.sheetTapStartX = pointerPoint ? pointerPoint.clientX : null;
	WoExploreNearbyState.sheetTapStartY = pointerPoint ? pointerPoint.clientY : pointerY;
	$('body').addClass('wo_explore_discovery_dragging');
	Wo_ExploreNearbyUpdateFloatingSheetHint();
	event.preventDefault();
}

function Wo_ExploreNearbyMoveSheetDrag(event) {
	var pointerY = Wo_ExploreNearbyGetPointerClientY(event);
	var delta = 0;

	if (Wo_ExploreNearbyIsFixedSheetLayout()) {
		return;
	}

	if (!WoExploreNearbyState.sheetDragging || pointerY === null) {
		return;
	}

	Wo_ExploreNearbyTrackSheetTapGestureMove(event);
	delta = WoExploreNearbyState.sheetDragStartY - pointerY;
	Wo_ExploreNearbyApplySheetHeight(Wo_ExploreNearbyClampSheetHeight(WoExploreNearbyState.sheetDragStartHeight + delta), false);
	event.preventDefault();
}

function Wo_ExploreNearbyEndSheetDrag() {
	if (Wo_ExploreNearbyIsFixedSheetLayout()) {
		return;
	}

	if (!WoExploreNearbyState.sheetDragging) {
		return;
	}

	WoExploreNearbyState.sheetDragging = false;
	$('body').removeClass('wo_explore_discovery_dragging');
	if (Wo_ExploreNearbyHandleSheetTapExpand()) {
		Wo_ExploreNearbyResetSheetTapGesture();
		Wo_ExploreNearbyUpdateFloatingSheetHint();
		return;
	}
	Wo_ExploreNearbySnapSheetToNearest(WoExploreNearbyState.sheetCurrentHeight || Wo_ExploreNearbyGetSheetSnapHeights()[WoExploreNearbyState.sheetSnap] || 0);
	Wo_ExploreNearbyResetSheetTapGesture();
	Wo_ExploreNearbyUpdateFloatingSheetHint();
}

function Wo_ExploreNearbyBindSheetInteractions() {
	if (WoExploreNearbyState.sheetBindingsReady) {
		return;
	}

	if (Wo_ExploreNearbyIsFixedSheetLayout()) {
		WoExploreNearbyState.sheetBindingsReady = true;
		return;
	}

	$(document).on('mousedown touchstart', '#explore-nearby-sheet-handle, #explore-nearby-sheet-header', Wo_ExploreNearbyStartSheetDrag);
	$(document).on('mousemove touchmove', Wo_ExploreNearbyMoveSheetDrag);
	$(document).on('mouseup touchend touchcancel', Wo_ExploreNearbyEndSheetDrag);
	WoExploreNearbyState.sheetBindingsReady = true;
}

function Wo_ExploreNearbyIsMapIntentIgnoredTarget(target) {
	return $(target).closest([
		'.wo-nearby-google-marker',
		'.wo-nearby-related-place-marker',
		'.leaflet-marker-icon',
		'.leaflet-popup',
		'.leaflet-control',
		'.gm-style-iw',
		'.gm-style-iw-t',
		'.gm-ui-hover-effect',
		'.gm-control-active',
		'.wo_explore_discovery_map_action',
		'.wo_explore_discovery_map_zoom_controls'
	].join(',')).length > 0;
}

function Wo_ExploreNearbyHandleMapIntent(event) {
	if (Wo_ExploreNearbyIsFixedSheetLayout()) {
		return;
	}

	if (!event || WoExploreNearbyState.sheetSnap === 'collapsed') {
		return;
	}

	if (Wo_ExploreNearbyIsPageScrollFirstGestureMode() && String(event.type || '').toLowerCase() !== 'wheel') {
		return;
	}

	if (Wo_ExploreNearbyIsMapIntentIgnoredTarget(event.target)) {
		return;
	}

	Wo_ExploreNearbySetSheetSnap('collapsed', true);
	setTimeout(Wo_ExploreNearbyRefreshMapSize, 260);
}

function Wo_ExploreNearbyHasMoreResults() {
	if (Wo_ExploreNearbyIsPlaceSearchMode()) {
		return false;
	}

	return (WoExploreNearbyState.usersEnabled && (WoExploreNearbyState.usersItems || []).length < (WoExploreNearbyState.usersCount || 0)) ||
		(WoExploreNearbyState.shopsEnabled && (WoExploreNearbyState.shopsItems || []).length < (WoExploreNearbyState.shopsCount || 0));
}

function Wo_ExploreNearbyUpdateInfiniteScrollState() {
	var sentinel = $('#explore-nearby-load-sentinel');
	var hasMore = Wo_ExploreNearbyHasMoreResults();

	WoExploreNearbyState.hasMoreResults = hasMore;
	sentinel.toggleClass('is-loading', !!WoExploreNearbyState.appendInProgress);
	sentinel.toggleClass('is-hidden', !hasMore && !WoExploreNearbyState.appendInProgress);
	sentinel.text(WoExploreNearbyState.appendInProgress ? 'Loading more nearby results' : (hasMore ? 'Drag up or scroll for more results' : ''));
}

function Wo_ExploreNearbyMaybeLoadMore() {
	if (WoExploreNearbyState.sheetSnap === 'collapsed' || !WoExploreNearbyState.hasMoreResults || WoExploreNearbyState.appendInProgress) {
		return;
	}

	Wo_ExploreNearbyLoadMore();
}

function Wo_ExploreNearbyBindInfiniteScroll() {
	var body = document.getElementById('explore-nearby-sheet-body');
	var sentinel = document.getElementById('explore-nearby-load-sentinel');

	if (WoExploreNearbyState.sheetObserverReady || !body || !sentinel) {
		return;
	}

	if ('IntersectionObserver' in window) {
		WoExploreNearbyState.sheetObserver = new IntersectionObserver(function(entries) {
			if (entries[0] && entries[0].isIntersecting) {
				Wo_ExploreNearbyMaybeLoadMore();
			}
		}, {
			root: body,
			rootMargin: '160px 0px 220px 0px'
		});
		WoExploreNearbyState.sheetObserver.observe(sentinel);
	}

	$(body).on('scroll.exploreNearby', function() {
		if ('IntersectionObserver' in window) {
			return;
		}

		if (this.scrollTop + this.clientHeight >= this.scrollHeight - 160) {
			Wo_ExploreNearbyMaybeLoadMore();
		}
	});

	WoExploreNearbyState.sheetObserverReady = true;
}

function Wo_ExploreNearbyRefreshMapSize() {
	if (WoExploreNearbyMapState.provider === 'leaflet' && WoExploreNearbyMapState.map && typeof WoExploreNearbyMapState.map.invalidateSize === 'function') {
		WoExploreNearbyMapState.map.invalidateSize();
		return;
	}

	if (WoExploreNearbyMapState.provider === 'google' && WoExploreNearbyMapState.map && typeof google !== 'undefined' && google.maps && google.maps.event) {
		google.maps.event.trigger(WoExploreNearbyMapState.map, 'resize');
