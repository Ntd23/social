function Wo_ExploreNearbyCreateRelatedPlaceMarkerElement(point) {
	var glyphUri = $.trim((point && point.svg_icon_mask_uri) || '');
	var background = Wo_ExploreNearbyGetRelatedPlaceMarkerBackground(point);
