		description: '',
		avatar: '',
		url: googleMapsUrl || Wo_ExploreNearbyBuildGooglePlaceUrl(placeId, placeTitle, lat, lng),
		ajax_url: '',
		place_id: placeId,
		primary_type: primaryType,
		primary_type_label: primaryTypeLabel,
		svg_icon_mask_uri: $.trim(result.svgIconMaskURI || result.svg_icon_mask_uri || '') ? $.trim(result.svgIconMaskURI || result.svg_icon_mask_uri || '') : ($.trim(result.icon_mask_base_uri || '') ? ($.trim(result.icon_mask_base_uri) + '.svg') : ''),
		icon_background_color: $.trim(result.icon_background_color || ''),
		location: locationText,
		location_dynamic: '',
		distance_value: distanceValue,
