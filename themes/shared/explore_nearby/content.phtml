	var handleScreenRotationChange = function() {
		if (WoExploreNearbyState.deviceHeadingSource === 'device') {
			Wo_ExploreNearbyRefreshSelfMarker();
			return;
		}

		Wo_ExploreNearbySetDeviceHeading(Wo_ExploreNearbyGetScreenRotationAngle(), 'screen');
	};

	window.addEventListener('orientationchange', handleScreenRotationChange, true);
	if (window.screen && window.screen.orientation && typeof window.screen.orientation.addEventListener === 'function') {
		window.screen.orientation.addEventListener('change', handleScreenRotationChange);
	}

	WoExploreNearbyState.screenOrientationBound = true;
