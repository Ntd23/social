function Wo_ExploreNearbyGetMapViewportPadding() {
	var topbarElement = $('#explore-nearby-map-shell .wo_explore_discovery_topbar:visible').get(0) || null;
	var topbarRect = topbarElement ? topbarElement.getBoundingClientRect() : null;
	var topbarBottom = topbarRect ? Math.max(0, Math.round(topbarRect.bottom)) : 0;
	var topbarHeight = topbarElement ? Math.ceil($(topbarElement).outerHeight() || 0) : 0;
	var sheetHeight = WoExploreNearbyState.sheetCurrentHeight || ($('#explore-nearby-sheet').outerHeight() || 0);
	var isCompactViewport = Wo_ExploreNearbyIsCompactViewport();
	var horizontalPadding = isCompactViewport ? 18 : 28;
	var topPadding = Math.max(
		isCompactViewport ? 78 : 92,
		isCompactViewport ? (topbarBottom ? (topbarBottom + 18) : 0) : (topbarHeight + 22)
	);
	var bottomPadding = Math.max(isCompactViewport ? 178 : 154, sheetHeight + 26);

	return {
		top: topPadding,
		right: horizontalPadding,
		bottom: bottomPadding,
		left: horizontalPadding
	};
}

function Wo_ExploreNearbyGetInitials(title) {
	var text = $.trim(title || '');
	if (!text) {
		return '?';
	}

	var parts = text.split(/\s+/);
	if (parts.length === 1) {
		return parts[0].slice(0, 1).toUpperCase();
	}

	return (parts[0].slice(0, 1) + parts[1].slice(0, 1)).toUpperCase();
}

function Wo_ExploreNearbyFormatCoordinateText(text) {
	var value = $.trim(text || '');
	var coordinateMatch = value.match(/^(-?\d+(?:\.\d+)?)\s*,\s*(-?\d+(?:\.\d+)?)(?:\s*,.*)?$/);
	if (!coordinateMatch) {
		return value;
	}

	return coordinateMatch[1].slice(0, 10) + ',' + coordinateMatch[2].slice(0, 10) + '...';
}

function Wo_ExploreNearbyCanUseGoogleGeocoder() {
	return typeof google !== 'undefined' &&
