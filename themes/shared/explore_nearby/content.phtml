		clearTimeout(WoExploreNearbyState.searchSuggestionTimer);
		Wo_ExploreNearbySyncSearchSelectionHint();
		if (!WoExploreNearbyState.searchSelectionHintQuery && hadAnchorSelection && query.length === 0) {
			if (Wo_ExploreNearbyClearSearchPlaceSelection()) {
				Wo_ExploreNearbyUpdateUi();
				Wo_ExploreNearbyRenderCurrentMap(null);
			}
		}

		if (query.length > 0) {
			WoExploreNearbyState.searchSuggestionTimer = setTimeout(function() {
				Wo_ExploreNearbyRequestSuggestions();
			}, 160);
		}
		else {
			Wo_ExploreNearbyCloseSuggestions();
		}

		WoExploreNearbyState.searchTimer = setTimeout(function() {
			Wo_ExploreNearbyLoad(false);
		}, 300);
	});

	$('#nearby-username').on('keydown', function(e) {
		var key = e.key || '';
		var keyCode = e.which || e.keyCode || 0;
		var isSuggestionsVisible = !$('#explore-nearby-search-suggestions').hasClass('wo_explore_nearby_hidden');

		if (key === 'ArrowDown' || keyCode === 40) {
			if (isSuggestionsVisible && (WoExploreNearbyState.searchSuggestionItems || []).length) {
				e.preventDefault();
				Wo_ExploreNearbyMoveSuggestion(1);
			}
			return;
		}

		if (key === 'ArrowUp' || keyCode === 38) {
			if (isSuggestionsVisible && (WoExploreNearbyState.searchSuggestionItems || []).length) {
				e.preventDefault();
				Wo_ExploreNearbyMoveSuggestion(-1);
			}
			return;
		}

		if (key === 'Escape' || keyCode === 27) {
			if (isSuggestionsVisible) {
				e.preventDefault();
				Wo_ExploreNearbyCloseSuggestions();
			}
			return;
		}

		if (key === 'Enter' || keyCode === 13) {
			e.preventDefault();

			if (isSuggestionsVisible && WoExploreNearbyState.searchSuggestionActiveIndex > -1) {
				Wo_ExploreNearbySelectSuggestionByIndex(WoExploreNearbyState.searchSuggestionActiveIndex);
				return;
			}

			Wo_ExploreNearbyCloseSuggestions();
			Wo_ExploreNearbyLoad(false);
		}
	});

	$('#nearby-username').on('focus', function() {
		Wo_ExploreNearbyEnsureSheetAtLeast('medium');
		clearTimeout(WoExploreNearbyState.searchSuggestionTimer);
		WoExploreNearbyState.isSuggestionInteraction = false;
		if (Wo_ExploreNearbyGetSearchValue().length > 0) {
			WoExploreNearbyState.searchSuggestionTimer = setTimeout(function() {
				Wo_ExploreNearbyRequestSuggestions();
			}, 80);
		}
	}).on('blur', function() {
		clearTimeout(WoExploreNearbyState.searchSuggestionTimer);
		WoExploreNearbyState.searchSuggestionTimer = setTimeout(function() {
			if (WoExploreNearbyState.isSuggestionInteraction) {
				WoExploreNearbyState.isSuggestionInteraction = false;
				return;
			}
			Wo_ExploreNearbyCloseSuggestions();
		}, 160);
	});

	$(document).on('click', '#explore-nearby-sheet-floating-hint-button', function(e) {
		e.preventDefault();
		Wo_ExploreNearbySetSheetSnap('medium', true);
	});

	$(window).on('resize', function() {
		Wo_ExploreNearbyUpdateViewportHeight();
		Wo_ExploreNearbyUpdateFullscreenButton();
		Wo_ExploreNearbySetSheetSnap(WoExploreNearbyState.sheetSnap || 'collapsed', false);
		Wo_ExploreNearbySyncMapGestureMode();
		if (!Wo_ExploreNearbyShouldOpenMarkerPopup(Wo_ExploreNearbyGetRenderedPointByKey(WoExploreNearbyState.openPopupPointKey || ''))) {
			Wo_ExploreNearbyCloseInfoPopup();
			WoExploreNearbyState.openPopupPointKey = null;
		}
		Wo_ExploreNearbyRefreshMapSize();
	});

	$(document).on('click', '.wo_explore_discovery_card', function(e) {
		var pointKey = $(this).attr('data-point-key');
		var item = Wo_ExploreNearbyResolvePointByKey(pointKey, false);

		if ($(e.target).closest('a,button').length) {
			return;
		}

		if (Wo_ExploreNearbyCanRouteToItem(item)) {
			Wo_ExploreNearbyStartRouteToPointByKey(pointKey, true);
			return;
		}

		Wo_ExploreNearbyFocusOnMapByKey(pointKey, true);
	});

	$(document).on('pointerdown mousedown touchstart', '.wo_explore_discovery_search_suggestion', function(e) {
		Wo_ExploreNearbyMarkSuggestionInteractionActive(e, parseInt($(this).attr('data-index'), 10));
	});

	$(document).on('mouseenter', '.wo_explore_discovery_search_suggestion', function() {
		var nextIndex = parseInt($(this).attr('data-index'), 10);
		if (isNaN(nextIndex)) {
			return;
		}

		WoExploreNearbyState.searchSuggestionActiveIndex = nextIndex;
		Wo_ExploreNearbyRenderSuggestions();
	});

	$(document).on('pointermove mousemove touchmove', function(e) {
		Wo_ExploreNearbyTrackSuggestionPointerMove(e);
	});

	$(document).on('pointerup mouseup touchend', '.wo_explore_discovery_search_suggestion', function(e) {
		e.preventDefault();
		e.stopPropagation();
		Wo_ExploreNearbyHandleSuggestionPointerRelease(e, parseInt($(this).attr('data-index'), 10));
	});

	$(document).on('pointerup mouseup touchend touchcancel', function(e) {
		if (String(e.type || '').toLowerCase() !== 'touchcancel' && $(e.target).closest('.wo_explore_discovery_search_suggestion').length) {
			return;
		}

		Wo_ExploreNearbyReleaseSuggestionInteraction();
	});

	$(document).on('click', '.wo_explore_discovery_search_suggestion', function(e) {
		var index = parseInt($(this).attr('data-index'), 10);
		e.preventDefault();
		e.stopPropagation();
		if (Wo_ExploreNearbyShouldIgnoreSuggestionClick(index)) {
			return;
		}
		if ((Date.now() - (WoExploreNearbyState.lastSuggestionSelectionAt || 0)) < 400) {
			return;
		}

		if (Wo_ExploreNearbyShouldHandleSuggestionReleaseSelection(e)) {
			return;
		}

		Wo_ExploreNearbyHandleSuggestionSelection(index);
	});

	$(document).on('click', function(e) {
		if ($(e.target).closest('.wo_explore_discovery_search').length) {
			return;
		}

		Wo_ExploreNearbyCloseSuggestions();
	});

	$(document).on('click', '.wo_explore_discovery_focus', function(e) {
		e.preventDefault();
		e.stopPropagation();
		var pointKey = $(this).attr('data-point-key');
		var item = Wo_ExploreNearbyResolvePointByKey(pointKey, false);
		if ($(this).is(':disabled')) {
			return;
		}
		if (Wo_ExploreNearbyCanRouteToItem(item)) {
			Wo_ExploreNearbyStartRouteToPointByKey(pointKey, true);
			return;
		}
		Wo_ExploreNearbyFocusOnMapByKey(pointKey, true);
	});

	$(document).on('click', '.wo_explore_discovery_card_my_location', function(e) {
		e.preventDefault();
		e.stopPropagation();
		Wo_ExploreNearbyCenterMapOnCurrentUser(true);
	});

	$(document).on('click', '.wo_explore_discovery_directions', function(e) {
		e.preventDefault();
		e.stopPropagation();
		if ($(this).is(':disabled')) {
			return;
		}

		Wo_ExploreNearbyStartRouteToPointByKey($(this).attr('data-point-key'), true);
	});

	$(document).on('click', '.wo_explore_discovery_share', function(e) {
		e.preventDefault();
		e.stopPropagation();
		if ($(this).is(':disabled')) {
			return;
		}

		Wo_ExploreNearbySharePointByKey($(this).attr('data-point-key'), this);
	});

	$(document).on('click touchend', '.wo-nearby-google-marker', function(e) {
		var pointKey = $(this).attr('data-point-key');
		if (!pointKey || WoExploreNearbyMapState.provider !== 'google' || Wo_ExploreNearbyWasPointSelectionHandledRecently()) {
			return;
		}

		e.preventDefault();
		e.stopPropagation();
		Wo_ExploreNearbyHandleGoogleMarkerDomSelection(pointKey);
	});

	$(document).on('click', '#explore-nearby-map-prompt-action', function(e) {
		e.preventDefault();
		e.stopPropagation();
		Wo_ExploreNearbyHandleLocationPromptAction();
	});

	$(document).on('click', '#explore-nearby-location-trigger', function(e) {
		e.preventDefault();
		e.stopPropagation();
		Wo_ExploreNearbyHandleLocationPromptAction();
	});

	$(document).on('pointerdown mousedown touchstart', '.wo_explore_discovery_map_action', function(e) {
		e.stopPropagation();
	});

	$(document).on('click', '.wo_explore_discovery_map_zoom_action', function(e) {
		e.preventDefault();
		e.stopPropagation();
		Wo_ExploreNearbyZoomMap($(this).attr('data-zoom-delta'));
	});

	$(document).on('click', '#explore-nearby-fullscreen-toggle', function(e) {
		e.preventDefault();
		e.stopPropagation();
		Wo_ExploreNearbyToggleFullscreen();
	});

	$(document).on('click', '#explore-nearby-my-location', function(e) {
		e.preventDefault();
		e.stopPropagation();
		Wo_ExploreNearbyCenterMapOnCurrentUser(true);
	});

	$(document).on('pointerdown mousedown touchstart', '#map', function(e) {
		if (WoExploreNearbyMapState.provider === 'google') {
			return;
		}

		Wo_ExploreNearbyHandleMapPointerStart(e);
	});

	$(document).on('pointermove mousemove touchmove', '#map', function(e) {
		if (WoExploreNearbyMapState.provider === 'google') {
			return;
		}

		Wo_ExploreNearbyHandleMapPointerMove(e);
	});

	$(document).on('pointerup mouseup touchend touchcancel', '#map', function(e) {
		if (WoExploreNearbyMapState.provider === 'google') {
			return;
		}

		Wo_ExploreNearbyHandleMapPointerEnd(e);
	});

	$(document).on('pointerdown mousedown touchstart wheel', '#map', Wo_ExploreNearbyHandleMapIntent);
});
</script>
