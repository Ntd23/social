	candidates.push(Wo_ExploreNearbyGetRenderedPointByKey(normalizedPointKey));
	candidates.push(Wo_ExploreNearbyGetMergedItemByKey(normalizedPointKey));

	for (i = 0; i < candidates.length; i++) {
		if (!candidates[i] || Wo_ExploreNearbyGetItemKey(candidates[i]) !== normalizedPointKey) {
