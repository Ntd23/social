	var nextType = (itemType === 'page' || itemType === 'place' || itemType === 'shop') ? itemType : 'user';
	var sourceLocation = overrideLocation || {};
	var lat = (sourceLocation.lat !== undefined && sourceLocation.lat !== null && sourceLocation.lat !== '') ? parseFloat(sourceLocation.lat) : parseFloat(sourceItem.lat);
	var lng = (sourceLocation.lng !== undefined && sourceLocation.lng !== null && sourceLocation.lng !== '') ? parseFloat(sourceLocation.lng) : parseFloat(sourceItem.lng);
	var title = Wo_ExploreNearbyNormalizeTextValue(sourceLocation.title || sourceItem.title || sourceItem.name || '');
	var location = Wo_ExploreNearbyNormalizeTextValue(sourceLocation.location || sourceLocation.formatted_address || sourceItem.location || sourceItem.address || title);
	var subtitle = Wo_ExploreNearbyNormalizeTextValue(sourceItem.subtitle || (nextType === 'shop' ? defaultShopTypeLabel : (nextType === 'page' ? defaultPageTypeLabel : (nextType === 'place' ? defaultPlaceTypeLabel : defaultUserTypeLabel))));
	var typeLabel = Wo_ExploreNearbyNormalizeTextValue(sourceItem.type_label || (nextType === 'shop' ? defaultShopTypeLabel : (nextType === 'page' ? defaultPageTypeLabel : (nextType === 'place' ? defaultPlaceTypeLabel : defaultUserTypeLabel))));
	var description = Wo_ExploreNearbyNormalizeTextValue(sourceItem.description || '');
	var placeId = $.trim(sourceLocation.place_id || sourceItem.place_id || '');
