	}

	return {
		item_key: placeId ? ('place|' + placeId) : (nextType + '|anchor|' + encodeURIComponent(itemIdentity.toLowerCase()) + '|' + lat.toFixed(5) + ',' + lng.toFixed(5)),
		offset_id: 0,
