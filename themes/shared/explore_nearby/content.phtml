		}).catch(function() {
			return null;
		});
		});
	}).catch(function() {
		return null;
	});
}

function Wo_ExploreNearbyReverseGeocodeCoordinates(lat, lng) {
	if (!Wo_ExploreNearbyHasValidCoordinates(lat, lng)) {
		return Promise.resolve('');
	}

	var numericLat = parseFloat(lat);
	var numericLng = parseFloat(lng);
	var cacheKey = numericLat.toFixed(6) + ',' + numericLng.toFixed(6);
	var fallbackText = Wo_ExploreNearbyBuildCoordinateText(numericLat, numericLng);

	if (Object.prototype.hasOwnProperty.call(WoExploreNearbyState.userReverseGeocodeCache, cacheKey)) {
		return Promise.resolve(WoExploreNearbyState.userReverseGeocodeCache[cacheKey] || fallbackText);
	}

	if (WoExploreNearbyState.userReverseGeocodePending[cacheKey]) {
		return WoExploreNearbyState.userReverseGeocodePending[cacheKey];
	}

	var resolvePromise = null;
	if (Wo_ExploreNearbyGetGoogleGeocoder()) {
		resolvePromise = new Promise(function(resolve) {
			Wo_ExploreNearbyGetGoogleGeocoder().geocode({
				location: {
					lat: numericLat,
					lng: numericLng
				}
			}, function(results, status) {
				var addressText = '';
				if (status === 'OK' && Array.isArray(results) && results[0]) {
					addressText = $.trim(results[0].formatted_address || '');
				}
				resolve(addressText);
			});
		});
	}
	else {
		resolvePromise = Promise.resolve('');
	}

	WoExploreNearbyState.userReverseGeocodePending[cacheKey] = resolvePromise.then(function(addressText) {
		var normalizedAddress = $.trim(addressText || '') || fallbackText;
		WoExploreNearbyState.userReverseGeocodeCache[cacheKey] = normalizedAddress;
		delete WoExploreNearbyState.userReverseGeocodePending[cacheKey];
		return normalizedAddress;
	}).catch(function() {
		WoExploreNearbyState.userReverseGeocodeCache[cacheKey] = fallbackText;
		delete WoExploreNearbyState.userReverseGeocodePending[cacheKey];
		return fallbackText;
	});

	return WoExploreNearbyState.userReverseGeocodePending[cacheKey];
}

