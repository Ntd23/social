	return {
		url: 'data:image/svg+xml;charset=UTF-8,' + encodeURIComponent(Wo_ExploreNearbyGetPinSvg(point)),
		scaledSize: new google.maps.Size(metrics.width, metrics.height),
		anchor: new google.maps.Point(metrics.anchorX, metrics.anchorY)
	};
}

function Wo_ExploreNearbyCreateLeafletMarkerIcon(point) {
	if (typeof L === 'undefined') {
		return null;
	}

	var metrics = Wo_ExploreNearbyGetPinMetrics(point);
	var shadow = (point && point.isSelf) ? 'drop-shadow(0 10px 18px rgba(13,110,253,0.34)) drop-shadow(0 0 18px rgba(37,99,235,0.22))' : 'drop-shadow(0 8px 16px rgba(15,23,42,0.24))';
	return L.divIcon({
		className: 'wo-nearby-user-map-marker',
		html: '<div style="width:' + metrics.width + 'px;height:' + metrics.height + 'px;filter:' + shadow + ';">' + Wo_ExploreNearbyGetPinSvg(point) + '</div>',
		iconSize: [metrics.width, metrics.height],
		iconAnchor: [metrics.anchorX, metrics.anchorY],
		popupAnchor: [0, metrics.popupY]
	});
}

function Wo_ExploreNearbyGetMarkerPosition(point, coordinateCounts) {
	var lat = parseFloat(point.lat);
	var lng = parseFloat(point.lng);
	if (isNaN(lat) || isNaN(lng)) {
		return null;
	}

	var key = lat.toFixed(6) + ',' + lng.toFixed(6);
	var duplicateIndex = coordinateCounts[key] || 0;
	coordinateCounts[key] = duplicateIndex + 1;

	if (duplicateIndex === 0) {
		return {lat: lat, lng: lng};
	}

	var angle = (duplicateIndex - 1) * (Math.PI / 3);
	var radius = 0.00012 * (Math.floor((duplicateIndex - 1) / 6) + 1);

	return {
		lat: lat + (Math.sin(angle) * radius),
		lng: lng + (Math.cos(angle) * radius)
	};
}

function Wo_ExploreNearbyGetRouteColor(point) {
	if (point && point.type === 'shop') {
