<script>
    function slugify(str) {
        str = str.toLowerCase().trim();

        // bỏ dấu tiếng Việt
        var from = "áàảãạăắằẳẵặâấầẩẫậéèẻẽẹêếềểễệíìỉĩịóòỏõọôốồổỗộơớờởỡợúùủũụưứừửữựýỳỷỹỵđ";
        var to   = "aaaaaaaaaaaaaaaaaeeeeeeeeeeeiiiiiooooooooooooooooouuuuuuuuuuuyyyyyd";

        for (var i = 0; i < from.length; i++) {
            str = str.replace(new RegExp(from[i], 'g'), to[i]);
        }

        // chỉ giữ a-z, 0-9, space, dấu -
        str = str
            .replace(/[^a-z0-9\s-]/g, '')  // bỏ ký tự lạ
            .replace(/\s+/g, '_')          // space -> -
            .replace(/-+/g, '_');          // gộp --- thành -

        return str;
    }

    $(document).ready(function () {
        $('#page_title').on('keyup blur', function () {
            var title = $(this).val();
            var slug  = slugify(title);

            $('#page_name').val(slug);

            // cập nhật preview
            $('#page_url_preview').text('<?php echo $wo['config']['site_url'];?>/' + slug);
        });
    });
</script>
