	});

	$('#nearby-username').on('input', function () {
		clearTimeout(nearbyShopsSearchTimer);
		nearbyShopsSearchTimer = setTimeout(function () {
			Wo_LoadNearByShops();
		}, 300);
	});

	$('#nearby-username').on('keypress', function (e) {
		if (e.which == 13) {
			e.preventDefault();
			$(this).blur();
			Wo_LoadNearByShops();
		}
	});

	function Wo_ShouldGeocodeNearbyShopResults(usersInfo) {
		var searchValue = ($('#nearby-username').val() || '').trim();
		if (!searchValue || !Array.isArray(usersInfo) || usersInfo.length === 0) {
			return false;
		}

		var distinctLocations = {};
		var duplicateCoordinates = false;
		var coordinateCounts = {};

		for (var i = 0; i < usersInfo.length; i++) {
			var item = usersInfo[i] || {};
			if (item.location) {
				distinctLocations[item.location.trim().toLowerCase()] = true;
			}

			var lat = parseFloat(item.lat);
			var lng = parseFloat(item.lng);
			if (!isNaN(lat) && !isNaN(lng)) {
				var coordinateKey = lat.toFixed(6) + ',' + lng.toFixed(6);
				coordinateCounts[coordinateKey] = (coordinateCounts[coordinateKey] || 0) + 1;
				if (coordinateCounts[coordinateKey] > 1) {
					duplicateCoordinates = true;
				}
			}
		}

		return duplicateCoordinates && Object.keys(distinctLocations).length > 1;
	}

	function Wo_GeocodeNearbyShopLocation(location) {
		var normalizedLocation = (location || '').trim();
		if (!normalizedLocation) {
			return Promise.resolve(null);
		}

		if (nearbyShopLocationGeocodeCache.hasOwnProperty(normalizedLocation)) {
			return Promise.resolve(nearbyShopLocationGeocodeCache[normalizedLocation]);
		}

		return fetch('https://nominatim.openstreetmap.org/search?format=jsonv2&limit=1&q=' + encodeURIComponent(normalizedLocation), {
			headers: {
				'Accept': 'application/json'
			}
		})
			.then(function(response) {
				if (!response.ok) {
					throw new Error('Geocoding request failed');
				}
				return response.json();
			})
			.then(function(results) {
				var geocodedLocation = null;
				if (Array.isArray(results) && results.length > 0) {
					var match = results[0];
					var lat = parseFloat(match.lat);
					var lng = parseFloat(match.lon);
					if (!isNaN(lat) && !isNaN(lng)) {
						geocodedLocation = {
							lat: lat,
							lng: lng
						};
					}
				}

				nearbyShopLocationGeocodeCache[normalizedLocation] = geocodedLocation;
				return geocodedLocation;
			})
			.catch(function() {
				nearbyShopLocationGeocodeCache[normalizedLocation] = null;
				return null;
			});
	}

	function Wo_ResolveNearbyShopMarkers(usersInfo) {
		if (!Wo_ShouldGeocodeNearbyShopResults(usersInfo)) {
			return Promise.resolve(usersInfo);
		}

		return Promise.all(usersInfo.map(function(item) {
			if (!item || !item.location) {
				return Promise.resolve(item);
			}

			return Wo_GeocodeNearbyShopLocation(item.location).then(function(geocodedLocation) {
				if (!geocodedLocation) {
					return item;
				}

				return $.extend({}, item, {
					lat: geocodedLocation.lat,
					lng: geocodedLocation.lng
				});
			});
		}));
	}

	function Wo_DrawNearbyShopMarkers(usersInfo, shouldFit, renderToken) {
		if (!map) {
			return;
		}

		if (typeof renderToken !== 'undefined' && renderToken !== nearbyMarkerRenderToken) {
			return;
		}

		for (var i = 0; i < markersArray.length; i++) {
			map.removeLayer(markersArray[i]);
		}

		markersArray = [];
		nearbyMarkerCoordinateCounts = {};

		if (!Array.isArray(usersInfo) || usersInfo.length === 0) {
			map.setView([<?php echo $wo['user']['lat']?>, <?php echo $wo['user']['lng']?>], 7);
			return;
		}

		var bounds = [];
		usersInfo.forEach(function(element) {
			var markerInfo = Wo_CreateNearbyShopMarkerPosition(element);
			if (!markerInfo) {
				return;
			}

			var popupHtml = '<strong>' + (element.name || '') + '</strong>';
			if (element.location) {
				popupHtml += '<br>' + element.location;
			}

			var marker = new L.marker([markerInfo.lat, markerInfo.lng])
				.bindPopup(popupHtml)
				.addTo(map);
			markersArray.push(marker);
			bounds.push([markerInfo.lat, markerInfo.lng]);
		});

		if (shouldFit !== false && bounds.length > 0) {
			map.fitBounds(bounds, {padding: [30, 30]});
		}
	}

	function Wo_ResetNearbyShopMarkers(usersInfo, shouldFit) {
		nearbyMarkerRenderToken++;
		var renderToken = nearbyMarkerRenderToken;

		Wo_ResolveNearbyShopMarkers(usersInfo || []).then(function(resolvedUsersInfo) {
			Wo_DrawNearbyShopMarkers(resolvedUsersInfo || [], shouldFit, renderToken);
		});
	}

	function Wo_CreateNearbyShopMarkerPosition(element) {
		var lat = parseFloat(element.lat);
		var lng = parseFloat(element.lng);
		if (isNaN(lat) || isNaN(lng)) {
			return null;
		}

		var key = lat.toFixed(6) + ',' + lng.toFixed(6);
		var duplicateIndex = nearbyMarkerCoordinateCounts[key] || 0;
		nearbyMarkerCoordinateCounts[key] = duplicateIndex + 1;

		if (duplicateIndex === 0) {
			return {lat: lat, lng: lng};
		}

		var angle = (duplicateIndex - 1) * (Math.PI / 3);
		var radius = 0.00012 * (Math.floor((duplicateIndex - 1) / 6) + 1);

		return {
			lat: lat + (Math.sin(angle) * radius),
			lng: lng + (Math.cos(angle) * radius)
		};
	}

	function Wo_ShowUserLocationMap(user_geoData = false) {
		if (!user_geoData) {return false;}
		<?php if ($wo['config']['google_map'] == 1) { ?>
		var google_map_api = 'https://www.google.com/maps/embed/v1/place?key=<?php echo $wo['config']['google_map_api']; ?>&q=' + user_geoData;
		$("#show_user_location_map").modal().find('iframe').attr('src', google_map_api);
		<?php } ?>
		<?php if ($wo['config']['yandex_map'] == 1) { ?>
			$('#show_user_location__map').html('');
			$("#show_user_location_map").modal();
			let geo = user_geoData.split(",");
			var userMap = new ymaps.Map('show_user_location__map', {
		        center: [geo[0],geo[1]],
		        zoom: 9
		    });
		    userMap.geoObjects.add(new ymaps.Placemark([geo[0],geo[1]], {
	            balloonContent: ''
	        }));
	    <?php } ?>

	}
	function Wo_LoadNearByShops(self = false){
		var name     = $("#nearby-username").val();
		var distance = $("#nearby-users-distance").val();
		if (self) {
			Wo_progressIconLoader($(self));
		}
		else{
			Wo_StartBar();
		}

		if (nearbyShopsRequest && nearbyShopsRequest.readyState !== 4) {
			nearbyShopsRequest.abort();
		}
		
		nearbyShopsRequest = $.ajax({
			url: Wo_Ajax_Requests_File(),
			type: 'GET',
			dataType: 'json',
			timeout: 10000,
			data: {
				f:'nearby_shops',
				s:'load',
				name:name,
				distance:distance
			},
		})
		.done(function(data) {

	        if (data['status'] == 200){
	        	$("#nearby_users_list").html(data.html);
	        	$("[data-toggle]").tooltip();
	        	$("#load_more_nearby_users").html('<span><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"></path></svg></span> <?php echo $wo['lang']['load_more']; ?>');
	        	Wo_ResetNearbyShopMarkers(data.users_info || [], true);
	        	$('.sun_users_count').find('b').text(data.count);

	        } 

	        else{
	        	$('.sun_users_count').find('b').text(0);
	        	Wo_ResetNearbyShopMarkers([], false);
	        	scrollToTop();
	        	$("#nearby_users_list").html('<h5 class="search-filter-center-text empty_state"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-users"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg> <?php echo $wo['lang']['no_result']; ?></h5>');
	        } 
		})
		.fail(function(xhr, status) {
			if (status !== 'abort') {
				$('.sun_users_count').find('b').text(0);
				Wo_ResetNearbyShopMarkers([], false);
				$("#nearby_users_list").html('<h5 class="search-filter-center-text empty_state"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-users"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg> <?php echo $wo['lang']['no_result']; ?></h5>');
			}
		})
		.always(function() {
			if (self) {
				Wo_progressIconLoader($(self));
			}
			else{
				Wo_FinishBar();
			}
		})
	}
	function Wo_LoadMoreNearByShops(){
		var after_id = ($(".page_last_id").length > 0) ? $(".page_last_id").last().attr('data-id') : 0;
		var name     = $("#nearby-username").val();
		var distance = $("#nearby-users-distance").val();
		if (!after_id) { return false;}
		Wo_progressIconLoader($('#load_more_nearby_users'));
		$.ajax({
			url: Wo_Ajax_Requests_File(),
			type: 'GET',
			dataType: 'json',
			data: {
				f:'nearby_shops',
				s:'load',
				offset:after_id,
				name:name,
				distance:distance,

			},
		})
		.done(function(data) {

	        if (data['status'] == 200){
	        	$("#nearby_users_list").append(data.html);
	        	$("[data-toggle]").tooltip();
	        	$("#load_more_nearby_users").html('<span><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"></path></svg></span> <?php echo $wo['lang']['load_more']; ?>');
	        	if (data.users_info != '') {
	        		Wo_ResolveNearbyShopMarkers(data.users_info).then(function(resolvedUsersInfo) {
	        			(resolvedUsersInfo || []).forEach(function(element) {
	        				var markerInfo = Wo_CreateNearbyShopMarkerPosition(element);
	        				if (!markerInfo) {
	        					return;
	        				}
	        				var popupHtml = '<strong>' + (element.name || '') + '</strong>';
	        				if (element.location) {
	        					popupHtml += '<br>' + element.location;
	        				}
	        				var marker = new L.marker([markerInfo.lat, markerInfo.lng])
	        					.bindPopup(popupHtml)
	        					.addTo(map);
							markersArray.push(marker);
						});
	        		});
	        	}
	        } 

	        else{
	        	$("#load_more_nearby_users").html('<?php echo $wo['lang']['no_result']; ?>');
	        } 
		})
		.fail(function() {
			console.log("error");
		})
	}
</script>
