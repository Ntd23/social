    }

    function updateUI() {
      const select = getSelectUserId();
      $('#messages-chips-inline').text(select.map(u => u.name).join(', '));

      const $all = $('#messages-multi-select-all');
      const $visible = $('#messages-multi-all .messages-multi-user-item:visible .messages-multi-ck');
      const total = $visible.length;
      const checked = $visible.filter(':checked').length;

      if (checked === 0) {
        $all.prop('indeterminate', false).prop('checked', false);
      } else if (checked === total) {
        $all.prop('indeterminate', false).prop('checked', true);
      } else {
        $all.prop('indeterminate', true).prop('checked', false);
      }
    }
    window.MessagesMultiGetSelected = getSelectUserId;
    window.MessagesMultiUpdateUI = updateUI;
    window.MessagesMultiToggleAll = function(el) {
      const isChecked = $(el).is(':checked');
