<script>
  (function($) {
    const ajaxUrl = (typeof Wo_Ajax_Requests_File === 'function') ? Wo_Ajax_Requests_File() : '/requests.php';
    function getTagHash() {
      return $('input[name="hash_id"]').val() ||
        $('.main_session').val() ||
        (window.wo && wo.user && wo.user.session_hash) ||
        '';
    }

    // Lưu target hiện hành
    const TARGET = {
      type: 'user',
      id: 0
    };

    // ==== helpers ====
    function hexOK(v) {
      return /^#[0-9A-Fa-f]{6}$/.test(v || '');
    }

    function esc(s) {
      return $('<div>').text(s || '').html();
    }

    // API
    function apiListLabels() {
      return $.post(`${ajaxUrl}?f=tags&s=list_labels`, {
        hash_id: getTagHash()
      }, null, 'json');
    }

    function apiListTargetTags() {
      if (!TARGET.id) return $.Deferred().resolve({
        status: 200,
        tags: []
      }).promise();
      return $.post(`${ajaxUrl}?f=tags&s=list_target_tags`, {
        target_type: TARGET.type,
        target_id: TARGET.id,
        hash_id: getTagHash()
      }, null, 'json');
      // console.log(target_type, target_id);
    }

    function apiAttach(label_id) {
      return $.post(`${ajaxUrl}?f=tags&s=attach_label`, {
        label_id,
        target_type: TARGET.type,
        target_id: TARGET.id,
        hash_id: getTagHash()
      }, null, 'json');
    }

    function apiDetach(label_id) {
      return $.post(`${ajaxUrl}?f=tags&s=detach`, {
        label_id,
        target_type: TARGET.type,
        target_id: TARGET.id,
        hash_id: getTagHash()
      }, null, 'json');
    }

    function apiCreate(name, color) {
      return $.post(`${ajaxUrl}?f=tags&s=create_label`, {
        label_name: name,
        label_color: color,
        hash_id: getTagHash()
      }, null, 'json');
    }

    function apiDelete(label_id) {
      return $.post(`${ajaxUrl}?f=tags&s=delete_label`, {
        label_id,
        hash_id: getTagHash()
      }, null, 'json');
    }

    // ==== render assign tab ====
    function loadAssign() {
      return $.when(apiListLabels(), apiListTargetTags()).done(function(labRes, curRes) {
        const labels = (labRes && labRes[0] && labRes[0].labels) || [];
        const current = (curRes && curRes[0] && curRes[0].tags) || [];

        const currSet = {};
        current.forEach(t => {
          const tid = (t && (t.id || t.tag_id || t.label_id)) | 0;
          if (tid) currSet[tid] = 1;
        });

        const $list = $('#assign-list').empty();
        if (!labels.length) {
          $list.html('<div class="list-group-item text-muted">(Chưa có thẻ)</div>');
          return;
        }

        labels.forEach(function(l) {
          const labelId = (l.id != null ? l.id : l.label_id) | 0; // <-- dùng labelId nhất quán
          const attached = !!currSet[labelId];

          $list.append(
            `<div class="list-group-item d-flex align-items-center ${attached?'is-attached':''}" data-id="${labelId}">
           <span style="width:12px;height:12px;border-radius:50%;background:${l.color||'#999'};display:inline-block;margin-right:10px;"></span>
           <span class="flex-fill">${esc(l.name)}</span>
           <button class="btn btn-sm btn-link chat-assign-toggle">${attached?'Gỡ':'Gắn'}</button>
         </div>`
          );
        });
      });
    }


    // ==== render manage tab ====
    function loadManage() {
      return apiListLabels().done(function(res) {
        const labels = (res && res.labels) || [];
        const $list = $('#manage-list').empty();
        if (!labels.length) {
          $list.html('<div class="list-group-item text-muted">(Chưa có thẻ)</div>');
          return;
        }
        labels.forEach(function(l) {
          $list.append(
            `<div class="list-group-item d-flex align-items-center" data-id="${l.id}">
             <span style="width:12px;height:12px;border-radius:50%;background:${l.color||'#999'};display:inline-block;margin-right:10px;"></span>
             <span class="flex-fill">${esc(l.name)}</span>
             <button class="btn btn-sm btn-link text-danger chat-tag-del">Xoá</button>
           </div>`
          );
        });
      });
    }

    // ==== mở modal từ nút gán ====
    $(document).on('click', '.btn-open-tag-modal', function(e) {
      e.preventDefault();
      e.stopPropagation();
      TARGET.type = String($(this).data('target-type') || 'user');
      TARGET.id = parseInt($(this).data('target-id'), 10) || 0;

      // mở modal & mặc định tab "Gán thẻ"
      $('#chat-tag-tabs a[href="#tab-assign"]').tab('show');
      if ($.fn.modal) $('#chatTagModal').modal('show');
      else $('#chatTagModal').show();
    });

    // mỗi lần modal mở → nạp tab đang active
