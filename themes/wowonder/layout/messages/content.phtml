  function escapeRegExp(str) {
    let arr = str.match(/[.*+?^{}()|[\]\\]/g)
    if (arr && arr.length) {
      for (let a of arr) {
        str = str.replace(/[.*+?^{}()|[\]\\]/g, '\\' + a)
      }
    }
    return str
  }

