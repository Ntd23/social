    });
    $('#messages_tag_user_id').on('change', function() {
      const tagId = $(this).val();
      var tagText = $('#messages_tag_user_id option:selected').text() || '';
      const main_hash_id =
        $('input[name="hash_id"]').val() ||
        $('.main_session').val() ||
        (window.wo && window.wo.user && window.wo.user.session_hash) ||
        '';
      console.log('Tag changed', tagId);
      if (tagId === '0') {
        $.ajax({
          url: (typeof Wo_Ajax_Requests_File === 'function' ?
            Wo_Ajax_Requests_File() :
            '/requests.php') + '?f=tags&s=all_tags',
          type: 'POST',
          dataType: 'json',
          data: {
            hash_id: main_hash_id
          },
          success: function(resp) {
            var ids = Array.isArray(resp && resp.user_ids) ? resp.user_ids : [];
            ids = ids.map(x => parseInt(x, 10) || null).filter(Boolean);
            $('.messages-multi-ck').prop('checked', false);

            // Hiển thị chỉ những user có thẻ + tick (tuỳ bạn)
            var set = {};
            ids.forEach(i => set[i] = 1);
            $('.messages-multi-user-item').each(function() {
              var uid = parseInt($(this).data('uid'), 10) || 0;
              $(this).toggle(!!set[uid]);
            });
            ids.forEach(function(uid) {
              $('.messages-multi-ck[value="' + uid + '"]').prop('checked', true);
            });

            $('#multi-status').text('Tất cả người đã gắn thẻ — ' + ids.length + ' user');
            updateUI();
          }
        });
        return;
      }


      $.ajax({
        url: (typeof Wo_Ajax_Requests_File === 'function' ?
          Wo_Ajax_Requests_File() :
          '/requests.php') + '?f=tags&s=selected_tags&hash=' + main_hash_id,
        method: 'POST',
        dataType: 'json',
        data: {
          tag_id: tagId,
          hash_id: main_hash_id
        },
        success: function(resp) {
          var ids = Array.isArray(resp && resp.user_ids) ?
            resp.user_ids :
            Array.isArray(resp && resp.data) ?
            resp.data.map(function(r) {
              return parseInt(r.target_user_id, 10) || null;
            }) : [];

          ids = ids.filter(Boolean); // loại null/NaN
          // 1) Tick checkbox đúng id
          $('.messages-multi-ck').prop('checked', false);
          ids.forEach(function(uid) {
            $('.messages-multi-ck[value="' + uid + '"]').prop('checked', true);
          });

          // 2) LỌC LIST: chỉ hiển thị user thuộc thẻ
          if (ids.length > 0) {
            var set = {};
            ids.forEach(function(id) {
              set[id] = 1;
            });
            $('.messages-multi-user-item').each(function() {
              var uid = parseInt($(this).data('uid'), 10) || 0;
              $(this).toggle(!!set[uid]);
            });
            $('#multi-status').text('Đang lọc theo thẻ "' + tagText + '" — ' + ids.length + ' user');
          } else {
            // Không có ai thuộc thẻ → ẩn tất cả cho rõ ràng
            $('.messages-multi-user-item').hide();
            $('#multi-status').text('Không có user nào gán thẻ "' + tagText + '"');
          }

          updateUI();
        },
        error: function(xhr) {
          console.error('AJAX failed', xhr);
        }
      });
    });

    function refreshTagFilterSelect({
      preserve = true,
      selectId = null
    } = {}) {
      const $sel = $('#messages_tag_user_id');
      const prev = preserve ? $sel.val() : null;

      return apiListLabels().done(function(res) {
        const labels = Array.isArray(res && res.labels) ? res.labels : [];

        const html = [];
        // Giữ nguyên hành vi: value="0" = "Tất cả người đã gắn thẻ"
        html.push('<option value="" disabled selected>Chọn thẻ…</option>');
        html.push('<option value="0">Tất cả người đã gắn thẻ</option>');
        labels.forEach(function(l) {
          const id = (l.id != null ? l.id : l.label_id) | 0;
          const name = esc(l.name);
          html.push(`<option value="${id}">${name}</option>`);
        });

        $sel.html(html.join(''));

        // Ưu tiên chọn thẻ vừa tạo nếu có selectId
        if (selectId != null && $sel.find(`option[value="${selectId}"]`).length) {
          $sel.val(String(selectId));
        } else if (preserve && prev != null && $sel.find(`option[value="${prev}"]`).length) {
          $sel.val(prev);
        } else {
          // Không giữ được state → để placeholder
          $sel.val('');
        }

        // Nếu đang dùng Select2:
        if ($sel.hasClass('select2-hidden-accessible')) {
          $sel.trigger('change.select2');
        }
      }).fail(function() {
        $sel.html('<option value="">(Không tải được thẻ)</option>');
      });
    }

    // Gọi 1 lần khi trang sẵn sàng
    $(document).ready(function() {
      refreshTagFilterSelect({
        preserve: false
      });
    });

    // Cho phép nơi khác trong app “bắn” sự kiện để refresh dropdown
    $(document).on('tags:labelsChanged', function(e, opts) {
      refreshTagFilterSelect(opts || {
        preserve: true
      });
    });
    window.MessagesMultiSubmitLegacy = function(e) {
      e.preventDefault();

      const selected = getSelectUserId();
      const ids = selected.map(u => parseInt(u.id, 10)).filter(Boolean);
      const text = ($('#messages-multi-text').val() || '').trim();
      const file = $('#messages-multi-file')[0]?.files?.[0] || null;

      const $btn = $(this);
      const $status = $('#multi-status');

      if (!ids.length) {
        $status.text('Chưa chọn người nhận.');
        return;
      }
      if (!text && !file) {
        $status.text('Nhập nội dung hoặc chọn file.');
        return;
      }

      const fd = new FormData();
      const main_hash_id =
        $('input[name="hash_id"]').val() ||
        $('.main_session').val() ||
        (window.wo && window.wo.user && window.wo.user.session_hash) ||
        '';
      fd.append('textSendMessage', text);
      fd.append('hash_id', main_hash_id);
      ids.forEach(id => fd.append('recipients[]', id));
      if (file) fd.append('sendMessageFile', file, file.name);

      $btn.prop('disabled', true).text('Sending…');
      $status.text('Đang gửi…');

      $.ajax({
          url: (typeof Wo_Ajax_Requests_File === 'function' ? Wo_Ajax_Requests_File() : '/requests.php') +
            '?f=messages&s=multi_send&hash=' + encodeURIComponent(main_hash_id),
          method: 'POST',
          data: fd,
          processData: false,
          contentType: false,
          dataType: 'json'
        })
        .done(function(res) {
          if (!res || typeof res.status === 'undefined') {
            $status.text('Có lỗi không xác định.');
            return;
          }

          if (res.status === 200) {
            const sentCount = Array.isArray(res.sent_ids) ? res.sent_ids.length : (parseInt(res.sent, 10) || 0);
            $status.text(`Đã gửi thành công cho ${sentCount} người.`);
            // Chỉ xóa input SAU KHI thành công:
            $('#messages-multi-text').val('');
            $('#messages-multi-file').val('');
            $('#messages-multi-select-all').prop('checked', false).prop('indeterminate', false);
            $('#messages-multi-all .messages-multi-ck').prop('checked', false);
            updateUI();
          } else if (res.status === 207) {
            const ok = Array.isArray(res.sent_ids) ? res.sent_ids.length : (parseInt(res.sent, 10) || 0);
            const bad = Array.isArray(res.failed) ? res.failed.length : (parseInt(res.failed_count, 10) || 0);
            $status.text(`Đã gửi cho ${ok} người, lỗi ${bad} người.`);
          } else if (res.status === 422) {
            $status.text(res.error || 'Thiếu dữ liệu.');
          } else if (res.status === 500) {
            $status.text('Gửi thất bại. Vui lòng thử lại.');
          } else {
            $status.text('Không rõ trạng thái.');
          }

          if (res.invalid_file === 1) $status.text('File vượt quá giới hạn dung lượng.');
          if (res.invalid_file === 2) $status.text('Định dạng file không được hỗ trợ.');
          if (res.invalid_file === 3) $status.text('Chỉ tài khoản Pro mới được gửi file/ghi âm.');
        })
        .fail(function(xhr) {
          console.error('multi_send error', xhr.status, xhr.responseText);
          $status.text('Lỗi kết nối máy chủ.');
        })
        .always(function() {
          $btn.prop('disabled', false).text('Send messages');
        });
    };
    $('#messages-multi-send-btn').off('click');




