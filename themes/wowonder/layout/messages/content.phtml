  function Wo_AddEmoToMessageInput(code) {
    inputTag = $('#sendMessage');
    inputVal = inputTag.val();
    if (typeof(inputTag.attr('placeholder')) != "undefined") {
      inputPlaceholder = inputTag.attr('placeholder');
      if (inputPlaceholder == inputVal) {
        inputTag.val('');
        inputVal = inputTag.val();
      }
    }
    if (inputVal.length == 0) {
      inputTag.val(code + ' ');
    } else {
      inputTag.val(inputVal + ' ' + code);
    }
    inputTag.keyup().focus();
    $(".emo-messages-container").slideUp('fast');
  }

  function Wo_GetInitialMessageUserFromUrl() {
    try {
      var pathname = window.location.pathname || '';
      var match = pathname.match(/\/messages\/(\d+)(?:\/)?$/);
      if (match && match[1]) {
        return parseInt(match[1], 10) || 0;
      }
      var params = new URLSearchParams(window.location.search || '');
      var userParam = params.get('user');
      if (userParam && /^\d+$/.test(userParam)) {
        return parseInt(userParam, 10) || 0;
      }
    } catch (e) {}
    return 0;
  }

    function Wo_IsMobileMessagesView() {
    return Math.max(window.innerWidth || 0, document.documentElement.clientWidth || 0, $(window).width() || 0) <= 991;
  }

