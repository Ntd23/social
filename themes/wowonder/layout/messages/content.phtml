<script>
  (function() {
    function qs(sel, root) {
      return (root || document).querySelector(sel);
    }

    function qsa(sel, root) {
      return Array.prototype.slice.call((root || document).querySelectorAll(sel));
    }

    function messagesVisibleItems() {
      return qsa('#messages-multi-all .messages-multi-user-item').filter(function(item) {
        return item.style.display !== 'none';
      });
    }

    function messagesVisibleChecks() {
      return messagesVisibleItems().map(function(item) {
        return qs('.messages-multi-ck', item);
      }).filter(Boolean);
    }

    function messagesCheckedData() {
      return messagesVisibleChecks().filter(function(input) {
        return input.checked;
      }).map(function(input) {
        return {
          id: input.value,
          name: input.getAttribute('data-name') || ''
        };
      });
    }

    function getMessagesHash() {
      return (qs('input[name="hash_id"]') && qs('input[name="hash_id"]').value) ||
        (qs('.main_session') && qs('.main_session').value) ||
        ((window.wo && wo.user && wo.user.session_hash) ? wo.user.session_hash : '');
    }

    function renderMessagesMultiState() {
      var chips = qs('#messages-chips-inline');
      var selectAll = qs('#messages-multi-select-all');
      var visibleChecks = messagesVisibleChecks();
      var checked = visibleChecks.filter(function(input) { return input.checked; }).length;
      if (chips) {
        chips.textContent = messagesCheckedData().map(function(x) { return x.name; }).join(', ');
      }
      if (selectAll) {
        if (!visibleChecks.length || checked === 0) {
          selectAll.checked = false;
          selectAll.indeterminate = false;
        } else if (checked === visibleChecks.length) {
          selectAll.checked = true;
          selectAll.indeterminate = false;
        } else {
          selectAll.checked = false;
          selectAll.indeterminate = true;
        }
      }
    }

    function applyMessagesIds(ids) {
      var set = {};
      ids.forEach(function(id) { set[String(id)] = true; });

      qsa('#messages-multi-all .messages-multi-user-item').forEach(function(item) {
        var uid = item.getAttribute('data-uid') || '';
        var input = qs('.messages-multi-ck', item);
        var matched = !!set[String(uid)];
        item.style.display = matched ? '' : 'none';
        if (input) {
          input.checked = matched;
        }
      });

      renderMessagesMultiState();
    }

    window.MessagesMultiUpdateUI = function() {
      renderMessagesMultiState();
    };

    window.MessagesMultiToggleAll = function(el) {
      messagesVisibleChecks().forEach(function(input) {
        input.checked = !!el.checked;
      });
      renderMessagesMultiState();
    };

    window.MessagesMultiApplyTagFilter = function(el) {
      var tagId = el && el.value ? String(el.value) : '';
      var status = qs('#multi-status');
      var ajaxUrl = (typeof Wo_Ajax_Requests_File === 'function') ? Wo_Ajax_Requests_File() : '/requests.php';
      var hash = getMessagesHash();

      if (!tagId) {
        qsa('#messages-multi-all .messages-multi-user-item').forEach(function(item) {
          item.style.display = '';
          var input = qs('.messages-multi-ck', item);
          if (input) input.checked = false;
        });
        if (status) status.textContent = '';
        renderMessagesMultiState();
        return;
      }

      var endpoint = tagId === '0' ? 'all_tags' : 'selected_tags';

      jQuery.ajax({
        url: ajaxUrl + '?f=tags&s=' + endpoint + '&hash=' + encodeURIComponent(hash),
        type: 'POST',
        dataType: 'json',
        data: tagId === '0' ? { hash_id: hash } : { tag_id: tagId, hash_id: hash }
      }).done(function(resp) {
        var ids = [];
        if (tagId === '0') {
          ids = Array.isArray(resp && resp.user_ids) ? resp.user_ids : [];
        } else if (Array.isArray(resp && resp.user_ids)) {
          ids = resp.user_ids;
        } else if (Array.isArray(resp && resp.data)) {
          ids = resp.data.map(function(r) { return parseInt(r.target_user_id, 10) || null; }).filter(Boolean);
        }

        applyMessagesIds(ids.map(function(x) { return parseInt(x, 10) || 0; }).filter(Boolean));
        if (status) {
          status.textContent = ids.length ? ('Đã chọn ' + ids.length + ' người dùng') : 'Không có người dùng phù hợp';
        }
      }).fail(function() {
        if (status) status.textContent = 'Không tải được danh sách người dùng theo thẻ';
      });
    };

    window.MessagesMultiSubmit = function(e) {
      if (e && typeof e.preventDefault === 'function') {
        e.preventDefault();
      }

      var status = qs('#multi-status');
      var button = qs('#messages-multi-send-btn');
      var textInput = qs('#messages-multi-text');
      var fileInput = qs('#messages-multi-file');
      var selected = messagesCheckedData();
      var ids = selected.map(function(item) {
        return parseInt(item.id, 10) || 0;
      }).filter(Boolean);
      var text = textInput ? (textInput.value || '').trim() : '';
      var file = (fileInput && fileInput.files && fileInput.files[0]) ? fileInput.files[0] : null;

      if (!ids.length) {
        if (status) status.textContent = 'Chưa chọn người nhận.';
        return false;
      }
      if (!text && !file) {
        if (status) status.textContent = 'Nhập nội dung hoặc chọn file.';
        return false;
      }

      var fd = new FormData();
      var hash = getMessagesHash();
      fd.append('textSendMessage', text);
      fd.append('hash_id', hash);
      ids.forEach(function(id) {
        fd.append('recipients[]', id);
      });
      if (file) {
        fd.append('sendMessageFile', file, file.name);
      }

      if (button) {
        button.disabled = true;
        button.textContent = 'Đang gửi...';
      }
      if (status) status.textContent = 'Đang gửi...';

      jQuery.ajax({
        url: ((typeof Wo_Ajax_Requests_File === 'function') ? Wo_Ajax_Requests_File() : '/requests.php') +
          '?f=messages&s=multi_send&hash=' + encodeURIComponent(hash),
        type: 'POST',
        data: fd,
        processData: false,
        contentType: false,
        dataType: 'json'
      }).done(function(res) {
        if (!res || typeof res.status === 'undefined') {
          if (status) status.textContent = 'Có lỗi không xác định.';
          return;
        }

        if (res.status === 200) {
          var sentCount = Array.isArray(res.sent_ids) ? res.sent_ids.length : (parseInt(res.sent, 10) || 0);
          if (status) status.textContent = 'Đã gửi thành công cho ' + sentCount + ' người.';
          if (textInput) textInput.value = '';
          if (fileInput) fileInput.value = '';
          messagesVisibleChecks().forEach(function(input) {
            input.checked = false;
          });
          var selectAll = qs('#messages-multi-select-all');
          if (selectAll) {
            selectAll.checked = false;
            selectAll.indeterminate = false;
          }
          renderMessagesMultiState();
        } else if (res.status === 207) {
          var ok = Array.isArray(res.sent_ids) ? res.sent_ids.length : (parseInt(res.sent, 10) || 0);
          var bad = Array.isArray(res.failed) ? res.failed.length : (parseInt(res.failed_count, 10) || 0);
          if (status) status.textContent = 'Đã gửi cho ' + ok + ' người, lỗi ' + bad + ' người.';
        } else if (res.status === 422) {
          if (status) status.textContent = res.error || 'Thiếu dữ liệu.';
        } else if (res.status === 500) {
          if (status) status.textContent = 'Gửi thất bại. Vui lòng thử lại.';
        } else {
          if (status) status.textContent = 'Không rõ trạng thái.';
        }

        if (res.invalid_file === 1 && status) status.textContent = 'File vượt quá giới hạn dung lượng.';
        if (res.invalid_file === 2 && status) status.textContent = 'Định dạng file không được hỗ trợ.';
        if (res.invalid_file === 3 && status) status.textContent = 'Chỉ tài khoản Pro mới được gửi file/ghi âm.';
      }).fail(function(xhr) {
        console.error('messages multi_send error', xhr.status, xhr.responseText);
        if (status) status.textContent = 'Lỗi kết nối máy chủ.';
      }).always(function() {
        if (button) {
          button.disabled = false;
          button.textContent = 'Gửi tin nhắn';
        }
      });

      return false;
    };

    document.addEventListener('change', function(e) {
      if (e.target && e.target.matches('.messages-multi-ck')) {
        renderMessagesMultiState();
      }
    });

    document.addEventListener('DOMContentLoaded', function() {
      renderMessagesMultiState();
      var btn = qs('#messages-multi-send-btn');
      if (btn) {
        btn.addEventListener('click', window.MessagesMultiSubmit);
      }
    });
  })();
</script>



