       <div class="user-status-dot" style="padding-left:70px!important;" title="' . ($u['is_online'] ? 'Online' : 'Offline') . '">
        <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="' . $dot . '" d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"/>
