<?php
// Đếm tin chưa đọc
$message_count = Wo_CountMessages(['new' => true, 'user_id' => $wo['recipient']['user_id']]);

// Cache tất cả tag đã gán (1 lần mỗi request)
static $tagsByUser = null;
if ($tagsByUser === null) {
    $tagsByUser = [];
    $all = Wo_GetAllAssignedTagsByOwner(); // mỗi item: target_user_id, name, color, ...
    if (!empty($all)) {
        foreach ($all as $row) {
            $uid = (int)($row['target_user_id'] ?? 0);
            if ($uid) {
                $tagsByUser[$uid][] = [
                    'name'  => $row['name']  ?? '',
                    'color' => $row['color'] ?? '#9ca3af',
                ];
            }
        }
    }
}

$uid   = (int)$wo['recipient']['user_id'];
$tags  = $tagsByUser[$uid] ?? [];
$recipient_display_name = !empty($wo['recipient']['first_name']) ? $wo['recipient']['first_name'] : $wo['recipient']['name'];

$message = Wo_GetMessagesHeader(['user_id' => $uid], 1);
if (!empty($message['from_id'])) {
   if ($message['seen'] == 0 && $uid == $message['from_id']) {
     $unread_class = ' unread';
   }
   $text = $message['text'] ?? '';
   if (strlen($message['text']) > 100) {
     // $message['text'] = mb_substr($message['text'], 0, 97, 'utf-8') . '...';
   }
   $message['text'] = Wo_Emo($message['text']);
}
?>

<div class="messages-recipients-list mobileopenlist<?php echo isset($unread_class)?$unread_class:''; ?> <?php echo (!empty($wo['session_active_background']) && $wo['session_active_background'] == $uid) ? 'active' : ''; ?>" id="messages-recipient-<?php echo $uid; ?>" onclick="Wo_GetUserMessages(<?php echo $uid; ?>,'<?php echo $recipient_display_name; ?>');">
  <div class="avatar <?php echo Wo_RightToLeft('pull-left');?>">
    <img alt="<?php echo $recipient_display_name; ?> Profile Picture" src="<?php echo $wo['recipient']['avatar'];?>">
    <?php if ($wo['recipient']['lastseen'] > (time() - 60)) { ?>
      <div class="online_dot"><div class="dot"></div></div>
    <?php } else { ?>
      <div class="online_dot off_usr"><div class="dot"></div></div>
    <?php } ?>
    <span class="new-message-alert <?php echo ($message_count == 0) ? 'hidden' : ''; ?>"></span>
    <?php if (!empty($wo['recipient']['is_open_to_work']) && $wo['config']['website_mode'] == 'linkedin') { ?>
      <span title="<?php echo($wo['lang']['open_to_work']); ?>">
        <!-- icon ... -->
      </span>
    <?php } ?>
  </div>

  <div class="msg_rght_prt">
    <div class="messages-last-sent <?php echo ($message_count == 0) ? '' : 'new_msg_lst_lsent'; ?> <?php echo Wo_RightToLeft('pull-right');?> time ajax-time" title="<?php echo date('c',$message['time']); ?>">
      <?php echo (!empty($message['time'])) ? Wo_Time_Elapsed_String($message['time']) : '';?>
    </div>

    <span class="msg_ava_name">
      <span class="messages-user-name"><?php echo $recipient_display_name; ?></span>
    </span>

    <!-- ===== Giống sidebar: dải badge + nút gán ===== -->
    <div class="user_tag" style="margin:4px 0 2px;">
      <?php foreach ($tags as $t) { ?>
        <span class="badge user_tag_badge"
              title="<?php echo htmlspecialchars($t['name'], ENT_QUOTES, 'UTF-8'); ?>"
              style="background:<?php echo htmlspecialchars($t['color']); ?>;width:12px;height:12px;display:inline-block;border-radius:3px;border:1px solid #e5e7eb;margin-right:4px;"></span>
      <?php } ?>
       <button
				class="btn-open-tag-modal btn btn-sm wow_chat_list-right"
				style="padding:2px 5px; font-size:11px;"
				data-target-type="user"
				data-target-id="<?php echo (int)$wo['recipient']['user_id']; ?>"
				title="Gán nhãn cho người dùng">
				<i class="fa fa-tags" style="font-size:11px;"></i>
				<span class="tag-dot"></span>
			</button>
    </div>
    <!-- ============================================== -->

    <p class="<?php echo ($message_count == 0) ? '' : 'new_msg_active_list'; ?>">
      <?php echo !empty($message['text']) ? $message['text'] : ''; ?>
    </p>
  </div>
  <div class="clear"></div>
</div>
