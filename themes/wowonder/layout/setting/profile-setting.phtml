		var val = $(this).val().trim();
		$('#profile_address_value').val(val);
		Wo_ClearProfileLocationCoordinates(false);
		woProfileLocTimer = setTimeout(function() {
			Wo_SearchProfileLocationSuggestions(val);
		}, 250);
	});
	$('#profile_location_input').on('change blur', function() {
		var locationValue = $(this).val().trim();
		$('#profile_address_value').val(locationValue);
		if (!locationValue) {
			Wo_ClearProfileLocationCoordinates(false);
		}
		setTimeout(function() { Wo_RenderProfileLocationSuggestions([]); }, 150);
	});
	$(document).on('mousedown', '.profile_location_suggestion_item', function(e) {
		e.preventDefault();
		var loc = $(this).attr('data-location') || '';
		var lat = $(this).attr('data-lat') || '';
		var lng = $(this).attr('data-lng') || '';
		$('#profile_location_input').val(loc);
		$('#profile_address_value').val(loc);
		Wo_SetProfileLocationCoordinates(lat, lng);
		Wo_RenderProfileLocationSuggestions([]);
		Wo_GeocodeProfilePlaceId(pid);
	});
});
</script>
