// --- Profile Location Autocomplete (Google Maps) ---
function Wo_SetProfileCoordinates(lat, lng) {
	$('#lat-profile').val(lat || '');
	$('#lng-profile').val(lng || '');
}
var woProfilePlaceAutocompleteElement = null;
function Wo_GetProfileLocationField() {
	return document.getElementById('location');
}
function Wo_ReadProfileLocationValue() {
	var locationField = Wo_GetProfileLocationField();
	if (!locationField) return '';
	if (woProfilePlaceAutocompleteElement && typeof woProfilePlaceAutocompleteElement.value === 'string') {
		locationField.value = woProfilePlaceAutocompleteElement.value;
	}
	return (locationField.value || '').trim();
}
function Wo_WriteProfileLocationValue(value) {
	var nv = (value || '');
	var lf = Wo_GetProfileLocationField();
	if (lf) lf.value = nv;
	if (woProfilePlaceAutocompleteElement && typeof woProfilePlaceAutocompleteElement.value !== 'undefined') {
		woProfilePlaceAutocompleteElement.value = nv;
	}
}
function Wo_ClearProfileCoordinates() {
	Wo_SetProfileCoordinates('', '');
}
var woProfileLocTimer = null;
var woProfileLocRequest = 0;
var woProfileGooglePredictionCache = {};
var woProfileGoogleSessionToken = null;
var woProfileLocLocale = <?php echo json_encode(strtolower($wo['language'])); ?>;

function Wo_ShouldUseInlineProfileLocationInput() {
	return window.matchMedia('(max-width: 768px)').matches || /Android|webOS|iPhone|iPad|iPod|Opera Mini|IEMobile|Mobile/i.test(navigator.userAgent || '');
}
function Wo_GetProfileLocationLanguage() {
	return (woProfileLocLocale || document.documentElement.lang || navigator.language || navigator.userLanguage || 'en').toLowerCase();
}
function Wo_ProfileGoogleAutocompleteAvailable() {
	return (typeof google !== 'undefined' && google.maps && typeof google.maps.importLibrary === 'function');
}

function Wo_ApplyGoogleProfilePlace(place) {
	if (!place) return false;
	var locObj = place.location || (place.geometry && place.geometry.location ? place.geometry.location : null);
	var addr = place.formattedAddress || place.formatted_address || place.displayName || place.name || Wo_ReadProfileLocationValue();
	
	var lat = ''; var lng = '';
	if (locObj) {
		lat = (typeof locObj.lat === 'function') ? locObj.lat() : locObj.lat;
		lng = (typeof locObj.lng === 'function') ? locObj.lng() : locObj.lng;
	}

	Wo_WriteProfileLocationValue(addr);
	var inlineInput = document.querySelector('.wo_product_location_inline_input');
	if (inlineInput) inlineInput.value = addr;

	Wo_SetProfileCoordinates(lat, lng);
	return true;
}

function Wo_SearchProfileLocationSuggestions(val) {
	var nval = (val || '').trim();
	if (nval.length < 2) {
		Wo_RenderProfileLocationSuggestions([]);
		return;
	}
	woProfileLocRequest++;
	var reqId = woProfileLocRequest;

	if (Wo_ProfileGoogleAutocompleteAvailable()) {
		google.maps.importLibrary('places').then(function() {
			if (reqId !== woProfileLocRequest) return;
			var places = google.maps.places;
			if (!places.AutocompleteSuggestion || typeof places.AutocompleteSuggestion.fetchAutocompleteSuggestions !== 'function') return;

			if (!woProfileGoogleSessionToken && typeof places.AutocompleteSessionToken === 'function') {
				woProfileGoogleSessionToken = new places.AutocompleteSessionToken();
			}

			var req = { input: nval, sessionToken: woProfileGoogleSessionToken };
			var lang = Wo_GetProfileLocationLanguage();
			if (lang.indexOf('vi') === 0) req.language = 'vi';

			places.AutocompleteSuggestion.fetchAutocompleteSuggestions(req).then(function(res) {
				if (reqId !== woProfileLocRequest) return;
				var sugs = (res && Array.isArray(res.suggestions)) ? res.suggestions : [];
				var mapped = sugs.map(function(s) {
					var p = s.placePrediction || s;
					var pid = p.placeId || p.place_id || '';
					if (pid) woProfileGooglePredictionCache[pid] = p;
					return {
						name: (p.text && typeof p.text.toString === 'function') ? p.text.toString() : (p.description || ''),
						place_id: pid
					};
				});
				Wo_RenderProfileLocationSuggestions(mapped);
			});
		});
	}
}
function Wo_SetProfileLocationCoordinates(lat, lng) {
	$('#profile_lat_value').val(lat || '');
	$('#profile_lng_value').val(lng || '');
}
function Wo_ClearProfileLocationCoordinates(resetToZero) {
	Wo_SetProfileLocationCoordinates(resetToZero ? '0' : '', resetToZero ? '0' : '');
}
function Wo_GetProfileLocationCoordinateValues() {
	return {
		lat: $.trim($('#profile_lat_value').val()),
		lng: $.trim($('#profile_lng_value').val())
	};
}
function Wo_GetProfileLocationFirstCoordinates(locationValue) {
	return fetch(Wo_GetProfileLocationSearchUrl(locationValue, 1), {
		headers: { 'Accept': 'application/json' }
	}).then(function(r) {
		if (!r.ok) {
			throw new Error('Profile location geocode request failed');
		}
		return r.json();
	}).then(function(results) {
		if (!Array.isArray(results) || results.length === 0) {
			return null;
		}

		var firstItem = results[0] || {};
		var lat = parseFloat(firstItem.lat);
		var lng = parseFloat(firstItem.lon || firstItem.lng);
		if (isNaN(lat) || isNaN(lng)) {
			return null;
		}

		return {
			lat: String(lat),
			lng: String(lng)
		};
	});
}
var woProfileLocationGeocodeInFlight = false;
function Wo_PrepareProfileLocationForSubmit($form) {
	var locationValue = $.trim($('#profile_location_input').val());
	var coordinateValues = Wo_GetProfileLocationCoordinateValues();

	$('#profile_address_value').val(locationValue);

	if (!locationValue) {
		Wo_ClearProfileLocationCoordinates(true);
		return true;
	}

	if (coordinateValues.lat !== '' && coordinateValues.lng !== '') {
		return true;
	}

	if (woProfileLocationGeocodeInFlight) {
		return false;
	}

	woProfileLocationGeocodeInFlight = true;
	Wo_GetProfileLocationFirstCoordinates(locationValue).then(function(coords) {
		if (coords) {
			Wo_SetProfileLocationCoordinates(coords.lat, coords.lng);
		} else {
			Wo_ClearProfileLocationCoordinates(true);
		}
	}).catch(function() {
		Wo_ClearProfileLocationCoordinates(true);
	}).then(function() {
		woProfileLocationGeocodeInFlight = false;
		$form.ajaxSubmit(window.woProfileFormOptions);
	});

	return false;
}
function Wo_RenderProfileLocationSuggestions(items, queryValue) {
	var box = $('.profile_location_suggestions');
	if (!items || items.length === 0) {
		box.empty().hide();
		return;
	}
	var html = '';
	items.forEach(function(item) {
		var dn = Wo_GetProfileLocationText(item, queryValue);
		var ndn = Wo_NormalizeProfileLocationPart(dn);
		if (!dn || seen[ndn]) return;
		seen[ndn] = true;
		html += '<p class="pointer product_location_suggestion_item profile_location_suggestion_item" data-location="' + escapeHtml(dn) + '" data-lat="' + escapeHtml(String(item.lat || '')) + '" data-lng="' + escapeHtml(String(item.lon || item.lng || '')) + '">' + escapeHtml(dn) + '</p>';
	});
	box.html(html).show();
}

async function Wo_GeocodeProfilePlaceId(pid) {
	if (!pid) return;
	var cached = woProfileGooglePredictionCache[pid];
	if (cached && typeof cached.toPlace === 'function') {
		var place = cached.toPlace();
		await place.fetchFields({ fields: ['displayName', 'formattedAddress', 'location'] });
		Wo_ApplyGoogleProfilePlace(place);
		return;
	}
	if (window.google && google.maps && typeof google.maps.Geocoder === 'function') {
		var geocoder = new google.maps.Geocoder();
		geocoder.geocode({ placeId: pid }, function(results, status) {
			if (status === 'OK' && results[0]) Wo_ApplyGoogleProfilePlace(results[0]);
		});
	}
}

async function Wo_InitGoogleProfileAutocomplete() {
	var input = Wo_GetProfileLocationField();
	var host = document.getElementById('location-autocomplete-host');
	if (!input || !host || host.dataset.profileGoogleAutocompleteReady === '1') return;

	if (Wo_ShouldUseInlineProfileLocationInput()) {
		if (Wo_ProfileGoogleAutocompleteAvailable()) {
			try { await google.maps.importLibrary('places'); } catch (err) {}
		}
		host.dataset.profileGoogleAutocompleteReady = '1';
		host.innerHTML = '';
		var inlineInput = document.createElement('input');
		inlineInput.type = 'text';
		inlineInput.className = 'wo_product_location_inline_input'; // Reuse same class for consistency
		inlineInput.autocomplete = 'off';
		inlineInput.placeholder = <?php echo json_encode($wo['lang']['location']); ?>;
		host.appendChild(inlineInput);
		inlineInput.value = input.value || '';

		inlineInput.addEventListener('input', function () {
			var val = inlineInput.value || '';
			Wo_WriteProfileLocationValue(val);
			Wo_ClearProfileCoordinates();
			clearTimeout(woProfileLocTimer);
			woProfileLocTimer = setTimeout(function() {
				Wo_SearchProfileLocationSuggestions(val);
			}, 250);
		});
		inlineInput.addEventListener('blur', function() {
			setTimeout(function() {
				Wo_RenderProfileLocationSuggestions([]);
			}, 200);
		});
		return;
	}

	if (!Wo_ProfileGoogleAutocompleteAvailable()) return;

	await google.maps.importLibrary('places');
	if (!google.maps.places || typeof google.maps.places.PlaceAutocompleteElement !== 'function') return;

	host.dataset.profileGoogleAutocompleteReady = '1';
	host.innerHTML = '';
	woProfilePlaceAutocompleteElement = new google.maps.places.PlaceAutocompleteElement({});
	woProfilePlaceAutocompleteElement.placeholder = <?php echo json_encode($wo['lang']['location']); ?>;
	if (typeof woProfilePlaceAutocompleteElement.value !== 'undefined') {
		woProfilePlaceAutocompleteElement.value = input.value || '';
	}
	host.appendChild(woProfilePlaceAutocompleteElement);

	// Fix styling: gmp-place-autocomplete uses Shadow DOM.
	// We read styles from a standard input to match the current theme (light or dark).
	(function() {
		try {
			var ref = document.querySelector('input[name="first_name"]') || document.querySelector('input[type="text"]');
			if (!ref) return;
			var cs = window.getComputedStyle(ref);
			var bg = cs.backgroundColor;
			var fg = cs.color;
			var border = cs.borderTopColor || cs.borderColor;
			var el = woProfilePlaceAutocompleteElement;
			
			// If background is transparent (rgba(0,0,0,0)), default to white
			if (bg === 'transparent' || bg === 'rgba(0, 0, 0, 0)') {
				bg = '#ffffff';
			}

			el.style.backgroundColor = 'transparent';
			el.style.setProperty('--gmp-mat-color-surface', 'transparent');
			el.style.setProperty('--gmp-mat-color-on-surface', fg);
			el.style.setProperty('--gmp-mat-color-outline', 'transparent');
			el.style.setProperty('--gmp-mat-color-on-surface-variant', fg);
			el.style.setProperty('--gmp-mat-color-primary', border);

			if (el.shadowRoot) {
				var styleEl = document.createElement('style');
				styleEl.textContent = '.container { background-color: transparent !important; } input, .pac-target-input { background-color: transparent !important; color: ' + fg + ' !important; border: none !important; box-shadow: none !important; padding-left: 40px !important; }';
				el.shadowRoot.appendChild(styleEl);
			}
		} catch (e) {}
	})();

	woProfilePlaceAutocompleteElement.addEventListener('gmp-select', async function (event) {
		var pred = event.placePrediction || (event.detail && event.detail.placePrediction) || null;
		if (!pred || typeof pred.toPlace !== 'function') return;
		var place = pred.toPlace();
		await place.fetchFields({ fields: ['displayName', 'formattedAddress', 'location'] });
		Wo_ApplyGoogleProfilePlace(place);
	});
}

