var relationship_users = [];
var relationship_user  = 0;
function Wo_RelationshipSearch(name = ''){
  if (!name) { return false;}
  $.ajax({
    url: Wo_Ajax_Requests_File(),
    type: 'GET',
    dataType: 'json',
    data: {f: 'family',s:'search',name:name},
  })
  .done(function(data) {
    if (data.status == 200 && data.users.length > 0) {
      relationship_users = data.users
      var html = '';
      for (var i = 0; i < data.users.length; i++) {
        html += '<li class="pointer select_relationship_user" data-id="'+i+'"><a>'+data.users[i].name+'</a></li>';        
      }
      $("#select_relationship_with").addClass('open').find('ul').html(html);
    }
    else{
      $("#select_relationship_with").removeClass('open');
    }
  })
  .fail(function() {
    console.log("error");
  })
}

$(function() {
  $(document).on('click', '.select_relationship_user', function(event) {
    event.preventDefault();
    var user_data     = relationship_users[$(this).attr('data-id')];
    $("#relationship_user_id").val(user_data.user_id);
    $(".choose_rel_ship_meta").find('h4').text(user_data.name);
    $(".choose_rel_ship_meta").find('p').html(user_data.lastseen);
    $(".choose_rel_ship_avatar").html('<img src="'+user_data.avatar+'" alt="Picture">');
    $("#select_relationship_with").removeClass('open').find('ul').empty();
  });

  $('form.setting-profile-form').ajaxForm({
    url: Wo_Ajax_Requests_File() + '?f=update_profile_setting',
    beforeSend: function() {
      $('.wo_settings_page').find('.add_wow_loader').addClass('btn-loading');
    },
    success: function(data) {
    	$('.skills_result').html('');
      if (data.status == 200) {
        <?php if($wo['user']['user_id'] == $wo['setting']['user_id']) { ?>
        if (data.first_name != '' || data.last_name != '') {
            var displayName = data.first_name || (data.last_name || '');
        	<?php if ($wo['config']['node_socket_flow'] == "1") { ?>
            socket.emit("on_name_changed", {from_id: _getCookie("user_id"), name: displayName});
            <?php } ?>
          $('[id^=user-full-name]').text(displayName);
        }
        <?php } ?>
        scrollToTop();
        $('.setting-profile-alert').html('<div class="alert alert-success">' + data.message + '</div>');
        $('.alert-success').fadeIn('fast', function() {
          $(this).delay(2500).slideUp(500, function() {
            $(this).remove();
          });
        });
      } else if (data.errors) {
        var errors = data.errors.join("<br>");
        scrollToTop();
        $('.setting-profile-alert').html('<div class="alert alert-danger">' + errors + '</div>');
        $('.alert-danger').fadeIn(300);
      }
      $('.wo_settings_page').find('.add_wow_loader').removeClass('btn-loading');
    }
  });
});

// --- Profile Location Autocomplete (Nominatim) ---
var woProfileLocationLocale = <?php echo json_encode(strtolower($wo['language'])); ?>;
function Wo_GetProfileLocationLanguage() {
	return (woProfileLocationLocale || document.documentElement.lang || navigator.language || navigator.userLanguage || 'en').toLowerCase();
}
function Wo_IsVietnameseProfileLocation() {
	var language = Wo_GetProfileLocationLanguage();
	return language.indexOf('vi') === 0 || language.indexOf('vietnam') !== -1;
}
function Wo_NormalizeProfileLocationPart(value) {
	return (value || '')
		.toLowerCase()
		.normalize('NFD')
		.replace(/[\u0300-\u036f]/g, '')
		.replace(/[^a-z0-9]+/g, ' ')
		.trim();
}
function Wo_GetProfileLocationCanonicalPart(value) {
	return Wo_NormalizeProfileLocationPart(value)
		.replace(/^(phuong|xa|quan|huyen|tinh|thanh pho|tp)\s+/i, '')
		.replace(/\s+(ward|district|province|city)$/i, '')
		.trim();
}
function Wo_LocalizeVietnameseProfileLocationPart(value) {
	if (!value) return '';
	var v = value.trim();
	v = v.replace(/^(.+?)\s+Road$/i, 'Đường $1');
	v = v.replace(/^(.+?)\s+Street$/i, '$1');
	v = v.replace(/^(.+?)\s+Ward$/i, 'Phường $1');
	v = v.replace(/^Ward\s+(.+)$/i, 'Phường $1');
	v = v.replace(/^District\s+(.+)$/i, 'Quận $1');
	v = v.replace(/^Province\s+(.+)$/i, 'Tỉnh $1');
	v = v.replace(/^City\s+(.+)$/i, 'Thành phố $1');
	v = v.replace(/^Vietnam$/i, 'Việt Nam');
	v = v.replace(/^Ha Noi$/i, 'Hà Nội');
	v = v.replace(/^Ho Chi Minh City$/i, 'TP Hồ Chí Minh');
	return v;
}
function Wo_GetProfileLocationText(item, queryValue) {
	if (!item || !item.address) {
		return item && (item.display_name || item.name) ? (item.display_name || item.name) : '';
	}
	var address = item.address;
	var isVi = Wo_IsVietnameseProfileLocation();
	var parts = [];
	var firstLine = [];
	var houseNumber = address.house_number || address.house_name || '';
	var road = address.road || address.pedestrian || address.footway || address.cycleway || '';
	var nq = Wo_NormalizeProfileLocationPart(queryValue || '');
	var nr = Wo_NormalizeProfileLocationPart(road);
	if (isVi && nq && nr) {
		if (nq.indexOf(nr) !== -1 || nr.indexOf(nq) !== -1) road = queryValue;
	}
	if (houseNumber) firstLine.push(houseNumber);
	if (road) firstLine.push(isVi ? Wo_LocalizeVietnameseProfileLocationPart(road) : road);
	if (firstLine.length > 0) parts.push(firstLine.join(' '));
	[
		address.suburb, address.neighbourhood, address.quarter,
		address.city_district, address.county, address.district,
		address.city, address.town, address.municipality,
		address.state_district, address.state, address.country
	].forEach(function(val) {
		if (!val) return;
		var lv = isVi ? Wo_LocalizeVietnameseProfileLocationPart(val) : val;
		var cv = Wo_GetProfileLocationCanonicalPart(lv);
		var exists = parts.some(function(ev) { return Wo_GetProfileLocationCanonicalPart(ev) === cv; });
		if (!exists) parts.push(lv);
	});
	return parts.join(', ');
}
function Wo_GetProfileLocationSearchUrl(locationValue, limit) {
	var params = new URLSearchParams({
		format: 'jsonv2',
		addressdetails: '1',
		limit: String(limit || 10),
		'accept-language': Wo_GetProfileLocationLanguage(),
		q: locationValue
	});
	if (Wo_IsVietnameseProfileLocation()) params.set('countrycodes', 'vn');
	return 'https://nominatim.openstreetmap.org/search?' + params.toString();
}
function Wo_RenderProfileLocationSuggestions(items, queryValue) {
	var box = $('.profile_location_suggestions');
	if (!Array.isArray(items) || items.length === 0) { box.empty().hide(); return; }
	var seen = {};
	var html = '';
	items.forEach(function(item) {
		var dn = Wo_GetProfileLocationText(item, queryValue);
		var ndn = Wo_NormalizeProfileLocationPart(dn);
		if (!dn || seen[ndn]) return;
		seen[ndn] = true;
		html += '<p class="pointer product_location_suggestion_item profile_location_suggestion_item" data-location="' + escapeHtml(dn) + '">' + escapeHtml(dn) + '</p>';
	});
	if (!html) { box.empty().hide(); return; }
	box.html(html).show();
}
function Wo_SearchProfileLocationSuggestions(locationValue) {
	if (!locationValue || locationValue.length < 3) { Wo_RenderProfileLocationSuggestions([], locationValue); return; }
	fetch(Wo_GetProfileLocationSearchUrl(locationValue, 10), {
		headers: { 'Accept': 'application/json' }
	}).then(function(r) {
		if (!r.ok) throw new Error('Profile location suggestion request failed');
		return r.json();
	}).then(function(results) {
		Wo_RenderProfileLocationSuggestions(results, locationValue);
	}).catch(function() {
		Wo_RenderProfileLocationSuggestions([], locationValue);
	});
}
$(function() {
	var woProfileLocTimer = null;
	$('#profile_location_input').on('input', function() {
		clearTimeout(woProfileLocTimer);
		var val = $(this).val().trim();
		$('#profile_address_value').val(val);
		woProfileLocTimer = setTimeout(function() {
			Wo_SearchProfileLocationSuggestions(val);
		}, 250);
	});
	$('#profile_location_input').on('change blur', function() {
		$('#profile_address_value').val($(this).val().trim());
		setTimeout(function() { Wo_RenderProfileLocationSuggestions([]); }, 150);
	});
	$(document).on('mousedown', '.profile_location_suggestion_item', function(e) {
		e.preventDefault();
		var loc = $(this).attr('data-location') || '';
		$('#profile_location_input').val(loc);
		$('#profile_address_value').val(loc);
		Wo_RenderProfileLocationSuggestions([]);
	});
	$('form.setting-profile-form').on('submit', function() {
		$('#profile_address_value').val($('#profile_location_input').val().trim());
	});
});
</script>
