<!-- JS: không cần jquery.form/autosize; có fallback an toàn -->
<script>
(function () {
  // Lấy dữ liệu an toàn từ data-attributes (tránh inject PHP thẳng vào JS)
  var dataEl = document.getElementById('verif-data');
  var ERR_MSG = (dataEl && dataEl.dataset.err) || 'Có lỗi xảy ra';
  var OK_MSG  = (dataEl && dataEl.dataset.ok)  || 'Thành công';
  var SITE    = (dataEl && dataEl.dataset.site) || '';

  // Lấy URL AJAX của WoWonder (nếu function JS có sẵn), nếu không thì fallback về /requests.php
  function getAjaxUrl() {
    try { if (typeof Wo_Ajax_Requests_File === 'function') return Wo_Ajax_Requests_File(); } catch(e){}
    return SITE ? (SITE.replace(/\/+$/,'') + '/requests.php') : '/requests.php';
  }

  // Fallback autosize nếu bạn không nạp autosize.js (tránh 404 gây lỗi)
  (function autosizeFallback(){
    if (window.autosize) { window.autosize(document.querySelectorAll('textarea')); return; }
    var tas = document.querySelectorAll('textarea');
    for (var i=0;i<tas.length;i++){
      (function(ta){
        function resize(){ ta.style.height='auto'; ta.style.height = ta.scrollHeight + 'px'; }
        ta.addEventListener('input', resize);
        resize();
      })(tas[i]);
    }
  })();

  // Helper: bind click -> mở file input + preview (ảnh/PDF)
  function bindPickAndPreview(boxId, inputId, allowPdf) {
    var box = document.getElementById(boxId);
    var input = document.getElementById(inputId);
    if (!box || !input) return;

    box.addEventListener('click', function(){ input.click(); });
    input.addEventListener('change', function() {
      var f = input.files && input.files[0]; if (!f) return;
      if (allowPdf && f.type === 'application/pdf') {
        box.innerHTML = "<div class='pdf-chip'>" + f.name + "</div>";
      } else {
        var url = URL.createObjectURL(f);
        box.innerHTML = "<img src='" + url + "' alt='' class='responsive-img'>";
      }
    });
  }

  // SHOP previews
  bindPickAndPreview('verif-passport','file-passport',false);
  bindPickAndPreview('verif-selfie','file-selfie',false);
  bindPickAndPreview('verif-shop','file-shop',false);
  bindPickAndPreview('verif-license','file-license',true);

  // USER previews
  bindPickAndPreview('userverif-passport','userfile-passport',false);
  bindPickAndPreview('userverif-selfie','userfile-selfie',false);

  // Submit form bằng fetch + FormData (không cần jquery-form)
  function bindAjaxForm(formSelector, endpoint, alertBoxId) {
    var form = document.querySelector(formSelector);
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = form.querySelector('.add_wow_loader');
      if (btn) btn.classList.add('btn-loading');

      var fd = new FormData(form);
      fetch(getAjaxUrl() + '?f=' + endpoint, {
        method: 'POST',
        body: fd,
        credentials: 'same-origin',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        var box = document.getElementById(alertBoxId);
        if (!box) return;
        if (data && data.status == 200) {
          box.innerHTML = '<div class="alert alert-success">' + (data.message || OK_MSG) + '</div>';
          if (data.url) { window.location = data.url; }
        } else {
          box.innerHTML = '<div class="alert alert-danger">' + (data && data.message ? data.message : ERR_MSG) + '</div>';
        }
      })
      .catch(function(){
        var box = document.getElementById(alertBoxId);
        if (box) box.innerHTML = '<div class="alert alert-danger">' + ERR_MSG + '</div>';
      })
      .finally(function(){
        var b2 = form.querySelector('.add_wow_loader');
        if (b2) b2.classList.remove('btn-loading');
      });
    });
  }
  // Gắn submit cho 2 form
  bindAjaxForm('.setting-verification-form', 'verificate-shop', 'verificate-user-alert');
  bindAjaxForm('.user-verification-form',     'verificate-user', 'user-verificate-alert');
})();
</script>


<style>
  .clickable { cursor: pointer; }
  .pdf-chip {
    display:inline-block; padding:6px 10px; border-radius:6px;
    background:#f3f4f6; border:1px solid #e5e7eb; font-size:12px;
  }
  .responsive-img { max-width:100%; height:auto; border-radius:6px; }
</style>
