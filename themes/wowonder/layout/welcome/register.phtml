<script>
	(function() {
		document.addEventListener('click', function(e) {
			var btn = e.target.closest('.pw-toggle');
			if (!btn) return;

			var wrap = btn.closest('.pw-wrap') || btn.closest('.pw-field') || btn.closest('.wow_form_fields');
			var input = wrap && wrap.querySelector('input[type="password"], input[type="text"]');
			if (!input) return;

			var show = (input.type === 'password'); // chuẩn bị chuyển sang hiển thị?
			input.type = show ? 'text' : 'password';
			btn.setAttribute('aria-pressed', String(show));

			// KHÔNG cần đổi hidden cho SVG nữa; CSS dựa vào aria-pressed sẽ tự đổi icon
		});
	})();
</script>
<script>
	// Validate live username: không khoảng trắng, không dấu
	(function() {
		var usernameInput = document.getElementById('username');
		var errorSpan = document.getElementById('username_error');
		if (!usernameInput || !errorSpan) return;

		function hasAccents(str) {
			if (!str) return false;
			// Bóc dấu ra, nếu khác nhau => có dấu
			try {
				return str.normalize('NFD').match(/[\u0300-\u036f]/);
			} catch (e) {
				// fallback: check ký tự ngoài ASCII
				return /[^\x00-\x7F]/.test(str);
			}
		}

		function validateUsernameLive() {
			var value = usernameInput.value || '';
			var hasSpace = /\s/.test(value);
			var hasAccent = hasAccents(value);

			// Nếu rỗng thì ẩn lỗi
			if (value.length === 0) {
				errorSpan.style.display = 'none';
				errorSpan.textContent = '';
				usernameInput.classList.remove('input-error');
				return;
			}

			if (hasSpace || hasAccent) {
				errorSpan.style.display = 'block';
				errorSpan.textContent = 'Tên tài khoản không được chứa khoảng trắng hoặc dấu. Vui lòng dùng chữ không dấu, không khoảng cách.';
				usernameInput.classList.add('input-error');
			} else {
				errorSpan.style.display = 'none';
				errorSpan.textContent = '';
				usernameInput.classList.remove('input-error');
			}
		}

		usernameInput.addEventListener('input', validateUsernameLive);
		usernameInput.addEventListener('blur', validateUsernameLive);
	})();
</script>
