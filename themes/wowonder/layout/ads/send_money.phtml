<script>
var sendMoneyCurrencyRule = <?php echo json_encode(Wo_GetCurrencyRule($wo['config']['ads_currency'])); ?>;

function normalizeSendMoneyAmount(value) {
  var input = String(value || '').trim();
  if (!input) {
    return '';
  }
  input = input.replace(/\s+/g, '');
  if ((sendMoneyCurrencyRule.decimals || 0) === 0) {
    return input.replace(/[^\d]/g, '');
  }
  input = input.replace(new RegExp('\\' + sendMoneyCurrencyRule.thousand_sep, 'g'), '');
  if (sendMoneyCurrencyRule.decimal_sep && sendMoneyCurrencyRule.decimal_sep !== '.') {
    input = input.replace(new RegExp('\\' + sendMoneyCurrencyRule.decimal_sep, 'g'), '.');
  }
  input = input.replace(/[^0-9.]/g, '');
  var firstDot = input.indexOf('.');
  if (firstDot !== -1) {
    input = input.slice(0, firstDot + 1) + input.slice(firstDot + 1).replace(/\./g, '');
  }
  return input;
}

function formatSendMoneyAmount(value) {
  var normalized = normalizeSendMoneyAmount(value);
  if (!normalized) {
    return '';
  }
  var decimals = parseInt(sendMoneyCurrencyRule.decimals || 0, 10);
  if (decimals === 0) {
    return normalized.replace(/\B(?=(\d{3})+(?!\d))/g, sendMoneyCurrencyRule.thousand_sep);
  }
  var parts = normalized.split('.');
  var integerPart = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, sendMoneyCurrencyRule.thousand_sep);
  var decimalPart = (parts[1] || '').slice(0, decimals);
  return decimalPart ? integerPart + sendMoneyCurrencyRule.decimal_sep + decimalPart : integerPart;
}
</script>

<script>
jQuery(function ($) {
  // ====== Config & cache DOM
  const ajaxUrl     = (typeof Wo_Ajax_Requests_File === 'function') ? Wo_Ajax_Requests_File() : '/requests.php';
  const $sendForm   = $('#send-money-form');
  const $searchInp  = $sendForm.find('#search');
  const $amountInp  = $sendForm.find('#amount');
  const $amountDisplay = $sendForm.find('#amount_display');
  const $recipIdInp = $('#recipient_user_id');
  const $alertBox   = $('#send-money-form-alert');
  const $scanModal  = $('#scan_qr_modal');
  let scanner = null; // Html5QrcodeScanner

  // ====== Utils
  function debounce(fn, t){ let id; return function(){ clearTimeout(id); id=setTimeout(fn, t); }; }
  function showFormAlert(msg, ok){
    $alertBox.html($('<div>', {class:'alert '+(ok?'alert-info':'alert-danger'), text: msg}));
  }
  function syncSendMoneyAmount(value){
    const raw = normalizeSendMoneyAmount(value);
    $amountInp.val(raw);
    $amountDisplay.val(formatSendMoneyAmount(raw));
    return raw;
  }
  async function closeQRUI(){
    try { if (scanner && typeof scanner.clear === 'function') await scanner.clear(); } catch(_) {}
    scanner = null;
    $('#qr-reader').empty();
    $('#qr-msg').hide().removeClass('alert-success alert-danger').text('');
    $('#qr-image').val('');
    $scanModal.modal('hide');
    // nếu có popup “QR nhận tiền” riêng:
    $('#modalReceiveQR').modal('hide');
    $('#receive-qr-img').attr('src','');
  }
  // Hỗ trợ các payload:
  //  WALLET|to=123|amount=99.5(|lock=1)  /  URL ?to=&amount=  /  {"type":"wallet","to":123,"amount":99.5}
  function parseWalletQR(text){
    const out = {to:null, amount:null, lock:false};
    if (!text) return out;

    // JSON
    if (text.trim().startsWith('{')) {
      try {
        const j = JSON.parse(text);
        if (j && (j.type==='wallet' || j.type==='send')) {
          out.to = j.to ? parseInt(j.to,10) : null;
          out.amount = (j.amount!=null) ? parseFloat(j.amount) : null;
          out.lock = !!j.lock;
          return out;
        }
      } catch(_) {}
    }
    // WALLET|...
    if (text.indexOf('|')>-1){
      const parts = text.split('|'); parts.shift();
      const map = {};
      parts.forEach(kv=>{ const i=kv.indexOf('='); if(i>-1) map[kv.slice(0,i)] = kv.slice(i+1); });
      if (map.to) out.to = parseInt(map.to,10);
      if (map.amount!=null && map.amount!=='') out.amount = parseFloat(map.amount);
      if (map.lock) out.lock = (parseInt(map.lock,10)===1);
      return out;
    }
    // URL
    try {
      const u = new URL(text);
      const to = u.searchParams.get('to'), am = u.searchParams.get('amount');
      if (to) out.to = parseInt(to,10);
      if (am) out.amount = parseFloat(am);
      return out;
    } catch(_) {}

    return out;
  }
  function fetchUserBrief(uid){
    // Cần có endpoint: ?f=qrcode&s=brief_by_id&id=UID (trả {status:200, name, username, email})
    $.getJSON(ajaxUrl, {f:'qrcode', s:'brief_by_id', id: uid})
      .done(function(res){
        const label = (res && res.status===200)
          ? (res.name || (res.username ? '@'+res.username : 'User #'+uid))
          : ('User #'+uid);
        $searchInp.val(label);
      })
      .fail(function(){ $searchInp.val('User #'+uid); });
  }
  function fillFromQR(text){
    const p = parseWalletQR(text);
    if (!p.to){ $('#qr-msg').show().addClass('alert-danger').text('QR không hợp lệ hoặc thiếu người nhận.'); return; }

    $recipIdInp.val(p.to);
    fetchUserBrief(p.to);
    if (p.amount!=null && !isNaN(p.amount)){
      syncSendMoneyAmount(String(Math.round(p.amount)));
      if (p.lock) $amountInp.prop('readonly', true);
      if (p.lock) $amountDisplay.prop('readonly', true);
      if (!p.lock) $amountInp.prop('readonly', false);
      if (!p.lock) $amountDisplay.prop('readonly', false);
    } else {
      $amountInp.prop('readonly', false);
      $amountDisplay.prop('readonly', false);
    }
    $scanModal.modal('hide');
    $('#send_money_modal').modal('show');
    showFormAlert('Đã điền người nhận #'+p.to+(p.amount!=null?(', số tiền '+p.amount):''), true);
  }

  // ====== Autocomplete tìm người nhận
  $searchInp.on('keyup', debounce(function(){
    const name = $(this).val();
    $.ajax({
      url: ajaxUrl,
      type: 'GET',
      dataType: 'json',
      data: { f:'family', s:'search', name:name }
    }).done(function(data){
      const $dd = $sendForm.find('.dropdown').addClass('open').find('ul.money-recipients-list').empty();
      if (data && data.status==200 && Array.isArray(data.users)){
        data.users.forEach(u=>{
          $('<li>', {class:'pointer', id:u.user_id, text:u.name}).appendTo($dd);
        });
      } else {
        $sendForm.find('.dropdown').removeClass('open').find('ul').empty();
      }
    });
  }, 250));

  $(document).on('click', 'ul.money-recipients-list li', function(e){
    e.preventDefault();
    $recipIdInp.val($(this).attr('id'));
    $searchInp.val($(this).text());
    $sendForm.find('.dropdown').removeClass('open').find('ul').empty();
  });

  // ====== Submit gửi tiền (AJAX)
  $amountDisplay.on('input', function(){
    syncSendMoneyAmount(this.value);
  });
  syncSendMoneyAmount($amountDisplay.val());

  $sendForm.ajaxForm({
    url: ajaxUrl + '?f=wallet&s=send',
    type: 'POST',
    dataType: 'json',
    beforeSubmit: function(){
      syncSendMoneyAmount($amountDisplay.val());
    },
    beforeSend: function(){
      $sendForm.find('.add_wow_loader').attr('disabled', true).addClass('btn-loading');
    },
    success: function(data){
      if (data && data.status==200){
        // đóng mọi UI quét/QR nếu đang mở
        closeQRUI();

        // socket (giữ nguyên logic có sẵn)
        if (typeof node_socket_flow !== 'undefined' && node_socket_flow == "1") {
          if (typeof socket !== 'undefined') {
            socket.emit("user_notification", {
              to_id: $recipIdInp.val(),
              user_id: (typeof _getCookie==='function') ? _getCookie("user_id") : null,
              type: "added"
            });
          }
        }

        showFormAlert(data.message || 'Đã gửi tiền thành công.', true);
        $sendForm.resetForm();
        $amountDisplay.val('');
        $amountDisplay.prop('readonly', false);
        $amountInp.prop('readonly', false);

        // đóng modal gửi sau 2s
        setTimeout(function(){
          $('#send_money_modal').modal('hide');
          $sendForm.find('.add_wow_loader').prop('disabled', false).removeClass('btn-loading');
        }, 2000);
      } else {
        showFormAlert((data && data.message) ? data.message : 'Có lỗi xảy ra.', false);
        $sendForm.find('.add_wow_loader').prop('disabled', false).removeClass('btn-loading');
      }
    },
    error: function(){
      showFormAlert('Không gửi được yêu cầu. Vui lòng thử lại.', false);
      $sendForm.find('.add_wow_loader').prop('disabled', false).removeClass('btn-loading');
    }
  });

  // ====== QR scan (mở modal, auto start)
  $(document).on('click', '#btn-open-scan', function(){ $scanModal.modal('show'); });

  $scanModal.on('shown.bs.modal', function(){
    try{
      if (typeof Html5QrcodeScanner === 'undefined'){
        $('#qr-msg').show().addClass('alert-danger').text('Không tải được thư viện quét QR.');
        return;
      }
      if (scanner) return;

      const config = {
        fps: 12,
        qrbox: {width: 250, height: 250},
        rememberLastUsedCamera: true,
        aspectRatio: 1.777,
        supportedScanTypes: (window.Html5QrcodeScanType) ? [Html5QrcodeScanType.SCAN_TYPE_CAMERA] : undefined
      };
      scanner = new Html5QrcodeScanner('qr-reader', config);
      scanner.render(onScanSuccess, onScanError);

      // auto-chọn camera sau khi dashboard render
      (function autoStart(){
        const root = document.getElementById('qr-reader__dashboard');
        if (!root){ setTimeout(autoStart, 100); return; }

        // ưu tiên camera sau
        const sel = root.querySelector('select');
        if (sel && sel.options && sel.options.length){
          let idx = 0;
          for (let i=0;i<sel.options.length;i++){
            if (/back|rear|environment/i.test(sel.options[i].textContent)){ idx=i; break; }
          }
          sel.selectedIndex = idx;
          sel.dispatchEvent(new Event('change'));
        }
        // click "Start / Permission"
        const btn = Array.from(root.querySelectorAll('button,a')).find(el => /start|scan|permission|quét/i.test(el.textContent||''));
        if (btn) btn.click();
      })();
    }catch(err){
      $('#qr-msg').show().addClass('alert-danger').text('Không thể khởi tạo camera: '+err);
    }
  });

  $scanModal.on('hidden.bs.modal', function(){
    Promise.resolve(scanner && scanner.clear()).catch(()=>{}).finally(()=>{
      scanner = null;
      $('#qr-reader').empty();
      $('#qr-msg').hide().removeClass('alert-success alert-danger').text('');
      $('#qr-image').val('');
    });
  });

  function onScanSuccess(decodedText){
    try { scanner && scanner.clear(); } catch(_){}
    fillFromQR(decodedText);
  }
  function onScanError(_err){ /* frame errors – ignore */ }

  // Fallback: quét từ ảnh
  $('#qr-image').on('change', async function(e){
    const file = e.target.files && e.target.files[0]; if (!file) return;
    try { const text = await Html5Qrcode.scanFile(file, true); fillFromQR(text); }
    catch { $('#qr-msg').show().addClass('alert-danger').text('Không đọc được mã từ ảnh.'); }
  });
});
</script>
