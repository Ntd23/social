<div class="story-video story-image-wrapper" data-story-video="<?php echo $wo['media']['id'];?>">
	<video class="story-video-preview" preload="metadata" muted loop playsinline webkit-playsinline x-webkit-airplay="deny" disablepictureinpicture disableremoteplayback style="width: 100%; height: 100%;">
	    <source src="<?php echo $wo['media']['filename'];?>" type='video/mp4'>
	    <source src="<?php echo $wo['media']['filename'];?>" type='video/webm'>
	</video>
</div>
<script>
jQuery(document).ready(function($) {
  var preview = $('.story-video[data-story-video="<?php echo $wo['media']['id'];?>"] .story-video-preview').get(0);
  if (!preview) {
    return;
  }

  preview.muted = true;
  preview.playsInline = true;
  preview.controls = false;

  var playPreview = preview.play();
  if (playPreview && typeof playPreview.catch === 'function') {
    playPreview.catch(function () {});
  }
});
</script>
