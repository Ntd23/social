<script type="text/javascript">
  var video = document.getElementById('basic-stream');
  var twilioVideoCallId = <?php echo (int) $wo['video_call']['call_id']; ?>;
  var twilioVideoJoinedAt = 0;
  var twilioVideoReported = false;
  var twilioVideoReturnUrl = <?php echo json_encode($wo['video_call']['return_url']); ?>;

function reportTwilioVideoCall(status, shouldRedirect) {
  if (twilioVideoReported || twilioVideoCallId < 1) {
    if (shouldRedirect === true) {
      location.href = twilioVideoReturnUrl;
    }
    return;
  }
  twilioVideoReported = true;
  var duration = 0;
  if (twilioVideoJoinedAt > 0) {
    duration = Math.max(0, Math.round((Date.now() - twilioVideoJoinedAt) / 1000));
  }
  $.get(Wo_Ajax_Requests_File(), {
    f: 'close_call',
    id: twilioVideoCallId,
    call_type: 'video',
    provider: 'twilio',
    status: status,
    duration: duration
  }).always(function () {
    if (shouldRedirect === true) {
      location.href = twilioVideoReturnUrl;
    }
  });
}

Twilio.Video.connect('<?php echo $wo['video_call']['access_token'];?>', { name: '<?php echo $wo['video_call']['room'];?>' }).then(room => {
  console.log('Connected to Room "%s"', room.name);
 
  room.participants.forEach(participantConnected);
  room.on('participantConnected', participantConnected);
 
  //room.on('participantDisconnected', participantDisconnected);
  //room.once('disconnected', error => room.participants.forEach(participantDisconnected));
  room.on('disconnected', room => {
    // Detach the local media elements
    room.localParticipant.tracks.forEach(publication => {
      const attachedElements = publication.track.detach();
      attachedElements.forEach(element => element.remove());
    });
    reportTwilioVideoCall((twilioVideoJoinedAt > 0 ? 'ended' : 'no_answer'), true);
  });
  room.on('participantDisconnected', function(participant) {
    console.log(participant.identity + ' left the Room');
    reportTwilioVideoCall((twilioVideoJoinedAt > 0 ? 'ended' : 'no_answer'), true);
  });
  $(document).on('click', 'a[data-ajax]', function(e) {
      reportTwilioVideoCall((twilioVideoJoinedAt > 0 ? 'ended' : 'cancelled'), false);
      room.disconnect();
  });
  $(document).on('click', '.end_vdo_call', function(e) {
      reportTwilioVideoCall((twilioVideoJoinedAt > 0 ? 'ended' : 'cancelled'), false);
      room.disconnect();
  });
});
 
function participantConnected(participant) {
  console.log('Participant "%s" connected', participant.identity);
  if (twilioVideoJoinedAt === 0) {
    twilioVideoJoinedAt = Date.now();
  }
 
  const div = document.createElement('div');
  div.id = participant.sid;
  //div.innerText = participant.identity;
  participant.tracks.forEach(publication => {
    if (publication.isSubscribed) {
      const track = publication.track;
      div.appendChild(track.attach());
    }
  });
  participant.on('trackSubscribed', track => {
    /*$('#remote-media').html('');*/
    document.getElementById('remote-media').appendChild(track.attach());
  });
 
  $('#remote-media').html(div);
  if (navigator.getUserMedia) {
    navigator.mediaDevices.getUserMedia({audio: true, video: true}).then((stream) => {video.srcObject = stream});
    $('#basic-stream').removeClass('hidden');
    $('.end_vdo_call').removeClass('hidden');
  }
}
</script>
