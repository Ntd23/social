<script src="https://cdn.jsdelivr.net/npm/livekit-client/dist/livekit-client.umd.min.js"></script>
<script>
const livekitHostSession = <?php echo json_encode($livekit_host); ?>;
const liveCreateUrl = Wo_Ajax_Requests_File() + "?f=live&s=create";
const liveDeleteUrl = Wo_Ajax_Requests_File() + "?f=live&s=delete";
const liveThumbUrl = Wo_Ajax_Requests_File() + "?f=live&s=create_thumb";
let hostRoom = null;
let hostTracks = [];
let liveCreated = false;
let deletingLive = false;

function setHostStatus(message) {
  $('#wo-livekit-host-status').text(message || '');
}

function getHostTrack(kind) {
  for (let i = 0; i < hostTracks.length; i += 1) {
    if (hostTracks[i] && hostTracks[i].kind === kind) {
      return hostTracks[i];
    }
  }
  return null;
}

function renderHostPreview() {
  const stage = document.getElementById('main_live_video');
  if (!stage) {
    return;
  }
  const oldVideos = stage.querySelectorAll('video');
  oldVideos.forEach(function(video) {
    video.remove();
  });
  const videoTrack = getHostTrack('video');
  if (!videoTrack || videoTrack.isMuted) {
    $('#wo-livekit-host-empty').removeClass('hidden').text('Camera dang tat');
    return;
  }
  const element = videoTrack.attach();
  element.id = 'wo-livekit-host-preview';
  element.muted = true;
  element.autoplay = true;
  element.playsInline = true;
  stage.appendChild(element);
  $('#wo-livekit-host-empty').addClass('hidden');
}

function updateTrackButtons() {
  const audioTrack = getHostTrack('audio');
  const videoTrack = getHostTrack('video');
  $('#wo-livekit-toggle-mic')
    .toggleClass('wo-livekit-track-off', !!(audioTrack && audioTrack.isMuted))
    .text(audioTrack && audioTrack.isMuted ? 'Mic dang tat' : 'Mic dang bat');
  $('#wo-livekit-toggle-cam')
    .toggleClass('wo-livekit-track-off', !!(videoTrack && videoTrack.isMuted))
    .text(videoTrack && videoTrack.isMuted ? 'Camera dang tat' : 'Camera dang bat');
}

async function ensureHostPreview() {
  if (hostTracks.length) {
    renderHostPreview();
    updateTrackButtons();
    return hostTracks;
  }
  if (!window.LivekitClient || !livekitHostSession || !livekitHostSession.ws_url || !livekitHostSession.token) {
    throw new Error('LiveKit chua duoc cau hinh day du.');
  }
  hostTracks = await LivekitClient.createLocalTracks({audio: true, video: true});
  renderHostPreview();
  updateTrackButtons();
  return hostTracks;
}

async function toggleHostTrack(kind) {
  try {
    await ensureHostPreview();
    const track = getHostTrack(kind);
    if (!track) {
      return;
    }
    if (track.isMuted) {
      await track.unmute();
    } else {
      await track.mute();
    }
    if (kind === 'video') {
      renderHostPreview();
    }
    updateTrackButtons();
  } catch (err) {
    setHostStatus(err && err.message ? err.message : 'Khong the truy cap camera/microphone.');
  }
}

function disconnectHostRoom() {
  if (hostRoom) {
    try {
      hostRoom.disconnect();
    } catch (err) {}
    hostRoom = null;
  }
  hostTracks.forEach(function(track) {
    if (!track) {
      return;
    }
    try {
      track.stop();
    } catch (err) {}
    try {
      track.detach().forEach(function(element) {
        element.remove();
      });
    } catch (err) {}
  });
  hostTracks = [];
}

function captureHostThumbnail(postId) {
  const preview = document.getElementById('wo-livekit-host-preview');
  if (!preview || !postId || !preview.videoWidth || !preview.videoHeight) {
    return;
  }
  const canvas = document.createElement('canvas');
  canvas.width = preview.videoWidth;
  canvas.height = preview.videoHeight;
  canvas.getContext('2d').drawImage(preview, 0, 0);
  canvas.toBlob(function(blob) {
    if (!blob) {
      return;
    }
    const formData = new FormData();
    formData.append('thumb', blob, 'thumb.png');
    formData.append('post_id', postId);
    $.ajax({
      processData: false,
      url: liveThumbUrl,
      type: 'POST',
      dataType: 'json',
      data: formData,
      contentType: false
    });
  }, 'image/png');
}

async function startHostLive() {
  if (liveCreated) {
    return;
  }
  $('#publishBtn').attr('disabled', true).text("<?php echo($wo['lang']['please_wait']); ?>");
  setHostStatus('Dang ket noi phong LiveKit');
  try {
    const tracks = await ensureHostPreview();
    hostRoom = new LivekitClient.Room({adaptiveStream: true, dynacast: true});
    await hostRoom.connect(livekitHostSession.ws_url, livekitHostSession.token);
    for (let i = 0; i < tracks.length; i += 1) {
      await hostRoom.localParticipant.publishTrack(tracks[i]);
    }
    const response = await $.ajax({
      url: liveCreateUrl,
      type: 'POST',
      dataType: 'json',
      data: {stream_name: livekitHostSession.stream_name}
    });
    if (!response || response.status !== 200 || !response.post_id) {
      throw new Error('Khong the tao bai livestream.');
    }
    liveCreated = true;
    $('#live_post_id').val(response.post_id);
    $('#publishBtn').addClass('hidden');
    $('#wo-livekit-end-live').removeClass('hidden');
    setHostStatus('Ban dang phat truc tiep');
    captureHostThumbnail(response.post_id);
  } catch (err) {
    if (hostRoom) {
      try {
        hostRoom.disconnect();
      } catch (disconnectErr) {}
      hostRoom = null;
    }
    $('#publishBtn').removeAttr('disabled').html('<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M17,14.5V11A1,1 0 0,0 16,10H4A1,1 0 0,0 3,11V21A1,1 0 0,0 4,22H16A1,1 0 0,0 17,21V17.5L21,21.5V10.5M3,3.86L4.4,5.24C7.5,2.19 12.5,2.19 15.6,5.24L17,3.86C13.14,0.05 6.87,0.05 3,3.86M5.8,6.62L7.2,8C8.75,6.5 11.25,6.5 12.8,8L14.2,6.62C11.88,4.34 8.12,4.34 5.8,6.62Z" /></svg> <?php echo $wo['lang']['go_live']; ?>');
    setHostStatus(err && err.message ? err.message : 'Khong the bat livestream.');
  }
}

function DeleteLive() {
  if (deletingLive) {
    return true;
  }
  const postId = $('#live_post_id').val();
  disconnectHostRoom();
  if (!postId) {
    return true;
  }
  deletingLive = true;
  try {
    fetch(liveDeleteUrl, {
      method: 'POST',
      credentials: 'same-origin',
      keepalive: true,
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: 'post_id=' + encodeURIComponent(postId)
    }).catch(function() {});
  } catch (err) {}
  $.post(liveDeleteUrl, {post_id: postId}, function() {});
  return true;
}

window.onbeforeunload = function() {
  DeleteLive();
};

var main_live = setInterval(function() {
  const postId = $('#live_post_id').val();
  if (!postId) {
    return;
  }
  const data = {};
  for (var i = 0; i < $('.live_comments').length; i++) {
    if ($($('.live_comments')[i]).attr('live_comment_id')) {
      data[i] = $($('.live_comments')[i]).attr('live_comment_id');
    }
  }
  $.post(Wo_Ajax_Requests_File() + "?f=live&s=check_comments", {post_id: postId, ids: data, page: 'live'}, function(response) {
    if (response.status == 200) {
      $('#live_post_comments').append(response.html);
      $('#live_count').html(response.count);
      $('#live_word').html(response.word);
      var comments = $('#live_post_comments .live_comments');
      if (comments.length > 4) {
        for (var j = 0; j < comments.length; j++) {
          if ($('#live_post_comments .live_comments').length > 4) {
            comments[j].remove();
          }
        }
      }
    } else if (response.removed == 'yes') {
      clearInterval(main_live);
    }
  });
}, 3000);

$('#publishBtn').on('click', function() {
  startHostLive();
});
$('#wo-livekit-toggle-mic').on('click', function() {
  toggleHostTrack('audio');
});
$('#wo-livekit-toggle-cam').on('click', function() {
  toggleHostTrack('video');
});

ensureHostPreview().then(function() {
  setHostStatus('San sang bat dau livestream');
}).catch(function(err) {
  setHostStatus(err && err.message ? err.message : 'Khong the truy cap camera/microphone.');
});
</script>
