<script src="https://cdn.jsdelivr.net/npm/livekit-client/dist/livekit-client.umd.min.js"></script>
<script>
const livekitHostSession = <?php echo json_encode($livekit_host); ?>;
const liveCreateUrl = Wo_Ajax_Requests_File() + "?f=live&s=create";
const liveDeleteUrl = Wo_Ajax_Requests_File() + "?f=live&s=delete";
const liveThumbUrl = Wo_Ajax_Requests_File() + "?f=live&s=create_thumb";
const liveCheckUrl = Wo_Ajax_Requests_File() + "?f=live&s=check_comments";
const studioRoot = document.getElementById('wo-livekit-studio');
const stageSetup = document.getElementById('main_live_video_setup');
const stageLive = document.getElementById('main_live_video_live');
const emptySetup = document.getElementById('wo-livekit-host-empty-setup');
const emptyLive = document.getElementById('wo-livekit-host-empty-live');
const cameraSelect = document.getElementById('wo-livekit-camera-select');
const micSelect = document.getElementById('wo-livekit-mic-select');
const audioMeter = document.getElementById('wo-livekit-audio-meter');
const commentsShell = document.getElementById('wo-livekit-comments-shell');
const commentsFeed = document.getElementById('live_post_comments');
const commentsEmpty = document.getElementById('wo-livekit-comments-empty');
const postIdInput = document.getElementById('live_post_id');
const titleInput = document.getElementById('wo-livekit-title-input');
const descriptionInput = document.getElementById('wo-livekit-description-input');
const publishBtn = document.getElementById('publishBtn');
const postLink = document.getElementById('wo-livekit-post-link');
const postLinkUrl = document.getElementById('wo-livekit-post-link-url');
const liveTimerEl = document.getElementById('wo-livekit-live-timer');

let hostRoom = null;
let hostTracks = [];
let liveCreated = false;
let deletingLive = false;
let studioMode = 'setup';
let liveTimerInterval = null;
let selectedDevices = {videoId: '', audioId: ''};
let liveMeta = {
  title: '',
  description: '',
  postId: 0,
  startedAt: 0,
  viewers: 0,
  comments: 0,
  reactions: 0,
  shares: 0,
  clips: 0
};

function setStudioMode(mode) {
  studioMode = mode === 'live' ? 'live' : 'setup';
  if (studioRoot) {
    studioRoot.setAttribute('data-mode', studioMode);
  }
  renderHostPreview();
  updateTrackButtons();
}

function getActiveStage() {
  return studioMode === 'live' ? stageLive : stageSetup;
}

function getActiveEmptyState() {
  return studioMode === 'live' ? emptyLive : emptySetup;
}

function getTitleValue() {
  return $.trim(titleInput ? titleInput.value : '');
}

function getDescriptionValue() {
  return $.trim(descriptionInput ? descriptionInput.value : '');
}

function syncSetupProgress() {
  const hasSource = hostTracks.length > 0;
  const hasMeta = true;
  const currentStep = liveCreated ? 3 : (hasSource ? 2 : 1);
  const progress = liveCreated ? 100 : (hasSource ? 67 : 33);

  $('#wo-livekit-setup-progress').css('width', progress + '%');
  $('#wo-livekit-progress-text').text(currentStep + '/3');

  $('#wo-step-source').toggleClass('done', hasSource).toggleClass('active', !hasSource);
  $('#wo-step-detail').toggleClass('done', hasSource && hasMeta).toggleClass('active', hasSource && !liveCreated);
  $('#wo-step-live').toggleClass('done', liveCreated).toggleClass('active', liveCreated);
}

function setHostStatus(message) {
  const safeMessage = message || '';
  $('#wo-livekit-host-status-setup').text(safeMessage);
  $('#wo-livekit-host-status-live').text(safeMessage);
}

function setLiveDetails(title, description) {
  const safeTitle = $.trim(title || '');
  const safeDescription = $.trim(description || '');
  const titleEl = $('#wo-livekit-live-title');
  const descriptionEl = $('#wo-livekit-live-description');

  titleEl
    .text(safeTitle || 'Chưa có tiêu đề')
    .toggleClass('empty', !safeTitle);
  descriptionEl
    .text(safeDescription || 'Chưa có mô tả')
    .toggleClass('empty', !safeDescription);
}

function setPostLink(postId) {
  if (!postId) {
    postLink.classList.add('wo-hidden');
    postLink.setAttribute('href', '#');
    postLinkUrl.textContent = 'Liên kết bài live sẽ hiện sau khi bắt đầu phát.';
    return;
  }
  const url = '<?php echo $wo['config']['site_url']; ?>/post/' + postId;
  postLink.classList.remove('wo-hidden');
  postLink.setAttribute('href', url);
  postLinkUrl.textContent = url;
}

function updateLiveCount(count) {
  const safeCount = Math.max(0, parseInt(count || 0, 10) || 0);
  liveMeta.viewers = safeCount;
  $('#live_count_setup').text(safeCount);
  $('#wo-livekit-side-count-chip').text(safeCount);
  $('#wo-livekit-stat-viewers').text(safeCount);
  $('#wo-livekit-detail-viewers').text(safeCount);
}

function updateCommentStats() {
  const count = $('#live_post_comments .live_comments').filter(function() {
    return !!$(this).attr('live_comment_id');
  }).length;
  liveMeta.comments = count;
  $('#wo-livekit-stat-comments').text(count);
  $('#wo-livekit-detail-comments').text(count);
}

function updateEngagementStats(reactions, shares, clips) {
  const safeReactions = Math.max(0, parseInt(reactions || 0, 10) || 0);
  const safeShares = Math.max(0, parseInt(shares || 0, 10) || 0);
  const safeClips = Math.max(0, parseInt(clips || 0, 10) || 0);
  liveMeta.reactions = safeReactions;
  liveMeta.shares = safeShares;
  liveMeta.clips = safeClips;
  $('#wo-livekit-detail-reactions').text(safeReactions);
  $('#wo-livekit-detail-shares').text(safeShares);
  $('#wo-livekit-detail-clips').text(safeClips);
}

function syncCommentsState() {
  const hasComments = $('#live_post_comments .live_comments').length > 0;
  commentsShell.classList.toggle('has-comments', hasComments);
  commentsEmpty.classList.toggle('wo-hidden', hasComments);
  updateCommentStats();
}

function getHostTrack(kind) {
  for (let i = 0; i < hostTracks.length; i += 1) {
    if (hostTracks[i] && hostTracks[i].kind === kind) {
      return hostTracks[i];
    }
  }
  return null;
}

function removeRenderedVideos() {
  [stageSetup, stageLive].forEach(function(stage) {
    if (!stage) {
      return;
    }
    stage.querySelectorAll('video').forEach(function(video) {
      video.remove();
    });
  });
}

function renderHostPreview() {
  const stage = getActiveStage();
  const emptyState = getActiveEmptyState();
  if (!stage || !emptyState) {
    return;
  }

  removeRenderedVideos();
  const videoTrack = getHostTrack('video');
  if (!videoTrack || videoTrack.isMuted) {
    emptyState.classList.remove('wo-hidden');
    emptyState.innerHTML = studioMode === 'live'
      ? '<div><strong>Camera đang tắt</strong><span>Bật camera để người xem thấy host trong lúc livestream.</span></div>'
      : '<div><strong>Xem trước camera</strong><span>Bật camera để kiểm tra khung hình trước khi phát.</span></div>';
    return;
  }

  const element = videoTrack.attach();
  element.id = 'wo-livekit-host-preview';
  element.muted = true;
  element.autoplay = true;
  element.playsInline = true;
  stage.appendChild(element);
  emptyState.classList.add('wo-hidden');
}

function updateTrackButtons() {
  const audioTrack = getHostTrack('audio');
  const videoTrack = getHostTrack('video');
  const micOn = !audioTrack || !audioTrack.isMuted;
  const camOn = !videoTrack || !videoTrack.isMuted;

  $('.js-toggle-mic')
    .text(micOn ? 'Mic đang bật' : 'Mic đang tắt')
    .toggleClass('primary', micOn);
  $('.js-toggle-cam')
    .text(camOn ? 'Camera đang bật' : 'Camera đang tắt')
    .toggleClass('primary', camOn);

  if (audioMeter) {
    audioMeter.classList.toggle('active', micOn);
  }
}

async function refreshDeviceLists() {
  if (!navigator.mediaDevices || !navigator.mediaDevices.enumerateDevices) {
    return;
  }
  const devices = await navigator.mediaDevices.enumerateDevices();
  const cameras = devices.filter(function(device) { return device.kind === 'videoinput'; });
  const microphones = devices.filter(function(device) { return device.kind === 'audioinput'; });

  if (cameraSelect) {
    cameraSelect.innerHTML = cameras.length ? '' : '<option value="">Không tìm thấy camera</option>';
    cameras.forEach(function(device, index) {
      const option = document.createElement('option');
      option.value = device.deviceId;
      option.textContent = device.label || ('Camera ' + (index + 1));
      cameraSelect.appendChild(option);
    });
    if (!selectedDevices.videoId && cameras[0]) {
      selectedDevices.videoId = cameras[0].deviceId;
    }
    if (selectedDevices.videoId) {
      cameraSelect.value = selectedDevices.videoId;
    }
  }

  if (micSelect) {
    micSelect.innerHTML = microphones.length ? '' : '<option value="">Không tìm thấy microphone</option>';
    microphones.forEach(function(device, index) {
      const option = document.createElement('option');
      option.value = device.deviceId;
      option.textContent = device.label || ('Microphone ' + (index + 1));
      micSelect.appendChild(option);
    });
    if (!selectedDevices.audioId && microphones[0]) {
      selectedDevices.audioId = microphones[0].deviceId;
    }
    if (selectedDevices.audioId) {
      micSelect.value = selectedDevices.audioId;
    }
  }
}

async function createLocalPreviewTracks() {
  if (!window.LivekitClient || !livekitHostSession || !livekitHostSession.ws_url || !livekitHostSession.token) {
    throw new Error('LiveKit chưa được cấu hình đầy đủ.');
  }
  return LivekitClient.createLocalTracks({
    audio: selectedDevices.audioId ? {deviceId: {exact: selectedDevices.audioId}} : true,
    video: selectedDevices.videoId ? {deviceId: {exact: selectedDevices.videoId}} : true
  });
}

function stopLocalTracks() {
  hostTracks.forEach(function(track) {
    if (!track) {
      return;
    }
    try {
      track.stop();
    } catch (err) {}
    try {
      track.detach().forEach(function(element) {
        element.remove();
      });
    } catch (err) {}
  });
  hostTracks = [];
  removeRenderedVideos();
}

async function ensureHostPreview(forceRecreate) {
  if (hostTracks.length && !forceRecreate) {
    renderHostPreview();
    updateTrackButtons();
    syncSetupProgress();
    return hostTracks;
  }

  if (hostTracks.length) {
    stopLocalTracks();
  }

  hostTracks = await createLocalPreviewTracks();
  await refreshDeviceLists();
  renderHostPreview();
  updateTrackButtons();
  syncSetupProgress();
  return hostTracks;
}

async function changePreviewDevice(kind, deviceId) {
  if (liveCreated) {
    return;
  }
  if (kind === 'video') {
    selectedDevices.videoId = deviceId || '';
  } else {
    selectedDevices.audioId = deviceId || '';
  }
  try {
    await ensureHostPreview(true);
    setHostStatus('Đã cập nhật thiết bị xem trước');
  } catch (err) {
    setHostStatus(err && err.message ? err.message : 'Không thể chuyển thiết bị.');
  }
}

async function toggleHostTrack(kind) {
  try {
    await ensureHostPreview();
    const track = getHostTrack(kind);
    if (!track) {
      return;
    }
    if (track.isMuted) {
      await track.unmute();
    } else {
      await track.mute();
    }
    renderHostPreview();
    updateTrackButtons();
  } catch (err) {
    setHostStatus(err && err.message ? err.message : 'Không thể truy cập camera hoặc microphone.');
  }
}

function disconnectHostRoom() {
  if (hostRoom) {
    try {
      hostRoom.disconnect();
    } catch (err) {}
    hostRoom = null;
  }
}

function captureHostThumbnail(postId) {
  const preview = document.getElementById('wo-livekit-host-preview');
  if (!preview || !postId || !preview.videoWidth || !preview.videoHeight) {
    return;
  }
  const canvas = document.createElement('canvas');
  canvas.width = preview.videoWidth;
  canvas.height = preview.videoHeight;
  canvas.getContext('2d').drawImage(preview, 0, 0);
  canvas.toBlob(function(blob) {
    if (!blob) {
      return;
    }
    const formData = new FormData();
    formData.append('thumb', blob, 'thumb.png');
    formData.append('post_id', postId);
    $.ajax({
      processData: false,
      url: liveThumbUrl,
      type: 'POST',
      dataType: 'json',
      data: formData,
      contentType: false
    });
  }, 'image/png');
}

function formatDuration(totalSeconds) {
  const safe = Math.max(0, parseInt(totalSeconds || 0, 10) || 0);
  const hours = Math.floor(safe / 3600);
  const minutes = Math.floor((safe % 3600) / 60);
  const seconds = safe % 60;
  if (hours > 0) {
    return String(hours).padStart(2, '0') + ':' + String(minutes).padStart(2, '0') + ':' + String(seconds).padStart(2, '0');
  }
  return String(minutes).padStart(2, '0') + ':' + String(seconds).padStart(2, '0');
}

function startLiveTimer() {
  stopLiveTimer();
  liveTimerEl.textContent = '00:00';
  liveTimerInterval = window.setInterval(function() {
    if (!liveMeta.startedAt) {
      return;
    }
    const elapsed = Math.floor((Date.now() - liveMeta.startedAt) / 1000);
    liveTimerEl.textContent = formatDuration(elapsed);
  }, 1000);
}

function stopLiveTimer() {
  if (liveTimerInterval) {
    clearInterval(liveTimerInterval);
    liveTimerInterval = null;
  }
}

async function startHostLive() {
  if (liveCreated) {
    return;
  }
  publishBtn.disabled = true;
  publishBtn.textContent = "<?php echo $wo['lang']['please_wait']; ?>";
  setHostStatus('Đang kết nối phòng LiveKit');

  liveMeta.title = getTitleValue();
  liveMeta.description = getDescriptionValue();

  try {
    const tracks = await ensureHostPreview();
    hostRoom = new LivekitClient.Room({adaptiveStream: true, dynacast: true});
    await hostRoom.connect(livekitHostSession.ws_url, livekitHostSession.token);

    for (let i = 0; i < tracks.length; i += 1) {
      await hostRoom.localParticipant.publishTrack(tracks[i]);
    }

    const response = await $.ajax({
      url: liveCreateUrl,
      type: 'POST',
      dataType: 'json',
      data: {
        stream_name: livekitHostSession.stream_name,
        title: liveMeta.title,
        description: liveMeta.description
      }
    });

    if (!response || response.status !== 200 || !response.post_id) {
      throw new Error('Không thể tạo bài livestream.');
    }

    liveCreated = true;
    liveMeta.postId = parseInt(response.post_id, 10) || 0;
    liveMeta.startedAt = Date.now();
    postIdInput.value = liveMeta.postId;
    setStudioMode('live');
    setHostStatus('Đang phát trực tiếp');
    setPostLink(liveMeta.postId);
    setLiveDetails(response.title || liveMeta.title, response.description || liveMeta.description);
    updateLiveCount(0);
    updateCommentStats();
    updateEngagementStats(0, 0, 0);
    startLiveTimer();
    captureHostThumbnail(liveMeta.postId);
    syncSetupProgress();
  } catch (err) {
    disconnectHostRoom();
    publishBtn.disabled = false;
    publishBtn.textContent = 'Phát trực tiếp';
    setHostStatus(err && err.message ? err.message : 'Không thể bắt đầu livestream.');
    return;
  }
}

function DeleteLive() {
  if (deletingLive) {
    return true;
  }

  const postId = postIdInput.value;
  disconnectHostRoom();
  stopLocalTracks();
  stopLiveTimer();

  if (!postId) {
    return true;
  }

  deletingLive = true;
  try {
    fetch(liveDeleteUrl, {
      method: 'POST',
      credentials: 'same-origin',
      keepalive: true,
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: 'post_id=' + encodeURIComponent(postId)
    }).catch(function() {});
  } catch (err) {}

  $.post(liveDeleteUrl, {post_id: postId}, function() {});
  return true;
}

window.onbeforeunload = function() {
  DeleteLive();
};

var main_live = setInterval(function() {
  const postId = postIdInput.value;
  if (!postId) {
    return;
  }

  const ids = {};
  $('#live_post_comments .live_comments').each(function(index, node) {
    const liveCommentId = $(node).attr('live_comment_id');
    if (liveCommentId) {
      ids[index] = liveCommentId;
    }
  });

  $.post(liveCheckUrl, {post_id: postId, ids: ids, page: 'live'}, function(response) {
    if (response.status == 200) {
      $('#live_post_comments').append(response.html);
      updateLiveCount(response.count);
      updateEngagementStats(response.reactions_count, response.shares_count, response.clips_count);

      const comments = $('#live_post_comments .live_comments');
      if (comments.length > 8) {
        comments.slice(0, comments.length - 8).remove();
      }
      syncCommentsState();
    } else if (response.removed == 'yes' || response.still_live === 'offline' || response.is_final === 1) {
      clearInterval(main_live);
      setHostStatus('Buổi phát đã kết thúc');
    }
  });
}, 3000);

$(document).on('click', '.js-toggle-mic', function() {
  toggleHostTrack('audio');
});

$(document).on('click', '.js-toggle-cam', function() {
  toggleHostTrack('video');
});

$(document).on('click', '.js-expand-video', function() {
  const stage = getActiveStage();
  if (!stage) {
    return;
  }
  const target = stage.requestFullscreen || stage.webkitRequestFullscreen || stage.msRequestFullscreen;
  if (target) {
    target.call(stage);
  }
});

$('#publishBtn').on('click', function() {
  startHostLive();
});

$('#wo-livekit-title-input, #wo-livekit-description-input').on('input', function() {
  syncSetupProgress();
});

$('#wo-livekit-camera-select').on('change', function() {
  changePreviewDevice('video', this.value);
});

$('#wo-livekit-mic-select').on('change', function() {
  changePreviewDevice('audio', this.value);
});

setStudioMode('setup');
setLiveDetails('', '');
setPostLink(0);
updateLiveCount(0);
updateEngagementStats(0, 0, 0);
syncCommentsState();
refreshDeviceLists().catch(function() {});
ensureHostPreview().then(function() {
  setHostStatus('Sẵn sàng bắt đầu livestream');
}).catch(function(err) {
  setHostStatus(err && err.message ? err.message : 'Không thể truy cập camera hoặc microphone.');
});
</script>
