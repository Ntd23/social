<?php if (empty($wo['livekit_live_assets_loaded'])) { $wo['livekit_live_assets_loaded'] = true; ?>
<style>
.wo-livekit-live-wrap {position: relative;background: #020617;border-radius: 16px;overflow: hidden}
.wo-livekit-live-stage {position: absolute;inset: 0;background: #020617}
.wo-livekit-live-stage video {width: 100%;height: 100%;display: block;object-fit: cover;background: #000}
.wo-livekit-live-state {position: absolute;inset: 0;display: flex;align-items: center;justify-content: center;text-align: center;padding: 20px;color: #e2e8f0;font-size: 16px;background: linear-gradient(180deg,rgba(15,23,42,.82),rgba(15,23,42,.96))}
.wo-livekit-live-state.is-ended {color: #fff;background: linear-gradient(180deg,rgba(127,29,29,.78),rgba(15,23,42,.96))}
.wo-livekit-live-hidden {display: none !important}
.wo-livekit-live-ended-card {display: flex;align-items: center;justify-content: center;min-height: 240px;padding: 28px;text-align: center;background: linear-gradient(180deg,#0f172a,#111827);color: #fff}
</style>
<script src="https://cdn.jsdelivr.net/npm/livekit-client/dist/livekit-client.umd.min.js"></script>
<script>
(function(window, document) {
  if (window.WoLiveKitLive && window.WoLiveKitLive.__ready) {
    return;
  }
  const players = {};

  function ensureDom(postId) {
    if (!players[postId]) {
      players[postId] = {postId: postId};
    }
    players[postId].stage = document.getElementById('wo-livekit-stage-' + postId);
    players[postId].audioSink = document.getElementById('wo-livekit-audio-' + postId);
    return players[postId];
  }

  function setStageMessage(postId, message, ended) {
    const entry = ensureDom(postId);
    if (!entry.stage) {
      return;
    }
    entry.stage.innerHTML = '';
    const state = document.createElement('div');
    state.className = 'wo-livekit-live-state' + (ended ? ' is-ended' : '');
    state.textContent = message;
    entry.stage.appendChild(state);
  }

  function clearAttachedTrack(track) {
    if (!track || typeof track.detach !== 'function') {
      return;
    }
    track.detach().forEach(function(element) {
      element.remove();
    });
  }

  function attachTrack(postId, track) {
    const entry = ensureDom(postId);
    if (!entry.stage || !entry.audioSink) {
      return;
    }
    const element = track.attach();
    element.autoplay = true;
    element.playsInline = true;
    if (track.kind === 'video') {
      entry.stage.innerHTML = '';
      entry.stage.appendChild(element);
      return;
    }
    element.classList.add('wo-livekit-live-hidden');
    entry.audioSink.appendChild(element);
  }

  async function fetchJoinPayload(joinUrl, postId) {
    const response = await fetch(joinUrl, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: 'post_id=' + encodeURIComponent(postId)
    });
    const raw = await response.text();
    return raw ? JSON.parse(raw) : {};
  }

  async function startPlayer(postId) {
    const entry = ensureDom(postId);
    if (!entry || entry.started || entry.stopped || !entry.joinUrl) {
      return;
    }
    entry.started = true;
    setStageMessage(postId, 'Dang ket noi livestream...', false);
    try {
      const payload = await fetchJoinPayload(entry.joinUrl, postId);
      if (!payload || payload.status !== 200 || !payload.token || !payload.ws_url) {
        entry.started = false;
        entry.stopped = true;
        setStageMessage(postId, entry.endedText || 'Livestream da ket thuc.', true);
        return;
      }
      entry.room = new window.LivekitClient.Room({adaptiveStream: true, dynacast: true});
      entry.room.on(window.LivekitClient.RoomEvent.TrackSubscribed, function(track) {
        attachTrack(postId, track);
      });
      entry.room.on(window.LivekitClient.RoomEvent.TrackUnsubscribed, function(track) {
        clearAttachedTrack(track);
      });
      entry.room.on(window.LivekitClient.RoomEvent.Disconnected, function() {
        if (!entry.stopped) {
          setStageMessage(postId, entry.endedText || 'Livestream da ket thuc.', true);
        }
      });
      await entry.room.connect(payload.ws_url, payload.token);
      if (!entry.room.remoteParticipants.size) {
        setStageMessage(postId, 'Dang cho host bat dau livestream...', false);
      }
      entry.room.remoteParticipants.forEach(function(participant) {
        participant.trackPublications.forEach(function(publication) {
          if (publication && publication.track) {
            attachTrack(postId, publication.track);
          }
        });
      });
    } catch (error) {
      entry.started = false;
      entry.stopped = true;
      setStageMessage(postId, entry.endedText || 'Livestream da ket thuc.', true);
    }
  }

  function stopPlayer(postId, endedText) {
    const entry = ensureDom(postId);
    entry.stopped = true;
    if (entry.room) {
      try {
        entry.room.disconnect();
      } catch (err) {}
      entry.room = null;
    }
    if (entry.audioSink) {
      entry.audioSink.innerHTML = '';
    }
    setStageMessage(postId, endedText || entry.endedText || 'Livestream da ket thuc.', true);
  }

  window.WoLiveKitLive = {
    __ready: true,
    register: function(options) {
      if (!options || !options.postId) {
        return;
      }
      const postId = String(options.postId);
      const entry = ensureDom(postId);
      entry.joinUrl = options.joinUrl || '';
      entry.endedText = options.endedText || 'Livestream da ket thuc.';
      entry.stopped = options.isStillLive === false;
      if (options.isStillLive === false) {
        stopPlayer(postId, entry.endedText);
        return;
      }
      startPlayer(postId);
    },
    stopPlayer: function(postId, endedText) {
      stopPlayer(String(postId), endedText);
    }
  };
})(window, document);
</script>
<?php } ?>
