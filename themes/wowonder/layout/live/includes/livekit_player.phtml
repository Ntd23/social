<div class="post-file" <?php echo $wo['story']['is_still_live'] ? 'style="/*height: 440px;*/"' : ''; ?> id="fullsizeimg">
    <?php if ($wo['story']['is_still_live']) { ?>
        <div class="embed-responsive embed-responsive-4by3 wo-livekit-live-wrap">
            <div id="wo-livekit-stage-<?php echo $wo['story']['id']; ?>" class="embed-responsive-item wo-livekit-live-stage">
                <div class="wo-livekit-live-state">Dang ket noi livestream...</div>
            </div>
            <div id="wo-livekit-audio-<?php echo $wo['story']['id']; ?>"></div>
            <div class="wow_liv_counter"><span id="live_word_<?php echo($wo['story']['id']) ?>"><?php echo $wo['lang']['live']; ?></span> <span id="live_count_<?php echo($wo['story']['id']) ?>"> <?php echo $wo['story']['live_sub_users']; ?></span></div>
        </div>
        <?php if (!empty($wo['page']) && $wo['page'] != 'story') { ?>
            <a href="<?php echo $wo['story']['url']; ?>" target="_blank" class="live_link_style live_link_<?php echo($wo['story']['id']) ?>"></a>
        <?php } ?>
        <?php if (!empty($wo['story']['comments_status']) && $wo['story']['comments_status'] == 1) { ?>
            <div id="live_post_comments_<?php echo($wo['story']['id']) ?>" class="wow_liv_comments_feed">
                <?php if (!empty($wo['story']['get_post_comments'])) {
                    $count = 0;
                    for ($i = count($wo['story']['get_post_comments']) - 1; $i >= 0; $i--) {
                        $wo['comment'] = $wo['story']['get_post_comments'][$i];
                        if (!empty($wo['comment']['text'])) {
                            echo Wo_LoadPage('story/includes/live_comment');
                            $count = $count + 1;
                            if ($count == 4) {
                                break;
                            }
                        }
                    }
                } ?>
            </div>
        <?php } ?>
        <script>
          if (window.WoLiveKitLive) {
            window.WoLiveKitLive.register({
              postId: <?php echo (int) $wo['story']['id']; ?>,
              joinUrl: "<?php echo $wo['config']['site_url']; ?>/requests.php?f=live&s=join",
              isStillLive: true,
              endedText: <?php echo json_encode($ended_text); ?>
            });
          }
        </script>
    <?php } else { ?>
        <div class="wo-livekit-live-ended-card">
            <h3 class="end_video_text"><?php echo $ended_text; ?></h3>
        </div>
    <?php } ?>
