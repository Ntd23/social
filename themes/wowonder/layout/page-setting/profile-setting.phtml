              $('.yandex_search_page').html('');
            }
            else{
              let html = '';
              for (var i = 0; i < res.geoObjects.getLength(); i++) {
                html += '<p class="pointer" onclick="AddYandexResult(\'#page_location_input\',this,\'.yandex_search_page\');$(\'#address_value\').val($(this).text())">'+res.geoObjects.get(i).properties.get('name')+'</p>';
              }
              $('.yandex_search_page').html(html);
            }
          },
          function (err) {
              $('.yandex_search_page').html('');
          }
      );
    });
  });
