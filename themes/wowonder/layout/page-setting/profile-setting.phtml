<script type="text/javascript">
var woPagePlaceAutocompleteElement = null;
var woPagePreviewMap = null;
var woPageLocationSuggestionTimer = null;
var woPageLocationSuggestionRequest = 0;
var woPageGooglePredictionCache = {};
var woPageGoogleSessionToken = null;
var woPageUseGoogleMobileSuggestions = true;
var woPageLocationLocale = <?php echo json_encode(strtolower($wo['language'])); ?>;
function Wo_ShouldUseInlinePageLocationInput() {
	return window.matchMedia('(max-width: 768px)').matches || /Android|webOS|iPhone|iPad|iPod|Opera Mini|IEMobile|Mobile/i.test(navigator.userAgent || '');
}
function Wo_GetPageLocationLanguage() {
	return (woPageLocationLocale || document.documentElement.lang || navigator.language || navigator.userLanguage || 'en').toLowerCase();
}
function Wo_GetPageLocationGoogleLanguage() {
	var language = Wo_GetPageLocationLanguage();
	if (!language) {
		return 'en';
	}
	if (language.indexOf('vi') === 0 || language.indexOf('vietnam') !== -1) {
		return 'vi';
	}
	if (language.indexOf('en') === 0 || language.indexOf('english') !== -1) {
		return 'en';
	}
	var normalizedLanguage = language.split(/[_-]/)[0];
	if (/^[a-z]{2}$/.test(normalizedLanguage)) {
		return normalizedLanguage;
	}
	return 'en';
}
function Wo_IsVietnamesePageLocation() {
	var language = Wo_GetPageLocationLanguage();
	return language.indexOf('vi') === 0 || language.indexOf('vietnam') !== -1;
}
function Wo_NormalizePageLocationPart(value) {
	return (value || '')
		.toLowerCase()
		.normalize('NFD')
		.replace(/[\u0300-\u036f]/g, '')
		.replace(/[^a-z0-9]+/g, ' ')
		.trim();
}
function Wo_GetPageLocationCanonicalPart(value) {
	return Wo_NormalizePageLocationPart(value)
		.replace(/^(phuong|xa|quan|huyen|tinh|thanh pho|tp)\s+/i, '')
		.replace(/\s+(ward|district|province|city)$/i, '')
		.trim();
}
function Wo_LocalizeVietnamesePageLocationPart(value) {
	if (!value) {
		return '';
	}

	var localizedValue = value.trim();
	localizedValue = localizedValue.replace(/^(.+?)\s+Road$/i, 'Duong $1');
	localizedValue = localizedValue.replace(/^(.+?)\s+Street$/i, '$1');
	localizedValue = localizedValue.replace(/^(.+?)\s+Ward$/i, 'Phuong $1');
	localizedValue = localizedValue.replace(/^Ward\s+(.+)$/i, 'Phuong $1');
	localizedValue = localizedValue.replace(/^District\s+(.+)$/i, 'Quan $1');
	localizedValue = localizedValue.replace(/^Province\s+(.+)$/i, 'Tinh $1');
	localizedValue = localizedValue.replace(/^City\s+(.+)$/i, 'Thanh pho $1');
	localizedValue = localizedValue.replace(/^Vietnam$/i, 'Viet Nam');
	localizedValue = localizedValue.replace(/^Ha Noi$/i, 'Ha Noi');
	localizedValue = localizedValue.replace(/^Ho Chi Minh City$/i, 'TP Ho Chi Minh');

	return localizedValue;
}
function Wo_GetPageLocationText(item, queryValue) {
	if (item && item.google_prediction === true) {
		return item.display_name || item.description || '';
	}
	if (!item || !item.address) {
		return item && (item.display_name || item.name) ? (item.display_name || item.name) : '';
	}

	var address = item.address;
	var isVietnamese = Wo_IsVietnamesePageLocation();
	var parts = [];
	var firstLine = [];
	var houseNumber = address.house_number || address.house_name || '';
	var road = address.road || address.pedestrian || address.footway || address.cycleway || '';
	var normalizedQuery = Wo_NormalizePageLocationPart(queryValue || '');
	var normalizedRoad = Wo_NormalizePageLocationPart(road);

	if (isVietnamese && normalizedQuery && normalizedRoad) {
		if (normalizedQuery.indexOf(normalizedRoad) !== -1 || normalizedRoad.indexOf(normalizedQuery) !== -1) {
			road = queryValue;
		}
	}

	if (houseNumber) {
		firstLine.push(houseNumber);
	}
	if (road) {
		firstLine.push(isVietnamese ? Wo_LocalizeVietnamesePageLocationPart(road) : road);
	}
	if (firstLine.length > 0) {
		parts.push(firstLine.join(' '));
	}

	[
		address.suburb,
		address.neighbourhood,
		address.quarter,
		address.city_district,
		address.county,
		address.district,
		address.city,
		address.town,
		address.municipality,
		address.state_district,
		address.state,
		address.country
	].forEach(function(value) {
		if (!value) {
			return;
		}
		var localizedValue = isVietnamese ? Wo_LocalizeVietnamesePageLocationPart(value) : value;
		var compareValue = Wo_GetPageLocationCanonicalPart(localizedValue);
		var alreadyExists = parts.some(function(existingValue) {
			return Wo_GetPageLocationCanonicalPart(existingValue) === compareValue;
		});
		if (!alreadyExists) {
			parts.push(localizedValue);
		}
	});

	return parts.join(', ');
}
function Wo_GetPageLocationSearchUrl(locationValue, limit) {
	var params = new URLSearchParams({
		format: 'jsonv2',
		addressdetails: '1',
		limit: String(limit || 10),
		'accept-language': Wo_GetPageLocationLanguage(),
		q: locationValue
	});
	if (Wo_IsVietnamesePageLocation()) {
		params.set('countrycodes', 'vn');
	}
	return 'https://nominatim.openstreetmap.org/search?' + params.toString();
}
function Wo_GetGooglePagePredictionLabel(prediction) {
	if (!prediction) {
		return '';
	}

	if (prediction.text && typeof prediction.text.toString === 'function') {
		return prediction.text.toString();
	}

	var mainText = '';
	var secondaryText = '';
	if (prediction.mainText && typeof prediction.mainText.toString === 'function') {
		mainText = prediction.mainText.toString();
	}
	if (prediction.secondaryText && typeof prediction.secondaryText.toString === 'function') {
		secondaryText = prediction.secondaryText.toString();
	}

	if (mainText && secondaryText) {
		return mainText + ', ' + secondaryText;
	}

	return mainText || secondaryText || prediction.description || '';
}
function Wo_FallbackPageLocationSuggestions(normalizedLocationValue, requestToken) {
	fetch(Wo_GetPageLocationSearchUrl(normalizedLocationValue, 5), {
		headers: {
			'Accept': 'application/json'
		}
	}).then(function(response) {
		if (!response.ok) {
			throw new Error('Page location suggestion request failed');
		}
		return response.json();
	}).then(function(results) {
		if (requestToken !== woPageLocationSuggestionRequest) {
			return;
		}
		Wo_RenderPageLocationSuggestions(results, normalizedLocationValue);
	}).catch(function() {
		if (requestToken !== woPageLocationSuggestionRequest) {
			return;
		}
		Wo_RenderPageLocationSuggestions([], normalizedLocationValue);
	});
}
function Wo_RenderPageLocationSuggestions(items, queryValue) {
	var suggestionBox = $('.page_setting_location_suggestions');
	if (!Array.isArray(items) || items.length === 0) {
		suggestionBox.empty().hide();
		return;
	}

	var html = '';
	items.forEach(function(item) {
		var displayName = item.display_name || '';
		var pid = item.place_id || '';
		html += '<p class="pointer page_location_suggestion_item" data-place-id="' + escapeHtml(String(pid)) + '" data-name="' + escapeHtml(displayName) + '">' + escapeHtml(displayName) + '</p>';
	});

	if (!html) {
		suggestionBox.empty().hide();
		return;
	}
	suggestionBox.html(html).show();
}
function Wo_SetPageCoordinates(lat, lng) {
	$('#page_lat_value').val(lat || '');
	$('#page_lng_value').val(lng || '');
	Wo_UpdatePageMapPreview();
}
function Wo_SetPagePlaceId(placeId) {
	$('#page_place_id_value').val(placeId || '');
}
function Wo_GetPageLocationField() {
	return document.getElementById('page_location_input');
}
function Wo_ReadPageLocationValue() {
	var locationField = Wo_GetPageLocationField();
	if (!locationField) {
		return '';
	}
	if (woPagePlaceAutocompleteElement && typeof woPagePlaceAutocompleteElement.value === 'string') {
		locationField.value = woPagePlaceAutocompleteElement.value;
	}
	return locationField.value || '';
}
function Wo_WritePageLocationValue(value) {
	var normalizedValue = value || '';
	var locationField = Wo_GetPageLocationField();
	if (locationField) {
		locationField.value = normalizedValue;
	}
	if (woPagePlaceAutocompleteElement && typeof woPagePlaceAutocompleteElement.value !== 'undefined') {
		woPagePlaceAutocompleteElement.value = normalizedValue;
	}
}
function Wo_ClearPageCoordinates() {
	Wo_SetPageCoordinates('', '');
}
function Wo_ClearPageLocationMeta() {
	Wo_ClearPageCoordinates();
	Wo_SetPagePlaceId('');
	Wo_UpdatePageMapPreview();
}
function Wo_PageGoogleAutocompleteAvailable() {
	return (typeof google !== 'undefined' &&
		google.maps &&
		typeof google.maps.importLibrary === 'function');
}
function Wo_ReadPageCoordinateValue(locationObject, axis) {
	if (!locationObject) {
		return '';
	}
	if (typeof locationObject[axis] === 'function') {
		return locationObject[axis]();
	}
	if (typeof locationObject[axis] === 'number') {
		return locationObject[axis];
	}
	return '';
}
function Wo_ApplyGooglePagePlace(place) {
	if (!place) {
		return false;
	}

	var locationObject = place.location || (place.geometry && place.geometry.location ? place.geometry.location : null);
	var displayName = '';
	if (place.displayName) {
		displayName = typeof place.displayName === 'string' ? place.displayName : (place.displayName.text || '');
	}
	var formattedAddress = place.formattedAddress || place.formatted_address || displayName || place.name || $.trim(Wo_ReadPageLocationValue());
	var lat = Wo_ReadPageCoordinateValue(locationObject, 'lat');
	var lng = Wo_ReadPageCoordinateValue(locationObject, 'lng');
	var placeId = place.id || place.place_id || '';

	Wo_WritePageLocationValue(formattedAddress);
	$('#address_value').val(formattedAddress);
	Wo_SetPageCoordinates(lat, lng);
	Wo_SetPagePlaceId(placeId);
	Wo_UpdatePageMapPreview();

	return true;
}
function Wo_PagePreviewHasRenderableLocation() {
	var lat = parseFloat($('#page_lat_value').val());
	var lng = parseFloat($('#page_lng_value').val());
	return !isNaN(lat) && !isNaN(lng);
}
function Wo_DestroyPagePreviewMap() {
	if (woPagePreviewMap && typeof woPagePreviewMap.remove === 'function') {
		woPagePreviewMap.remove();
	}
	woPagePreviewMap = null;
	$('#wo_page_map_preview_canvas').empty();
}
function Wo_HidePageMapPreview() {
	$('#wo_page_map_preview_card').hide();
	$('#wo_page_map_preview_frame').removeClass('wo_ui_map_state_loading');
	Wo_DestroyPagePreviewMap();
}
function Wo_RenderPageMapPreview(lat, lng) {
	if (!Wo_PagePreviewHasRenderableLocation() || typeof L === 'undefined') {
		Wo_HidePageMapPreview();
		return;
	}

	Wo_DestroyPagePreviewMap();
	woPagePreviewMap = L.map('wo_page_map_preview_canvas', {
		zoomControl: false,
		scrollWheelZoom: false,
		dragging: false,
		doubleClickZoom: false,
		boxZoom: false,
		keyboard: false,
		tap: false,
		touchZoom: false
	}).setView([lat, lng], 14);

	var mapFrameNode = document.getElementById('wo_page_map_preview_frame');
	var tileConfig = window.WoLeafletMutedMapConfig || {
		tileUrl: 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',
		tileOptions: {
			attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
			subdomains: 'abcd',
			maxZoom: 20
		}
	};
	var tileLayer = L.tileLayer(tileConfig.tileUrl, $.extend({
		attribution: '',
		maxZoom: 18
	}, tileConfig.tileOptions || {})).addTo(woPagePreviewMap);
	var clearMapLoading = function() {
		if (mapFrameNode) {
			mapFrameNode.classList.remove('wo_ui_map_state_loading');
		}
	};
	tileLayer.once('load', clearMapLoading);
	tileLayer.once('tileerror', clearMapLoading);

	L.marker([lat, lng]).addTo(woPagePreviewMap);
	setTimeout(function() {
		woPagePreviewMap.invalidateSize();
	}, 120);
}
function Wo_UpdatePageMapPreview() {
	var lat = parseFloat($('#page_lat_value').val());
	var lng = parseFloat($('#page_lng_value').val());

	if (!Wo_PagePreviewHasRenderableLocation()) {
		Wo_HidePageMapPreview();
		return;
	}

	$('#wo_page_map_preview_card').show();
	$('#wo_page_map_preview_frame').addClass('wo_ui_map_state_loading');
	Wo_RenderPageMapPreview(lat, lng);
}
async function Wo_InitGooglePageAutocomplete() {
	var input = Wo_GetPageLocationField();
	var host = document.getElementById('page_location_autocomplete_host');
	if (!input || !host || host.dataset.pageGoogleAutocompleteReady === '1') {
		return;
	}

	if (Wo_ShouldUseInlinePageLocationInput()) {
		if (Wo_PageGoogleAutocompleteAvailable()) {
			try {
				await google.maps.importLibrary('places');
			} catch (err) {}
		}
		host.dataset.pageGoogleAutocompleteReady = '1';
		host.innerHTML = '';
		var inlineInput = document.createElement('input');
		inlineInput.type = 'text';
		inlineInput.className = 'wo_page_location_inline_input';
		inlineInput.autocomplete = 'off';
		inlineInput.autocorrect = 'off';
		inlineInput.autocapitalize = 'off';
		inlineInput.spellcheck = false;
		inlineInput.placeholder = <?php echo json_encode($wo['lang']['location']); ?>;
		host.appendChild(inlineInput);

		inlineInput.value = input.value || '';
		inlineInput.addEventListener('input', function() {
			var locationValue = inlineInput.value || '';
			Wo_WritePageLocationValue(locationValue);
			$('#address_value').val(locationValue);
			Wo_ClearPageLocationMeta();
			clearTimeout(woPageLocationSuggestionTimer);
			woPageLocationSuggestionTimer = setTimeout(function() {
				Wo_SearchPageLocationSuggestions(locationValue);
			}, 220);
		});
		inlineInput.addEventListener('change', function() {
			var locationValue = inlineInput.value || '';
			Wo_WritePageLocationValue(locationValue);
			$('#address_value').val(locationValue);
			if (!Wo_PageHasCoordinates() && locationValue) {
				Wo_GeocodePageLocation(locationValue);
				return;
			}
			Wo_UpdatePageMapPreview();
		});
		inlineInput.addEventListener('blur', function() {
			setTimeout(function() {
				Wo_RenderPageLocationSuggestions([]);
			}, 200);
		});
		return;
	}

	if (!Wo_PageGoogleAutocompleteAvailable()) {
		return;
	}

	await google.maps.importLibrary('places');
	if (!google.maps.places || typeof google.maps.places.PlaceAutocompleteElement !== 'function') {
		return;
	}

	host.dataset.pageGoogleAutocompleteReady = '1';
	host.innerHTML = '';
	woPagePlaceAutocompleteElement = new google.maps.places.PlaceAutocompleteElement({});
	woPagePlaceAutocompleteElement.placeholder = <?php echo json_encode($wo['lang']['location']); ?>;
	if (typeof woPagePlaceAutocompleteElement.value !== 'undefined') {
		woPagePlaceAutocompleteElement.value = input.value || '';
	}
	host.appendChild(woPagePlaceAutocompleteElement);

	woPagePlaceAutocompleteElement.addEventListener('input', function() {
		var locationValue = woPagePlaceAutocompleteElement.value || '';
		Wo_WritePageLocationValue(locationValue);
		$('#address_value').val(locationValue);
		Wo_ClearPageLocationMeta();
		Wo_RenderPageLocationSuggestions([]);
	});

	woPagePlaceAutocompleteElement.addEventListener('change', function() {
		var locationValue = woPagePlaceAutocompleteElement.value || '';
		Wo_WritePageLocationValue(locationValue);
		$('#address_value').val(locationValue);
		if (!Wo_PageHasCoordinates() && locationValue) {
			Wo_GeocodePageLocation(locationValue);
			return;
		}
		Wo_UpdatePageMapPreview();
	});

	woPagePlaceAutocompleteElement.addEventListener('gmp-select', async function(event) {
		var placePrediction = event.placePrediction || (event.detail && event.detail.placePrediction) || null;
		if (!placePrediction || typeof placePrediction.toPlace !== 'function') {
			return;
		}

		var place = placePrediction.toPlace();
		await place.fetchFields({
			fields: ['displayName', 'formattedAddress', 'location', 'id']
		});
		Wo_RenderPageLocationSuggestions([]);
		Wo_ApplyGooglePagePlace(place);
	});
}
function Wo_SearchPageLocationSuggestions(locationValue) {
	var normalizedLocationValue = (locationValue || '').trim();
	woPageLocationSuggestionRequest++;
	var requestToken = woPageLocationSuggestionRequest;

	if (!normalizedLocationValue || normalizedLocationValue.length < 2) {
		Wo_RenderPageLocationSuggestions([], normalizedLocationValue);
		return;
	}

	if (Wo_PageGoogleAutocompleteAvailable()) {
		google.maps.importLibrary('places').then(function() {
			if (requestToken !== woPageLocationSuggestionRequest) return;
			var placesLib = google.maps.places;
			if (!placesLib.AutocompleteSuggestion || typeof placesLib.AutocompleteSuggestion.fetchAutocompleteSuggestions !== 'function') return;

			if (!woPageGoogleSessionToken && typeof placesLib.AutocompleteSessionToken === 'function') {
				woPageGoogleSessionToken = new placesLib.AutocompleteSessionToken();
			}

			var req = {
				input: normalizedLocationValue,
				sessionToken: woPageGoogleSessionToken
			};
			var lang = Wo_GetPageLocationLanguage();
			if (lang.indexOf('vi') === 0) req.language = 'vi';

			placesLib.AutocompleteSuggestion.fetchAutocompleteSuggestions(req).then(function(response) {
				if (requestToken !== woPageLocationSuggestionRequest) return;
				var suggestions = (response && Array.isArray(response.suggestions)) ? response.suggestions : [];
				var mapped = suggestions.map(function(s) {
					var p = s.placePrediction || s;
					var pid = p.placeId || p.place_id || '';
					if (pid) woPageGooglePredictionCache[pid] = p;
					return {
						display_name: Wo_GetGooglePagePredictionLabel(p),
						place_id: pid
					};
				});
				Wo_RenderPageLocationSuggestions(mapped, normalizedLocationValue);
			});
		});
	}
}
function Wo_GeocodePageLocation(locationValue) {
	if (!locationValue) {
		Wo_ClearPageLocationMeta();
		return Promise.resolve(false);
	}
	if (Wo_PageGoogleAutocompleteAvailable() && google.maps && typeof google.maps.Geocoder === 'function') {
		return new Promise(function(resolve) {
			var geocoder = new google.maps.Geocoder();
			geocoder.geocode({ address: locationValue }, function(results, status) {
				if (status === 'OK' && Array.isArray(results) && results[0]) {
					resolve(Wo_ApplyGooglePagePlace(results[0]));
					return;
				}

				Wo_ClearPageLocationMeta();
				resolve(false);
			});
		});
	}

	Wo_ClearPageLocationMeta();
	return Promise.resolve(false);
}
function Wo_GeocodePagePlaceId(placeId) {
	if (!placeId) {
		return Promise.resolve(false);
	}

	var cachedPrediction = woPageGooglePredictionCache[placeId];
	if (cachedPrediction && typeof cachedPrediction.toPlace === 'function') {
		return new Promise(function(resolve) {
			var place = cachedPrediction.toPlace();
			place.fetchFields({
				fields: ['displayName', 'formattedAddress', 'location', 'id']
			}).then(function() {
				resolve(Wo_ApplyGooglePagePlace(place));
			}).catch(function() {
				resolve(false);
			});
		}).then(function(resolved) {
			if (resolved && window.google && google.maps && google.maps.places && typeof google.maps.places.AutocompleteSessionToken === 'function') {
				woPageGoogleSessionToken = new google.maps.places.AutocompleteSessionToken();
			}
			return resolved;
		});
	}

	if (!(window.google && google.maps && typeof google.maps.Geocoder === 'function')) {
		return Promise.resolve(false);
	}

	return new Promise(function(resolve) {
		var geocoder = new google.maps.Geocoder();
		geocoder.geocode({ placeId: placeId }, function(results, status) {
			if (status === 'OK' && Array.isArray(results) && results[0]) {
				resolve(Wo_ApplyGooglePagePlace(results[0]));
				return;
			}
			resolve(false);
		});
	});
}
function Wo_PageHasCoordinates() {
	return $.trim($('#page_lat_value').val()) !== '' && $.trim($('#page_lng_value').val()) !== '';
}
function Wo_ResolvePageCoordinates(callback) {
	var locationValue = $.trim(Wo_ReadPageLocationValue());
	if (!locationValue) {
		Wo_ClearPageLocationMeta();
		callback();
		return;
	}
	if (Wo_PageHasCoordinates() || $.trim($('#page_place_id_value').val()) !== '') {
		callback();
		return;
	}
	Wo_GeocodePageLocation(locationValue).then(function() {
		callback();
	});
}
function Wo_SyncPagePreviewLocation() {
	var address = $.trim($('#address_value').val() || Wo_ReadPageLocationValue());
	var placeId = $.trim($('#page_place_id_value').val());
	if (Wo_PageHasCoordinates()) {
		Wo_UpdatePageMapPreview();
		return;
	}
	if (placeId) {
		Wo_GeocodePagePlaceId(placeId).then(function(resolved) {
			if (!resolved) {
				Wo_HidePageMapPreview();
			}
		});
		return;
	}
	if (address) {
		Wo_GeocodePageLocation(address).then(function(resolved) {
			if (!resolved) {
				Wo_HidePageMapPreview();
			}
		});
		return;
	}
	Wo_HidePageMapPreview();
}
   $(function() {
     Wo_InitGooglePageAutocomplete();
     $(document).on('mousedown ontouchstart', '.page_setting_location_suggestions .page_location_suggestion_item', function(e) {
     	e.preventDefault();
     	var selectedLocation = $(this).attr('data-name') || '';
     	var placeId = $(this).attr('data-place-id') || '';
     	Wo_WritePageLocationValue(selectedLocation);
     	$('#address_value').val(selectedLocation);
     	Wo_RenderPageLocationSuggestions([]);
     	$('.wo_page_location_inline_input').val(selectedLocation);
     	if (placeId) {
     		Wo_SetPageCoordinates('', '');
     		Wo_SetPagePlaceId(placeId);
     		Wo_GeocodePagePlaceId(placeId);
     	}
     });
     Wo_SyncPagePreviewLocation();
     $('form.setting-information-form').ajaxForm({
       url: Wo_Ajax_Requests_File() + '?f=pages&s=update_information_setting',
       beforeSend: function() {
          $('.setting-information-form').find('.add_wow_loader').addClass('btn-loading');
       },
       beforeSubmit: function(arr, form, options) {
         if ($(form).data('page-info-geocode-ready') === true) {
         	$(form).removeData('page-info-geocode-ready');
         	return true;
         }
         $('#address_value').val(Wo_ReadPageLocationValue());
         Wo_ResolvePageCoordinates(function() {
         	$(form).data('page-info-geocode-ready', true);
         	$(form).ajaxSubmit(options);
         });
         return false;
       },
        success: function(data) {
         if (data.status == 200) {
           scrollToTop();
           $('.setting-information-alert').html('<div class="alert alert-success">' + data.message + '</div>');
           $('.alert-success').fadeIn('fast', function() {
             $(this).delay(2500).slideUp(500, function() {
               $(this).remove();
             });
           });
         } else {
           var errors = data.errors.join("<br>");
           scrollToTop();
           $('.setting-profile-alert').html('<div class="alert alert-danger">' + errors + '</div>');
           $('.alert-danger').fadeIn(300);
         }
         $('.setting-information-form').find('.add_wow_loader').removeClass('btn-loading');
       }
     });
   });
</script>
