  <script>
    (function($) {
      const ajaxUrl = (typeof Wo_Ajax_Requests_File === 'function') ? Wo_Ajax_Requests_File() : '/requests.php';
      const csrf = (window.wo && wo.user && wo.user.session_hash) ? wo.user.session_hash : null;

      // Lưu target hiện hành
      const TARGET = {
        type: 'user',
        id: 0
      };

      // ==== helpers ====
      function hexOK(v) {
        return /^#[0-9A-Fa-f]{6}$/.test(v || '');
      }

      function esc(s) {
        return $('<div>').text(s || '').html();
      }

      // API
      function apiListLabels() {
        return $.post(`${ajaxUrl}?f=tags&s=list_labels`, {
          hash_id: csrf
        }, null, 'json');
      }

      function apiListTargetTags() {
        if (!TARGET.id) return $.Deferred().resolve({
          status: 200,
          tags: []
        }).promise();
        return $.post(`${ajaxUrl}?f=tags&s=list_target_tags`, {
          target_type: TARGET.type,
          target_id: TARGET.id,
          hash_id: csrf
        }, null, 'json');
        // console.log(target_type, target_id);
      }

      function apiAttach(label_id) {
        return $.post(`${ajaxUrl}?f=tags&s=attach_label`, {
          label_id,
          target_type: TARGET.type,
          target_id: TARGET.id,
          hash_id: csrf
        }, null, 'json');
      }

      function apiDetach(label_id) {
        return $.post(`${ajaxUrl}?f=tags&s=detach`, {
          label_id,
          target_type: TARGET.type,
          target_id: TARGET.id,
          hash_id: csrf
        }, null, 'json');
      }

      function apiCreate(name, color) {
        return $.post(`${ajaxUrl}?f=tags&s=create_label`, {
          label_name: name,
          label_color: color,
          hash_id: csrf
        }, null, 'json');
      }

      function apiDelete(label_id) {
        return $.post(`${ajaxUrl}?f=tags&s=delete_label`, {
          label_id,
          hash_id: csrf
        }, null, 'json');
      }

      // ==== render assign tab ====
      function loadAssign() {
        return $.when(apiListLabels(), apiListTargetTags()).done(function(labRes, curRes) {
          const labels = (labRes && labRes[0] && labRes[0].labels) || [];
          const current = (curRes && curRes[0] && curRes[0].tags) || [];

          const currSet = {};
          current.forEach(t => {
            const tid = (t && (t.id || t.tag_id || t.label_id)) | 0;
            if (tid) currSet[tid] = 1;
          });

          const $list = $('#assign-list').empty();
          if (!labels.length) {
            $list.html('<div class="list-group-item text-muted">(Chưa có thẻ)</div>');
            return;
          }

          labels.forEach(function(l) {
            const labelId = (l.id != null ? l.id : l.label_id) | 0; // <-- dùng labelId nhất quán
            const attached = !!currSet[labelId];

            $list.append(
              `<div class="list-group-item d-flex align-items-center ${attached?'is-attached':''}" data-id="${labelId}">
           <span style="width:12px;height:12px;border-radius:50%;background:${l.color||'#999'};display:inline-block;margin-right:10px;"></span>
           <span class="flex-fill">${esc(l.name)}</span>
           <button class="btn btn-sm btn-link chat-assign-toggle">${attached?'Gỡ':'Gắn'}</button>
         </div>`
            );
          });
        });
      }


      // ==== render manage tab ====
      function loadManage() {
        return apiListLabels().done(function(res) {
          const labels = (res && res.labels) || [];
          const $list = $('#manage-list').empty();
          if (!labels.length) {
            $list.html('<div class="list-group-item text-muted">(Chưa có thẻ)</div>');
            return;
          }
          labels.forEach(function(l) {
            $list.append(
              `<div class="list-group-item d-flex align-items-center" data-id="${l.id}">
             <span style="width:12px;height:12px;border-radius:50%;background:${l.color||'#999'};display:inline-block;margin-right:10px;"></span>
             <span class="flex-fill">${esc(l.name)}</span>
             <button class="btn btn-sm btn-link text-danger chat-tag-del">Xoá</button>
           </div>`
            );
          });
        });
      }

      // ==== mở modal từ nút gán ====
      $(document).on('click', '.btn-open-tag-modal', function(e) {
        e.preventDefault();
        e.stopPropagation();
        TARGET.type = String($(this).data('target-type') || 'user');
        TARGET.id = parseInt($(this).data('target-id'), 10) || 0;

        // mở modal & mặc định tab "Gán thẻ"
        $('#chat-tag-tabs a[href="#tab-assign"]').tab('show');
        if ($.fn.modal) $('#chatTagModal').modal('show');
        else $('#chatTagModal').show();
      });

      // mỗi lần modal mở → nạp tab đang active
      $('#chatTagModal').on('shown.bs.modal', function() {
        const active = $('#chat-tag-tabs li.active a').attr('href');
        if (active === '#tab-assign') loadAssign();
        else loadManage();
      });

      // khi chuyển tab
      $('#chat-tag-tabs a[data-toggle="tab"]').on('shown.bs.tab', function(e) {
        const target = $(e.target).attr('href');
        if (target === '#tab-assign') loadAssign();
        else loadManage();
      });

      // click Gắn/Gỡ trong tab assign
      $(document).on('click', '#assign-list .chat-assign-toggle', function(e) {
        e.preventDefault();
        if (!TARGET.id) return alert('Chưa chọn đối tượng.');

        const $row = $(this).closest('[data-id]');
        const label_id = parseInt($row.data('id'), 10) || 0;
        const attached = $row.hasClass('is-attached');

        (attached ? apiDetach(label_id) : apiAttach(label_id)).done(function(res) {
          if (res && res.status === 200) {
            // LUÔN refresh toàn bộ danh sách để đồng bộ với DB
            loadAssign();
          } else {
            alert((res && res.error) || 'Thao tác thất bại.');
          }
        });
      });

      // tạo thẻ mới (tab manage)
      function bindColorSync() {
        $('#chat-tag-new-color').on('input', function() {
          const v = this.value;
          $('#chat-tag-new-color-hex').val(v);
          $('#chat-tag-color-swatch').css('background', v);
        });
        $('#chat-tag-new-color-hex').on('input', function() {
          const v = this.value;
          if (hexOK(v)) {
            $('#chat-tag-new-color').val(v);
            $('#chat-tag-color-swatch').css('background', v);
          }
        });
      }
      bindColorSync();

      $('#chat-btn-create-tag').on('click', function() {
        const name = ($('#chat-tag-new-name').val() || '').trim();
        let color = ($('#chat-tag-new-color-hex').val() || '').trim();
        if (!name) return alert('Nhập tên thẻ.');
        if (!hexOK(color)) color = '#3b82f6';

        apiCreate(name, color).done(function(res) {
          if (res && res.status === 200) {
            $('#chat-tag-new-name').val('');
            loadManage(); // refresh tab quản lý
            loadAssign(); // và refresh tab gán để có thẻ mới
          } else {
            alert((res && res.error) || 'Không tạo được thẻ.');
          }
        });
      });

      // xoá thẻ (tab manage)
      $(document).on('click', '#manage-list .chat-tag-del', function(e) {
        e.preventDefault();
        const id = parseInt($(this).closest('[data-id]').data('id'), 10) || 0;
        if (!id) return;
        if (!confirm('Xoá thẻ này? Mọi gán của bạn với thẻ này sẽ bị gỡ.')) return;

        apiDelete(id).done(function(res) {
          if (res && res.status === 200) {
            loadManage();
            loadAssign(); // cập nhật cả tab assign
          } else {
            alert((res && res.error) || 'Không xoá được.');
          }
        });
      });

      function getSelectUserId() {
        return $('.multi-ck:checked').map(function() {
          return {
            id: $(this).val(),
            name: $(this).data('name') || $(this).attr('data-name') || ''
          };
        }).get();
      }

      function updateUI() {
        const select = getSelectUserId();
        $('#chips-inline').text(select.map(u => u.name).join(', '));

        const $all = $('#multi-select-all');
        const total = $('.multi-ck').length;
        const checked = $('.multi-ck:checked').length;

        if (checked === 0) {
          $all.prop('indeterminate', false).prop('checked', false);
        } else if (checked === total) {
          $all.prop('indeterminate', false).prop('checked', true);
        } else {
          $all.prop('indeterminate', true).prop('checked', false);
        }
      }
      $(document).on('change', '.multi-ck', updateUI);

      $('#multi-select-all').on('change', function() {
        const isChecked = $(this).is(':checked');
        $('.multi-ck').prop('checked', isChecked);
        $(this).prop('indeterminate', false);
        updateUI();
      });

      $(document).ready(function() {
        updateUI(); // sync UI ban đầu
      });
      function renderSidebarMultiUserItem(u) {
        const id = parseInt(u.user_id || u.target_user_id, 10);
        const name = u.user_name || u.name || '';
        const avatar = u.avatar || u.user_avatar || '';
        const isOnline = !!u.lastseen && (Date.now() / 1000 - parseInt(u.lastseen, 10) < 60);
        const dot = isOnline ? '#60d465' : '#CDCDCD';

        return `
          <li class="multi-user-item" data-uid="${id}" data-name="${name}" data-avatar="${avatar}">
            <div class="recipient-chat-user-mul">
              <div class="user-information">
                <img src="${avatar}" width="36" height="36" alt="" style="border-radius:50%; object-fit:cover;">
                <span class="chat-user-text-mul" style="margin-left:10px;">${name}</span>
                <div class="user-status-dot" style="padding-left:70px!important;" title="${isOnline ? 'Online' : 'Offline'}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill="${dot}" d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"/>
                  </svg>
                </div>
              </div>
              <div class="wow_chat_list-right">
                <label style="margin:0 8px;">
                  <input type="checkbox" class="multi-ck" value="${id}" data-name="${name}"> Chọn
                </label>
                <button class="btn btn-default btn-xs" onclick="Wo_OpenChatTab(${id});return false;">
                  Mở chat
                </button>
              </div>
            </div>
          </li>`;
      }

      var sidebarChatOriginalHTML = '';
      $(document).ready(function() {
        sidebarChatOriginalHTML = $('#multi-all').html();
        updateUI();
      });

      $('#tag_user_id').on('change', function() {
        const tagId = $(this).val();
        const tagText = $('#tag_user_id option:selected').text() || '';
        const main_hash_id = $('.main_session').val() || (window.wo?.user?.session_hash || '');
        
        if (!tagId || tagId === "") {
          $('#multi-all').html(sidebarChatOriginalHTML);
          $('#multi-status').text('');
          updateUI();
          return;
        }

        var endpoint = tagId === '0' ? 'all_tags' : 'selected_tags';
        var postData = tagId === '0' ? { hash_id: main_hash_id } : { tag_id: tagId, hash_id: main_hash_id };

        console.log('Sidebar Tag Filter:', endpoint, tagId);

        $.ajax({
          url: (typeof Wo_Ajax_Requests_File === 'function' ? Wo_Ajax_Requests_File() : '/requests.php') + '?f=tags&s=' + endpoint + '&hash=' + main_hash_id,
          method: 'POST',
          dataType: 'json',
          data: postData,
          success: function(resp) {
            const users = Array.isArray(resp && resp.data) ? resp.data : [];
            if (users.length > 0) {
              let html = '';
              users.forEach(function(u) {
                html += renderSidebarMultiUserItem(u);
              });
              $('#multi-all').html(html);
              
              // Auto-check all (matching Messenger structure)
              setTimeout(function() {
                $('#multi-all .multi-ck').prop('checked', true);
                updateUI();
              }, 50);

              const label = (tagId === '0') ? 'Tất cả người đã gắn thẻ' : 'Đang lọc theo thẻ "' + tagText + '"';
              $('#multi-status').text(label + ' — ' + users.length + ' user');
            } else {
              $('#multi-all').html('');
              $('#multi-status').text('Không có user nào thuộc thẻ "' + tagText + '"');
              updateUI();
            }
          }
        });
      });

      function refreshTagFilterSelect({
        preserve = true,
        selectId = null
      } = {}) {
        const $sel = $('#tag_user_id');
        const prev = preserve ? $sel.val() : null;

        return apiListLabels().done(function(res) {
          const labels = Array.isArray(res && res.labels) ? res.labels : [];

          const html = [];
          // Giữ nguyên hành vi: value="0" = "Tất cả người đã gắn thẻ"
          html.push('<option value="" disabled selected>Chọn thẻ…</option>');
          html.push('<option value="0">Tất cả người đã gắn thẻ</option>');
          labels.forEach(function(l) {
            const id = (l.id != null ? l.id : l.label_id) | 0;
            const name = esc(l.name);
            html.push(`<option value="${id}">${name}</option>`);
          });

          $sel.html(html.join(''));

          // Ưu tiên chọn thẻ vừa tạo nếu có selectId
          if (selectId != null && $sel.find(`option[value="${selectId}"]`).length) {
            $sel.val(String(selectId));
          } else if (preserve && prev != null && $sel.find(`option[value="${prev}"]`).length) {
            $sel.val(prev);
          } else {
            // Không giữ được state → để placeholder
            $sel.val('');
          }

          // Nếu đang dùng Select2:
          if ($sel.hasClass('select2-hidden-accessible')) {
            $sel.trigger('change.select2');
          }
        }).fail(function() {
          $sel.html('<option value="">(Không tải được thẻ)</option>');
        });
      }

      // Gọi 1 lần khi trang sẵn sàng
      $(document).ready(function() {
        refreshTagFilterSelect({
          preserve: false
        });
      });

      // Cho phép nơi khác trong app “bắn” sự kiện để refresh dropdown
      $(document).on('tags:labelsChanged', function(e, opts) {
        refreshTagFilterSelect(opts || {
          preserve: true
        });
      });
      $('#multi-send-btn').on('click', function(e) {
        e.preventDefault();

        const selected = getSelectUserId();
        const ids = selected.map(u => parseInt(u.id, 10)).filter(Boolean);
        const text = ($('#multi-text').val() || '').trim();
        const file = $('#multi-file')[0]?.files?.[0] || null;

        const $btn = $(this);
        const $status = $('#multi-status');

        if (!ids.length) {
          $status.text('Chưa chọn người nhận.');
          return;
        }
        if (!text && !file) {
          $status.text('Nhập nội dung hoặc chọn file.');
          return;
        }

        const fd = new FormData();
        const main_hash_id = $('.main_session').val() || (window.wo?.user?.session_hash || '');
        fd.append('textSendMessage', text);
        ids.forEach(id => fd.append('recipients[]', id));
        if (file) fd.append('sendMessageFile', file, file.name);

        $btn.prop('disabled', true).text('Sending…');
        $status.text('Đang gửi…');

        $.ajax({
            url: (typeof Wo_Ajax_Requests_File === 'function' ? Wo_Ajax_Requests_File() : '/requests.php') +
              '?f=messages&s=multi_send&hash=' + encodeURIComponent(main_hash_id),
            method: 'POST',
            data: fd,
            processData: false,
            contentType: false,
            dataType: 'json'
          })
          .done(function(res) {
            if (!res || typeof res.status === 'undefined') {
              $status.text('Có lỗi không xác định.');
              return;
            }

            if (res.status === 200) {
              $status.text(`Đã gửi thành công cho ${res.sent_ids?.length || 0} người.`);
              // Chỉ xóa input SAU KHI thành công:
              $('#multi-text').val('');
              $('#multi-file').val('');
              if (res.sent_ids?.length && typeof Wo_OpenChatTab === 'function') {
                Wo_OpenChatTab(res.sent_ids[0]);
              }
            } else if (res.status === 207) {
              const ok = res.sent_ids?.length || 0;
              const bad = res.failed?.length || 0;
              $status.text(`Đã gửi cho ${ok} người, lỗi ${bad} người.`);
            } else if (res.status === 422) {
              $status.text(res.error || 'Thiếu dữ liệu.');
            } else if (res.status === 500) {
              $status.text('Gửi thất bại. Vui lòng thử lại.');
            } else {
              $status.text('Không rõ trạng thái.');
            }

            if (res.invalid_file === 1) $status.text('File vượt quá giới hạn dung lượng.');
            if (res.invalid_file === 2) $status.text('Định dạng file không được hỗ trợ.');
            if (res.invalid_file === 3) $status.text('Chỉ tài khoản Pro mới được gửi file/ghi âm.');
          })
          .fail(function(xhr) {
            console.error('multi_send error', xhr.status, xhr.responseText);
            $status.text('Lỗi kết nối máy chủ.');
          })
          .always(function() {
            $btn.prop('disabled', false).text('Gửi tin nhắn');
          });
      });




