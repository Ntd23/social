            if (!empty($RecentChatUsers)) {
              foreach ($RecentChatUsers as $chat_user) {
                if (empty($chat_user['user_id'])) {
                  continue;
                }
                if (Wo_IsOnline($chat_user['user_id']) === true) {
                  $OnlineUsers[] = $chat_user;
                } else {
                  $Offlineusers[] = $chat_user;
                }
              }
            }
                  // Chuẩn hoá & gắn cờ
                  $all = [];
                  foreach ($OnlineUsers as $u) {
                    $display_name = !empty($u['first_name']) ? $u['first_name'] : $u['name'];
                    $all[] = [
                      'id'       => (int)$u['user_id'],
                      'name'     => htmlspecialchars($display_name, ENT_QUOTES, 'UTF-8'),
                      'avatar'   => $u['avatar'],
                      'lastseen' => isset($u['lastseen']) ? (int)$u['lastseen'] : 0,
                      'is_online' => true
                    ];
                  }
                  foreach ($Offlineusers as $u) {
                    $display_name = !empty($u['first_name']) ? $u['first_name'] : $u['name'];
                    $all[] = [
                      'id'       => (int)$u['user_id'],
                      'name'     => htmlspecialchars($display_name, ENT_QUOTES, 'UTF-8'),
                      'avatar'   => $u['avatar'],
                      'lastseen' => isset($u['lastseen']) ? (int)$u['lastseen'] : 0,
                      'is_online' => false
                    ];
                  }

                  // (Tuỳ chọn) loại bỏ trùng id nếu hàm trả trùng
                  $seen = [];
                  $all  = array_values(array_filter($all, function ($x) use (&$seen) {
                    if (isset($seen[$x['id']])) return false;
                    $seen[$x['id']] = 1;
                    return true;
                  }));

                  // Sắp xếp: Online trước, cùng trạng thái thì lastseen mới nhất trước
                  usort($all, function ($a, $b) {
                    if ($a['is_online'] != $b['is_online']) return $a['is_online'] ? -1 : 1;
                    return $b['lastseen'] <=> $a['lastseen'];
                  });
                  $allTags  = Wo_GetAllAssignedTagsByOwner();

