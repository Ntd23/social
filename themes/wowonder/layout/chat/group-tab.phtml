          $(".group-messages-wrapper-<?php echo $wo['chat']['group']['group_id'];?>").empty();
        }
      })
      .fail(function() {
        console.log("error");
    });
    });

    console.log("Group chat "+'<?php echo $wo['chat']['group']['group_id'];?>')
   <?php if ($wo['config']['node_socket_flow'] == "1") { ?>
    var chat_messages_wrapper = $('.group-messages-wrapper-<?php echo $wo['chat']['group']['group_id'];?>');
      $('.group-chat-sending-<?php echo $wo['chat']['group']['group_id'];?>').unbind('submit').submit(function(e) { 
        e.preventDefault();
        var form = $(this);
        var text_message = escapeHTML(form.find('textarea').val().trim());
        if (form.hasClass('sending') && form.find('input[type=file]').val() != '') {
            return false;
        }
        if (!text_message && form.find('input[type=file]').val() == '') {
            form.find('textarea').val('');
            return false;
        }

        form.addClass('sending');
        form.find('textarea').val(''); // Clear immediately

        socket.emit("group_message", {
          group_id: '<?php echo $wo['chat']['group']['group_id'];?>', 
          from_id: _getCookie("user_id"),
          username: '<?php echo $wo['user']['username']; ?>',
          msg: text_message,
          isSticker: false
        },  (data)=>{
          form.removeClass('sending');

          if (data.status == 200) {
            var msgHtml = $($.parseHTML(String(data.html).trim()));
            var msgId = msgHtml.filter('.messages-wrapper').attr('id') || msgHtml.find('.messages-wrapper').attr('id') || msgHtml.attr('id');
            var is_exist = (msgId && $('#' + msgId).length > 0) || (data.message_id && $('#messageId_' + data.message_id).length > 0);
            if (!is_exist) {
                if ($('#no_messages_<?php echo $wo['chat']['group']['group_id'];?>').length > 0) {
                  $(".group-messages-wrapper-<?php echo $wo['chat']['group']['group_id'];?>").find('.chat-messages').html(data.html);
                }
                else{
                  $(".group-messages-wrapper-<?php echo $wo['chat']['group']['group_id'];?>").find('.chat-messages').append(data.html);
                }
            }
            if (data.invalid_file == 1) {
                $("#invalid_file").modal('show');
                Wo_Delay(function(){
                  $("#invalid_file").modal('hide');
                },3000);
            }
            if (data.invalid_file == 2) {
                $("#file_not_supported").modal('show');
                Wo_Delay(function(){
                  $("#file_not_supported").modal('hide');
                },3000);
            }
            if (data.file == true) {
              form.find('.ball-pulse').fadeOut(100);
            }
          }
          else if(data.status == 500 && data.invalid_file == 1){
            $("#invalid_file").modal('show');
                Wo_Delay(function(){
                  $("#invalid_file").modal('hide');
            },3000);
            $('form.group-chat-sending-<?php echo $wo['chat']['group']['group_id'];?>').find('.ball-pulse').fadeOut(100);
          }
          else if(data.status == 500 && data.invalid_file == 2){
            $("#file_not_supported").modal('show');
                Wo_Delay(function(){
                  $("#file_not_supported").modal('hide');
            },3000);
            $('form.group-chat-sending-<?php echo $wo['chat']['group']['group_id'];?>').find('.ball-pulse').fadeOut(100);
          }
          else if(data.status == 500 && data.invalid_file == 3){
            $("#pro_upload_file").modal('show');
            Wo_Delay(function(){
              $("#pro_upload_file").modal('hide');
            },3000);
            $('form.chat-sending-form-<?php echo $wo['chat']['group']['group_id'];?>').find('.ball-pulse').fadeOut(100);
          }
          $(".chat_group_<?php echo $wo['chat']['group']['group_id'];?>").find('#sendMessasgeFile').val('');
          setTimeout(function() {
                chat_messages_wrapper.scrollTop(chat_messages_wrapper[0].scrollHeight);
          }, 100);
        });
        return false
      });
    <?php } ?>

    <?php if ($wo['config']['node_socket_flow'] == "0"){?>
      var chat_messages_wrapper = $('.group-messages-wrapper-<?php echo $wo['chat']['group']['group_id'];?>');
      chat_messages_wrapper.scrollTop(chat_messages_wrapper[0].scrollHeight);
      $('.group-chat-sending-<?php echo $wo['chat']['group']['group_id'];?>').ajaxForm({
          url: Wo_Ajax_Requests_File() + '?f=chat&s=send_message&group_id=<?php echo $wo['chat']['group']['group_id'];?>&hash=' + main_hash_id,
          type:"POST",
          beforeSubmit: function(arr, $form, options) {
              if ($form.hasClass('sending') && $form.find('input[type=file]').val() != '') {
                  return false;
              }
              $form.addClass('sending');
              $form.find('textarea').val(''); // Clear immediately
          },
          uploadProgress: function() {
              $('form.group-chat-sending-<?php echo $wo['chat']['group']['group_id'];?>').find('.ball-pulse').fadeIn(100);
          },
          success: function(data) {
              var form = $('.group-chat-sending-<?php echo $wo['chat']['group']['group_id'];?>');
              form.removeClass('sending');

              if (data.status == 200) {
                var msgHtml = $($.parseHTML(String(data.html).trim()));
                var msgId = msgHtml.filter('.messages-wrapper').attr('id') || msgHtml.find('.messages-wrapper').attr('id') || msgHtml.attr('id');
                var is_exist = (msgId && $('#' + msgId).length > 0) || (data.message_id && $('#messageId_' + data.message_id).length > 0);
                if (!is_exist) {
                    if ($('#no_messages_<?php echo $wo['chat']['group']['group_id'];?>').length > 0) {
                      $(".group-messages-wrapper-<?php echo $wo['chat']['group']['group_id'];?>").find('.chat-messages').html(data.html);
                    }
                    else{
                      $(".group-messages-wrapper-<?php echo $wo['chat']['group']['group_id'];?>").find('.chat-messages').append(data.html);
                    }
                }
                if (data.invalid_file == 1) {
                    $("#invalid_file").modal('show');
                    Wo_Delay(function(){
                      $("#invalid_file").modal('hide');
                    },3000);
                }
                if (data.invalid_file == 2) {
                    $("#file_not_supported").modal('show');
                    Wo_Delay(function(){
                      $("#file_not_supported").modal('hide');
                    },3000);
                }
                if (data.file == true) {
                  form.find('.ball-pulse').fadeOut(100);
                }
              }
              else if(data.status == 500 && data.invalid_file == 1){
                $("#invalid_file").modal('show');
                    Wo_Delay(function(){
                      $("#invalid_file").modal('hide');
                },3000);
                form.find('.ball-pulse').fadeOut(100);
              }
              else if(data.status == 500 && data.invalid_file == 2){
                $("#file_not_supported").modal('show');
                    Wo_Delay(function(){
                      $("#file_not_supported").modal('hide');
                },3000);
                form.find('.ball-pulse').fadeOut(100);
              }
              else if(data.status == 500 && data.invalid_file == 3){
                $("#pro_upload_file").modal('show');
                Wo_Delay(function(){
                  $("#pro_upload_file").modal('hide');
                },3000);
                form.find('.ball-pulse').fadeOut(100);
              }
              form.find('input[type=file]').val('');
              setTimeout(function() {
                    chat_messages_wrapper.scrollTop(chat_messages_wrapper[0].scrollHeight);
              }, 100);
          }
      });

      setInterval(function(){
        var last_group_message = ($("[data-group-tmessage-id]").length > 0) ? $("[data-group-tmessage-id]").last().attr('data-group-tmessage-id') : 0;
        $.ajax({
          url: Wo_Ajax_Requests_File(),
          type: 'GET',
          dataType: 'json',
          data: {f: 'chat',s:'get_new_group_messages',message_id:last_group_message,group_id:'<?php echo $wo['chat']['group']['group_id'];?>'},
        })
        .done(function(data) {
          if (data.status == 200) {
            var newElements = $($.parseHTML(String(data.html).trim()));
            var container = $(".group-messages-wrapper-<?php echo $wo['chat']['group']['group_id'];?>").find('.chat-messages');

            if (container.find('.no_message').length > 0) {
                container.empty();
            }

            var appended = false;
            newElements.each(function() {
                var el = $(this);
                if (el[0].nodeType === 3) return; // ignore text nodes

                var msgId = el.filter('.messages-wrapper').attr('id') || el.find('.messages-wrapper').attr('id') || el.attr('id');
                if (msgId && $('#' + msgId).length > 0) {
                    // Already in DOM (via socket), skip it
                } else {
                    container.append(el);
                    appended = true;
                }
            });

            if (appended) {
                chat_messages_wrapper.scrollTop(chat_messages_wrapper[0].scrollHeight);
            }
          }
        })
        .fail(function() {
          console.log("error");
        })
      },5000);
      <?php } ?>

  });

  function Wo_SubmitChatGroupForm(e, id) {
    if (!id) { return false; }
    var form = $('.group-chat-sending-' + id);
    
    if (e.type == 'change' || (e.keyCode == 13 && e.shiftKey == 0)) {
       e.preventDefault();
       if (form.hasClass('sending') && $("#sendMessasgeFile-" + id).val() != '') {
           return false;
       }
       if ($("#sendMessasgeFile-" + id).val() != '') {
          var chat_messages_wrapper = $('.group-messages-wrapper-' + id);
          chat_messages_wrapper.scrollTop(chat_messages_wrapper[0].scrollHeight);
          var main_hash_id = $('.main_session').val();

          form.addClass('sending');

          form.ajaxSubmit({
              url: Wo_Ajax_Requests_File() + '?f=chat&s=send_message&group_id=' + id + '&hash=' + main_hash_id,
              type:"POST",
              uploadProgress: function() {
                form.find('.ball-pulse').fadeIn(100);
              },
              success: function(data) {
                  form.removeClass('sending');
                  
                  if (data.status == 200) {
                    var msgHtml = $($.parseHTML(String(data.html).trim()));
                    var htmlMsgId = msgHtml.filter('.messages-wrapper').attr('id') || msgHtml.find('.messages-wrapper').attr('id') || msgHtml.attr('id');
                    var is_exist = (htmlMsgId && $('#' + htmlMsgId).length > 0) || (data.message_id && $('#messageId_' + data.message_id).length > 0);
                    if (!is_exist) {
                      if ($('.group-messages-wrapper-'+id).find('.no_message').length > 0) {
                        $('.group-messages-wrapper-'+id).find('.chat-messages').html(data.html);
                      }
                      else {
                        $('.group-messages-wrapper-'+id).find('.chat-messages').append(data.html);
                      }
                    }
                    var dom = $($.parseHTML(data.html));
                    var mediaId = dom.attr("data-group-tmessage-id");
                    
                    if (data.invalid_file == 1) {
                        $("#invalid_file").modal('show');
                        Wo_Delay(function(){ $("#invalid_file").modal('hide'); },3000);
                    }
                    else if (data.invalid_file == 2) {
                        $("#file_not_supported").modal('show');
                        Wo_Delay(function(){ $("#file_not_supported").modal('hide'); },3000);
                    }
                    else {
                      socket.emit("group_message", {
                        group_id: id, 
                        from_id: _getCookie("user_id"),
                        username: '<?php echo $wo['user']['username']; ?>',
                        mediaId: mediaId,
                        isSticker: false
                      })
                    }

                    if (data.file == true) {
                      form.find('.ball-pulse').fadeOut(100);
                    }
                  } 
                  form.find('input[type=file]').val('');
                  setTimeout(function() {
                        $('.group-messages-wrapper-'+id).scrollTop($('.group-messages-wrapper-'+id)[0].scrollHeight);
                  }, 100);
            }
          });
       }
       else {
          <?php if ($wo['config']['node_socket_flow'] == "1"){ ?>
            if(!groupChatListener[id]){
              groupChatListener[id] = 1;
            }
            var chat_messages_wrapper = $('.group-messages-wrapper-' + id);
            chat_messages_wrapper.scrollTop(chat_messages_wrapper[0].scrollHeight);
            form.submit();
          <?php } else { ?>
            form.submit();
          <?php } ?>
       }
    }
  }

 function Wo_ClearGroupHistory(id = false){
    if (!id) { return false;}
    $.ajax({
      url: Wo_Ajax_Requests_File(),
      type: 'GET',
      dataType: 'json',
      data: {f: 'chat',s:'clear_group_chat',group_id:'<?php echo $wo['chat']['group']['group_id'];?>'},
    })
    .done(function(data) {
      if (data.status == 200) {
        $(".group-messages-wrapper-<?php echo $wo['chat']['group']['group_id'];?>")
        .find('.chat-messages')
        .html(
          '\
            <p class="no_message" id="no_messages_<?php echo $wo['chat']['group']['group_id'];?>">\
            <?php echo $wo['lang']['conversation_deleted']; ?>\
            </p>'
          );
      }
    })
    .fail(function() {
      console.log("error");
    })
  }
