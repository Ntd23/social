<script type="text/javascript">
<?php
$js_array = json_encode($wo['page_sub_categories']);
echo "var sub_categories_array = " . $js_array . ";\n";
?>
function GetPageSubCategory(self) {
	id = $(self).val();
	var text = "";
	if (typeof(sub_categories_array[id]) == 'undefined') {
		$('#page_sub_category').html('');
	}
	else {
		sub_categories_array[id].forEach(function(entry) {
			text = text + "<option value='" + entry.id + "'>" + entry.lang + "</option>";
		});
		$('#page_sub_category').html(text);
	}
}

var woPageDesktopAutocomplete = null;
var woPagePlacesLibraryPromise = null;
var woPageLocationSuggestionTimer = null;
var woPageLocationSuggestionRequest = 0;
var woPageGooglePredictionCache = {};
var woPageGoogleSessionToken = null;
var woPageLocationLocale = <?php echo json_encode(strtolower($wo['language'])); ?>;

function Wo_GetPageLocationVisibleInput() {
	return document.getElementById('page_location_visible_input');
}

function Wo_GetPageLocationSearchField() {
	return document.getElementById('page_location_input');
}

function Wo_ReadPageLocationValue() {
	var visibleInput = Wo_GetPageLocationVisibleInput();
	var hiddenInput = Wo_GetPageLocationSearchField();

	if (visibleInput && $.trim(visibleInput.value || '') !== '') {
		return $.trim(visibleInput.value || '');
	}

	return $.trim(hiddenInput ? hiddenInput.value || '' : '');
}

function Wo_WritePageLocationValue(value) {
	var normalizedValue = value || '';
	var visibleInput = Wo_GetPageLocationVisibleInput();
	var hiddenInput = Wo_GetPageLocationSearchField();

	if (visibleInput) {
		visibleInput.value = normalizedValue;
	}
	if (hiddenInput) {
		hiddenInput.value = normalizedValue;
	}

	$('#address_value').val(normalizedValue);
}

function Wo_SetPageCoordinates(lat, lng) {
	$('#page_lat_value').val((lat !== undefined && lat !== null) ? lat : '');
	$('#page_lng_value').val((lng !== undefined && lng !== null) ? lng : '');
}

function Wo_SetPagePlaceId(placeId) {
	$('#page_place_id_value').val(placeId || '');
}

function Wo_ClearPageLocationMeta() {
	Wo_SetPageCoordinates('', '');
	Wo_SetPagePlaceId('');
}

function Wo_PageHasCoordinates() {
	return $.trim($('#page_lat_value').val()) !== '' && $.trim($('#page_lng_value').val()) !== '';
}

function Wo_PageLocationShouldUseInlineSuggestions() {
	return (window.matchMedia && window.matchMedia('(max-width: 768px)').matches) ||
		/Android|webOS|iPhone|iPad|iPod|Opera Mini|IEMobile|Mobile/i.test(navigator.userAgent || '');
}

function Wo_PageGoogleAutocompleteAvailable() {
	return typeof google !== 'undefined' && google.maps && typeof google.maps.importLibrary === 'function';
}

function Wo_EnsurePagePlacesLibrary() {
	if (!Wo_PageGoogleAutocompleteAvailable()) {
		return Promise.resolve(false);
	}

	if (woPagePlacesLibraryPromise) {
		return woPagePlacesLibraryPromise;
	}

	woPagePlacesLibraryPromise = google.maps.importLibrary('places').then(function() {
		return true;
	}).catch(function() {
		return false;
	});

	return woPagePlacesLibraryPromise;
}

function Wo_GetPageLocationLanguage() {
	return (woPageLocationLocale || document.documentElement.lang || navigator.language || navigator.userLanguage || 'en').toLowerCase();
}

function Wo_GetPageLocationGoogleLanguage() {
	var language = Wo_GetPageLocationLanguage();
	if (!language) {
		return 'en';
	}

	return language.split(/[_-]/)[0] || 'en';
}

function Wo_GetPageLocationSearchUrl(locationValue, limit) {
	var params = new URLSearchParams({
		format: 'jsonv2',
		addressdetails: '1',
		limit: String(limit || 5),
		'accept-language': Wo_GetPageLocationLanguage(),
		q: locationValue
	});

	return 'https://nominatim.openstreetmap.org/search?' + params.toString();
}

function Wo_EscapePageLocationHtml(text) {
	return String(text || '')
		.replace(/&/g, '&amp;')
		.replace(/</g, '&lt;')
		.replace(/>/g, '&gt;')
		.replace(/"/g, '&quot;')
		.replace(/'/g, '&#039;');
}

function Wo_GetGooglePagePredictionLabel(prediction) {
	if (!prediction) {
		return '';
	}
	if (prediction.text && typeof prediction.text.toString === 'function') {
		return prediction.text.toString();
	}

	var mainText = '';
	var secondaryText = '';
	if (prediction.mainText && typeof prediction.mainText.toString === 'function') {
		mainText = prediction.mainText.toString();
	}
	if (prediction.secondaryText && typeof prediction.secondaryText.toString === 'function') {
		secondaryText = prediction.secondaryText.toString();
	}

	if (mainText && secondaryText) {
		return mainText + ', ' + secondaryText;
	}

	return mainText || secondaryText || prediction.description || '';
}

function Wo_ReadGoogleCoordinateValue(locationObject, axis) {
	if (!locationObject) {
		return '';
	}
	if (typeof locationObject[axis] === 'function') {
		return locationObject[axis]();
	}
	if (locationObject[axis] !== undefined && locationObject[axis] !== null) {
		return locationObject[axis];
	}

	return '';
}

function Wo_ApplyGooglePagePlace(place) {
	if (!place) {
		return false;
	}

	var locationObject = (place.geometry && place.geometry.location) ? place.geometry.location : (place.location || null);
	var formattedAddress = $.trim(place.formatted_address || place.formattedAddress || place.name || Wo_ReadPageLocationValue());
	var lat = Wo_ReadGoogleCoordinateValue(locationObject, 'lat');
	var lng = Wo_ReadGoogleCoordinateValue(locationObject, 'lng');
	var placeId = $.trim(place.place_id || place.id || '');

	Wo_WritePageLocationValue(formattedAddress);
	Wo_SetPageCoordinates(lat, lng);
	Wo_SetPagePlaceId(placeId);

	return true;
}

function Wo_ApplyFallbackPageLocation(item) {
	if (!item) {
		return false;
	}

	var label = $.trim(item.display_name || item.name || Wo_ReadPageLocationValue());
	if (!label) {
		return false;
	}

	Wo_WritePageLocationValue(label);
	Wo_SetPageCoordinates(item.lat || '', item.lon || item.lng || '');
	Wo_SetPagePlaceId('');

	return true;
}

function Wo_ClearPageLocationSuggestions() {
	$('.page_location_suggestions').empty().hide();
}

function Wo_RenderPageLocationSuggestions(items) {
	var suggestionBox = $('.page_location_suggestions');
	var html = '';
	var seen = {};

	if (!Array.isArray(items) || !items.length) {
		Wo_ClearPageLocationSuggestions();
		return;
	}

	items.forEach(function(item) {
		var displayName = $.trim(item.display_name || item.name || '');
		var signature = displayName.toLowerCase();

		if (!displayName || seen[signature]) {
			return;
		}

		seen[signature] = true;
		html += '<div class="page_location_suggestion_item"'
			+ ' data-source="' + Wo_EscapePageLocationHtml(item.source || 'fallback') + '"'
			+ ' data-name="' + Wo_EscapePageLocationHtml(displayName) + '"'
			+ ' data-place-id="' + Wo_EscapePageLocationHtml(item.google_place_id || '') + '"'
			+ ' data-lat="' + Wo_EscapePageLocationHtml(item.lat || '') + '"'
			+ ' data-lng="' + Wo_EscapePageLocationHtml(item.lon || item.lng || '') + '">'
			+ Wo_EscapePageLocationHtml(displayName)
			+ '</div>';
	});

	if (!html) {
		Wo_ClearPageLocationSuggestions();
		return;
	}

	suggestionBox.html(html).show();
}

function Wo_FallbackPageLocationSuggestions(locationValue, requestToken) {
	fetch(Wo_GetPageLocationSearchUrl(locationValue, 5), {
		headers: {
			'Accept': 'application/json'
		}
	}).then(function(response) {
		if (!response.ok) {
			throw new Error('Location suggestions failed');
		}
		return response.json();
	}).then(function(results) {
		if (requestToken !== woPageLocationSuggestionRequest) {
			return;
		}

		results = Array.isArray(results) ? results : [];
		results = results.map(function(item) {
			item.source = 'fallback';
			return item;
		});
		Wo_RenderPageLocationSuggestions(results);
	}).catch(function() {
		if (requestToken === woPageLocationSuggestionRequest) {
			Wo_ClearPageLocationSuggestions();
		}
	});
}

function Wo_SearchPageLocationSuggestions(locationValue) {
	var normalizedLocationValue = $.trim(locationValue || '');
	var requestToken = ++woPageLocationSuggestionRequest;

	if (normalizedLocationValue.length < 2) {
		Wo_ClearPageLocationSuggestions();
		return;
	}

	if (!Wo_PageGoogleAutocompleteAvailable()) {
		Wo_FallbackPageLocationSuggestions(normalizedLocationValue, requestToken);
		return;
	}

	Wo_EnsurePagePlacesLibrary().then(function(isReady) {
		if (!isReady || requestToken !== woPageLocationSuggestionRequest) {
			if (requestToken === woPageLocationSuggestionRequest) {
				Wo_FallbackPageLocationSuggestions(normalizedLocationValue, requestToken);
			}
			return;
		}

		if (!google.maps.places || !google.maps.places.AutocompleteSuggestion || typeof google.maps.places.AutocompleteSuggestion.fetchAutocompleteSuggestions !== 'function') {
			Wo_FallbackPageLocationSuggestions(normalizedLocationValue, requestToken);
			return;
		}

		if (!woPageGoogleSessionToken && typeof google.maps.places.AutocompleteSessionToken === 'function') {
			woPageGoogleSessionToken = new google.maps.places.AutocompleteSessionToken();
		}

		var request = {
			input: normalizedLocationValue,
			language: Wo_GetPageLocationGoogleLanguage()
		};
		if (woPageGoogleSessionToken) {
			request.sessionToken = woPageGoogleSessionToken;
		}

		google.maps.places.AutocompleteSuggestion.fetchAutocompleteSuggestions(request).then(function(response) {
			if (requestToken !== woPageLocationSuggestionRequest) {
				return;
			}

			var suggestions = (response && Array.isArray(response.suggestions)) ? response.suggestions : [];
			if (!suggestions.length) {
				Wo_FallbackPageLocationSuggestions(normalizedLocationValue, requestToken);
				return;
			}

			var mappedSuggestions = suggestions.map(function(suggestion) {
				var prediction = suggestion.placePrediction || suggestion;
				var placeId = $.trim(prediction.placeId || prediction.place_id || '');

				if (placeId) {
					woPageGooglePredictionCache[placeId] = prediction;
				}

				return {
					source: 'google',
					display_name: Wo_GetGooglePagePredictionLabel(prediction),
					google_place_id: placeId
				};
			});

			Wo_RenderPageLocationSuggestions(mappedSuggestions);
		}).catch(function() {
			if (requestToken === woPageLocationSuggestionRequest) {
				Wo_FallbackPageLocationSuggestions(normalizedLocationValue, requestToken);
			}
		});
	}).catch(function() {
		if (requestToken === woPageLocationSuggestionRequest) {
			Wo_FallbackPageLocationSuggestions(normalizedLocationValue, requestToken);
		}
	});
}

function Wo_FallbackPageLocationGeocode(locationValue) {
	return fetch(Wo_GetPageLocationSearchUrl(locationValue, 1), {
		headers: {
			'Accept': 'application/json'
		}
	}).then(function(response) {
		if (!response.ok) {
			throw new Error('Location geocode failed');
		}
		return response.json();
	}).then(function(results) {
		if (!Array.isArray(results) || !results.length) {
			return false;
		}

		results[0].source = 'fallback';
		return Wo_ApplyFallbackPageLocation(results[0]);
	}).catch(function() {
		return false;
	});
}

function Wo_GeocodePageLocation(locationValue) {
	var normalizedLocationValue = $.trim(locationValue || '');

	if (!normalizedLocationValue) {
		Wo_ClearPageLocationMeta();
		return Promise.resolve(false);
	}

	if (typeof google !== 'undefined' && google.maps && typeof google.maps.Geocoder === 'function') {
		return new Promise(function(resolve) {
			var geocoder = new google.maps.Geocoder();
			geocoder.geocode({
				address: normalizedLocationValue
			}, function(results, status) {
				if (status === 'OK' && Array.isArray(results) && results[0]) {
					resolve(Wo_ApplyGooglePagePlace(results[0]));
					return;
				}

				Wo_FallbackPageLocationGeocode(normalizedLocationValue).then(resolve);
			});
		});
	}

	return Wo_FallbackPageLocationGeocode(normalizedLocationValue);
}

function Wo_GeocodePagePlaceId(placeId) {
	var normalizedPlaceId = $.trim(placeId || '');
	var cachedPrediction = normalizedPlaceId ? woPageGooglePredictionCache[normalizedPlaceId] : null;

	if (!normalizedPlaceId) {
		return Promise.resolve(false);
	}

	if (cachedPrediction && typeof cachedPrediction.toPlace === 'function') {
		return new Promise(function(resolve) {
			var place = cachedPrediction.toPlace();
			place.fetchFields({
				fields: ['displayName', 'formattedAddress', 'location', 'id']
			}).then(function() {
				resolve(Wo_ApplyGooglePagePlace(place));
			}).catch(function() {
				resolve(false);
			});
		});
	}

	if (typeof google !== 'undefined' && google.maps && typeof google.maps.Geocoder === 'function') {
		return new Promise(function(resolve) {
			var geocoder = new google.maps.Geocoder();
			geocoder.geocode({
				placeId: normalizedPlaceId
			}, function(results, status) {
				if (status === 'OK' && Array.isArray(results) && results[0]) {
					resolve(Wo_ApplyGooglePagePlace(results[0]));
					return;
				}

				resolve(false);
			});
		});
	}

	return Promise.resolve(false);
}

function Wo_InitPageLocationAutocomplete() {
	var visibleInput = Wo_GetPageLocationVisibleInput();

	if (!visibleInput) {
		return;
	}

	visibleInput.addEventListener('input', function() {
		Wo_WritePageLocationValue(this.value || '');
		Wo_ClearPageLocationMeta();
		clearTimeout(woPageLocationSuggestionTimer);

		if (Wo_PageLocationShouldUseInlineSuggestions() || !woPageDesktopAutocomplete) {
			woPageLocationSuggestionTimer = setTimeout(function() {
				Wo_SearchPageLocationSuggestions(Wo_ReadPageLocationValue());
			}, 220);
			return;
		}

		Wo_ClearPageLocationSuggestions();
	});

	visibleInput.addEventListener('change', function() {
		Wo_WritePageLocationValue(this.value || '');
	});

	visibleInput.addEventListener('blur', function() {
		setTimeout(function() {
			Wo_ClearPageLocationSuggestions();
		}, 150);
	});

	if (Wo_PageLocationShouldUseInlineSuggestions() || !Wo_PageGoogleAutocompleteAvailable()) {
		return;
	}

	Wo_EnsurePagePlacesLibrary().then(function(isReady) {
		if (!isReady || !google.maps.places || typeof google.maps.places.Autocomplete !== 'function') {
			return;
		}

		woPageDesktopAutocomplete = new google.maps.places.Autocomplete(visibleInput, {
			fields: ['formatted_address', 'geometry', 'name', 'place_id']
		});
		woPageDesktopAutocomplete.addListener('place_changed', function() {
			var place = woPageDesktopAutocomplete.getPlace();
			Wo_ApplyGooglePagePlace(place);
			Wo_ClearPageLocationSuggestions();
		});
	});
}

function Wo_ResolvePageLocation(callback) {
	var locationValue = Wo_ReadPageLocationValue();
	var placeId = $.trim($('#page_place_id_value').val() || '');

	$('#address_value').val(locationValue);

	if (!locationValue) {
		Wo_ClearPageLocationMeta();
		callback();
		return;
	}

	if (placeId && !Wo_PageHasCoordinates()) {
		Wo_GeocodePagePlaceId(placeId).then(function(resolved) {
			if (!resolved) {
				Wo_ClearPageLocationMeta();
				$('#address_value').val(locationValue);
			}

			callback();
		});
		return;
	}

	if (Wo_PageHasCoordinates()) {
		callback();
		return;
	}

	Wo_GeocodePageLocation(locationValue).then(function(resolved) {
		if (!resolved) {
			Wo_ClearPageLocationMeta();
			$('#address_value').val(locationValue);
		}

		callback();
	});
}

$(function() {
	Wo_InitPageLocationAutocomplete();

	$(document).on('mousedown touchstart', '.page_location_suggestions .page_location_suggestion_item', function(event) {
		var source = $(this).attr('data-source') || 'fallback';
		var name = $(this).attr('data-name') || '';
		var placeId = $(this).attr('data-place-id') || '';
		var lat = $(this).attr('data-lat') || '';
		var lng = $(this).attr('data-lng') || '';

		event.preventDefault();
		Wo_WritePageLocationValue(name);
		Wo_ClearPageLocationSuggestions();

		if (source === 'google' && placeId) {
			Wo_ClearPageLocationMeta();
			Wo_SetPagePlaceId(placeId);
			Wo_GeocodePagePlaceId(placeId).then(function(resolved) {
				if (!resolved) {
					$('#address_value').val(name);
				}
			});
			return;
		}

		Wo_ApplyFallbackPageLocation({
			display_name: name,
			lat: lat,
			lng: lng
		});
	});

	$('form.create-page-form').ajaxForm({
		url: Wo_Ajax_Requests_File() + '?f=pages&s=create_page',
		beforeSend: function() {
			$('.create-page-form').find('.add_wow_loader').addClass('btn-loading');
		},
		beforeSubmit: function(arr, form, options) {
			if ($(form).data('page-create-geocode-ready') === true) {
				$(form).removeData('page-create-geocode-ready');
				return true;
			}

			Wo_ResolvePageLocation(function() {
				$(form).data('page-create-geocode-ready', true);
				$(form).ajaxSubmit(options);
			});

			return false;
		},
		success: function(data) {
			scrollToTop();
			if (data.status == 200) {
				window.location.href = data.location;
			} else {
				var errors = data.errors.join("<br>");
				$('.app-general-alert').html('<div class="alert alert-danger">' + errors + '</div>');
				$('.alert-danger').fadeIn(300);
			}
			$('.create-page-form').find('.add_wow_loader').removeClass('btn-loading');
		}
	});
});
</script>
