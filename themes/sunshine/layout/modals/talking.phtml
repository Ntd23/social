<script>
var woTalkingReturnUrl = document.referrer || "<?php echo $wo['config']['site_url']; ?>";
var woTalkingCallId = <?php echo (int) $wo['incall']['id']; ?>;
var woTalkingJoinedAt = 0;
var woTalkingClosed = false;

function Wo_ReportTalkingClose(status, redirectNow) {
  if (woTalkingClosed || woTalkingCallId < 1) {
    if (redirectNow === true) {
      location.href = woTalkingReturnUrl;
    }
    return;
  }
  woTalkingClosed = true;
  var duration = woTalkingJoinedAt > 0 ? Math.max(0, Math.round((Date.now() - woTalkingJoinedAt) / 1000)) : 0;
  $.get(Wo_Ajax_Requests_File(), {
    f: 'close_call',
    id: woTalkingCallId,
    call_type: 'audio',
    provider: '<?php echo (!empty($wo['incall']['provider']) ? $wo['incall']['provider'] : Wo_GetActiveCallProvider('audio')); ?>',
    status: status,
    duration: duration
  }).always(function () {
    if (redirectNow === true) {
      location.href = woTalkingReturnUrl;
    }
  });
}

navigator.getUserMedia = navigator.getUserMedia || navigator.webkitGetUserMedia || navigator.mozGetUserMedia || navigator.msGetUserMedia;
if (!navigator.getUserMedia) {
  $('#remote-media h3').text('Sorry, WebRTC is not available in your browser.');
}

Twilio.Video.connect('<?php echo $wo['incall']['access_token'];?>', { name: '<?php echo $wo['incall']['room'];?>', audio: true, video: false }).then(room => {
  console.log('Connected to Room "%s"', room.name);

  room.participants.forEach(participantConnected);
  room.on('participantConnected', participantConnected);
  room.on('disconnected', room => {
    room.localParticipant.tracks.forEach(publication => {
      const attachedElements = publication.track.detach();
      attachedElements.forEach(element => element.remove());
      Wo_ReportTalkingClose((woTalkingJoinedAt > 0 ? 'ended' : 'cancelled'), true);
    });
  });
  room.on('participantDisconnected', function(participant) {
    console.log(participant.identity + ' left the Room');
    Wo_ReportTalkingClose((woTalkingJoinedAt > 0 ? 'ended' : 'cancelled'), true);
  });

  $(document).on('click', 'a[data-ajax]', function(e) {
      Wo_ReportTalkingClose((woTalkingJoinedAt > 0 ? 'ended' : 'cancelled'), false);
      room.disconnect();
  });
  $(document).on('click', '.decline-call', function(e) {
      Wo_ReportTalkingClose((woTalkingJoinedAt > 0 ? 'ended' : 'cancelled'), false);
      room.disconnect();
  });
});

function participantConnected(participant) {
  console.log('Participant "%s" connected', participant.identity);
  if (woTalkingJoinedAt === 0) {
    woTalkingJoinedAt = Date.now();
  }

  const div = document.createElement('div');
  div.id = participant.sid;
  participant.tracks.forEach(publication => {
    if (publication.isSubscribed) {
      const track = publication.track;
      div.appendChild(track.attach());
    }
  });
  participant.on('trackSubscribed', track => {
    document.getElementById('remote-media').appendChild(track.attach());
  });

  $('#remote-media').html(div);
}
</script>
<?php } ?>
